<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DWE | Subagent Delegations</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', sans-serif;
            background-color: #0a0e27;
            background-image:
                radial-gradient(ellipse at 20% 30%, rgba(0,0,0,0.5) 0%, transparent 50%),
                radial-gradient(ellipse at 80% 70%, rgba(0,0,0,0.3) 0%, transparent 50%),
                linear-gradient(135deg, #0a0e27 0%, #1a1e3c 50%, #0a0e27 100%);
            background-attachment: fixed;
            color: #fff;
            min-height: 100vh;
            padding: 2rem;
        }
        .back-link {
            display: inline-flex; align-items: center; gap: 6px;
            color: rgba(255,255,255,0.5); text-decoration: none; font-size: 0.75rem;
            margin-bottom: 1.5rem;
        }
        .back-link:hover { color: #00f5ff; }
        h1 { font-size: 1.6rem; font-weight: 800; margin-bottom: 0.3rem; }
        .subtitle { font-size: 0.75rem; color: rgba(255,255,255,0.4); margin-bottom: 1.5rem; }
        .panel {
            background: rgba(15, 20, 60, 0.7);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 14px;
            padding: 1.2rem;
            margin-bottom: 1rem;
        }
        .panel-title {
            font-size: 0.7rem; color: rgba(255,255,255,0.45);
            text-transform: uppercase; letter-spacing: 0.06em;
            margin-bottom: 0.8rem;
        }
        .stat-row { display: flex; gap: 1rem; margin-bottom: 1rem; }
        .stat-box {
            text-align: center; padding: 1rem 1.5rem;
            background: rgba(0,245,255,0.05); border: 1px solid rgba(0,245,255,0.12);
            border-radius: 10px; min-width: 120px;
        }
        .stat-num { font-size: 2.2rem; font-weight: 800; color: #00f5ff; }
        .stat-label { font-size: 0.65rem; color: rgba(255,255,255,0.4); margin-top: 0.2rem; }
        .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
        .badge {
            display: inline-flex; align-items: center; gap: 5px;
            padding: 5px 12px; border-radius: 6px; margin: 3px;
        }
        .badge-num { font-size: 0.9rem; font-weight: 700; }
        .badge-name { font-size: 0.7rem; color: rgba(255,255,255,0.6); }
        .flow-row {
            display: flex; align-items: center; gap: 8px;
            padding: 6px 8px; border-radius: 6px;
            background: rgba(255,255,255,0.02); margin-bottom: 3px;
        }
        .flow-ts { font-size: 0.65rem; color: rgba(255,255,255,0.25); font-family: monospace; flex-shrink: 0; width: 90px; }
        .flow-agent { font-size: 0.72rem; font-weight: 600; }
        .flow-arrow { font-size: 0.65rem; color: rgba(255,255,255,0.25); }
        .flow-task { font-size: 0.65rem; color: rgba(255,255,255,0.4); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
        .pair-row {
            display: flex; align-items: center; gap: 8px;
            padding: 6px 10px; background: rgba(255,255,255,0.03);
            border-radius: 6px; margin-bottom: 4px;
        }
        .pair-count { font-size: 1.1rem; font-weight: 700; color: #00f5ff; min-width: 30px; text-align: center; }
        .pair-label { font-size: 0.72rem; color: rgba(255,255,255,0.55); }
        #updated { font-size: 0.65rem; color: rgba(255,255,255,0.3); margin-top: 0.5rem; }
    </style>
</head>
<body>
    <a href="/" class="back-link">← Back to Command Center</a>
    <h1>Subagent Delegation Tracker</h1>
    <div class="subtitle">Agent-to-agent task delegation history and metrics</div>

    <!-- Summary stats -->
    <div class="stat-row">
        <div class="stat-box">
            <div class="stat-num" id="total">—</div>
            <div class="stat-label">Total Delegations</div>
        </div>
        <div class="stat-box" style="background:rgba(0,255,136,0.05);border-color:rgba(0,255,136,0.12);">
            <div class="stat-num" style="color:#00ff88;" id="unique-sources">—</div>
            <div class="stat-label">Agents Delegating</div>
        </div>
        <div class="stat-box" style="background:rgba(184,41,221,0.05);border-color:rgba(184,41,221,0.12);">
            <div class="stat-num" style="color:#b829dd;" id="unique-targets">—</div>
            <div class="stat-label">Agents Receiving</div>
        </div>
    </div>

    <div class="grid-2">
        <!-- Source (who delegates) -->
        <div class="panel">
            <div class="panel-title">Delegated Out (by source agent)</div>
            <div id="source-badges"></div>
        </div>
        <!-- Target (who receives) -->
        <div class="panel">
            <div class="panel-title">Delegated To (by target agent)</div>
            <div id="target-badges"></div>
        </div>
    </div>

    <!-- Delegation pairs -->
    <div class="panel">
        <div class="panel-title">Delegation Pairs</div>
        <div id="pairs-list"></div>
    </div>

    <!-- Recent delegations -->
    <div class="panel">
        <div class="panel-title">Recent Delegations</div>
        <div id="recent-list"></div>
    </div>

    <div id="updated"></div>

    <script>
        const AGENT_COLORS = {
            'Steve': '#00f5ff', 'Anita': '#b829dd', 'Fran': '#00ff88',
            'Nicole': '#ff9500', 'CE': '#ff00aa', 'Jarvis': '#7b61ff'
        };
        const TARGET_MAP = {
            'cto': 'Steve', 'anita': 'Anita', 'nicole': 'Nicole',
            'cfo': 'Fran', 'chief-engineer': 'CE', 'jarvis': 'Jarvis'
        };

        function colorFor(name) { return AGENT_COLORS[name] || '#aaa'; }

        async function load() {
            try {
                const d = await fetch('/mc/delegation-stats').then(r => r.json());

                document.getElementById('total').textContent = d.total || 0;
                document.getElementById('unique-sources').textContent = Object.keys(d.bySource || {}).length;
                document.getElementById('unique-targets').textContent = Object.keys(d.byTarget || {}).length;

                // Source badges
                let srcHtml = '';
                Object.entries(d.bySource || {}).sort((a,b) => b[1]-a[1]).forEach(([name, count]) => {
                    const c = colorFor(name);
                    srcHtml += `<div class="badge" style="background:${c}11;border:1px solid ${c}33;">
                        <span class="badge-num" style="color:${c};">${count}</span>
                        <span class="badge-name">${name}</span>
                    </div>`;
                });
                document.getElementById('source-badges').innerHTML = srcHtml || '<span style="color:rgba(255,255,255,0.2);font-size:0.7rem;">No delegations yet</span>';

                // Target badges
                let tgtHtml = '';
                Object.entries(d.byTarget || {}).sort((a,b) => b[1]-a[1]).forEach(([id, count]) => {
                    const name = TARGET_MAP[id] || id;
                    const c = colorFor(name);
                    tgtHtml += `<div class="badge" style="background:${c}11;border:1px solid ${c}33;">
                        <span class="badge-num" style="color:${c};">${count}</span>
                        <span class="badge-name">${name}</span>
                    </div>`;
                });
                document.getElementById('target-badges').innerHTML = tgtHtml || '<span style="color:rgba(255,255,255,0.2);font-size:0.7rem;">No delegations yet</span>';

                // Pairs
                let pairsHtml = '';
                Object.entries(d.pairs || {}).sort((a,b) => b[1]-a[1]).forEach(([pair, count]) => {
                    pairsHtml += `<div class="pair-row">
                        <div class="pair-count">${count}</div>
                        <div class="pair-label">${pair}</div>
                    </div>`;
                });
                document.getElementById('pairs-list').innerHTML = pairsHtml || '<span style="color:rgba(255,255,255,0.2);font-size:0.7rem;">No pairs</span>';

                // Recent
                let recentHtml = '';
                (d.recent || []).forEach(r => {
                    const srcC = colorFor(r.source);
                    const tgtName = TARGET_MAP[r.target] || r.target;
                    const tgtC = colorFor(tgtName);
                    recentHtml += `<div class="flow-row">
                        <span class="flow-ts">${r.timestamp || ''}</span>
                        <span class="flow-agent" style="color:${srcC};">${r.source}</span>
                        <span class="flow-arrow">→</span>
                        <span class="flow-agent" style="color:${tgtC};">${tgtName}</span>
                        <span class="flow-task">${r.task || ''}</span>
                    </div>`;
                });
                document.getElementById('recent-list').innerHTML = recentHtml || '<span style="color:rgba(255,255,255,0.2);font-size:0.7rem;">No delegations recorded</span>';

                document.getElementById('updated').textContent = 'Last updated: ' + new Date().toLocaleTimeString();
            } catch(e) {
                document.getElementById('total').textContent = 'Error';
            }
        }

        load();
        setInterval(load, 60000);
    </script>
</body>
</html>
