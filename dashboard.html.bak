<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DWE | Command Center</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Inter', sans-serif;
            background-color: #3A41CC;
            background-image:
                radial-gradient(ellipse at 20% 30%, rgba(0,0,0,0.3) 0%, transparent 50%),
                radial-gradient(ellipse at 80% 70%, rgba(0,0,0,0.2) 0%, transparent 50%),
                linear-gradient(135deg, #2a3190 0%, #3A41CC 50%, #2a3190 100%);
            background-attachment: fixed;
            color: #fff;
            min-height: 100vh;
        }

        .container { display: flex; position: relative; z-index: 1; }

        .sidebar {
            width: 220px;
            background: rgba(20, 25, 70, 0.95);
            backdrop-filter: blur(20px);
            border-radius: 20px;
            padding: 1.1rem 0.9rem 1rem;
            position: fixed;
            height: calc(100vh - 3.3rem);
            top: 2.9rem;
            left: 14px;
            display: flex;
            flex-direction: column;
            box-shadow: 0 8px 40px rgba(0, 0, 0, 0.3);
            z-index: 100;
            border: 1px solid rgba(255, 255, 255, 0.1);
            overflow-y: auto;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            margin-bottom: 0.85rem;
            padding: 0.35rem 0.5rem;
            border: 1px solid rgba(255, 200, 0, 0.35);
            border-radius: 10px;
            padding-bottom: 0.85rem;
            flex-shrink: 0;
        }

        .logo-icon {
            width: 28px;
            height: 28px;
            background: linear-gradient(135deg, #fff, #e0e0e0);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.9rem;
        }

        .logo-text { display: flex; flex-direction: column; }
        .logo-value { font-size: 1rem; font-weight: 700; letter-spacing: 1px; }

        .nav-section {
            margin-bottom: 0.75rem;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            padding-bottom: 0.75rem;
            flex-shrink: 0;
        }
        .nav-section:last-of-type { border-bottom: none; }

        .nav-section-title {
            font-size: 0.65rem;
            color: rgba(255, 255, 255, 0.4);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 0.5rem;
            padding-left: 0.5rem;
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.5rem 0.65rem;
            margin-bottom: 0.2rem;
            border-radius: 10px;
            color: rgba(255, 255, 255, 0.6);
            text-decoration: none;
            transition: all 0.2s;
            font-size: 0.8rem;
            font-weight: 500;
            border: none;
            background: transparent;
            cursor: pointer;
            width: 100%;
        }
        .nav-item:hover { background: rgba(255, 255, 255, 0.05); color: #fff; }
        .nav-item.active {
            background: linear-gradient(135deg, rgba(0, 245, 255, 0.2) 0%, rgba(184, 41, 221, 0.1) 100%);
            color: #fff;
            box-shadow: 0 4px 15px rgba(0, 245, 255, 0.2);
        }

        .nav-icon {
            width: 26px;
            height: 26px;
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.9rem;
            background: rgba(255, 255, 255, 0.05);
        }
        .nav-item.active .nav-icon { background: linear-gradient(135deg, #00f5ff, #b829dd); }

        .help-box {
            margin-top: auto;
            background: rgba(0, 0, 0, 0.2);
            border-radius: 12px;
            padding: 0.7rem;
            text-align: center;
            border: 1px solid rgba(255, 255, 255, 0.05);
            flex-shrink: 0;
        }
        .help-icon {
            width: 32px; height: 32px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            margin: 0 auto 0.5rem;
            font-size: 1rem;
        }
        .help-title { font-size: 0.8rem; font-weight: 600; margin-bottom: 0.15rem; }
        .help-text { font-size: 0.7rem; color: rgba(255, 255, 255, 0.5); margin-bottom: 0.75rem; }
        .refresh-indicator {
            font-size: 0.65rem;
            color: rgba(255,255,255,0.4);
            margin-top: 0.5rem;
            text-align: center;
        }

        .main {
            flex: 1;
            padding: 2rem;
            max-width: 100%;
            box-sizing: border-box;
            position: relative;
            overflow: hidden;
        }

        .bg-blob { position: absolute; border-radius: 50%; filter: blur(80px); opacity: 0.15; z-index: 0; pointer-events: none; }
        .bg-blob-1 { width: 400px; height: 400px; background: linear-gradient(135deg, #00f5ff, #00ff88); top: 10%; right: -100px; }
        .bg-blob-2 { width: 300px; height: 300px; background: linear-gradient(135deg, #b829dd, #ff00aa); bottom: 20%; left: 10%; }
        .bg-blob-3 { width: 250px; height: 250px; background: linear-gradient(135deg, #ff9500, #ff00aa); top: 40%; left: 30%; }
        .main > *:not(.bg-blob) { position: relative; z-index: 1; }

        .hero {
            background: rgba(20, 25, 70, 0.7);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(200, 200, 200, 0.18);
            border-radius: 20px;
            padding: 1.5rem 2rem;
            margin-bottom: 1.5rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 0 0 1px rgba(200,200,200,0.08), 0 4px 24px rgba(0,0,0,0.4);
            position: relative;
            overflow: hidden;
        }
        .hero-watermark {
            position: absolute;
            top: 50%; left: 50%;
            transform: translate(-50%, -50%);
            pointer-events: none;
            z-index: 0;
            display: flex; flex-direction: column; align-items: center; justify-content: center;
            gap: 4px;
        }
        .hero-watermark svg {
            width: 64px; height: 64px;
            fill: none; stroke: rgba(255,255,255,0.06);
            stroke-width: 1.2; stroke-linecap: round; stroke-linejoin: round;
        }
        .hero-watermark .wm-title {
            font-family: 'Inter', sans-serif;
            font-size: 2.2rem; font-weight: 800;
            letter-spacing: 6px; text-transform: uppercase;
            color: rgba(255,255,255,0.06);
        }
        .hero-watermark .wm-sub {
            font-family: 'Inter', sans-serif;
            font-size: 1rem; font-weight: 700;
            letter-spacing: 8px; text-transform: uppercase;
            color: rgba(255,255,255,0.05);
        }
        /* n8n Workflow summary chips (detail page at /n8n-workflows) */
        .n8n-summary-chips { display: flex; gap: 0.4rem; align-items: center; }
        .n8n-chip {
            font-size: 0.58rem; font-weight: 600; padding: 2px 8px; border-radius: 10px;
        }
        .n8n-chip.total { background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.5); }
        .n8n-chip.active { background: rgba(0,255,136,0.1); color: #00ff88; }
        .n8n-chip.inactive { background: rgba(255,60,60,0.08); color: rgba(255,100,100,0.6); }
        .sp-grid { display:flex; gap:0; padding:0.5rem 0.75rem 0.75rem; }
        .sp-col { flex:1; display:flex; flex-direction:column; gap:0.4rem; padding:0 0.6rem; }
        .sp-col + .sp-col { border-left:1px solid rgba(255,255,255,0.35); }
        .sp-tile {
            background:rgba(255,255,255,0.025); border:1px solid rgba(255,255,255,0.07);
            border-radius:10px; padding:0.5rem 0.6rem; display:flex; flex-direction:column; gap:0.3rem;
            transition:border-color 0.2s, background 0.2s;
        }
        .sp-tile:hover { background:rgba(255,255,255,0.04); border-color:rgba(255,255,255,0.12); }
        .sp-tile.active { border-color:rgba(0,255,136,0.2); }
        .sp-tile-header { display:flex; align-items:center; gap:0.4rem; }
        .sp-dot { width:7px; height:7px; border-radius:50%; flex-shrink:0; }
        .sp-dot.on { background:#00ff88; box-shadow:0 0 6px rgba(0,255,136,0.4); }
        .sp-dot.off { background:rgba(255,60,60,0.4); box-shadow:0 0 4px rgba(255,60,60,0.2); }
        .sp-name { font-size:0.68rem; font-weight:600; color:rgba(255,255,255,0.75); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; flex:1; }
        .sp-meta { display:flex; align-items:center; gap:0.35rem; }
        .sp-badge { font-size:0.52rem; font-weight:600; padding:1px 5px; border-radius:3px; text-transform:uppercase; letter-spacing:0.4px; }
        .sp-badge.schedule { background:rgba(0,140,255,0.15); color:#4da6ff; }
        .sp-badge.webhook { background:rgba(160,0,255,0.15); color:#b366ff; }
        .sp-badge.trigger { background:rgba(255,140,0,0.15); color:#ff8c42; }
        .sp-badge.manual { background:rgba(255,255,255,0.06); color:rgba(255,255,255,0.35); }
        .sp-badge.sub-workflow { background:rgba(0,200,150,0.12); color:#40c8a0; }
        .sp-status { font-size:0.55rem; color:rgba(0,255,136,0.5); }
        .sp-status.off { color:rgba(255,100,100,0.5); }
        .sp-section-header { display:flex; align-items:center; gap:0.5rem; padding:0.5rem 0.75rem 0; font-size:0.7rem; color:rgba(255,255,255,0.35); border-top:1px solid rgba(255,255,255,0.06); }
        .sp-count { margin-left:auto; font-size:0.6rem; color:rgba(0,255,136,0.5); }
        /* Content Intelligence card */
        .ci-stats { display:flex; gap:1rem; padding:0.4rem 0.75rem; font-size:0.65rem; color:rgba(255,255,255,0.4); }
        .ci-stat-val { color:rgba(255,200,60,0.9); font-weight:700; }
        .ci-nuggets { padding:0.3rem 0.75rem 0.6rem; display:flex; flex-direction:column; gap:0.4rem; }
        .ci-nugget { background:rgba(255,255,255,0.025); border:1px solid rgba(255,255,255,0.07); border-radius:8px; padding:0.45rem 0.6rem; display:flex; gap:0.5rem; align-items:flex-start; transition:border-color 0.2s; }
        .ci-nugget:hover { border-color:rgba(255,200,60,0.25); }
        .ci-score { flex-shrink:0; font-size:0.6rem; font-weight:700; padding:2px 6px; border-radius:4px; }
        .ci-score.high { background:rgba(0,255,136,0.12); color:#00ff88; }
        .ci-score.med { background:rgba(255,200,60,0.12); color:#ffc83c; }
        .ci-nugget-body { flex:1; min-width:0; }
        .ci-nugget-text { font-size:0.67rem; color:rgba(255,255,255,0.7); line-height:1.35; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; }
        .ci-nugget-meta { display:flex; gap:0.5rem; margin-top:0.2rem; font-size:0.55rem; color:rgba(255,255,255,0.3); }
        .ci-urgency { font-size:0.5rem; font-weight:600; padding:1px 5px; border-radius:3px; text-transform:uppercase; letter-spacing:0.3px; }
        .ci-urgency.act_now { background:rgba(255,60,60,0.15); color:#ff6b6b; }
        .ci-urgency.this_week { background:rgba(255,200,60,0.12); color:#ffc83c; }
        .ci-urgency.this_month { background:rgba(0,140,255,0.12); color:#4da6ff; }
        .ci-urgency.track { background:rgba(255,255,255,0.05); color:rgba(255,255,255,0.3); }
        .ci-verdict { font-size:0.5rem; font-weight:700; padding:2px 5px; border-radius:3px; text-transform:uppercase; letter-spacing:0.3px; white-space:nowrap; }
        .ci-verdict.watch { background:rgba(0,255,136,0.15); color:#00ff88; }
        .ci-verdict.skim { background:rgba(255,200,60,0.12); color:#ffc83c; }
        .ci-verdict.skip { background:rgba(255,255,255,0.06); color:rgba(255,255,255,0.35); }
        .ci-empty { text-align:center; padding:1.2rem; color:rgba(255,255,255,0.2); font-size:0.7rem; }
        .ci-scan-time { font-size:0.55rem; color:rgba(255,255,255,0.2); padding:0 0.75rem 0.5rem; }

        .hero h2 { font-size: 0.75rem; color: rgba(255, 255, 255, 0.5); margin-bottom: 0.25rem; text-transform: uppercase; letter-spacing: 1px; }
        .hero h1 { font-size: 2rem; font-weight: 700; background: linear-gradient(135deg, #fff 0%, #00f5ff 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
        .hero .date { font-size: 0.85rem; color: rgba(255, 255, 255, 0.6); margin-bottom: 0.25rem; }
        .hero .clock { font-size: 1.75rem; font-weight: 600; }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(6, 1fr);
            gap: 1rem;
            margin-bottom: 1.5rem;
        }

        .stat-card {
            background: rgba(15, 20, 60, 0.85);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 16px;
            padding: 1rem;
            border-left: 3px solid #00f5ff;
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 0.75rem;
        }
        .stat-card.success { border-left-color: #00ff88; }
        .stat-card.warning { border-left-color: #ff9500; }
        .stat-card.danger  { border-left-color: #ff00aa; }
        .stat-card.brain   { border-left-color: #b829dd; }

        .stat-content { display: flex; flex-direction: column; gap: 0.35rem; }
        .stat-label { font-size: 0.75rem; color: rgba(255, 255, 255, 0.5); margin-bottom: 0; }
        .stat-value-row { display: flex; align-items: baseline; gap: 0.5rem; }
        .stat-value { font-size: 1.6rem; font-weight: 700; }
        .stat-change { font-size: 0.85rem; font-weight: 600; color: #00ff88; }
        .stat-icon {
            width: 44px; height: 44px;
            border-radius: 12px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.25rem;
            background: linear-gradient(135deg, rgba(0, 245, 255, 0.2) 0%, rgba(184, 41, 221, 0.1) 100%);
            flex-shrink: 0;
        }

        .progress-section {
            background: rgba(15, 20, 60, 0.85);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 20px;
            padding: 1.5rem;
            margin-bottom: 1.5rem;
            display: flex;
            align-items: center;
            gap: 2rem;
        }

        .progress-circle { position: relative; width: 140px; height: 140px; flex-shrink: 0; }
        .progress-bg { fill: none; stroke: rgba(255, 255, 255, 0.1); stroke-width: 10; }
        .progress-bar { fill: none; stroke: url(#gradient); stroke-width: 10; stroke-linecap: round; stroke-dasharray: 377; stroke-dashoffset: 170; transition: stroke-dashoffset 0.8s ease; }
        .progress-text { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); text-align: center; }
        .progress-text .percent { font-size: 2rem; font-weight: 800; background: linear-gradient(135deg, #00f5ff, #b829dd); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }

        .progress-stats { flex: 1; display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }
        .progress-stat { text-align: center; padding: 1rem; background: rgba(0, 0, 0, 0.2); border-radius: 12px; }
        .progress-stat .number { font-size: 1.75rem; font-weight: 700; }

        .services-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1rem;
            align-items: stretch;
        }

        .service-panel {
            background: rgba(15, 20, 60, 0.85);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 16px;
            padding: 1rem;
            display: flex;
            flex-direction: column;
        }

        .health-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 1rem;
            margin-bottom: 1rem;
        }

        .health-panel {
            background: rgba(15, 20, 60, 0.85);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 16px;
            padding: 1rem;
        }

        .health-item {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.625rem 0.5rem;
            font-size: 0.85rem;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }
        .health-item:last-child { border-bottom: none; }
        .health-item span:nth-child(2) { flex: 1; }
        .health-status { color: rgba(255, 255, 255, 0.5); font-size: 0.8rem; }
        .health-status.ok { color: #00ff88; }
        .health-status.warning { color: #ff9500; }
        .health-status.error { color: #ff00aa; }

        .mini-ecosystem {
            background: rgba(15, 20, 60, 0.85);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 16px;
            padding: 1rem;
            cursor: pointer;
            transition: all 0.3s;
        }
        .mini-ecosystem:hover { border-color: rgba(0, 255, 136, 0.3); box-shadow: 0 0 20px rgba(0, 255, 136, 0.1); }
        .mini-ecosystem-svg { width: 100%; overflow: visible; }
        .mini-conn { stroke-width: 2; fill: none; opacity: 0.8; }
        .mini-conn.online { stroke: #00ff88; animation: pulseLine 2s infinite; }

        @keyframes pulseLine { 0%, 100% { opacity: 0.6; } 50% { opacity: 1; } }

        .heartbeat { display: inline-block; animation: heartbeat 1.5s ease-in-out infinite; }
        @keyframes heartbeat { 0%, 100% { transform: scale(1); } 25% { transform: scale(1.1); } 50% { transform: scale(1); } 75% { transform: scale(1.1); } }

        .panel-header {
            display: flex; align-items: center; gap: 0.5rem;
            margin-bottom: 0.75rem; padding-bottom: 0.5rem;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }
        .panel-icon {
            width: 32px; height: 32px;
            background: linear-gradient(135deg, #00f5ff, #b829dd);
            border-radius: 8px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1rem;
        }
        .panel-title { font-size: 0.85rem; font-weight: 600; }

        .service-item {
            display: flex; align-items: center; gap: 0.5rem;
            padding: 0.45rem 0.5rem;
            margin-bottom: 0.2rem;
            font-size: 0.78rem;
            border-radius: 8px;
            background: rgba(0, 0, 0, 0.15);
        }
        .service-item span.label { flex: 1; }
        .service-item .badge {
            font-size: 0.65rem;
            padding: 0.1rem 0.35rem;
            border-radius: 4px;
            font-weight: 600;
        }
        .badge.running  { background: rgba(0,255,136,0.2);  color: #00ff88; }
        .badge.waiting  { background: rgba(255,255,255,0.1); color: rgba(255,255,255,0.4); }
        .badge.warning  { background: rgba(255,149,0,0.2);   color: #ff9500; }
        .badge.error    { background: rgba(255,0,170,0.2);   color: #ff00aa; }

        .pulse-dot {
            width: 6px; height: 6px;
            border-radius: 50%;
            background: #00ff88;
            box-shadow: 0 0 6px #00ff88;
            animation: pulse 2s infinite;
            flex-shrink: 0;
        }
        .pulse-dot.warning { background: #ff9500; box-shadow: 0 0 6px #ff9500; }
        .pulse-dot.error   { background: #ff00aa; box-shadow: 0 0 6px #ff00aa; }
        .pulse-dot.offline { background: #555; box-shadow: none; animation: none; }

        @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }

        .brain-bar {
            width: 100%;
            background: rgba(255,255,255,0.1);
            border-radius: 4px;
            height: 4px;
            margin-top: 0.3rem;
        }
        .brain-bar-fill {
            height: 4px;
            border-radius: 4px;
            background: linear-gradient(90deg, #b829dd, #00f5ff);
            transition: width 0.8s ease;
        }

        .panel-footer {
            margin-top: auto;
            padding-top: 0.75rem;
            border-top: 1px solid rgba(255,255,255,0.1);
            display: flex;
            align-items: stretch;
            justify-content: space-between;
            gap: 0.5rem;
        }
        .footer-btn {
            flex: 1;
            min-height: 2.2rem;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            padding: 0.4rem 0.35rem;
            background: rgba(100, 100, 100, 0.2);
            border: 1px solid rgba(100, 100, 100, 0.3);
            border-radius: 6px;
            color: #aaa;
            font-size: 0.7rem;
            line-height: 1.2;
            text-decoration: none;
            cursor: pointer;
            box-sizing: border-box;
        }
        .footer-btn:hover { background: rgba(100,100,100,0.35); color: #fff; }

        /* Brain Knowledge tile spacing */
        .stat-card.brain { padding: 1.1rem 1rem 1.1rem; }
        .stat-card.brain .stat-content { gap: 0.55rem; }
        .brain-bar { margin: 0.1rem 0 0.25rem; height: 5px; border-radius: 3px; }
        #stat-brain-detail { margin-top: 0 !important; font-size: 0.72rem !important; line-height: 1.5; }
        #brain-btn-logs, #brain-btn-run, #brain-btn-restart { padding: 5px 0 !important; font-size: 0.7rem !important; border-radius: 6px !important; }

        @media (max-width: 1600px) { .stats-grid { grid-template-columns: repeat(3, 1fr); } }
        @media (max-width: 1200px) { .stats-grid { grid-template-columns: repeat(2, 1fr); } .services-grid { grid-template-columns: 1fr; } }

        /* ── Mobile responsive ───────────────────────────────────────── */
        @media (max-width: 768px) {
            .main { padding: 0.8rem !important; }
            .stats-grid { grid-template-columns: 1fr !important; }
            .services-grid { grid-template-columns: 1fr !important; }
            .hero-stat { min-width: 80px !important; padding: 0.6rem !important; }
            .hero-stat-num { font-size: 1.8rem !important; }
        }

        /* HUD layer toggle buttons */
        .hud-tog {
            font-family: 'Courier New', monospace;
            font-size: 0.58rem;
            font-weight: 600;
            letter-spacing: 0.04em;
            padding: 3px 7px;
            border-radius: 3px;
            border: 1px solid var(--tog-c, rgba(255,255,255,0.3));
            background: rgba(2,6,18,0.75);
            color: var(--tog-c, rgba(255,255,255,0.6));
            cursor: pointer;
            opacity: 1;
            transition: opacity 0.2s, background 0.2s;
            white-space: nowrap;
        }
        .hud-tog:hover { background: rgba(255,255,255,0.08); }
        .hud-tog.tog-off {
            opacity: 0.3;
            background: rgba(2,6,18,0.5);
            border-color: rgba(255,255,255,0.12);
            color: rgba(255,255,255,0.25);
        }
    </style>

    <!-- ── CSS2: Deep Neon ─────────────────────────────────────────── -->
    <style id="theme-css2" disabled>
        [data-theme="css2"] body {
            background-color: #050814;
            background-image:
                radial-gradient(ellipse at 20% 30%, rgba(0,220,255,0.08) 0%, transparent 55%),
                radial-gradient(ellipse at 80% 70%, rgba(255,0,200,0.06) 0%, transparent 55%),
                linear-gradient(135deg, #050814 0%, #090d1f 50%, #050814 100%);
        }
        [data-theme="css2"] .hero {
            background: rgba(5, 8, 25, 0.85);
            border-color: rgba(200, 200, 200, 0.18);
            box-shadow: 0 0 0 1px rgba(200,200,200,0.08), 0 4px 24px rgba(0,0,0,0.4);
        }
        [data-theme="css2"] .hero h1 {
            background: linear-gradient(135deg, #fff 0%, #00dcff 100%);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent;
        }
        [data-theme="css2"] .stat-card {
            background: rgba(5, 8, 30, 0.92);
            border-color: rgba(0,220,255,0.08);
            border-left-color: #00dcff;
            box-shadow: 0 4px 24px rgba(0,0,0,0.5), inset 0 1px 0 rgba(0,220,255,0.06);
        }
        [data-theme="css2"] .stat-card.success { border-left-color: #00ff9f; }
        [data-theme="css2"] .stat-card.warning { border-left-color: #ff9900; }
        [data-theme="css2"] .stat-card.danger  { border-left-color: #ff00cc; }
        [data-theme="css2"] .stat-card.brain   { border-left-color: #cc00ff; }
        [data-theme="css2"] .stat-icon {
            background: linear-gradient(135deg, rgba(0,220,255,0.2) 0%, rgba(200,0,255,0.12) 100%);
        }
        [data-theme="css2"] .progress-section,
        [data-theme="css2"] .health-panel,
        [data-theme="css2"] .mini-ecosystem,
        [data-theme="css2"] .service-panel {
            background: rgba(5, 8, 30, 0.92);
            border-color: rgba(0,220,255,0.08);
            box-shadow: 0 4px 24px rgba(0,0,0,0.5);
        }
        [data-theme="css2"] .nav-item.active {
            background: linear-gradient(135deg, rgba(0,220,255,0.18) 0%, rgba(200,0,255,0.1) 100%);
            box-shadow: 0 4px 15px rgba(0,220,255,0.2);
        }
        [data-theme="css2"] .nav-item.active .nav-icon { background: linear-gradient(135deg, #00dcff, #cc00ff); }
        [data-theme="css2"] .bg-blob-1 { background: linear-gradient(135deg, #00dcff, #0066ff); }
        [data-theme="css2"] .bg-blob-2 { background: linear-gradient(135deg, #cc00ff, #ff00aa); }
        [data-theme="css2"] .panel-icon { background: linear-gradient(135deg, #00dcff, #cc00ff); }
        [data-theme="css2"] .brain-bar-fill { background: linear-gradient(90deg, #cc00ff, #00dcff); }
        [data-theme="css2"] .progress-text .percent {
            background: linear-gradient(135deg, #00dcff, #cc00ff);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent;
        }
    </style>

    <!-- ── CSS4: Carbon — clean dark with equal tile spacing ──────── -->
    <style id="theme-css4" disabled>
        [data-theme="css4"] body {
            background-color: #111418;
            background-image:
                radial-gradient(ellipse at 20% 30%, rgba(32,178,170,0.07) 0%, transparent 55%),
                radial-gradient(ellipse at 80% 70%, rgba(100,200,100,0.05) 0%, transparent 55%),
                linear-gradient(135deg, #0d1014 0%, #111418 50%, #0d1014 100%);
        }
        [data-theme="css4"] #main-container {
            position: relative;
            z-index: 1;
        }
        [data-theme="css4"] .hero {
            background: rgba(10, 12, 16, 0.85);
            border-color: rgba(200, 200, 200, 0.18);
            box-shadow: 0 0 0 1px rgba(200,200,200,0.08), 0 4px 24px rgba(0,0,0,0.4);
        }
        [data-theme="css4"] .hero h1 {
            background: linear-gradient(135deg, #fff 0%, #20b2aa 100%);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent;
        }
        /* Equal-spacing tile reset */
        [data-theme="css4"] .stat-card {
            background: rgba(10, 12, 16, 0.95);
            border-color: rgba(255,255,255,0.06);
            border-left-color: #20b2aa;
            align-items: flex-start;
            gap: 0.75rem;
            padding: 1rem 1rem 1rem;
            box-shadow: 0 2px 12px rgba(0,0,0,0.4);
        }
        [data-theme="css4"] .stat-content {
            display: flex;
            flex-direction: column;
            gap: 0.35rem;
        }
        [data-theme="css4"] .stat-label {
            margin-bottom: 0;
            font-size: 0.7rem;
            letter-spacing: 0.04em;
        }
        [data-theme="css4"] .stat-value-row {
            gap: 0.4rem;
            align-items: baseline;
        }
        [data-theme="css4"] .stat-icon {
            background: linear-gradient(135deg, rgba(32,178,170,0.2) 0%, rgba(100,200,100,0.12) 100%);
            flex-shrink: 0;
            margin-top: 0;
        }
        [data-theme="css4"] .stat-card.success { border-left-color: #4dcc88; }
        [data-theme="css4"] .stat-card.warning { border-left-color: #e8a838; }
        [data-theme="css4"] .stat-card.danger  { border-left-color: #cc4455; }
        [data-theme="css4"] .stat-card.brain   { border-left-color: #7b68ee; }
        [data-theme="css4"] .progress-section,
        [data-theme="css4"] .health-panel,
        [data-theme="css4"] .mini-ecosystem,
        [data-theme="css4"] .service-panel {
            background: rgba(10, 12, 16, 0.95);
            border-color: rgba(255,255,255,0.06);
            box-shadow: 0 2px 12px rgba(0,0,0,0.4);
        }
        [data-theme="css4"] .progress-stat {
            padding: 0.85rem 0.75rem;
            gap: 0.35rem;
            display: flex; flex-direction: column; align-items: center;
        }
        [data-theme="css4"] .service-item {
            padding: 0.5rem 0.6rem;
            margin-bottom: 0.25rem;
            gap: 0.6rem;
        }
        [data-theme="css4"] .health-item {
            padding: 0.6rem 0.5rem;
            gap: 0.7rem;
        }
        /* Brain Knowledge tile — better internal spacing */
        [data-theme="css4"] .stat-card.brain {
            padding: 1.1rem 1rem 1.1rem;
        }
        [data-theme="css4"] .stat-card.brain .stat-content {
            gap: 0.55rem;
        }
        [data-theme="css4"] .stat-card.brain .stat-label {
            margin-bottom: 0.1rem;
        }
        [data-theme="css4"] .stat-card.brain .stat-value-row {
            margin-bottom: 0.1rem;
        }
        [data-theme="css4"] .brain-bar {
            height: 5px;
            border-radius: 3px;
            margin: 0.1rem 0 0.25rem;
        }
        [data-theme="css4"] #stat-brain-detail {
            margin-top: 0 !important;
            font-size: 0.72rem !important;
            line-height: 1.5;
        }
        [data-theme="css4"] #brain-btn-logs,
        [data-theme="css4"] #brain-btn-run,
        [data-theme="css4"] #brain-btn-restart {
            padding: 5px 0 !important;
            font-size: 0.7rem !important;
            border-radius: 6px !important;
        }
        [data-theme="css4"] .nav-item.active {
            background: linear-gradient(135deg, rgba(32,178,170,0.18) 0%, rgba(100,200,100,0.1) 100%);
            box-shadow: 0 4px 12px rgba(32,178,170,0.15);
        }
        [data-theme="css4"] .nav-item.active .nav-icon { background: linear-gradient(135deg, #20b2aa, #4dcc88); }
        [data-theme="css4"] .bg-blob-1 { background: linear-gradient(135deg, #20b2aa, #4dcc88); }
        [data-theme="css4"] .bg-blob-2 { background: linear-gradient(135deg, #7b68ee, #20b2aa); }
        [data-theme="css4"] .bg-blob-3 { background: linear-gradient(135deg, #e8a838, #20b2aa); }
        [data-theme="css4"] .panel-icon { background: linear-gradient(135deg, #20b2aa, #4dcc88); }
        [data-theme="css4"] .brain-bar-fill { background: linear-gradient(90deg, #7b68ee, #20b2aa); }
        [data-theme="css4"] .progress-text .percent {
            background: linear-gradient(135deg, #20b2aa, #7b68ee);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent;
        }
        [data-theme="css4"] .pulse-dot { background: #20b2aa; box-shadow: 0 0 6px #20b2aa; }
        [data-theme="css4"] .pulse-dot.warning { background: #e8a838; box-shadow: 0 0 6px #e8a838; }
        [data-theme="css4"] .pulse-dot.error { background: #cc4455; box-shadow: 0 0 6px #cc4455; }
        [data-theme="css4"] .health-status.ok { color: #4dcc88; }
        [data-theme="css4"] .mini-conn.online { stroke: #20b2aa; }
    </style>

    <!-- ── CSS3: Amber Terminal ─────────────────────────────────────── -->
    <style id="theme-css3" disabled>
        [data-theme="css3"] body {
            background-color: #0f0a00;
            background-image:
                radial-gradient(ellipse at 20% 30%, rgba(255,160,0,0.07) 0%, transparent 55%),
                radial-gradient(ellipse at 80% 70%, rgba(255,80,0,0.05) 0%, transparent 55%),
                linear-gradient(135deg, #0a0800 0%, #120e01 50%, #0a0800 100%);
        }
        [data-theme="css3"] .hero {
            background: rgba(12, 9, 0, 0.85);
            border-color: rgba(200, 200, 200, 0.18);
            box-shadow: 0 0 0 1px rgba(200,200,200,0.08), 0 4px 24px rgba(0,0,0,0.4);
        }
        [data-theme="css3"] .hero h1 {
            background: linear-gradient(135deg, #fff 0%, #ffaa00 100%);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent;
        }
        [data-theme="css3"] .stat-card {
            background: rgba(15, 10, 0, 0.92);
            border-color: rgba(255,160,0,0.08);
            border-left-color: #ffaa00;
            box-shadow: 0 4px 24px rgba(0,0,0,0.6), inset 0 1px 0 rgba(255,160,0,0.05);
        }
        [data-theme="css3"] .stat-card.success { border-left-color: #aaff44; }
        [data-theme="css3"] .stat-card.warning { border-left-color: #ff6600; }
        [data-theme="css3"] .stat-card.danger  { border-left-color: #ff3300; }
        [data-theme="css3"] .stat-card.brain   { border-left-color: #ff9900; }
        [data-theme="css3"] .stat-icon {
            background: linear-gradient(135deg, rgba(255,160,0,0.18) 0%, rgba(255,80,0,0.1) 100%);
        }
        [data-theme="css3"] .progress-section,
        [data-theme="css3"] .health-panel,
        [data-theme="css3"] .mini-ecosystem,
        [data-theme="css3"] .service-panel {
            background: rgba(15, 10, 0, 0.92);
            border-color: rgba(255,160,0,0.08);
            box-shadow: 0 4px 24px rgba(0,0,0,0.5);
        }
        [data-theme="css3"] .nav-item.active {
            background: linear-gradient(135deg, rgba(255,160,0,0.18) 0%, rgba(255,80,0,0.1) 100%);
            box-shadow: 0 4px 15px rgba(255,160,0,0.18);
        }
        [data-theme="css3"] .nav-item.active .nav-icon { background: linear-gradient(135deg, #ffaa00, #ff4400); }
        [data-theme="css3"] .bg-blob-1 { background: linear-gradient(135deg, #ffaa00, #ff6600); }
        [data-theme="css3"] .bg-blob-2 { background: linear-gradient(135deg, #ff6600, #cc2200); }
        [data-theme="css3"] .bg-blob-3 { background: linear-gradient(135deg, #ffcc00, #ff6600); }
        [data-theme="css3"] .panel-icon { background: linear-gradient(135deg, #ffaa00, #ff4400); }
        [data-theme="css3"] .brain-bar-fill { background: linear-gradient(90deg, #ff6600, #ffcc00); }
        [data-theme="css3"] .progress-text .percent {
            background: linear-gradient(135deg, #ffaa00, #ff4400);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent;
        }
        [data-theme="css3"] .pulse-dot { background: #ffaa00; box-shadow: 0 0 6px #ffaa00; }
        [data-theme="css3"] .pulse-dot.warning { background: #ff6600; box-shadow: 0 0 6px #ff6600; }
        [data-theme="css3"] .pulse-dot.error { background: #ff3300; box-shadow: 0 0 6px #ff3300; }
        [data-theme="css3"] .health-status.ok { color: #aaff44; }
        [data-theme="css3"] .mini-conn.online { stroke: #ffaa00; }
        /* Equal tile spacing */
        [data-theme="css3"] .stat-card {
            align-items: flex-start;
            gap: 0.75rem;
        }
        [data-theme="css3"] .stat-content {
            display: flex;
            flex-direction: column;
            gap: 0.35rem;
        }
        [data-theme="css3"] .stat-label { margin-bottom: 0; }
        [data-theme="css3"] .stat-icon { flex-shrink: 0; margin-top: 0; }
        [data-theme="css3"] .progress-stat {
            padding: 0.85rem 0.75rem;
            display: flex; flex-direction: column; align-items: center; gap: 0.35rem;
        }
        [data-theme="css3"] .service-item { padding: 0.5rem 0.6rem; margin-bottom: 0.25rem; gap: 0.6rem; }
        [data-theme="css3"] .health-item { padding: 0.6rem 0.5rem; gap: 0.7rem; }
        /* Brain Knowledge tile */
        [data-theme="css3"] .stat-card.brain { padding: 1.1rem 1rem 1.1rem; }
        [data-theme="css3"] .stat-card.brain .stat-content { gap: 0.55rem; }
        [data-theme="css3"] .stat-card.brain .stat-label { margin-bottom: 0.1rem; }
        [data-theme="css3"] .stat-card.brain .stat-value-row { margin-bottom: 0.1rem; }
        [data-theme="css3"] .brain-bar { height: 5px; border-radius: 3px; margin: 0.1rem 0 0.25rem; }
        [data-theme="css3"] #stat-brain-detail { margin-top: 0 !important; font-size: 0.72rem !important; line-height: 1.5; }
        [data-theme="css3"] #brain-btn-logs,
        [data-theme="css3"] #brain-btn-run,
        [data-theme="css3"] #brain-btn-restart { padding: 5px 0 !important; font-size: 0.7rem !important; border-radius: 6px !important; }
    </style>

    <!-- ── CSS6: Plasma Shader ────────────────────────────────────────── -->
    <style id="theme-css6" disabled>
        [data-theme="css6"] body {
            background-color: #050510;
        }
        [data-theme="css6"] #main-container {
            position: relative;
            z-index: 1;
        }
        [data-theme="css6"] .hero {
            background: rgba(8, 5, 20, 0.82);
            border-color: rgba(120, 80, 200, 0.2);
            box-shadow: 0 0 0 1px rgba(100,50,200,0.1), 0 4px 24px rgba(0,0,0,0.5);
        }
        [data-theme="css6"] .hero h1 {
            background: linear-gradient(135deg, #fff 0%, #b480ff 100%);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent;
        }
        [data-theme="css6"] .stat-card {
            background: rgba(8, 5, 20, 0.9);
            border-color: rgba(100,50,200,0.1);
            border-left-color: #8b5cf6;
            box-shadow: 0 4px 24px rgba(0,0,0,0.5), inset 0 1px 0 rgba(100,50,200,0.08);
        }
        [data-theme="css6"] .stat-card.success { border-left-color: #22c55e; }
        [data-theme="css6"] .stat-card.warning { border-left-color: #f59e0b; }
        [data-theme="css6"] .stat-card.danger  { border-left-color: #ef4444; }
        [data-theme="css6"] .stat-card.brain   { border-left-color: #a855f7; }
        [data-theme="css6"] .stat-content {
            display: flex; flex-direction: column; gap: 0.35rem;
        }
        [data-theme="css6"] .stat-label { margin-bottom: 0; font-size: 0.7rem; letter-spacing: 0.04em; }
        [data-theme="css6"] .stat-value-row { gap: 0.4rem; align-items: baseline; }
        [data-theme="css6"] .stat-icon {
            background: linear-gradient(135deg, rgba(139,92,246,0.22) 0%, rgba(168,85,247,0.12) 100%);
            flex-shrink: 0; margin-top: 0;
        }
        [data-theme="css6"] .progress-section,
        [data-theme="css6"] .health-panel,
        [data-theme="css6"] .mini-ecosystem,
        [data-theme="css6"] .service-panel {
            background: rgba(8, 5, 20, 0.9);
            border-color: rgba(100,50,200,0.1);
            box-shadow: 0 4px 24px rgba(0,0,0,0.5);
        }
        [data-theme="css6"] .progress-stat {
            padding: 0.85rem 0.75rem; gap: 0.35rem;
            display: flex; flex-direction: column; align-items: center;
        }
        [data-theme="css6"] .service-item { padding: 0.5rem 0.6rem; margin-bottom: 0.25rem; gap: 0.6rem; }
        [data-theme="css6"] .health-item { padding: 0.6rem 0.5rem; gap: 0.7rem; }
        [data-theme="css6"] .stat-card.brain { padding: 1.1rem 1rem 1.1rem; }
        [data-theme="css6"] .stat-card.brain .stat-content { gap: 0.55rem; }
        [data-theme="css6"] .stat-card.brain .stat-label { margin-bottom: 0.1rem; }
        [data-theme="css6"] .stat-card.brain .stat-value-row { margin-bottom: 0.1rem; }
        [data-theme="css6"] .brain-bar { height: 5px; border-radius: 3px; margin: 0.1rem 0 0.25rem; }
        [data-theme="css6"] #stat-brain-detail { margin-top: 0 !important; font-size: 0.72rem !important; line-height: 1.5; }
        [data-theme="css6"] #brain-btn-logs,
        [data-theme="css6"] #brain-btn-run,
        [data-theme="css6"] #brain-btn-restart { padding: 5px 0 !important; font-size: 0.7rem !important; border-radius: 6px !important; }
        [data-theme="css6"] .nav-item.active {
            background: linear-gradient(135deg, rgba(139,92,246,0.2) 0%, rgba(168,85,247,0.12) 100%);
            box-shadow: 0 4px 15px rgba(139,92,246,0.2);
        }
        [data-theme="css6"] .nav-item.active .nav-icon { background: linear-gradient(135deg, #8b5cf6, #a855f7); }
        [data-theme="css6"] .bg-blob-1 { background: linear-gradient(135deg, #8b5cf6, #6d28d9); }
        [data-theme="css6"] .bg-blob-2 { background: linear-gradient(135deg, #a855f7, #7c3aed); }
        [data-theme="css6"] .bg-blob-3 { background: linear-gradient(135deg, #c084fc, #8b5cf6); }
        [data-theme="css6"] .panel-icon { background: linear-gradient(135deg, #8b5cf6, #a855f7); }
        [data-theme="css6"] .brain-bar-fill { background: linear-gradient(90deg, #a855f7, #8b5cf6); }
        [data-theme="css6"] .progress-text .percent {
            background: linear-gradient(135deg, #8b5cf6, #c084fc);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent;
        }
        [data-theme="css6"] .pulse-dot { background: #8b5cf6; box-shadow: 0 0 6px #8b5cf6; }
        [data-theme="css6"] .pulse-dot.warning { background: #f59e0b; box-shadow: 0 0 6px #f59e0b; }
        [data-theme="css6"] .pulse-dot.error { background: #ef4444; box-shadow: 0 0 6px #ef4444; }
        [data-theme="css6"] .health-status.ok { color: #22c55e; }
        [data-theme="css6"] .mini-conn.online { stroke: #8b5cf6; }
    </style>
</head>
<body>
    <svg width="0" height="0">
        <defs>
            <linearGradient id="gradient" x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="0%" style="stop-color:#00f5ff"/>
                <stop offset="100%" style="stop-color:#b829dd"/>
            </linearGradient>
        </defs>
    </svg>

    <!-- CSS1 sea life background -->
    <canvas id="css1-bg" style="position:fixed; top:0; left:0; width:100%; height:100%; z-index:0; pointer-events:none; display:block; opacity:0.65;"></canvas>
    <!-- CSS4 animated neural background -->
    <canvas id="css4-bg" style="position:fixed; top:0; left:0; width:100%; height:100%; z-index:0; pointer-events:none; display:none; opacity:0.55;"></canvas>
    <!-- CSS6 WebGL plasma shader background -->
    <canvas id="css6-bg" style="position:fixed; top:0; left:0; width:100%; height:100%; z-index:0; pointer-events:none; display:none;"></canvas>

    <div class="container" id="main-container">
        <main class="main">
            <div class="bg-blob bg-blob-1"></div>
            <div class="bg-blob bg-blob-2"></div>
            <div class="bg-blob bg-blob-3"></div>

            <!-- Pinecone Migration Banner (auto-hides when complete) -->
            <div id="migration-tile" style="display:none;margin:0.6rem 0;padding:0.65rem 1rem;background:linear-gradient(135deg,rgba(255,170,0,0.12),rgba(0,255,136,0.08));border:1px solid rgba(255,170,0,0.3);border-radius:12px;backdrop-filter:blur(10px);align-items:center;gap:0.8rem;">
                <div style="font-size:1.1rem;">🔄</div>
                <div style="flex:1;">
                    <div style="font-weight:700;font-size:0.8rem;color:#ffaa00;">Pinecone Migration <span id="migration-status" style="font-weight:400;font-size:0.7rem;color:rgba(255,255,255,0.6);">Loading...</span></div>
                    <div style="display:flex;align-items:center;gap:0.8rem;margin-top:5px;">
                        <span id="migration-pct" style="font-size:1.1rem;font-weight:700;color:#ffaa00;min-width:3rem;">—%</span>
                        <div style="flex:1;background:rgba(255,255,255,0.08);border-radius:4px;height:8px;overflow:hidden;">
                            <div id="migration-bar" style="height:100%;background:linear-gradient(90deg,#ffaa00,#00ff88);border-radius:4px;transition:width 0.5s;width:0%;"></div>
                        </div>
                    </div>
                    <div style="display:flex;justify-content:space-between;margin-top:4px;font-size:0.65rem;color:rgba(255,255,255,0.45);">
                        <span id="migration-files">— / — files queued</span>
                        <span id="migration-vectors">— vectors in v3</span>
                    </div>
                </div>
            </div>

            <!-- OpenClaw Update Banner (hidden by default) -->
            <div id="oc-update-banner" style="display:none;margin:0.6rem 0;padding:0.65rem 1rem;background:linear-gradient(135deg,rgba(255,170,0,0.15),rgba(255,100,0,0.1));border:1px solid rgba(255,170,0,0.35);border-radius:12px;backdrop-filter:blur(10px);align-items:center;gap:0.8rem;">
                <div style="font-size:1.1rem;">🦞</div>
                <div style="flex:1;">
                    <div style="font-weight:700;font-size:0.8rem;color:#ffaa00;">OpenClaw Update Available</div>
                    <div style="font-size:0.7rem;color:rgba(255,255,255,0.6);margin-top:2px;">
                        <span id="oc-banner-current"></span> → <span id="oc-banner-target" style="color:#00ff88;font-weight:600;"></span>
                        <span id="oc-banner-notes" style="margin-left:0.5rem;"></span>
                    </div>
                    <div id="oc-banner-impact" style="font-size:0.65rem;color:rgba(255,255,255,0.45);margin-top:3px;"></div>
                </div>
                <div style="display:flex;gap:0.4rem;flex-shrink:0;">
                    <a id="oc-banner-link" href="#" target="_blank" style="font-size:0.65rem;padding:4px 10px;background:rgba(255,170,0,0.2);border:1px solid rgba(255,170,0,0.4);border-radius:6px;color:#ffaa00;text-decoration:none;cursor:pointer;">Release Notes</a>
                    <button onclick="dismissUpdateBanner()" style="font-size:0.65rem;padding:4px 10px;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);border-radius:6px;color:rgba(255,255,255,0.5);cursor:pointer;">Dismiss</button>
                </div>
            </div>

            <!-- Sprint Mode Banner (hidden by default) -->
            <div id="sprint-banner" style="display:none;margin:0.6rem 0;padding:0.65rem 1rem;background:linear-gradient(135deg,rgba(0,245,255,0.12),rgba(0,255,136,0.08));border:1px solid rgba(0,245,255,0.3);border-radius:12px;backdrop-filter:blur(10px);align-items:center;gap:0.8rem;">
                <div style="font-size:1.1rem;" id="sprint-icon">🏃</div>
                <div style="flex:1;">
                    <div style="font-weight:700;font-size:0.8rem;color:#00f5ff;">Sprint Mode <span id="sprint-status-label">ACTIVE</span></div>
                    <div style="font-size:0.7rem;color:rgba(255,255,255,0.6);margin-top:2px;">
                        <span id="sprint-watch-dot" style="display:inline-block;width:7px;height:7px;border-radius:50%;margin-right:4px;"></span><span id="sprint-watch-label" style="font-size:0.65rem;margin-right:8px;"></span>
                        Trigger: <span id="sprint-trigger">—</span> | Cycles: <span id="sprint-cycles">0</span> | Since: <span id="sprint-since">—</span>
                    </div>
                    <div id="sprint-assignments" style="font-size:0.65rem;color:rgba(255,255,255,0.45);margin-top:3px;"></div>
                </div>
                <div style="display:flex;gap:0.4rem;flex-shrink:0;">
                    <button id="sprint-toggle-btn" onclick="toggleSprint()" style="font-size:0.65rem;padding:4px 12px;background:rgba(0,245,255,0.2);border:1px solid rgba(0,245,255,0.4);border-radius:6px;color:#00f5ff;cursor:pointer;font-weight:600;">Deactivate</button>
                    <button onclick="manualSprintCycle()" style="font-size:0.65rem;padding:4px 10px;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);border-radius:6px;color:rgba(255,255,255,0.5);cursor:pointer;">Run Cycle</button>
                </div>
            </div>

            <div class="hero" style="align-items:stretch;padding:1.75rem 2rem;">
                <div class="hero-watermark">
                    <svg viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
                    <span class="wm-title">DWE</span>
                    <span class="wm-sub">Command Center</span>
                </div>
                <div style="display:flex;flex-direction:column;justify-content:center;position:relative;z-index:1;">
                    <h2>Welcome Back</h2>
                    <h1>Sidney Garcia</h1>
                    <div style="font-size: 0.85rem; color: rgba(255,255,255,0.5); margin-top: 0.25rem;">CEO / Founder — Digital Wealth Ecosystem</div>
                </div>
                <div style="display:flex;flex-direction:column;align-items:flex-end;justify-content:space-between;min-height:100%;position:relative;z-index:1;">
                    <div style="display:flex;gap:0.5rem;align-items:center;">
                        <select id="theme-dropdown" onchange="setTheme(this.value)" style="background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.15);color:#fff;border-radius:0.4rem;padding:0.25rem 0.5rem;font-family:Inter,sans-serif;font-size:0.7rem;cursor:pointer;outline:none;">
                            <option value="css1">CSS1</option>
                            <option value="css2">CSS2</option>
                            <option value="css3">CSS3</option>
                            <option value="css4">CSS4</option>
                            <option value="css6">CSS6</option>
                        </select>
                        <a id="ceo-corner-pill" href="/ceo-corner" style="text-decoration:none;background:rgba(255,170,0,0.15);border:1px solid rgba(255,170,0,0.35);color:#ffaa00;font-family:Inter,sans-serif;font-size:0.7rem;font-weight:600;padding:0.25rem 0.7rem;border-radius:0.4rem;letter-spacing:0.03em;transition:all 0.2s;">CEO's Corner &rarr;</a>
                    </div>
                    <div style="text-align:right;margin-top:1.25rem;">
                        <div class="date" id="date">Loading...</div>
                        <div class="clock" id="clock" style="margin-top:0.15rem;">00:00</div>
                    </div>
                </div>
            </div>

            <!-- Stat Cards -->
            <div class="stats-grid">
                <div class="stat-card success">
                    <div class="stat-content">
                        <div class="stat-label">Server Status</div>
                        <div class="stat-value-row">
                            <div class="stat-value" id="stat-server" style="color: #00ff88;">Online</div>
                        </div>
                        <div style="font-size:0.7rem; color:rgba(255,255,255,0.4); margin-top:0.2rem;" id="stat-memory">— MB</div>
                    </div>
                    <div class="stat-icon">🟢</div>
                </div>
                <div class="stat-card">
                    <div class="stat-content">
                        <div class="stat-label">Active Agents</div>
                        <div class="stat-value-row">
                            <div class="stat-value" id="stat-agents">6</div>
                        </div>
                        <div style="font-size:0.7rem; color:rgba(255,255,255,0.4); margin-top:0.2rem;" id="stat-gateway">Checking...</div>
                    </div>
                    <div class="stat-icon">🤖</div>
                </div>
                <div class="stat-card danger">
                    <div class="stat-content">
                        <div class="stat-label">Tasks In Progress</div>
                        <div class="stat-value-row">
                            <div class="stat-value" id="stat-inprogress">—</div>
                        </div>
                        <div style="font-size:0.7rem; color:rgba(255,255,255,0.4); margin-top:0.2rem;" id="stat-overdue">Loading Notion...</div>
                    </div>
                    <div class="stat-icon">📋</div>
                </div>
                <div class="stat-card brain" style="padding:1.2rem 1.3rem;">
                    <div class="stat-content">
                        <div class="stat-label" style="margin-bottom:0.5rem;">Brain Knowledge</div>
                        <div class="stat-value-row">
                            <div class="stat-value" id="stat-brain-score" style="color: #b829dd;">—%</div>
                            <div style="font-size:0.72rem; color:rgba(255,255,255,0.4); margin-left:0.5rem; align-self:flex-end; padding-bottom:2px;" id="stat-brain-pages">— / — pages</div>
                        </div>
                        <div class="brain-bar" style="margin-top:0.4rem;"><div class="brain-bar-fill" id="brain-bar-fill" style="width:0%"></div></div>

                        <div style="display:flex; justify-content:space-between; align-items:center; margin-top:0.65rem; padding-top:0.55rem; border-top:1px solid rgba(255,255,255,0.06);">
                            <div style="font-size:0.78rem; font-weight:600; color:#b829dd;" id="stat-brain-pinecone-index">dwe-v3</div>
                            <div style="font-size:0.78rem; font-weight:600; color:#00f5ff;" id="stat-brain-pinecone-vectors">— vectors</div>
                        </div>
                        <div style="font-size:0.68rem; color:rgba(255,255,255,0.4); margin-top:0.4rem;" id="stat-brain-queue"></div>
                        <div style="font-size:0.62rem; color:rgba(255,255,255,0.3); margin-top:0.35rem;" id="stat-brain-detail">Loading...</div>

                        <div style="display:flex; gap:0.5rem; margin-top:0.7rem; padding-top:0.5rem; border-top:1px solid rgba(255,255,255,0.06);">
                            <button id="brain-btn-logs" onclick="brainToggleLogs()" style="flex:1; padding:5px 0; font-size:0.65rem; background:rgba(255,255,255,0.07); border:1px solid rgba(255,255,255,0.15); border-radius:5px; color:rgba(255,255,255,0.7); cursor:pointer;">Logs</button>
                            <button id="brain-btn-run" onclick="brainRunNow()" style="flex:1; padding:5px 0; font-size:0.65rem; background:rgba(184,41,221,0.2); border:1px solid rgba(184,41,221,0.4); border-radius:5px; color:#d97eff; cursor:pointer;">Run Now</button>
                            <button id="brain-btn-restart" onclick="brainRestart()" style="flex:1; padding:5px 0; font-size:0.65rem; background:rgba(255,80,80,0.12); border:1px solid rgba(255,80,80,0.3); border-radius:5px; color:#ff9090; cursor:pointer;">Reboot</button>
                        </div>
                        <div id="brain-log-panel" style="display:none; margin-top:0.6rem; font-size:0.6rem; font-family:monospace; color:rgba(255,255,255,0.45); background:rgba(0,0,0,0.3); border-radius:5px; padding:8px; max-height:80px; overflow-y:auto; line-height:1.4; white-space:pre-wrap;" id="brain-log-text">Loading logs...</div>
                    </div>
                    <div class="stat-icon" style="background: linear-gradient(135deg, rgba(184,41,221,0.2), rgba(0,245,255,0.1));">🧠</div>
                </div>

                <!-- Ask the DWE Brain — question tile -->
                <div class="stat-card" style="border-left-color:#00f5ff; padding:1.15rem 1.2rem;">
                    <div class="stat-content" style="width:100%;">
                        <div class="stat-label" style="margin-bottom:0.65rem;">Ask the DWE Brain</div>
                        <div style="display:flex; flex-direction:column; gap:0.6rem;">
                            <textarea id="brain-query-input" placeholder="Ask anything about DWE..."
                                onkeydown="if(event.key==='Enter' && !event.shiftKey){ event.preventDefault(); brainQuery(); }"
                                rows="4"
                                style="width:100%; padding:9px 11px; font-size:0.72rem; background:rgba(0,245,255,0.05); border:1px solid rgba(0,245,255,0.2); border-radius:6px; color:#fff; outline:none; resize:none; line-height:1.55; box-sizing:border-box; font-family:inherit;"></textarea>
                            <button onclick="brainQuery()" id="brain-query-btn"
                                style="width:100%; padding:8px 0; font-size:0.74rem; background:rgba(0,245,255,0.15); border:1px solid rgba(0,245,255,0.35); border-radius:5px; color:#00f5ff; cursor:pointer; letter-spacing:0.03em;">Ask the Brain ↵</button>
                        </div>
                    </div>
                    <div class="stat-icon" style="background:linear-gradient(135deg,rgba(0,245,255,0.15),rgba(184,41,221,0.1)); align-self:flex-start;">💬</div>
                </div>

                <!-- Brain Answer tile -->
                <div class="stat-card" style="border-left-color:#b829dd; padding:1.15rem 1.2rem;">
                    <div class="stat-content" style="width:100%;">
                        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:0.65rem;">
                            <div class="stat-label" style="margin-bottom:0;">DWE Brain Response</div>
                            <div style="display:flex; gap:0.45rem;">
                                <button onclick="openDriveInFinder()"
                                    style="font-size:0.65rem; padding:5px 10px; background:rgba(0,245,255,0.1); border:1px solid rgba(0,245,255,0.25); border-radius:4px; color:#00f5ff; cursor:pointer;">
                                    📁 Browse Drive
                                </button>
                                <button onclick="toggleDriveBrowser()" id="drive-browse-btn"
                                    style="font-size:0.65rem; padding:5px 10px; background:rgba(184,41,221,0.1); border:1px solid rgba(184,41,221,0.25); border-radius:4px; color:#b829dd; cursor:pointer;">
                                    🔍 Search Files
                                </button>
                            </div>
                        </div>
                        <div id="brain-query-answer" style="font-size:0.72rem; color:rgba(255,255,255,0.8); line-height:1.65; min-height:80px; max-height:140px; overflow-y:auto; white-space:pre-wrap;">
                            <span style="color:rgba(255,255,255,0.2); font-style:italic;">Waiting for a question...</span>
                        </div>
                        <!-- Drive File Browser (hidden by default) -->
                        <div id="drive-browser" style="display:none; margin-top:0.85rem; border-top:1px solid rgba(255,255,255,0.08); padding-top:0.85rem;">
                            <div style="display:flex; gap:0.5rem; margin-bottom:0.6rem;">
                                <input type="text" id="drive-search" placeholder="Search files..."
                                    onkeyup="debounceDriveSearch()"
                                    style="flex:1; padding:7px 10px; font-size:0.72rem; background:rgba(0,245,255,0.05); border:1px solid rgba(0,245,255,0.2); border-radius:5px; color:#fff; outline:none; font-family:inherit;">
                                <button onclick="searchDriveFiles()" style="padding:7px 12px; font-size:0.67rem; background:rgba(0,245,255,0.15); border:1px solid rgba(0,245,255,0.3); border-radius:5px; color:#00f5ff; cursor:pointer;">Search</button>
                            </div>
                            <div id="drive-status" style="font-size:0.67rem; color:rgba(255,255,255,0.4); margin-bottom:0.5rem;"></div>
                            <div id="drive-file-list" style="max-height:220px; overflow-y:auto; display:flex; flex-direction:column; gap:3px;"></div>
                        </div>
                    </div>
                    <div class="stat-icon" style="background:linear-gradient(135deg,rgba(184,41,221,0.2),rgba(0,245,255,0.1)); align-self:flex-start;">🧬</div>
                </div>

                <!-- System Uptime + Mac mini Health — unified card -->
                <div class="stat-card" style="border-left-color:#7b61ff; grid-column: span 3;">
                    <div class="stat-content" style="width:100%;">
                        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.6rem;">
                            <div class="stat-label" style="margin-bottom:0;">System Uptime</div>
                            <a href="/delegations" style="text-decoration:none;background:rgba(123,97,255,0.15);border:1px solid rgba(123,97,255,0.35);color:#a78bff;font-family:Inter,sans-serif;font-size:0.7rem;font-weight:600;padding:0.25rem 0.7rem;border-radius:0.4rem;letter-spacing:0.03em;transition:all 0.2s;" onmouseover="this.style.background='rgba(123,97,255,0.28)'" onmouseout="this.style.background='rgba(123,97,255,0.15)'">Logs &rarr;</a>
                        </div>
                        <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:0.8rem 1.2rem;">
                            <!-- Mac mini (uptime + health merged) -->
                            <div style="background:rgba(123,97,255,0.08); border:1px solid rgba(123,97,255,0.2); border-radius:8px; padding:0.75rem 0.85rem; display:flex; flex-direction:column;">
                                <div style="display:flex; align-items:center; gap:0.4rem; margin-bottom:0.25rem;">
                                    <span style="font-size:0.75rem;">🖥️</span>
                                    <span style="font-size:0.65rem; color:rgba(255,255,255,0.45); text-transform:uppercase; letter-spacing:0.05em;">Mac mini</span>
                                    <span style="margin-left:auto; font-size:0.55rem; color:rgba(255,255,255,0.35);" id="mac-chip">Apple M4 · 10 cores</span>
                                </div>
                                <div style="font-size:1.05rem; font-family:monospace; font-weight:600; color:#a78bff; letter-spacing:0.02em;"><span class="heartbeat">💓</span> <span id="mac-uptime-counter">—</span></div>
                                <div style="font-size:0.58rem; color:rgba(255,255,255,0.3); margin-top:0.15rem; margin-bottom:0.45rem;" id="mac-boot-time">—</div>
                                <!-- Ollama -->
                                <div style="display:flex; align-items:center; gap:0.35rem; padding:0.3rem 0.5rem; background:rgba(255,255,255,0.03); border-radius:5px;">
                                    <span id="mac-ollama-dot" style="width:6px;height:6px;border-radius:50%;background:#555;flex-shrink:0;"></span>
                                    <span style="font-size:0.6rem; color:rgba(255,255,255,0.5);">Ollama GPU</span>
                                    <span id="mac-ollama-status" style="margin-left:auto; font-size:0.55rem; color:rgba(255,255,255,0.35); font-family:monospace;">—</span>
                                </div>
                                <!-- CPU / RAM / Disk bars -->
                                <div style="display:flex; flex-direction:column; gap:0.35rem; margin-top:auto; padding:0.4rem 0.5rem; background:rgba(255,255,255,0.03); border-radius:5px;">
                                    <div>
                                        <div style="display:flex; justify-content:space-between; font-size:0.6rem; color:rgba(255,255,255,0.5); margin-bottom:3px;">
                                            <span>CPU</span><span id="mac-cpu-pct">—%</span>
                                        </div>
                                        <div style="height:4px; background:rgba(255,255,255,0.08); border-radius:3px; overflow:hidden;">
                                            <div id="mac-cpu-bar" style="height:100%; width:0%; background:#00bfff; border-radius:3px; transition:width 0.6s;"></div>
                                        </div>
                                    </div>
                                    <div>
                                        <div style="display:flex; justify-content:space-between; font-size:0.6rem; color:rgba(255,255,255,0.5); margin-bottom:3px;">
                                            <span>RAM</span><span id="mac-ram-pct">—</span>
                                        </div>
                                        <div style="height:4px; background:rgba(255,255,255,0.08); border-radius:3px; overflow:hidden;">
                                            <div id="mac-ram-bar" style="height:100%; width:0%; background:#00ff88; border-radius:3px; transition:width 0.6s;"></div>
                                        </div>
                                    </div>
                                    <div>
                                        <div style="display:flex; justify-content:space-between; font-size:0.6rem; color:rgba(255,255,255,0.5); margin-bottom:3px;">
                                            <span>Disk /</span><span id="mac-disk-pct">—</span>
                                        </div>
                                        <div style="height:4px; background:rgba(255,255,255,0.08); border-radius:3px; overflow:hidden;">
                                            <div id="mac-disk-bar" style="height:100%; width:0%; background:#ff9500; border-radius:3px; transition:width 0.6s;"></div>
                                        </div>
                                    </div>
                                </div>
                                <div style="display:flex; gap:0.3rem; padding-top:0.5rem;">
                                    <button onclick="openTerminal()" style="flex:1; padding:4px 0; font-size:0.55rem; background:rgba(123,97,255,0.15); border:1px solid rgba(123,97,255,0.35); border-radius:4px; color:#a78bff; cursor:pointer;">Terminal</button>
                                </div>
                            </div>
                            <!-- OpenClaw -->
                            <div style="background:rgba(0,255,136,0.06); border:1px solid rgba(0,255,136,0.18); border-radius:8px; padding:0.75rem 0.85rem; display:flex; flex-direction:column;">
                                <div style="display:flex; align-items:center; gap:0.4rem; margin-bottom:0.45rem;">
                                    <span style="font-size:0.75rem;">⚡</span>
                                    <span style="font-size:0.65rem; color:rgba(255,255,255,0.45); text-transform:uppercase; letter-spacing:0.05em;">OpenClaw</span>
                                    <span id="oc-version-badge" style="margin-left:auto;font-size:0.68rem;padding:2px 8px;border-radius:4px;background:rgba(0,255,136,0.1);color:rgba(0,255,136,0.6);font-family:monospace;font-weight:500;">v...</span>
                                </div>
                                <div style="font-size:1.05rem; font-family:monospace; font-weight:600; color:#00ff88; letter-spacing:0.02em;" id="gateway-uptime-counter">—</div>
                                <div style="font-size:0.58rem; color:rgba(255,255,255,0.3); margin-top:0.25rem;" id="gateway-start-time">—</div>
                                <!-- OpenRouter credit balance -->
                                <div id="oc-openrouter-row" style="display:flex; align-items:center; gap:0.35rem; margin-top:0.5rem; padding:0.3rem 0.5rem; background:rgba(255,255,255,0.03); border-radius:5px;">
                                    <span id="oc-openrouter-dot" style="width:6px;height:6px;border-radius:50%;background:#555;flex-shrink:0;"></span>
                                    <span style="font-size:0.6rem; color:rgba(255,255,255,0.5);">OpenRouter</span>
                                    <span id="oc-openrouter-credit" style="margin-left:auto; font-size:0.6rem; font-weight:700; color:rgba(255,255,255,0.35); font-family:monospace;">—</span>
                                </div>
                                <!-- Daemon statuses -->
                                <div style="display:flex; flex-direction:column; gap:0.3rem; margin-top:auto; padding:0.4rem 0.5rem; background:rgba(255,255,255,0.03); border-radius:5px;">
                                    <div style="display:flex; align-items:center; gap:0.35rem;">
                                        <span id="oc-gateway-dot" style="width:6px;height:6px;border-radius:50%;background:#555;flex-shrink:0;"></span>
                                        <span style="font-size:0.6rem; color:rgba(255,255,255,0.5);">Gateway</span>
                                        <span id="oc-gateway-status" style="margin-left:auto; font-size:0.55rem; color:rgba(255,255,255,0.35); font-family:monospace;">—</span>
                                    </div>
                                    <div style="display:flex; align-items:center; gap:0.35rem;">
                                        <span id="oc-relay-dot" style="width:6px;height:6px;border-radius:50%;background:#555;flex-shrink:0;"></span>
                                        <span style="font-size:0.6rem; color:rgba(255,255,255,0.5);">Relay Daemon</span>
                                        <span id="oc-relay-status" style="margin-left:auto; font-size:0.55rem; color:rgba(255,255,255,0.35); font-family:monospace;">—</span>
                                    </div>
                                    <div style="display:flex; align-items:center; gap:0.35rem;">
                                        <span id="oc-backup-dot" style="width:6px;height:6px;border-radius:50%;background:#555;flex-shrink:0;"></span>
                                        <span style="font-size:0.6rem; color:rgba(255,255,255,0.5);">Backup</span>
                                        <span id="oc-backup-status" style="margin-left:auto; font-size:0.55rem; color:rgba(255,255,255,0.35); font-family:monospace;">—</span>
                                    </div>
                                    <div style="display:flex; align-items:center; gap:0.35rem;">
                                        <span id="oc-clawhub-dot" style="width:6px;height:6px;border-radius:50%;background:#555;flex-shrink:0;"></span>
                                        <span style="font-size:0.6rem; color:rgba(255,255,255,0.5);">ClawHub Check</span>
