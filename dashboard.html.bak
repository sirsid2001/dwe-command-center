            <!-- ═══ ECOSYSTEM HUD ═══ -->
            <style>
                @keyframes hud-spin { from{transform:rotate(0deg)} to{transform:rotate(360deg)} }
                @keyframes hud-spin-rev { from{transform:rotate(360deg)} to{transform:rotate(0deg)} }
                @keyframes hud-relay-pulse { 0%,100%{stroke-opacity:1;stroke-width:5} 50%{stroke-opacity:0.4;stroke-width:3} }
                @keyframes hud-pulse { 0%{opacity:0.4} 50%{opacity:1} 100%{opacity:0.4} }
                @keyframes hud-core-breathe { 0%{r:4} 50%{r:7} 100%{r:4} }
                @keyframes hud-scan { 0%{stroke-dashoffset:0} 100%{stroke-dashoffset:-60} }
                @keyframes hud-bar-glow { 0%{filter:brightness(1)} 50%{filter:brightness(1.4)} 100%{filter:brightness(1)} }
                .hud-frame {
                    position:relative; padding:0.5rem 0.65rem; font-family:'Courier New',monospace; z-index:2;
                    background:rgba(2,8,22,0.85); backdrop-filter:blur(6px);
                    clip-path:polygon(0 0,calc(100% - 8px) 0,100% 8px,100% 100%,8px 100%,0 calc(100% - 8px));
                }
                .hud-frame::before {
                    content:''; position:absolute; inset:0; pointer-events:none;
                    clip-path:polygon(0 0,calc(100% - 8px) 0,100% 8px,100% 100%,8px 100%,0 calc(100% - 8px));
                    border:1px solid rgba(0,180,255,0.25);
                }
                .hud-frame::after {
                    content:''; position:absolute; top:0; left:0; width:12px; height:12px; pointer-events:none;
                    border-top:2px solid rgba(0,180,255,0.6); border-left:2px solid rgba(0,180,255,0.6);
                }
                .hud-frame .corner-br { position:absolute; bottom:0; right:0; width:12px; height:12px;
                    border-bottom:2px solid rgba(0,180,255,0.6); border-right:2px solid rgba(0,180,255,0.6); }
                .hud-frame .corner-tr { position:absolute; top:0; right:0; width:12px; height:12px;
                    border-top:2px solid rgba(255,160,40,0.5); border-right:2px solid rgba(255,160,40,0.5); }
                .hud-frame .corner-bl { position:absolute; bottom:0; left:0; width:12px; height:12px;
                    border-bottom:2px solid rgba(255,160,40,0.5); border-left:2px solid rgba(255,160,40,0.5); }
                .hud-ftitle {
                    font-size:0.52rem; letter-spacing:0.14em; text-transform:uppercase;
                    color:rgba(0,180,255,0.7); margin-bottom:0.35rem; padding-bottom:0.2rem;
                    border-bottom:1px solid rgba(0,180,255,0.12); display:flex; align-items:center; gap:6px;
                }
                .hud-ftitle .hud-bar-accent { flex:1; height:2px;
                    background:linear-gradient(90deg,rgba(0,180,255,0.3),transparent); }
                .hud-row { display:flex; align-items:center; gap:6px; padding:2px 0; }
                .hud-dot { width:6px; height:6px; border-radius:50%; background:#334; flex-shrink:0;
                    box-shadow:0 0 6px rgba(0,180,255,0.15); }
                .hud-name { font-size:0.58rem; color:rgba(180,210,240,0.6); }
                .hud-st { margin-left:auto; font-size:0.5rem; color:rgba(0,180,255,0.35); }
                .hud-bar-track { flex:1; height:3px; background:rgba(0,180,255,0.08); border-radius:2px; overflow:hidden; margin-left:4px; }
                .hud-bar-fill { height:100%; border-radius:2px; animation:hud-bar-glow 3s ease-in-out infinite; }
            </style>
            <div style="margin-bottom:1.2rem;background:linear-gradient(180deg,rgba(2,6,18,0.97) 0%,rgba(4,12,35,0.97) 60%,rgba(8,20,50,0.95) 100%);border:1px solid rgba(0,180,255,0.18);border-radius:14px;overflow:hidden;box-shadow:0 0 40px rgba(0,120,255,0.06),0 0 100px rgba(0,80,200,0.03),inset 0 1px 0 rgba(255,255,255,0.04),inset 0 -80px 120px rgba(0,40,120,0.06);">
                <!-- HUD Header -->
                <div style="display:flex;align-items:center;padding:0.5rem 1.1rem;border-bottom:1px solid rgba(0,180,255,0.1);background:linear-gradient(90deg,rgba(0,180,255,0.06),transparent 40%,transparent 60%,rgba(255,160,40,0.03));">
                    <div style="display:flex;align-items:center;gap:6px;">
                        <div style="width:8px;height:8px;background:rgba(0,180,255,0.6);clip-path:polygon(50% 0%,100% 50%,50% 100%,0% 50%);"></div>
                        <span style="font-size:0.55rem;font-family:'Courier New',monospace;color:rgba(0,180,255,0.6);letter-spacing:0.14em;">SYS::ECOSYSTEM</span>
                    </div>
                    <span style="margin:0 0.7rem;color:rgba(0,180,255,0.12);">|</span>
                    <span style="font-size:0.82rem;font-weight:700;color:rgba(220,240,255,0.92);letter-spacing:0.05em;text-shadow:0 0 12px rgba(0,180,255,0.2);">DWE HUD</span>
                    <div style="margin-left:auto;display:flex;align-items:center;gap:0.7rem;">
                        <span id="hud-clock" style="font-size:0.55rem;font-family:'Courier New',monospace;color:rgba(0,180,255,0.4);letter-spacing:0.06em;"></span>
                        <div style="display:flex;gap:4px;">
                            <div style="width:4px;height:4px;border-radius:50%;background:rgba(0,255,120,0.6);box-shadow:0 0 4px rgba(0,255,120,0.4);"><div style="animation:hud-pulse 2s infinite;width:100%;height:100%;border-radius:50%;background:inherit;"></div></div>
                            <div style="width:4px;height:4px;border-radius:50%;background:rgba(0,180,255,0.6);box-shadow:0 0 4px rgba(0,180,255,0.4);"></div>
                            <div style="width:4px;height:4px;border-radius:50%;background:rgba(255,160,40,0.5);box-shadow:0 0 4px rgba(255,160,40,0.3);"></div>
                        </div>
                        <a id="ecosystem-btn" href="/ecosystem" style="font-size:0.7rem;padding:0.25rem 0.7rem;background:rgba(0,255,136,0.15);border:1px solid rgba(0,255,136,0.35);color:#00ff88;text-decoration:none;font-family:Inter,sans-serif;font-weight:600;border-radius:0.4rem;letter-spacing:0.03em;transition:all 0.2s;" onmouseover="this.style.background='rgba(0,255,136,0.28)'" onmouseout="this.style.background='rgba(0,255,136,0.15)'">Ecosystem &rarr;</a>
                    </div>
                </div>

                <!-- HUD Body: 3-column layout — panels | reticle | panels -->
                <div style="display:grid;grid-template-columns:210px 1fr 210px;min-height:700px;gap:0;">

                    <!-- LEFT COLUMN: Brain, COO, Cron (evenly spaced, Cron flush bottom) -->
                    <div style="display:flex;flex-direction:column;justify-content:space-between;padding:12px;border-right:1px solid rgba(0,180,255,0.06);">
                        <!-- BRAIN -->
                        <div class="hud-frame">
                            <div class="corner-br"></div><div class="corner-tr"></div><div class="corner-bl"></div>
                            <div class="hud-ftitle"><span>🧠 BRAIN</span><div class="hud-bar-accent"></div></div>
                            <div class="hud-row"><span id="hud-seed-watcher-dot" class="hud-dot"></span><span class="hud-name">Seed Watcher</span><span id="hud-seed-watcher-st" class="hud-st">—</span></div>
                            <div class="hud-row"><span id="hud-notion-sync-dot" class="hud-dot"></span><span class="hud-name">Notion Sync</span><span id="hud-notion-sync-st" class="hud-st">—</span></div>
                            <div class="hud-row"><span id="hud-brain-trainer-dot" class="hud-dot"></span><span class="hud-name">Brain Trainer</span><span id="hud-brain-trainer-st" class="hud-st">—</span></div>
                            <div class="hud-row"><span id="hud-nightly-review-dot" class="hud-dot"></span><span class="hud-name">Nightly Review</span><span id="hud-nightly-review-st" class="hud-st">—</span></div>
                            <div class="hud-row"><span id="hud-memory-decay-dot" class="hud-dot"></span><span class="hud-name">Memory Decay</span><span id="hud-memory-decay-st" class="hud-st">—</span></div>
                        </div>
                        <!-- DWE OPS -->
                        <div class="hud-frame">
                            <div class="corner-br"></div><div class="corner-tr"></div><div class="corner-bl"></div>
                            <div class="hud-ftitle" style="color:rgba(255,160,40,0.7);border-color:rgba(255,160,40,0.12);"><span>📋 DWE OPS</span><div class="hud-bar-accent" style="background:linear-gradient(90deg,rgba(255,160,40,0.3),transparent);"></div></div>
                            <div id="hud-coo-ops">
                                <div class="hud-row"><span id="hud-email-batch-dot" class="hud-dot"></span><span class="hud-name">Email Batch</span><span id="hud-email-batch-st" class="hud-st">—</span></div>
                                <div class="hud-row"><span id="hud-notion-triage-dot" class="hud-dot"></span><span class="hud-name">Notion Triage</span><span id="hud-notion-triage-st" class="hud-st">—</span></div>
                                <div class="hud-row"><span id="hud-morning-digest-dot" class="hud-dot"></span><span class="hud-name">Morning Digest</span><span id="hud-morning-digest-st" class="hud-st">—</span></div>
                            </div>
                        </div>
                        <!-- CRON (flush bottom) -->
                        <div class="hud-frame">
                            <div class="corner-br"></div><div class="corner-tr"></div><div class="corner-bl"></div>
                            <div class="hud-ftitle"><span>⏰ CRON</span><div class="hud-bar-accent"></div></div>
                            <div id="crons-list">
                                <div class="hud-row"><span class="hud-dot"></span><span class="hud-name">Loading...</span></div>
                            </div>
                        </div>
                    </div>

                    <!-- CENTER: Targeting Reticle / Ecosystem Map -->
                    <div style="position:relative;display:flex;align-items:center;justify-content:center;overflow:hidden;padding:8px;">
                        <!-- Subtle radial background glow -->
                        <div style="position:absolute;width:500px;height:500px;border-radius:50%;background:radial-gradient(circle,rgba(0,120,255,0.07) 0%,transparent 70%);pointer-events:none;"></div>
                        <svg viewBox="0 0 500 500" style="width:100%;height:100%;">
                            <defs>
                                <radialGradient id="hud-core-glow2" cx="50%" cy="50%" r="50%">
                                    <stop offset="0%" stop-color="rgba(0,180,255,0.18)"/>
                                    <stop offset="60%" stop-color="rgba(0,120,255,0.04)"/>
                                    <stop offset="100%" stop-color="transparent"/>
                                </radialGradient>
                                <filter id="hud-glow"><feGaussianBlur stdDeviation="2" result="g"/><feMerge><feMergeNode in="g"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
                                <!-- Data flow paths -->
                                <path id="fp1" d="M250,250 Q170,170 110,100"/>
                                <path id="fp2" d="M250,250 Q330,170 400,110"/>
                                <path id="fp3" d="M250,250 Q170,330 100,400"/>
                                <path id="fp4" d="M250,250 Q330,330 410,390"/>
                                <path id="fp5" d="M250,250 Q250,160 250,60"/>
                                <path id="fp6" d="M250,250 Q250,340 250,440"/>
                            </defs>

                            <!-- Outer ring 4 — very faint, large -->
                            <circle cx="250" cy="250" r="230" fill="none" stroke="rgba(0,180,255,0.04)" stroke-width="0.5"/>
                            <!-- Tick marks on outer ring -->
                            <g style="transform-origin:250px 250px;animation:hud-spin 120s linear infinite;">
                                <line x1="250" y1="21" x2="250" y2="28" stroke="rgba(0,180,255,0.15)" stroke-width="1"/>
                                <line x1="250" y1="472" x2="250" y2="479" stroke="rgba(0,180,255,0.15)" stroke-width="1"/>
                                <line x1="21" y1="250" x2="28" y2="250" stroke="rgba(0,180,255,0.15)" stroke-width="1"/>
                                <line x1="472" y1="250" x2="479" y2="250" stroke="rgba(0,180,255,0.15)" stroke-width="1"/>
                            </g>

                            <!-- Ring 3 — dashed, rotating — speed + color driven by router WAN throughput -->
                            <circle id="hud-outer-ring" cx="250" cy="250" r="190" fill="none" stroke="rgba(0,180,255,0.07)" stroke-width="1" stroke-dasharray="12 8" style="transform-origin:250px 250px;animation:hud-spin 80s linear infinite;"/>

                            <!-- Ring 2 — orange arc segments — speed driven by network bandwidth -->
                            <g id="hud-net-ring" style="transform-origin:250px 250px;animation:hud-spin-rev 35s linear infinite;">
                                <!-- Arc segment top -->
                                <path d="M250,105 A145,145 0 0,1 380,190" fill="none" stroke="rgba(255,160,40,0.4)" stroke-width="2.5" stroke-linecap="round"/>
                                <!-- Arc segment bottom -->
                                <path d="M250,395 A145,145 0 0,1 120,310" fill="none" stroke="rgba(255,160,40,0.3)" stroke-width="2" stroke-linecap="round"/>
                                <!-- Small tick arcs -->
                                <path d="M145,155 A130,130 0 0,1 175,125" fill="none" stroke="rgba(255,160,40,0.25)" stroke-width="1.5"/>
                                <path d="M355,345 A130,130 0 0,1 325,375" fill="none" stroke="rgba(255,160,40,0.25)" stroke-width="1.5"/>
                            </g>

                            <!-- Ring 1 — main targeting ring — speed + color driven by router throughput -->
                            <g id="hud-ring1" style="transform-origin:250px 250px;animation:hud-spin 50s linear infinite;">
                                <circle cx="250" cy="250" r="110" fill="none" stroke="rgba(0,180,255,0.25)" stroke-width="2"/>
                                <!-- Notch marks every 30 degrees -->
                                <line x1="250" y1="141" x2="250" y2="148" stroke="rgba(0,180,255,0.4)" stroke-width="1.5"/>
                                <line x1="305" y1="155" x2="301" y2="161" stroke="rgba(0,180,255,0.3)" stroke-width="1"/>
                                <line x1="345" y1="195" x2="339" y2="199" stroke="rgba(0,180,255,0.3)" stroke-width="1"/>
                                <line x1="360" y1="250" x2="352" y2="250" stroke="rgba(0,180,255,0.4)" stroke-width="1.5"/>
                                <line x1="345" y1="305" x2="339" y2="301" stroke="rgba(0,180,255,0.3)" stroke-width="1"/>
                                <line x1="305" y1="345" x2="301" y2="339" stroke="rgba(0,180,255,0.3)" stroke-width="1"/>
                                <line x1="250" y1="360" x2="250" y2="352" stroke="rgba(0,180,255,0.4)" stroke-width="1.5"/>
                                <line x1="195" y1="345" x2="199" y2="339" stroke="rgba(0,180,255,0.3)" stroke-width="1"/>
                                <line x1="155" y1="305" x2="161" y2="301" stroke="rgba(0,180,255,0.3)" stroke-width="1"/>
                                <line x1="140" y1="250" x2="148" y2="250" stroke="rgba(0,180,255,0.4)" stroke-width="1.5"/>
                                <line x1="155" y1="195" x2="161" y2="199" stroke="rgba(0,180,255,0.3)" stroke-width="1"/>
                                <line x1="195" y1="155" x2="199" y2="161" stroke="rgba(0,180,255,0.3)" stroke-width="1"/>
                            </g>

                            <!-- Inner dashed ring -->
                            <circle cx="250" cy="250" r="70" fill="none" stroke="rgba(0,180,255,0.12)" stroke-width="1" stroke-dasharray="4 6" style="transform-origin:250px 250px;animation:hud-spin-rev 20s linear infinite;"/>

                            <!-- Crosshairs -->
                            <line x1="250" y1="180" x2="250" y2="220" stroke="rgba(0,180,255,0.3)" stroke-width="1"/>
                            <line x1="250" y1="280" x2="250" y2="320" stroke="rgba(0,180,255,0.3)" stroke-width="1"/>
                            <line x1="180" y1="250" x2="220" y2="250" stroke="rgba(0,180,255,0.3)" stroke-width="1"/>
                            <line x1="280" y1="250" x2="320" y2="250" stroke="rgba(0,180,255,0.3)" stroke-width="1"/>
                            <!-- Diagonal cross -->
                            <line x1="205" y1="205" x2="220" y2="220" stroke="rgba(255,160,40,0.2)" stroke-width="0.8"/>
                            <line x1="280" y1="220" x2="295" y2="205" stroke="rgba(255,160,40,0.2)" stroke-width="0.8"/>
                            <line x1="205" y1="295" x2="220" y2="280" stroke="rgba(255,160,40,0.2)" stroke-width="0.8"/>
                            <line x1="280" y1="280" x2="295" y2="295" stroke="rgba(255,160,40,0.2)" stroke-width="0.8"/>


                            <!-- ═══ CENTER: RELAY — the router/gateway that connects everything ═══ -->
                            <circle cx="250" cy="250" r="60" fill="url(#hud-core-glow2)"/>
                            <circle id="hud-relay-ring" cx="250" cy="250" r="38" fill="rgba(2,6,18,0.95)" stroke="rgba(0,255,136,0.6)" stroke-width="2.5" style="transform-origin:250px 250px; animation: hud-spin-rev 14s linear infinite;"/>
                            <circle id="hud-inner-spin" cx="250" cy="250" r="45" fill="none" stroke="rgba(0,255,136,0.12)" stroke-width="1" stroke-dasharray="3 3" style="transform-origin:250px 250px;animation:hud-spin 12s linear infinite;"/>
                            <text x="250" y="244" text-anchor="middle" font-size="14" fill="rgba(220,240,255,0.95)" font-family="'Courier New',monospace" font-weight="700" filter="url(#hud-glow)">ROUTER</text>
                            <text x="250" y="262" text-anchor="middle" font-size="8" fill="rgba(0,255,136,0.6)" font-family="'Courier New',monospace" letter-spacing="1">192.168.1.254</text>
                            <text id="hud-router-extip" x="250" y="272" text-anchor="middle" font-size="6" fill="rgba(0,255,136,0.35)" font-family="'Courier New',monospace">—</text>
                            <!-- Relay status breathing dot — dynamic via JS -->
                            <circle id="hud-relay-pulse" cx="250" cy="250" r="4" fill="rgba(0,255,136,0.5)">
                                <animate attributeName="r" values="4;7;4" dur="3s" repeatCount="indefinite"/>
                                <animate attributeName="opacity" values="0.5;0.15;0.5" dur="3s" repeatCount="indefinite"/>
                            </circle>

                            <!-- ═══ CONNECTION LINES: Relay connects everything ═══ -->
                            <!-- Relay → AI Team -->
                            <line x1="250" y1="212" x2="250" y2="78" stroke="rgba(0,255,136,0.1)" stroke-width="0.8"/>
                            <!-- Relay → Notion -->
                            <line x1="213" y1="225" x2="134" y2="171" stroke="rgba(0,180,255,0.08)" stroke-width="0.8"/>
                            <!-- Relay → n8n (lower-left) -->
                            <line x1="228" y1="274" x2="151" y2="349" stroke="rgba(255,160,40,0.08)" stroke-width="0.8"/>
                            <!-- Relay → Brain (lower-left, 8:00 of n8n) -->
                            <line x1="215" y1="278" x2="64" y2="401" stroke="rgba(255,80,200,0.07)" stroke-width="0.8"/>
                            <!-- Relay → OpenRouter -->
                            <line x1="286" y1="223" x2="355" y2="172" stroke="rgba(255,200,50,0.07)" stroke-width="0.8"/>
                            <!-- Relay ⚡ Mac Mini — yellow lightning bolt -->
                            <defs>
                                <filter id="lightning-glow">
                                    <feGaussianBlur stdDeviation="3" result="g"/>
                                    <feMerge><feMergeNode in="g"/><feMergeNode in="g"/><feMergeNode in="SourceGraphic"/></feMerge>
                                </filter>
                            </defs>
                            <!-- ═══ REAL-TIME TRAFFIC SYSTEM — all paths + per-service containers ═══ -->
                            <defs>
                                <path id="relay-macmini-line" d="M250,212 L250,88"/>
                                <path id="pulse-macmini-relay" d="M250,60 L250,250"/>
                                <path id="pulse-mm-openrouter" d="M250,60 L250,250 L369,161"/>
                                <path id="pulse-mm-brain" d="M141,359 L50,412"/>
                                <path id="pulse-mm-github" d="M250,60 L250,250 L55,250"/>
                                <path id="pulse-mm-notion" d="M250,60 L250,250 L119,161"/>
                                <path id="pulse-n8n-mm" d="M141,359 L250,250 L250,60"/>
                                <path id="pulse-mm-telegram" d="M250,60 L250,250 L420,250"/>
                                <path id="pulse-n8n-ollama" d="M141,359 L250,250 L250,60 L175,22"/>
                                <!-- Brain query full path: Mac Mini → n8n relay → Brain (pink end-to-end) -->
                                <path id="pulse-brain-relay" d="M250,60 L250,250 L141,359 L50,412"/>
                            </defs>
                            <!-- Faint connector lines (static, always visible) -->
                            <line x1="141" y1="359" x2="50" y2="412" stroke="rgba(255,100,200,0.12)" stroke-width="1"/>
                            <line x1="250" y1="250" x2="55" y2="250" stroke="rgba(0,140,255,0.06)" stroke-width="1"/>
                            <line x1="250" y1="250" x2="119" y2="161" stroke="rgba(0,255,136,0.06)" stroke-width="1"/>
                            <line x1="141" y1="359" x2="250" y2="250" stroke="rgba(255,140,40,0.06)" stroke-width="1"/>
                            <line x1="250" y1="250" x2="369" y2="161" stroke="rgba(255,200,50,0.06)" stroke-width="1"/>
                            <line x1="250" y1="250" x2="250" y2="60" stroke="rgba(0,255,136,0.06)" stroke-width="1"/>
                            <line x1="288" y1="250" x2="395" y2="250" stroke="rgba(0,200,255,0.06)" stroke-width="1"/>
                            <!-- n8n ↔ Ollama connector — no separate line needed, dots follow existing segments -->
                            <!-- Per-service real-time traffic containers (populated by JS) -->
                            <g id="rt-traffic-n8n-ollama"></g>
                            <g id="rt-traffic-notion"></g>
                            <g id="rt-traffic-n8n"></g>
                            <g id="rt-traffic-openrouter"></g>
                            <g id="rt-traffic-github"></g>
                            <g id="rt-traffic-brain"></g>
                            <g id="rt-traffic-brain-relay"></g>
                            <g id="rt-traffic-telegram"></g>
                            <g id="rt-traffic-total"></g>
                            <!-- Total throughput readout -->
                            <text id="traffic-readout" x="342" y="238" font-size="5" fill="rgba(0,255,200,0.7)" text-anchor="middle" font-family="'Courier New',monospace"></text>

                            <!-- Cross connections -->
                            <line x1="119" y1="161" x2="50" y2="412" stroke="rgba(0,180,255,0.04)" stroke-width="0.5"/>
                            <line x1="250" y1="60" x2="119" y2="161" stroke="rgba(0,255,136,0.04)" stroke-width="0.5"/>
                            <line x1="250" y1="60" x2="369" y2="161" stroke="rgba(0,255,136,0.04)" stroke-width="0.5"/>

                            <!-- (Old data flow particles removed — all traffic now uses colored line system above) -->

                            <!-- ═══ ECOSYSTEM NODES ═══ -->



                            <!-- Telegram (right) — agent comms — CYAN -->
                            <g>
                                <circle cx="420" cy="250" r="20" fill="rgba(2,6,18,0.92)" stroke="rgba(0,200,255,0.5)" stroke-width="1.8"/>
                                <circle cx="420" cy="250" r="26" fill="none" stroke="rgba(0,200,255,0.08)" stroke-width="0.8" stroke-dasharray="3 4"/>
                                <text x="420" y="256" text-anchor="middle" font-size="17">✈️</text>
                                <text x="420" y="222" text-anchor="middle" font-size="9" fill="#fff" font-weight="700" font-family="'Courier New',monospace">TELEGRAM</text>
                                <circle id="hud-telegram-pulse" cx="438" cy="232" r="4" fill="rgba(0,200,255,0.8)">
                                    <animate attributeName="opacity" values="1;0.3;1" dur="3s" repeatCount="indefinite"/>
                                </circle>
                            </g>



                            <!-- Notion — midpoint GitHub/MEM — BLUE -->
                            <g>
                                <circle id="hud-notion-ring" cx="119" cy="161" r="18" fill="rgba(2,6,18,0.92)" stroke="rgba(80,120,255,0.45)" stroke-width="1.5"/>
                                <circle cx="119" cy="161" r="23" fill="none" stroke="rgba(80,120,255,0.08)" stroke-width="0.8" stroke-dasharray="3 4"/>
                                <text x="119" y="167" text-anchor="middle" font-size="15">✅</text>
                                <circle id="hud-notion-pulse" cx="137" cy="145" r="4" fill="rgba(80,120,255,0.8)">
                                    <animate attributeName="opacity" values="1;0.3;1" dur="4s" repeatCount="indefinite"/>
                                </circle>
                                <text x="119" y="138" text-anchor="middle" font-size="9" fill="#fff" font-weight="700" font-family="'Courier New',monospace">NOTION</text>
                            </g>


                            <!-- n8n (lower-left, 7:30) — dynamic status — ORANGE -->
                            <g>
                                <circle id="hud-n8n-ring" cx="141" cy="359" r="18" fill="rgba(2,6,18,0.92)" stroke="rgba(255,140,40,0.45)" stroke-width="1.5"/>
                                <circle cx="141" cy="359" r="23" fill="none" stroke="rgba(255,140,40,0.08)" stroke-width="0.8" stroke-dasharray="3 4"/>
                                <text x="141" y="365" text-anchor="middle" font-size="15">⚡</text>
                                <text x="141" y="335" text-anchor="middle" font-size="9" fill="#fff" font-weight="700" font-family="'Courier New',monospace">N8N</text>
                                <circle id="hud-n8n-pulse" cx="159" cy="343" r="4" fill="rgba(255,140,40,0.8)">
                                    <animate attributeName="opacity" values="1;0.3;1" dur="4s" repeatCount="indefinite"/>
                                </circle>
                            </g>



                            <!-- DWE Brain / Pinecone — 8:00 of n8n — MAGENTA -->
                            <g>
                                <circle id="hud-brain-ring" cx="50" cy="412" r="18" fill="rgba(2,6,18,0.92)" stroke="rgba(255,80,200,0.4)" stroke-width="1.5"/>
                                <circle cx="50" cy="412" r="23" fill="none" stroke="rgba(255,80,200,0.08)" stroke-width="0.8" stroke-dasharray="3 4"/>
                                <text x="50" y="418" text-anchor="middle" font-size="15">🧠</text>
                                <text x="50" y="389" text-anchor="middle" font-size="9" fill="#fff" font-weight="700" font-family="'Courier New',monospace">DWE BRAIN</text>
                                <circle id="hud-brain-pulse" cx="68" cy="396" r="4" fill="rgba(255,80,200,0.8)">
                                    <animate attributeName="opacity" values="1;0.3;1" dur="4s" repeatCount="indefinite"/>
                                </circle>
                            </g>


                            <!-- OpenRouter — midpoint OpenClaw/Telegram — GOLD -->
                            <g>
                                <circle id="hud-openrouter-ring" cx="369" cy="161" r="18" fill="rgba(2,6,18,0.92)" stroke="rgba(255,200,50,0.4)" stroke-width="1.5"/>
                                <circle cx="369" cy="161" r="23" fill="none" stroke="rgba(255,200,50,0.08)" stroke-width="0.8" stroke-dasharray="3 4"/>
                                <text x="369" y="167" text-anchor="middle" font-size="15">🤖</text>
                                <text x="369" y="138" text-anchor="middle" font-size="9" fill="#fff" font-weight="700" font-family="'Courier New',monospace">OPENROUTER</text>
                                <circle id="hud-openrouter-pulse" cx="387" cy="145" r="4" fill="rgba(255,200,50,0.8)">
                                    <animate attributeName="opacity" values="1;0.3;1" dur="4s" repeatCount="indefinite"/>
                                </circle>
                            </g>



                            <!-- GitHub (far left) — LAVENDER -->
                            <g>
                                <circle cx="55" cy="250" r="14" fill="rgba(2,6,18,0.9)" stroke="rgba(180,160,255,0.4)" stroke-width="1.2"/>
                                <text x="55" y="255" text-anchor="middle" font-size="12">🐙</text>
                                <text x="55" y="234" text-anchor="middle" font-size="7" fill="#fff" font-weight="700" font-family="'Courier New',monospace">GITHUB</text>
                            </g>

                            <!-- ═══ MAC MINI CLUSTER (top) — local services crown above it ═══ -->
                            <g>
                                <!-- Mac Mini hub -->
                                <circle cx="250" cy="60" r="24" fill="rgba(2,6,18,0.92)" stroke="rgba(0,255,136,0.55)" stroke-width="2"/>
                                <circle cx="250" cy="60" r="30" fill="none" stroke="rgba(0,255,136,0.08)" stroke-width="0.8" stroke-dasharray="3 4"/>
                                <!-- Heartbeat pulse ring -->
                                <circle cx="250" cy="60" r="24" fill="none" stroke="rgba(0,255,136,0.4)" stroke-width="1.5">
                                    <animate attributeName="r" values="24;36;24" dur="2s" repeatCount="indefinite"/>
                                    <animate attributeName="opacity" values="0.4;0;0.4" dur="2s" repeatCount="indefinite"/>
                                </circle>
                                <circle cx="250" cy="60" r="24" fill="none" stroke="rgba(0,255,136,0.3)" stroke-width="1">
                                    <animate attributeName="r" values="24;42;24" dur="2s" repeatCount="indefinite" begin="0.3s"/>
                                    <animate attributeName="opacity" values="0.3;0;0.3" dur="2s" repeatCount="indefinite" begin="0.3s"/>
                                </circle>
                                <text x="250" y="66" text-anchor="middle" font-size="18">🖥️</text>
                                <text x="250" y="36" text-anchor="middle" font-size="9" fill="#fff" font-weight="700" font-family="'Courier New',monospace">MAC MINI</text>
                                <!-- RAM badge at 12 o'clock — live RAM % -->
                                <text id="hud-ram-badge" x="250" y="26" text-anchor="middle" font-size="6" fill="rgba(0,255,136,0.55)" font-family="'Courier New',monospace">RAM —%</text>
                                <!-- Green heartbeat dot -->
                                <circle cx="268" cy="42" r="4" fill="rgba(0,255,136,0.8)">
                                    <animate attributeName="opacity" values="1;0.3;1" dur="2s" repeatCount="indefinite"/>
                                    <animate attributeName="r" values="4;5;4" dur="2s" repeatCount="indefinite"/>
                                </circle>

                                <!-- Satellite laser beam lines (yellow) -->
                                <line x1="250" y1="60" x2="175" y2="22" stroke="rgba(255,220,50,0.45)" stroke-width="1.2"/>
                                <line x1="250" y1="60" x2="325" y2="22" stroke="rgba(255,220,50,0.45)" stroke-width="1.2"/>
                                <line x1="250" y1="60" x2="318" y2="72" stroke="rgba(255,220,50,0.45)" stroke-width="1.2"/>
                                <line x1="250" y1="60" x2="182" y2="72" stroke="rgba(255,220,50,0.45)" stroke-width="1.2"/>

                                <!-- Local process traffic paths (reused by JS) -->
                                <defs>
                                    <path id="laser-ollama"   d="M250,60 L175,22"/>
                                    <path id="laser-mcporter" d="M250,60 L325,22"/>
                                    <path id="laser-openclaw" d="M250,60 L318,72"/>
                                    <path id="laser-mem"      d="M250,60 L182,72"/>
                                </defs>
                                <!-- Real-time local process traffic containers (populated by JS) -->
                                <g id="rt-local-ollama"></g>
                                <g id="rt-local-mcp"></g>
                                <g id="rt-local-openclaw"></g>
                                <g id="rt-local-mem"></g>

                                <!-- Ollama (upper-left) -->
                                <circle cx="175" cy="22" r="12" fill="rgba(2,6,18,0.9)" stroke="rgba(255,220,50,0.35)" stroke-width="1.2"/>
                                <text x="175" y="27" text-anchor="middle" font-size="10">🦙</text>
                                <text x="175" y="9" text-anchor="middle" font-size="6" fill="#fff" font-weight="700" font-family="'Courier New',monospace">OLLAMA</text>

                                <!-- MCporter (upper-right) -->
                                <circle cx="325" cy="22" r="12" fill="rgba(2,6,18,0.9)" stroke="rgba(255,220,50,0.35)" stroke-width="1.2"/>
                                <text x="325" y="27" text-anchor="middle" font-size="10">🔌</text>
                                <text x="325" y="9" text-anchor="middle" font-size="6" fill="#fff" font-weight="700" font-family="'Courier New',monospace">MCPORTER</text>

                                <!-- OpenClaw (lower-right) -->
                                <circle cx="318" cy="72" r="13" fill="rgba(2,6,18,0.9)" stroke="rgba(255,220,50,0.4)" stroke-width="1.2"/>
                                <text x="318" y="77" text-anchor="middle" font-size="10">🎯</text>
                                <text x="318" y="90" text-anchor="middle" font-size="6" fill="#fff" font-weight="700" font-family="'Courier New',monospace">OPENCLAW</text>

                                <!-- MEM (lower-left) — live RAM % -->
                                <circle id="hud-mem-ring" cx="182" cy="72" r="12" fill="rgba(2,6,18,0.9)" stroke="rgba(255,220,50,0.35)" stroke-width="1.2"/>
                                <text id="hud-mem-pct" x="182" y="76" text-anchor="middle" font-size="7" fill="rgba(255,220,50,0.9)" font-weight="700" font-family="'Courier New',monospace">—%</text>
                                <text x="182" y="57" text-anchor="middle" font-size="6" fill="#fff" font-weight="700" font-family="'Courier New',monospace">MEM</text>
                            </g>

                            <!-- Status badge bottom -->
                            <rect x="185" y="468" width="130" height="20" rx="3" fill="rgba(0,180,255,0.06)" stroke="rgba(0,180,255,0.2)" stroke-width="0.8"/>
                            <circle cx="200" cy="478" r="4" fill="rgba(0,255,120,0.7)">
                                <animate attributeName="opacity" values="1;0.3;1" dur="2s" repeatCount="indefinite"/>
                            </circle>
                            <text x="255" y="482" text-anchor="middle" font-size="9" fill="rgba(0,180,255,0.7)" font-family="'Courier New',monospace" font-weight="600">6 AGENTS ONLINE</text>

                            <!-- Scanning arc (rotating partial arc — speed driven by memory %) -->
                            <g id="hud-scan-arc" style="transform-origin:250px 250px;animation:hud-spin 8s linear infinite;">
                                <path d="M250,85 A165,165 0 0,1 390,175" fill="none" stroke="rgba(0,255,180,0.12)" stroke-width="1.5" stroke-linecap="round"/>
                            </g>
                        </svg>
                        <!-- ── HUD Layer Toggle Controls ── -->
                        <div id="hud-toggles" style="position:absolute;bottom:6px;left:0;right:0;display:flex;flex-wrap:wrap;justify-content:center;gap:4px;padding:0 8px;pointer-events:all;">
                            <!-- Services -->
                            <button onclick="hudToggle('telegram')"   id="tog-telegram"   class="hud-tog" style="--tog-c:rgba(0,200,255,0.8)">📡 Telegram</button>
                            <button onclick="hudToggle('notion')"     id="tog-notion"     class="hud-tog" style="--tog-c:rgba(0,255,136,0.8)">📝 Notion</button>
                            <button onclick="hudToggle('openrouter')" id="tog-openrouter" class="hud-tog" style="--tog-c:rgba(255,200,50,0.8)">🤖 OpenRouter</button>
                            <button onclick="hudToggle('n8n')"        id="tog-n8n"        class="hud-tog" style="--tog-c:rgba(255,140,40,0.8)">⚡ n8n</button>
                            <button onclick="hudToggle('brain')"      id="tog-brain"      class="hud-tog" style="--tog-c:rgba(255,100,200,0.8)">🧠 Brain</button>
                            <button onclick="hudToggle('github')"     id="tog-github"     class="hud-tog" style="--tog-c:rgba(0,140,255,0.8)">🐙 GitHub</button>
                            <!-- Local -->
                            <button onclick="hudToggle('ollama')"     id="tog-ollama"     class="hud-tog" style="--tog-c:rgba(255,220,50,0.8)">🦙 Ollama</button>
                            <button onclick="hudToggle('mcp')"        id="tog-mcp"        class="hud-tog" style="--tog-c:rgba(255,180,50,0.8)">🔌 MCP</button>
                            <button onclick="hudToggle('openclaw')"   id="tog-openclaw"   class="hud-tog" style="--tog-c:rgba(255,200,80,0.8)">🐾 OpenClaw</button>
                            <!-- Rings -->
                            <button onclick="hudToggle('ring-cpu')"   id="tog-ring-cpu"   class="hud-tog" style="--tog-c:rgba(0,255,180,0.8)">◌ CPU</button>
                            <button onclick="hudToggle('ring-mem')"   id="tog-ring-mem"   class="hud-tog" style="--tog-c:rgba(0,255,136,0.8)">◌ MEM</button>
                            <button onclick="hudToggle('ring-net')"   id="tog-ring-net"   class="hud-tog" style="--tog-c:rgba(255,160,40,0.8)">◌ NET</button>
                            <button onclick="hudToggle('ring-router')" id="tog-ring-router" class="hud-tog" style="--tog-c:rgba(0,255,136,0.8)">◌ Router</button>
                        </div>
                    </div>

                    <!-- RIGHT COLUMN: Core Infra, Monitor, Routines (evenly spaced, Routines flush bottom) -->
                    <div style="display:flex;flex-direction:column;justify-content:space-between;padding:12px;border-left:1px solid rgba(0,180,255,0.06);">
                        <!-- CORE INFRA -->
                        <div class="hud-frame">
                            <div class="corner-br"></div><div class="corner-tr"></div><div class="corner-bl"></div>
                            <div class="hud-ftitle"><span>⚡ CORE INFRA</span><div class="hud-bar-accent"></div></div>
                            <div class="hud-row"><span id="hud-core-gateway-dot" class="hud-dot"></span><span class="hud-name">Gateway</span><span id="hud-core-gateway-st" class="hud-st">—</span></div>
                            <div class="hud-row"><span id="hud-core-relay-dot" class="hud-dot"></span><span class="hud-name">Relay</span><span id="hud-core-relay-st" class="hud-st">—</span></div>
                            <div class="hud-row"><span id="hud-core-mc-dot" class="hud-dot"></span><span class="hud-name">Mission Ctrl</span><span id="hud-core-mc-st" class="hud-st">—</span></div>
                        </div>
                        <!-- MONITOR -->
                        <div class="hud-frame">
                            <div class="corner-br"></div><div class="corner-tr"></div><div class="corner-bl"></div>
                            <div class="hud-ftitle" style="color:rgba(0,220,255,0.7);"><span>📡 MONITOR</span><div class="hud-bar-accent"></div></div>
                            <div id="hud-monitor">
                                <div class="hud-row"><span id="hud-health-monitor-dot" class="hud-dot"></span><span class="hud-name">Health Monitor</span><span id="hud-health-monitor-st" class="hud-st">—</span></div>
                                <div class="hud-row"><span id="hud-anomaly-check-dot" class="hud-dot"></span><span class="hud-name">Anomaly Check</span><span id="hud-anomaly-check-st" class="hud-st">—</span></div>
                                <div class="hud-row"><span id="hud-ralphy-monitor-dot" class="hud-dot"></span><span class="hud-name">Ralph Monitor</span><span id="hud-ralphy-monitor-st" class="hud-st">—</span></div>
                            </div>
                        </div>
                        <!-- ROUTINES (flush bottom) -->
                        <div class="hud-frame">
                            <div class="corner-br"></div><div class="corner-tr"></div><div class="corner-bl"></div>
                            <div class="hud-ftitle" style="color:rgba(255,200,50,0.7);border-color:rgba(255,200,50,0.12);"><span>🔧 ROUTINES</span><div class="hud-bar-accent" style="background:linear-gradient(90deg,rgba(255,200,50,0.3),transparent);"></div></div>
                            <div id="hud-routines">
                                <div class="hud-row"><span id="hud-clawhub-check-dot" class="hud-dot"></span><span class="hud-name">ClawHub Check</span><span id="hud-clawhub-check-st" class="hud-st">—</span></div>
                                <div class="hud-row"><span id="hud-soul-calibration-dot" class="hud-dot"></span><span class="hud-name">Soul Calibration</span><span id="hud-soul-calibration-st" class="hud-st">—</span></div>
                                <div class="hud-row"><span id="hud-night-mode-dot" class="hud-dot"></span><span class="hud-name">Night Mode</span><span id="hud-night-mode-st" class="hud-st">—</span></div>
                                <div class="hud-row"><span id="hud-oc-backup-dot" class="hud-dot"></span><span class="hud-name">OC Backup</span><span id="hud-oc-backup-st" class="hud-st">—</span></div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>

            <!-- CSO Pipeline + Financial Pulse -->
            <div class="services-grid" style="margin-bottom:1.5rem;grid-template-columns:1fr 1fr;">
                <div class="service-panel">
                    <div class="panel-header">
                        <div class="panel-icon">📈</div>
                        <div class="panel-title">CSO Pipeline</div>
                    </div>
                    <div id="cso-pipeline-list" style="flex:1;">
                        <div class="service-item"><span class="pulse-dot offline"></span><span>Loading...</span></div>
                    </div>
                    <div class="panel-footer" style="font-size:0.65rem;color:rgba(255,255,255,0.4);padding:0.5rem 0.75rem;" id="cso-last-report">—</div>
                </div>
                <div class="service-panel">
                    <div class="panel-header">
                        <div class="panel-icon">💰</div>
                        <div class="panel-title">Financial Pulse</div>
                    </div>
                    <div id="financial-pulse-list" style="flex:1;">
                        <div class="service-item"><span class="pulse-dot offline"></span><span>Loading...</span></div>
                    </div>
                    <div class="panel-footer" style="font-size:0.65rem;color:rgba(255,255,255,0.4);padding:0.5rem 0.75rem;" id="financial-last-pulse">—</div>
                </div>
            </div>

            <!-- Document Pipeline — File Manager -->
            <div style="background:rgba(255,255,255,0.018);border:1px solid rgba(255,255,255,0.07);border-radius:14px;margin-bottom:1.5rem;overflow:hidden;">
                <div class="panel-header" style="border-radius:14px 14px 0 0;padding:0.55rem 0.85rem;">
                    <div class="panel-icon" style="font-size:0.9rem;">🗂️</div>
                    <div class="panel-title">Document Pipeline</div>
                    <div style="margin-left:auto;display:flex;align-items:center;gap:0.5rem;">
                        <span style="font-size:0.58rem;color:rgba(255,255,255,0.25);">double-click to read · drag to move</span>
                        <button onclick="fetchPipeline()" style="background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.12);color:rgba(255,255,255,0.5);font-size:0.6rem;padding:2px 8px;border-radius:4px;cursor:pointer;">↻</button>
                    </div>
                </div>
                <div id="pipeline-board" style="display:grid;grid-template-columns:repeat(5,1fr);gap:0;min-height:180px;max-height:320px;">
                    <!-- injected by fetchPipeline() -->
                </div>
            </div>

            <!-- File Reader Modal -->
            <div id="pipeline-modal" onclick="if(event.target===this)closePipelineModal()" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,0.78);backdrop-filter:blur(4px);align-items:center;justify-content:center;">
                <div style="background:#13131f;border:1px solid rgba(255,255,255,0.11);border-radius:14px;width:min(800px,92vw);max-height:82vh;display:flex;flex-direction:column;box-shadow:0 28px 90px rgba(0,0,0,0.85);">
                    <div style="display:flex;align-items:center;gap:8px;padding:0.7rem 0.9rem;border-bottom:1px solid rgba(255,255,255,0.07);flex-shrink:0;">
                        <span style="font-size:0.9rem;">📄</span>
                        <span id="modal-filename" style="font-weight:700;font-size:0.78rem;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-family:monospace;"></span>
                        <span id="modal-stage-badge" style="font-size:0.58rem;padding:2px 7px;border-radius:3px;background:rgba(255,255,255,0.07);color:rgba(255,255,255,0.4);font-family:monospace;flex-shrink:0;"></span>
                        <!-- TTS Controls -->
                        <div id="tts-controls" style="display:flex;align-items:center;gap:4px;flex-shrink:0;">
                            <button id="tts-play-btn" onclick="ttsToggle()" title="Read aloud" style="background:rgba(0,200,120,0.12);border:1px solid rgba(0,200,120,0.25);color:#00c878;font-size:0.72rem;padding:3px 10px;border-radius:4px;cursor:pointer;">▶ Read</button>
                            <button id="tts-stop-btn" onclick="ttsStop()" title="Stop reading" style="display:none;background:rgba(255,80,80,0.12);border:1px solid rgba(255,80,80,0.25);color:#ff5050;font-size:0.72rem;padding:3px 10px;border-radius:4px;cursor:pointer;">■ Stop</button>
                            <select id="tts-speed" onchange="ttsUpdateSpeed()" title="Reading speed" style="background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);color:rgba(255,255,255,0.5);font-size:0.58rem;padding:2px 4px;border-radius:4px;cursor:pointer;">
                                <option value="0.8">0.8x</option>
                                <option value="1" selected>1x</option>
                                <option value="1.2">1.2x</option>
                                <option value="1.5">1.5x</option>
                                <option value="2">2x</option>
                            </select>
                        </div>
                        <button onclick="closePipelineModal()" style="background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);color:rgba(255,255,255,0.6);font-size:0.65rem;padding:3px 10px;border-radius:4px;cursor:pointer;flex-shrink:0;">✕</button>
                    </div>
                    <pre id="modal-content" style="flex:1;overflow:auto;padding:0.9rem 1rem;font-size:0.7rem;line-height:1.65;color:rgba(255,255,255,0.78);white-space:pre-wrap;word-break:break-word;font-family:'Courier New',monospace;margin:0;"></pre>
                    <div id="modal-footer" style="padding:0.55rem 0.9rem;border-top:1px solid rgba(255,255,255,0.07);display:flex;gap:0.4rem;flex-wrap:wrap;align-items:center;flex-shrink:0;"></div>
                </div>
            </div>

            <!-- services-list hidden (all services moved to tiles/HUD) -->
            <div id="services-list" style="display:none;"></div>
            <div id="launchd-list" style="display:none;"></div>
            <!-- Opportunities Panel (toggled via sidebar) -->
            <div id="opportunities-panel" style="display: none; margin-top: 2rem;">
                <div class="panel" style="background: var(--card-bg, rgba(20,20,40,0.6)); border: 1px solid rgba(255,255,255,0.08); border-radius: 1rem; overflow: hidden;">
                    <div class="panel-header" style="display: flex; justify-content: space-between; align-items: center; padding: 1rem 1.25rem;">
                        <div style="display: flex; align-items: center; gap: 0.5rem;">
                            <div class="panel-icon">💰</div>
                            <div class="panel-title">Opportunity Capture</div>
                        </div>
                        <div style="display: flex; gap: 0.5rem;">
                            <a href="https://docs.google.com/spreadsheets/d/1nkhSpjxS11rWC2MPP40GLYvA7LYsaFba91hC5mWpi80/edit" target="_blank" style="font-size: 0.75rem; color: rgba(255,255,255,0.5); text-decoration: none; padding: 0.25rem 0.5rem; border: 1px solid rgba(255,255,255,0.15); border-radius: 0.375rem;">↗ Open in Sheets</a>
                            <button onclick="toggleOpportunities()" style="font-size: 0.75rem; color: rgba(255,255,255,0.5); background: none; border: 1px solid rgba(255,255,255,0.15); border-radius: 0.375rem; padding: 0.25rem 0.5rem; cursor: pointer;">✕ Close</button>
                        </div>
                    </div>
                    <div style="padding: 0 1.25rem 0.5rem;">
                        <p style="color: rgba(255,255,255,0.4); font-size: 0.75rem; margin-bottom: 0.75rem;">Live feed from 6 ingestion workflows: RSS, Reddit, Email, Google Search, Twitter, Telegram</p>
                    </div>
                    <iframe
                        src="https://docs.google.com/spreadsheets/d/e/2PACX-1vQrp71fA3RafPPAwhLoFIYD3a3XuiNUuA6ZuOMsptKTBlNv12cHDI5XZ-NDZafVa9a_DPcsiU7QftRQ/pubhtml?gid=600103938&single=true"
                        style="width: 100%; height: 500px; border: none; border-top: 1px solid rgba(255,255,255,0.08);"
                        loading="lazy"
                        title="Opportunity Capture Spreadsheet">
                    </iframe>
                </div>
            </div>

            <!-- ── Revenue Panel (IncomeOps_Monitor) ────────────────────────── -->
            <div id="revenue-panel" style="display:none; padding: 1.5rem;">

                <!-- Revenue Header -->
                <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:1.5rem;">
                    <div style="display:flex; align-items:center; gap:0.75rem;">
                        <h2 style="color:#fff; font-family:Inter,sans-serif; font-size:1.5rem; margin:0;">
                            📈 IncomeOps Monitor
                        </h2>
                        <span id="rev-updated" style="color:rgba(255,255,255,0.3); font-size:0.7rem; font-family:Inter,sans-serif;"></span>
                    </div>
                    <div style="display:flex; gap:0.5rem;">
                        <button onclick="revFetchData()" id="rev-refresh-btn" style="background:rgba(0,255,136,0.1); border:1px solid rgba(0,255,136,0.2); color:#00ff88; border-radius:0.5rem; padding:0.4rem 1rem; cursor:pointer; font-family:Inter,sans-serif; font-size:0.85rem;">
                            Refresh
                        </button>
                        <a href="https://docs.google.com/spreadsheets/d/1nkhSpjxS11rWC2MPP40GLYvA7LYsaFba91hC5mWpi80/edit" target="_blank" rel="noopener" style="background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.12); color:#fff; border-radius:0.5rem; padding:0.4rem 1rem; cursor:pointer; font-family:Inter,sans-serif; font-size:0.85rem; text-decoration:none; display:inline-flex; align-items:center;">
                            Open Sheet
                        </a>
                        <button onclick="toggleRevenue()" style="background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.12); color:#fff; border-radius:0.5rem; padding:0.4rem 1rem; cursor:pointer; font-family:Inter,sans-serif; font-size:0.85rem;">
                            Close
                        </button>
                    </div>
                </div>

                <!-- Summary Cards -->
                <div style="display:grid; grid-template-columns: repeat(5, 1fr); gap:1rem; margin-bottom:1.5rem;" class="rev-top-row">
                    <div style="background:rgba(20,20,40,0.6); border:1px solid rgba(0,255,136,0.15); border-radius:0.75rem; padding:1rem; text-align:center; backdrop-filter:blur(12px);">
                        <div style="color:rgba(255,255,255,0.5); font-size:0.65rem; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:0.35rem;">Daily Income</div>
                        <div id="rev-sum-daily" style="color:#00ff88; font-size:1.4rem; font-weight:700; font-family:Inter,sans-serif;">—</div>
                    </div>
                    <div style="background:rgba(20,20,40,0.6); border:1px solid rgba(0,200,255,0.15); border-radius:0.75rem; padding:1rem; text-align:center; backdrop-filter:blur(12px);">
                        <div style="color:rgba(255,255,255,0.5); font-size:0.65rem; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:0.35rem;">Weekly Income</div>
                        <div id="rev-sum-weekly" style="color:#00c8ff; font-size:1.4rem; font-weight:700; font-family:Inter,sans-serif;">—</div>
                    </div>
                    <div style="background:rgba(20,20,40,0.6); border:1px solid rgba(0,245,255,0.15); border-radius:0.75rem; padding:1rem; text-align:center; backdrop-filter:blur(12px);">
                        <div style="color:rgba(255,255,255,0.5); font-size:0.65rem; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:0.35rem;">Monthly Income</div>
                        <div id="rev-sum-monthly" style="color:#00f5ff; font-size:1.4rem; font-weight:700; font-family:Inter,sans-serif;">—</div>
                    </div>
                    <div style="background:rgba(20,20,40,0.6); border:1px solid rgba(184,41,221,0.15); border-radius:0.75rem; padding:1rem; text-align:center; backdrop-filter:blur(12px);">
                        <div style="color:rgba(255,255,255,0.5); font-size:0.65rem; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:0.35rem;">Yearly Projection</div>
                        <div id="rev-sum-yearly" style="color:#b829dd; font-size:1.4rem; font-weight:700; font-family:Inter,sans-serif;">—</div>
                    </div>
                    <div style="background:rgba(20,20,40,0.6); border:1px solid rgba(255,170,0,0.15); border-radius:0.75rem; padding:1rem; text-align:center; backdrop-filter:blur(12px);">
                        <div style="color:rgba(255,255,255,0.5); font-size:0.65rem; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:0.35rem;">Total Staked</div>
                        <div id="rev-sum-staked" style="color:#ffaa00; font-size:1.4rem; font-weight:700; font-family:Inter,sans-serif;">—</div>
                    </div>
                </div>

                <!-- Cash Flow vs Long-Term Split -->
                <div style="display:grid; grid-template-columns: 1fr 1fr; gap:1rem; margin-bottom:1.5rem;">
                    <div style="background:rgba(20,20,40,0.6); border:1px solid rgba(0,255,136,0.2); border-radius:0.75rem; padding:1rem; text-align:center; backdrop-filter:blur(12px);">
                        <div style="color:rgba(255,255,255,0.5); font-size:0.65rem; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:0.35rem;">Cash Flow (Monthly)</div>
                        <div id="rev-cashflow-monthly" style="color:#00ff88; font-size:1.6rem; font-weight:700; font-family:Inter,sans-serif;">$0</div>
                        <div style="color:rgba(255,255,255,0.3); font-size:0.65rem; margin-top:0.25rem;"><span id="rev-cashflow-count">0</span> streams</div>
                    </div>
                    <div style="background:rgba(20,20,40,0.6); border:1px solid rgba(0,200,255,0.2); border-radius:0.75rem; padding:1rem; text-align:center; backdrop-filter:blur(12px);">
                        <div style="color:rgba(255,255,255,0.5); font-size:0.65rem; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:0.35rem;">Long-Term (Monthly)</div>
                        <div id="rev-longterm-monthly" style="color:#00c8ff; font-size:1.6rem; font-weight:700; font-family:Inter,sans-serif;">$0</div>
                        <div style="color:rgba(255,255,255,0.3); font-size:0.65rem; margin-top:0.25rem;"><span id="rev-longterm-count">0</span> streams</div>
                    </div>
                </div>
                <!-- Cash Flow Progress Bar -->
                <div style="background:rgba(20,20,40,0.6); border:1px solid rgba(255,255,255,0.08); border-radius:0.75rem; padding:1rem; margin-bottom:1.5rem; backdrop-filter:blur(12px);">
                    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:0.5rem;">
                        <span style="color:rgba(255,255,255,0.5); font-size:0.75rem; font-family:Inter,sans-serif;">Cash Flow Progress</span>
                        <span id="rev-cf-progress-label" style="color:#00ff88; font-size:0.75rem; font-family:Inter,sans-serif; font-weight:600;">$0 / $10,000</span>
                    </div>
                    <div style="width:100%; height:10px; background:rgba(255,255,255,0.06); border-radius:5px; overflow:hidden;">
                        <div id="rev-cf-progress-bar" style="width:0%; height:100%; background:linear-gradient(to right, #00ff88, #00f5ff); border-radius:5px; transition:width 0.6s ease;"></div>
                    </div>
                </div>

                <!-- Gauge + Projected Profit -->
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:1.5rem; margin-bottom:1.5rem;" class="rev-gauge-row">
                    <!-- Monthly Revenue Gauge -->
                    <div style="background:rgba(20,20,40,0.6); border:1px solid rgba(255,255,255,0.08); border-radius:1rem; padding:1.5rem; backdrop-filter:blur(12px); text-align:center;">
                        <h3 style="color:rgba(255,255,255,0.6); font-family:Inter,sans-serif; font-size:0.85rem; margin:0 0 1rem; text-transform:uppercase; letter-spacing:0.06em;">Monthly Revenue Goal</h3>
                        <div style="position:relative; width:180px; height:180px; margin:0 auto 1rem;">
                            <div id="rev-gauge" style="width:180px; height:180px; border-radius:50%; background:conic-gradient(#00ff88 0%, #00ff88 0%, rgba(255,255,255,0.06) 0%); display:flex; align-items:center; justify-content:center; transition: background 0.6s ease;">
                                <div style="width:140px; height:140px; border-radius:50%; background:rgba(12,12,30,0.95); display:flex; flex-direction:column; align-items:center; justify-content:center;">
                                    <span id="rev-gauge-pct" style="color:#00ff88; font-size:2rem; font-weight:700; font-family:Inter,sans-serif;">0%</span>
                                    <span id="rev-gauge-mrr" style="color:rgba(255,255,255,0.5); font-size:0.75rem; font-family:Inter,sans-serif;">$0/mo</span>
                                </div>
                            </div>
                        </div>
                        <div style="display:flex; align-items:center; justify-content:center; gap:0.5rem;">
                            <span style="color:rgba(255,255,255,0.5); font-size:0.85rem; font-family:Inter,sans-serif;">Goal:</span>
                            <span id="rev-goal-display" onclick="revEditGoal()" style="color:#00f5ff; font-size:1.1rem; font-weight:600; font-family:Inter,sans-serif; cursor:pointer; border-bottom:1px dashed rgba(0,245,255,0.3);">$10,000</span>
                            <input id="rev-goal-input" type="number" style="display:none; width:100px; background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.15); color:#fff; border-radius:0.4rem; padding:0.3rem 0.5rem; font-family:Inter,sans-serif; font-size:0.95rem; text-align:center;" onblur="revSaveGoal()" onkeydown="if(event.key==='Enter')revSaveGoal()">
                        </div>
                    </div>

                    <!-- Projected Profit -->
                    <div style="background:rgba(20,20,40,0.6); border:1px solid rgba(255,255,255,0.08); border-radius:1rem; padding:1.5rem; backdrop-filter:blur(12px);">
                        <h3 style="color:rgba(255,255,255,0.6); font-family:Inter,sans-serif; font-size:0.85rem; margin:0 0 1.25rem; text-transform:uppercase; letter-spacing:0.06em;">Portfolio Snapshot</h3>
                        <div style="display:flex; flex-direction:column; gap:1rem;">
                            <div style="background:rgba(255,255,255,0.03); border-radius:0.75rem; padding:1rem;">
                                <div style="color:rgba(255,255,255,0.45); font-size:0.75rem; font-family:Inter,sans-serif; margin-bottom:0.35rem;">Total Projected Profit</div>
                                <div id="rev-proj-profit" style="color:#00ff88; font-size:1.5rem; font-weight:700; font-family:Inter,sans-serif;">—</div>
                            </div>
                            <div style="background:rgba(255,255,255,0.03); border-radius:0.75rem; padding:1rem;">
                                <div style="color:rgba(255,255,255,0.45); font-size:0.75rem; font-family:Inter,sans-serif; margin-bottom:0.35rem;">Active Streams</div>
                                <div id="rev-proj-streams" style="color:#00f5ff; font-size:1.5rem; font-weight:700; font-family:Inter,sans-serif;">0</div>
                            </div>
                            <div style="background:rgba(255,255,255,0.03); border-radius:0.75rem; padding:1rem;">
                                <div style="color:rgba(255,255,255,0.45); font-size:0.75rem; font-family:Inter,sans-serif; margin-bottom:0.35rem;">Avg Daily Growth</div>
                                <div id="rev-proj-growth" style="color:#b829dd; font-size:1.5rem; font-weight:700; font-family:Inter,sans-serif;">—</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Daily Income Bar Chart -->
                <div style="background:rgba(20,20,40,0.6); border:1px solid rgba(255,255,255,0.08); border-radius:1rem; padding:1.5rem; backdrop-filter:blur(12px); margin-bottom:1.5rem;">
                    <h3 style="color:rgba(255,255,255,0.6); font-family:Inter,sans-serif; font-size:0.85rem; margin:0 0 1.25rem; text-transform:uppercase; letter-spacing:0.06em;">Daily Income by Stream</h3>
                    <div id="rev-chart" style="display:flex; align-items:flex-end; gap:1rem; height:200px; padding:0 0.5rem;"></div>
                </div>

                <!-- Income Streams Table -->
                <div style="background:rgba(20,20,40,0.6); border:1px solid rgba(255,255,255,0.08); border-radius:1rem; padding:1.5rem; backdrop-filter:blur(12px); margin-bottom:1.5rem;">
                    <h3 style="color:rgba(255,255,255,0.6); font-family:Inter,sans-serif; font-size:0.85rem; margin:0 0 1rem; text-transform:uppercase; letter-spacing:0.06em;">Income Streams</h3>
                    <div style="overflow-x:auto;">
                        <table style="width:100%; border-collapse:collapse; font-family:Inter,sans-serif;">
                            <thead>
                                <tr style="border-bottom:1px solid rgba(255,255,255,0.08);">
                                    <th style="text-align:left; padding:0.6rem 0.75rem; color:rgba(255,255,255,0.4); font-size:0.7rem; font-weight:500; text-transform:uppercase; letter-spacing:0.05em;">Stream</th>
                                    <th style="text-align:center; padding:0.6rem 0.75rem; color:rgba(255,255,255,0.4); font-size:0.7rem; font-weight:500; text-transform:uppercase; letter-spacing:0.05em;">Platform</th>
                                    <th style="text-align:center; padding:0.6rem 0.75rem; color:rgba(255,255,255,0.4); font-size:0.7rem; font-weight:500; text-transform:uppercase; letter-spacing:0.05em;">Status</th>
                                    <th style="text-align:right; padding:0.6rem 0.75rem; color:rgba(255,255,255,0.4); font-size:0.7rem; font-weight:500; text-transform:uppercase; letter-spacing:0.05em;">Staked</th>
                                    <th style="text-align:right; padding:0.6rem 0.75rem; color:rgba(255,255,255,0.4); font-size:0.7rem; font-weight:500; text-transform:uppercase; letter-spacing:0.05em;">Daily</th>
                                    <th style="text-align:right; padding:0.6rem 0.75rem; color:rgba(255,255,255,0.4); font-size:0.7rem; font-weight:500; text-transform:uppercase; letter-spacing:0.05em;">Monthly</th>
                                    <th style="text-align:right; padding:0.6rem 0.75rem; color:rgba(255,255,255,0.4); font-size:0.7rem; font-weight:500; text-transform:uppercase; letter-spacing:0.05em;">Yearly</th>
                                    <th style="text-align:right; padding:0.6rem 0.75rem; color:rgba(255,255,255,0.4); font-size:0.7rem; font-weight:500; text-transform:uppercase; letter-spacing:0.05em;">Proj Profit</th>
                                    <th style="text-align:center; padding:0.6rem 0.75rem; color:rgba(255,255,255,0.4); font-size:0.7rem; font-weight:500; text-transform:uppercase; letter-spacing:0.05em;">ROI</th>
                                    <th style="text-align:center; padding:0.6rem 0.75rem; color:rgba(255,255,255,0.4); font-size:0.7rem; font-weight:500; text-transform:uppercase; letter-spacing:0.05em;">Tier</th>
                                    <th style="text-align:center; padding:0.6rem 0.75rem; color:rgba(255,255,255,0.4); font-size:0.7rem; font-weight:500; text-transform:uppercase; letter-spacing:0.05em;">Type</th>
                                </tr>
                            </thead>
                            <tbody id="rev-streams-tbody"></tbody>
                        </table>
                    </div>
                    <div id="rev-loading" style="text-align:center; padding:2rem; color:rgba(255,255,255,0.3); font-family:Inter,sans-serif; font-size:0.9rem;">Loading IncomeOps data...</div>
                </div>

                <!-- Graduate Product -->
                <div style="background:rgba(20,20,40,0.6); border:1px solid rgba(0,255,136,0.12); border-radius:1rem; padding:1.5rem; backdrop-filter:blur(12px); margin-bottom:1.5rem;">
                    <h3 style="color:rgba(255,255,255,0.6); font-family:Inter,sans-serif; font-size:0.85rem; margin:0 0 1rem; text-transform:uppercase; letter-spacing:0.06em;">Graduate Product → IncomeOps</h3>
                    <div style="display:flex; gap:0.75rem; align-items:center; flex-wrap:wrap;">
                        <select id="grad-product-select" style="flex:1; min-width:200px; background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.15); color:#fff; border-radius:0.5rem; padding:0.5rem 0.75rem; font-family:Inter,sans-serif; font-size:0.85rem;">
                            <option value="">Loading GO products...</option>
                        </select>
                        <button onclick="gradGraduate()" id="grad-btn" style="background:rgba(0,255,136,0.15); border:1px solid rgba(0,255,136,0.3); color:#00ff88; border-radius:0.5rem; padding:0.5rem 1.25rem; cursor:pointer; font-family:Inter,sans-serif; font-size:0.85rem; font-weight:600; white-space:nowrap;">
                            Graduate to Cash Flow
                        </button>
                    </div>
                    <div id="grad-status" style="margin-top:0.5rem; font-size:0.75rem; font-family:Inter,sans-serif; color:rgba(255,255,255,0.4);"></div>
                </div>

                <!-- Responsive styles for revenue panel -->
                <style>
                    @media (max-width: 768px) {
                        .rev-top-row { grid-template-columns: 1fr 1fr !important; }
                        .rev-gauge-row { grid-template-columns: 1fr !important; }
                    }
                    @media (max-width: 480px) {
                        .rev-top-row { grid-template-columns: 1fr !important; }
                    }
                </style>
            </div>

            <!-- ── Intel Panel ────────────────────────────────────────────── -->
            <div id="intel-panel" style="display:none; padding: 1.5rem;">

                <!-- Intel Header -->
                <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:1.5rem;">
                    <h2 style="color:#fff; font-family:Inter,sans-serif; font-size:1.5rem; margin:0;">
                        📡 Intel Feed
                    </h2>
                    <div style="display:flex; gap:0.5rem; align-items:center;">
                        <select id="intel-filter" onchange="intelRender()" style="background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.12); color:#fff; border-radius:0.5rem; padding:0.4rem 0.8rem; font-family:Inter,sans-serif; font-size:0.8rem; cursor:pointer;">
                            <option value="all">All Categories</option>
                            <option value="ai-news">AI News</option>
                            <option value="industry">Industry Trends</option>
                            <option value="competitor">Competitor Watch</option>
                            <option value="opportunity">Opportunities</option>
                        </select>
                        <select id="intel-importance-filter" onchange="intelRender()" style="background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.12); color:#fff; border-radius:0.5rem; padding:0.4rem 0.8rem; font-family:Inter,sans-serif; font-size:0.8rem; cursor:pointer;">
                            <option value="all">All Importance</option>
                            <option value="critical">Critical</option>
                            <option value="high">High</option>
                            <option value="medium">Medium</option>
                            <option value="low">Low</option>
                        </select>
                        <button onclick="toggleIntel()" style="background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.12); color:#fff; border-radius:0.5rem; padding:0.4rem 1rem; cursor:pointer; font-family:Inter,sans-serif; font-size:0.85rem;">
                            Close
                        </button>
                    </div>
                </div>

                <!-- Daily Brief -->
                <div id="intel-brief" style="background:linear-gradient(135deg, rgba(0,200,255,0.08), rgba(100,50,255,0.08)); border:1px solid rgba(0,200,255,0.2); border-radius:1rem; padding:1.25rem 1.5rem; margin-bottom:1.5rem; backdrop-filter:blur(12px);">
                    <div style="display:flex; align-items:center; gap:0.5rem; margin-bottom:0.75rem;">
                        <span style="font-size:1.1rem;">🗞️</span>
                        <h3 style="color:#00c8ff; font-family:Inter,sans-serif; font-size:0.95rem; margin:0; text-transform:uppercase; letter-spacing:0.05em;">Daily Brief</h3>
                        <span id="intel-brief-date" style="color:rgba(255,255,255,0.4); font-size:0.75rem; margin-left:auto; font-family:Inter,sans-serif;"></span>
                    </div>
                    <textarea id="intel-brief-text" rows="3" placeholder="Write today's brief — key takeaways, action items, market moves..." style="width:100%; background:rgba(0,0,0,0.2); border:1px solid rgba(255,255,255,0.08); border-radius:0.5rem; color:#fff; font-family:Inter,sans-serif; font-size:0.85rem; padding:0.75rem; resize:vertical; line-height:1.5;" oninput="intelSaveBrief()"></textarea>
                </div>

                <!-- Critical / Blocked Tickets -->
                <div id="intel-critical-tickets" style="background:rgba(255,60,60,0.06); border:1px solid rgba(255,60,60,0.2); border-radius:1rem; padding:1.25rem 1.5rem; margin-bottom:1.5rem; backdrop-filter:blur(12px); display:none;">
                    <div style="display:flex; align-items:center; gap:0.5rem; margin-bottom:0.75rem;">
                        <span style="font-size:1.1rem;">🚨</span>
                        <h3 style="color:#ff6b6b; font-family:Inter,sans-serif; font-size:0.95rem; margin:0; text-transform:uppercase; letter-spacing:0.05em;">Critical & Blocked Tickets</h3>
                        <span id="intel-critical-count" style="background:rgba(255,60,60,0.2); color:#ff6b6b; font-size:0.7rem; font-weight:700; padding:0.15rem 0.5rem; border-radius:0.25rem; font-family:Inter,sans-serif;">0</span>
                    </div>
                    <div id="intel-critical-list" style="display:flex; flex-direction:column; gap:0.5rem;"></div>
                </div>

                <!-- OpenClaw Update Info -->
                <div id="intel-oc-update" style="background:linear-gradient(135deg, rgba(255,170,0,0.06), rgba(255,100,0,0.04)); border:1px solid rgba(255,170,0,0.2); border-radius:1rem; padding:1.25rem 1.5rem; margin-bottom:1.5rem; backdrop-filter:blur(12px); display:none;">
                    <div style="display:flex; align-items:center; gap:0.5rem; margin-bottom:0.75rem;">
                        <span style="font-size:1.1rem;">🦞</span>
                        <h3 style="color:#ffaa00; font-family:Inter,sans-serif; font-size:0.95rem; margin:0; text-transform:uppercase; letter-spacing:0.05em;">OpenClaw Update Available</h3>
                    </div>
                    <div id="intel-oc-update-body" style="font-family:Inter,sans-serif; font-size:0.85rem; color:rgba(255,255,255,0.7); line-height:1.5;"></div>
                </div>

                <!-- Category Stats -->
                <div style="display:grid; grid-template-columns: repeat(4, 1fr); gap:1rem; margin-bottom:1.5rem;" class="intel-stats-row">
                    <div id="intel-stat-ai" style="background:rgba(20,20,40,0.6); border:1px solid rgba(0,200,255,0.15); border-radius:0.75rem; padding:1rem; text-align:center; backdrop-filter:blur(12px);">
                        <div style="font-size:1.5rem; margin-bottom:0.25rem;">🤖</div>
                        <div style="color:rgba(255,255,255,0.5); font-size:0.65rem; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:0.25rem;">AI News</div>
                        <div id="intel-count-ai" style="color:#00c8ff; font-size:1.4rem; font-weight:700; font-family:Inter,sans-serif;">0</div>
                    </div>
                    <div id="intel-stat-industry" style="background:rgba(20,20,40,0.6); border:1px solid rgba(0,255,136,0.15); border-radius:0.75rem; padding:1rem; text-align:center; backdrop-filter:blur(12px);">
                        <div style="font-size:1.5rem; margin-bottom:0.25rem;">📊</div>
                        <div style="color:rgba(255,255,255,0.5); font-size:0.65rem; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:0.25rem;">Industry</div>
                        <div id="intel-count-industry" style="color:#00ff88; font-size:1.4rem; font-weight:700; font-family:Inter,sans-serif;">0</div>
                    </div>
                    <div id="intel-stat-competitor" style="background:rgba(20,20,40,0.6); border:1px solid rgba(255,170,0,0.15); border-radius:0.75rem; padding:1rem; text-align:center; backdrop-filter:blur(12px);">
                        <div style="font-size:1.5rem; margin-bottom:0.25rem;">🔍</div>
                        <div style="color:rgba(255,255,255,0.5); font-size:0.65rem; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:0.25rem;">Competitors</div>
                        <div id="intel-count-competitor" style="color:#ffaa00; font-size:1.4rem; font-weight:700; font-family:Inter,sans-serif;">0</div>
                    </div>
                    <div id="intel-stat-opportunity" style="background:rgba(20,20,40,0.6); border:1px solid rgba(200,100,255,0.15); border-radius:0.75rem; padding:1rem; text-align:center; backdrop-filter:blur(12px);">
                        <div style="font-size:1.5rem; margin-bottom:0.25rem;">💎</div>
                        <div style="color:rgba(255,255,255,0.5); font-size:0.65rem; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:0.25rem;">Opportunities</div>
                        <div id="intel-count-opportunity" style="color:#c864ff; font-size:1.4rem; font-weight:700; font-family:Inter,sans-serif;">0</div>
                    </div>
                </div>

                <!-- Add New Intel Item -->
                <div style="background:rgba(20,20,40,0.6); border:1px solid rgba(255,255,255,0.08); border-radius:1rem; padding:1.25rem; margin-bottom:1.5rem; backdrop-filter:blur(12px);">
                    <h3 style="color:rgba(255,255,255,0.7); font-family:Inter,sans-serif; font-size:0.85rem; margin:0 0 1rem; text-transform:uppercase; letter-spacing:0.05em;">Add Intel Item</h3>
                    <div style="display:grid; grid-template-columns:1fr 1fr; gap:0.75rem; margin-bottom:0.75rem;" class="intel-form-grid">
                        <input id="intel-title" type="text" placeholder="Title / Headline" style="background:rgba(0,0,0,0.3); border:1px solid rgba(255,255,255,0.1); border-radius:0.5rem; color:#fff; font-family:Inter,sans-serif; font-size:0.85rem; padding:0.6rem 0.75rem;">
                        <input id="intel-source" type="text" placeholder="Source (e.g. TechCrunch, Twitter)" style="background:rgba(0,0,0,0.3); border:1px solid rgba(255,255,255,0.1); border-radius:0.5rem; color:#fff; font-family:Inter,sans-serif; font-size:0.85rem; padding:0.6rem 0.75rem;">
                        <select id="intel-category" style="background:rgba(0,0,0,0.3); border:1px solid rgba(255,255,255,0.1); border-radius:0.5rem; color:#fff; font-family:Inter,sans-serif; font-size:0.85rem; padding:0.6rem 0.75rem; cursor:pointer;">
                            <option value="ai-news">AI News</option>
                            <option value="industry">Industry Trends</option>
                            <option value="competitor">Competitor Watch</option>
                            <option value="opportunity">Opportunities</option>
                        </select>
                        <select id="intel-importance" style="background:rgba(0,0,0,0.3); border:1px solid rgba(255,255,255,0.1); border-radius:0.5rem; color:#fff; font-family:Inter,sans-serif; font-size:0.85rem; padding:0.6rem 0.75rem; cursor:pointer;">
                            <option value="medium">Medium</option>
                            <option value="critical">Critical</option>
                            <option value="high">High</option>
                            <option value="low">Low</option>
                        </select>
                    </div>
                    <textarea id="intel-notes" rows="2" placeholder="Notes / Analysis / Key Takeaway" style="width:100%; background:rgba(0,0,0,0.3); border:1px solid rgba(255,255,255,0.1); border-radius:0.5rem; color:#fff; font-family:Inter,sans-serif; font-size:0.85rem; padding:0.6rem 0.75rem; resize:vertical; margin-bottom:0.75rem;"></textarea>
                    <input id="intel-url" type="text" placeholder="URL (optional)" style="width:100%; background:rgba(0,0,0,0.3); border:1px solid rgba(255,255,255,0.1); border-radius:0.5rem; color:#fff; font-family:Inter,sans-serif; font-size:0.85rem; padding:0.6rem 0.75rem; margin-bottom:0.75rem;">
                    <button onclick="intelAdd()" style="background:linear-gradient(135deg, #00c8ff, #0080ff); border:none; color:#fff; border-radius:0.5rem; padding:0.6rem 1.5rem; cursor:pointer; font-family:Inter,sans-serif; font-size:0.85rem; font-weight:600;">
                        + Add Item
                    </button>
                </div>

                <!-- Intel Feed -->
                <div id="intel-feed" style="display:flex; flex-direction:column; gap:0.75rem;"></div>

                <!-- Responsive styles for intel panel -->
                <style>
                    @media (max-width: 768px) {
                        .intel-stats-row { grid-template-columns: 1fr 1fr !important; }
                        .intel-form-grid { grid-template-columns: 1fr !important; }
                    }
                </style>
            </div>

            <!-- ═══ NEWSLETTER DIGEST PANEL ═══ -->
            <div id="newsletters-panel" style="display:none; padding: 1.5rem;">
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.5rem; flex-wrap:wrap; gap:0.75rem;">
                    <h2 style="color:#fff; font-family:Inter,sans-serif; font-size:1.3rem; margin:0;">📰 Newsletter Digest</h2>
                    <div style="display:flex; gap:0.5rem; flex-wrap:wrap;">
                        <button onclick="newsRunDigest()" id="news-run-btn" style="background:linear-gradient(135deg, #00c8ff, #0080ff); border:none; color:#fff; border-radius:0.5rem; padding:0.5rem 1.2rem; cursor:pointer; font-family:Inter,sans-serif; font-size:0.85rem; font-weight:600;">
                            Run Digest
                        </button>
                        <button onclick="newsRunDigest(true)" id="news-tg-btn" style="background:linear-gradient(135deg, #0088cc, #00aaee); border:none; color:#fff; border-radius:0.5rem; padding:0.5rem 1.2rem; cursor:pointer; font-family:Inter,sans-serif; font-size:0.85rem; font-weight:600;">
                            Run + Telegram
                        </button>
                        <button onclick="toggleNewsletters()" style="background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.12); color:#fff; border-radius:0.5rem; padding:0.5rem 1rem; cursor:pointer; font-family:Inter,sans-serif; font-size:0.85rem;">
                            Close
                        </button>
                    </div>
                </div>

                <!-- Status bar -->
                <div id="news-status" style="display:none; background:rgba(0,200,255,0.08); border:1px solid rgba(0,200,255,0.2); border-radius:0.75rem; padding:0.75rem 1rem; margin-bottom:1rem; font-family:Inter,sans-serif; font-size:0.85rem; color:rgba(255,255,255,0.7);">
                    Scanning newsletters...
                </div>

                <!-- Synergy section -->
                <div id="news-synergy" style="display:none; background:linear-gradient(135deg, rgba(255,100,0,0.08), rgba(255,200,0,0.06)); border:1px solid rgba(255,150,0,0.25); border-radius:1rem; padding:1.25rem 1.5rem; margin-bottom:1.5rem; backdrop-filter:blur(12px);">
                    <div style="display:flex; align-items:center; gap:0.5rem; margin-bottom:0.75rem;">
                        <span style="font-size:1.1rem;">🔗</span>
                        <h3 style="color:#ff9500; font-family:Inter,sans-serif; font-size:0.95rem; margin:0; text-transform:uppercase; letter-spacing:0.05em;">Cross-Sender Intelligence</h3>
                    </div>
                    <div id="news-synergy-content" style="color:rgba(255,255,255,0.85); font-family:Inter,sans-serif; font-size:0.85rem; line-height:1.6;"></div>
                </div>

                <!-- Sender cards -->
                <div id="news-senders" style="display:flex; flex-direction:column; gap:1rem;"></div>

                <!-- Footer -->
                <div id="news-footer" style="display:none; margin-top:1.5rem; padding:1rem; background:rgba(20,20,40,0.6); border:1px solid rgba(255,255,255,0.08); border-radius:0.75rem; text-align:center; font-family:Inter,sans-serif; font-size:0.9rem; color:rgba(255,255,255,0.6);"></div>
            </div>

            <!-- ═══ SKOOL DIGEST PANEL ═══ -->
            <div id="skool-panel" style="display:none; padding: 1.5rem;">
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.5rem; flex-wrap:wrap; gap:0.75rem;">
                    <h2 style="color:#fff; font-family:Inter,sans-serif; font-size:1.3rem; margin:0;">🎓 Skool Digest</h2>
                    <div style="display:flex; gap:0.5rem; flex-wrap:wrap;">
                        <button onclick="skoolRunDigest()" id="skool-email-btn" style="background:linear-gradient(135deg, #b480ff, #8b5cf6); border:none; color:#fff; border-radius:0.5rem; padding:0.5rem 1.2rem; cursor:pointer; font-family:Inter,sans-serif; font-size:0.85rem; font-weight:600;">
                            Email Scan
                        </button>
                        <button onclick="skoolDirectScrape()" id="skool-direct-btn" style="background:linear-gradient(135deg, #ff8844, #ff6600); border:none; color:#fff; border-radius:0.5rem; padding:0.5rem 1.2rem; cursor:pointer; font-family:Inter,sans-serif; font-size:0.85rem; font-weight:600;">
                            Direct Scrape
                        </button>
                        <button onclick="skoolDirectScrape(true)" id="skool-unreads-btn" style="background:linear-gradient(135deg, #00cc88, #00aa66); border:none; color:#fff; border-radius:0.5rem; padding:0.5rem 1.2rem; cursor:pointer; font-family:Inter,sans-serif; font-size:0.85rem; font-weight:600;">
                            Unreads Only
                        </button>
                        <button onclick="skoolRunDigest(true)" id="skool-tg-btn" style="background:linear-gradient(135deg, #0088cc, #00aaee); border:none; color:#fff; border-radius:0.5rem; padding:0.5rem 1.2rem; cursor:pointer; font-family:Inter,sans-serif; font-size:0.85rem; font-weight:600;">
                            + Telegram
                        </button>
                        <button onclick="toggleSkool()" style="background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.12); color:#fff; border-radius:0.5rem; padding:0.5rem 1rem; cursor:pointer; font-family:Inter,sans-serif; font-size:0.85rem;">
                            Close
                        </button>
                    </div>
                </div>

                <!-- Status bar -->
                <div id="skool-status" style="display:none; background:rgba(139,92,246,0.08); border:1px solid rgba(139,92,246,0.2); border-radius:0.75rem; padding:0.75rem 1rem; margin-bottom:1rem; font-family:Inter,sans-serif; font-size:0.85rem; color:rgba(255,255,255,0.7);">
                    Scanning Skool...
                </div>

                <!-- Cross-Classroom Intelligence -->
                <div id="skool-themes" style="display:none; background:linear-gradient(135deg, rgba(139,92,246,0.08), rgba(200,100,255,0.06)); border:1px solid rgba(139,92,246,0.25); border-radius:1rem; padding:1.25rem 1.5rem; margin-bottom:1.5rem; backdrop-filter:blur(12px);">
                    <div style="display:flex; align-items:center; gap:0.5rem; margin-bottom:0.75rem;">
                        <span style="font-size:1.1rem;">🎓</span>
                        <h3 style="color:#b480ff; font-family:Inter,sans-serif; font-size:0.95rem; margin:0; text-transform:uppercase; letter-spacing:0.05em;">Cross-Classroom Intelligence</h3>
                        <button onclick="skoolTTSThemes()" id="skool-themes-tts-btn" style="margin-left:auto; background:rgba(139,92,246,0.1); border:1px solid rgba(139,92,246,0.25); color:rgba(255,255,255,0.5); border-radius:0.4rem; padding:0.3rem 0.6rem; cursor:pointer; font-size:0.75rem; font-family:Inter,sans-serif; transition:all 0.2s;" title="Listen">🔊 Listen</button>
                    </div>
                    <div id="skool-themes-content" style="color:rgba(255,255,255,0.85); font-family:Inter,sans-serif; font-size:0.85rem; line-height:1.6;"></div>
                </div>

                <!-- Video Golden Nuggets -->
                <div id="skool-videos" style="display:none; background:linear-gradient(135deg, rgba(255,100,0,0.06), rgba(255,200,0,0.04)); border:1px solid rgba(255,150,0,0.2); border-radius:1rem; padding:1.25rem 1.5rem; margin-bottom:1.5rem; backdrop-filter:blur(12px);">
                    <div style="display:flex; align-items:center; gap:0.5rem; margin-bottom:0.75rem;">
                        <span style="font-size:1.1rem;">🎬</span>
                        <h3 style="color:#ff9500; font-family:Inter,sans-serif; font-size:0.95rem; margin:0; text-transform:uppercase; letter-spacing:0.05em;">Video Golden Nuggets</h3>
                        <span id="skool-video-count" style="background:rgba(255,150,0,0.15); color:#ff9500; border-radius:1rem; padding:0.15rem 0.6rem; font-size:0.72rem; font-weight:600;">0</span>
                    </div>
                    <div id="skool-videos-content" style="display:flex; flex-direction:column; gap:0.75rem;"></div>
                </div>

                <!-- Classroom cards -->
                <div id="skool-classrooms" style="display:flex; flex-direction:column; gap:1rem;"></div>

                <!-- Skool Config (inline) -->
                <div style="margin-top:1.5rem; background:rgba(20,20,40,0.5); border:1px solid rgba(139,92,246,0.15); border-radius:1rem; padding:1.25rem 1.5rem; backdrop-filter:blur(12px);">
                    <div style="display:flex; align-items:center; gap:0.5rem; margin-bottom:0.75rem; flex-wrap:wrap;">
                        <span style="font-size:1rem;">📚</span>
                        <h3 style="color:#b480ff; font-family:Inter,sans-serif; font-size:0.95rem; margin:0;">Skool Communities</h3>
                        <span id="skool-session-status" style="font-size:0.72rem; padding:0.2rem 0.6rem; border-radius:1rem; background:rgba(255,255,255,0.06); color:rgba(255,255,255,0.4);">Checking...</span>
                        <div style="margin-left:auto; display:flex; gap:0.4rem;">
                            <button onclick="skoolReauth()" id="skool-reauth-btn" style="background:rgba(255,170,0,0.1); border:1px solid rgba(255,170,0,0.2); color:#ffaa00; border-radius:0.4rem; padding:0.35rem 0.7rem; cursor:pointer; font-family:Inter,sans-serif; font-size:0.75rem; font-weight:600;">Re-auth</button>
                            <button onclick="skoolSaveConfig()" id="skool-save-btn" style="background:linear-gradient(135deg, #b480ff, #8b5cf6); border:none; color:#fff; border-radius:0.4rem; padding:0.35rem 0.8rem; cursor:pointer; font-family:Inter,sans-serif; font-size:0.75rem; font-weight:600;">Save</button>
                        </div>
                    </div>
                    <div id="skool-community-tags" style="display:flex; flex-wrap:wrap; gap:0.4rem; margin-bottom:0.75rem;"></div>
                    <div style="display:flex; gap:0.5rem;">
                        <input id="skool-community-input" type="text" placeholder="Add Skool community URL (e.g. https://www.skool.com/community-name)" style="flex:1; background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.15); color:#fff; border-radius:0.5rem; padding:0.5rem 0.75rem; font-family:Inter,sans-serif; font-size:0.85rem; outline:none;" onkeydown="if(event.key==='Enter')skoolAddCommunity()">
                        <button onclick="skoolAddCommunity()" style="background:rgba(139,92,246,0.15); border:1px solid rgba(139,92,246,0.3); color:#b480ff; border-radius:0.5rem; padding:0.5rem 1rem; cursor:pointer; font-family:Inter,sans-serif; font-size:0.85rem; font-weight:600;">+ Add</button>
                    </div>
                    <div id="skool-config-footer" style="margin-top:0.5rem; font-size:0.72rem; color:rgba(255,255,255,0.3); text-align:center;"></div>
                </div>

                <!-- Footer -->
                <div id="skool-footer" style="display:none; margin-top:1.5rem; padding:1rem; background:rgba(20,20,40,0.6); border:1px solid rgba(255,255,255,0.08); border-radius:0.75rem; text-align:center; font-family:Inter,sans-serif; font-size:0.9rem; color:rgba(255,255,255,0.6);"></div>
            </div>

            <!-- WF2 Reddit Config Panel -->
            <div id="wf2-config-panel" style="display:none; padding: 1.5rem;">
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.5rem; flex-wrap:wrap; gap:0.75rem;">
                    <h2 style="color:#fff; font-family:Inter,sans-serif; font-size:1.3rem; margin:0;">🎯 Reddit Pain Point Config (WF2)</h2>
                    <div style="display:flex; gap:0.5rem; flex-wrap:wrap;">
                        <button onclick="wf2SaveConfig()" id="wf2-save-btn" style="background:linear-gradient(135deg, #00ff88, #00c853); border:none; color:#111; border-radius:0.5rem; padding:0.5rem 1.2rem; cursor:pointer; font-family:Inter,sans-serif; font-size:0.85rem; font-weight:600;">
                            Save to Sheet
                        </button>
                        <button onclick="wf2FetchConfig()" style="background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.12); color:#fff; border-radius:0.5rem; padding:0.5rem 1rem; cursor:pointer; font-family:Inter,sans-serif; font-size:0.85rem;">
                            Refresh
                        </button>
                        <button onclick="toggleWF2Config()" style="background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.12); color:#fff; border-radius:0.5rem; padding:0.5rem 1rem; cursor:pointer; font-family:Inter,sans-serif; font-size:0.85rem;">
                            Close
                        </button>
                    </div>
                </div>

                <!-- Status bar -->
                <div id="wf2-status" style="display:none; background:rgba(0,255,136,0.08); border:1px solid rgba(0,255,136,0.2); border-radius:0.75rem; padding:0.75rem 1rem; margin-bottom:1rem; font-family:Inter,sans-serif; font-size:0.85rem; color:rgba(255,255,255,0.7);"></div>

                <!-- Subreddits Section -->
                <div style="background:rgba(20,20,40,0.5); border:1px solid rgba(255,255,255,0.08); border-radius:1rem; padding:1.25rem 1.5rem; margin-bottom:1rem; backdrop-filter:blur(12px);">
                    <h3 style="color:#00f5ff; font-family:Inter,sans-serif; font-size:0.95rem; margin:0 0 0.75rem 0; text-transform:uppercase; letter-spacing:0.05em;">Subreddits</h3>
                    <div id="wf2-subs-tags" style="display:flex; flex-wrap:wrap; gap:0.4rem; margin-bottom:0.75rem;"></div>
                    <div style="display:flex; gap:0.5rem;">
                        <input id="wf2-sub-input" type="text" placeholder="Add subreddit (e.g. smallbusiness)" style="flex:1; background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.15); color:#fff; border-radius:0.5rem; padding:0.5rem 0.75rem; font-family:Inter,sans-serif; font-size:0.85rem; outline:none;" onkeydown="if(event.key==='Enter')wf2AddSub()">
                        <button onclick="wf2AddSub()" style="background:rgba(0,245,255,0.15); border:1px solid rgba(0,245,255,0.3); color:#00f5ff; border-radius:0.5rem; padding:0.5rem 1rem; cursor:pointer; font-family:Inter,sans-serif; font-size:0.85rem; font-weight:600;">+ Add</button>
                    </div>
                </div>

                <!-- Keywords Section -->
                <div style="background:rgba(20,20,40,0.5); border:1px solid rgba(255,255,255,0.08); border-radius:1rem; padding:1.25rem 1.5rem; margin-bottom:1rem; backdrop-filter:blur(12px);">
                    <h3 style="color:#b829dd; font-family:Inter,sans-serif; font-size:0.95rem; margin:0 0 0.75rem 0; text-transform:uppercase; letter-spacing:0.05em;">Pain Signal Keywords <span id="wf2-kw-count" style="color:rgba(255,255,255,0.4); font-size:0.8rem; font-weight:400;"></span></h3>
                    <div id="wf2-kw-tags" style="display:flex; flex-wrap:wrap; gap:0.4rem; margin-bottom:0.75rem;"></div>
                    <div style="display:flex; gap:0.5rem;">
                        <input id="wf2-kw-input" type="text" placeholder="Add keyword or phrase (e.g. need funding)" style="flex:1; background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.15); color:#fff; border-radius:0.5rem; padding:0.5rem 0.75rem; font-family:Inter,sans-serif; font-size:0.85rem; outline:none;" onkeydown="if(event.key==='Enter')wf2AddKw()">
                        <button onclick="wf2AddKw()" style="background:rgba(184,41,221,0.15); border:1px solid rgba(184,41,221,0.3); color:#b829dd; border-radius:0.5rem; padding:0.5rem 1rem; cursor:pointer; font-family:Inter,sans-serif; font-size:0.85rem; font-weight:600;">+ Add</button>
                    </div>
                </div>

                <!-- Footer info -->
                <div id="wf2-footer" style="padding:0.75rem 1rem; background:rgba(20,20,40,0.4); border:1px solid rgba(255,255,255,0.06); border-radius:0.75rem; text-align:center; font-family:Inter,sans-serif; font-size:0.8rem; color:rgba(255,255,255,0.4);">
                    Changes apply on next WF2 run (every 3 hours)
                </div>
            </div>

        </main>
    </div>

    <script>
        // ── Opportunities panel toggle ───────────────────────────────────────
        function toggleOpportunities() {
            const panel = document.getElementById('opportunities-panel');
            const isVisible = panel.style.display !== 'none';
            panel.style.display = isVisible ? 'none' : 'block';
            if (!isVisible) panel.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }

        // ── Revenue Panel (IncomeOps_Monitor) ──────────────────────────────
        let revData = null; // cached API response
        const REV_GOAL_KEY = 'dwe_revenue_goal';

        function revFmt(str) {
            // Returns the dollar string as-is from the sheet, or '—' if empty
            if (!str || str.trim() === '' || str.trim() === '$0' || str.trim() === '$0.00') return '$0';
            return str.trim();
        }

        function revParseDollar(str) {
            if (!str) return 0;
            return parseFloat(String(str).replace(/[$,]/g, '')) || 0;
        }

        function revFmtCurrency(n) {
            return '$' + Number(n).toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
        }

        async function revFetchData() {
            const btn = document.getElementById('rev-refresh-btn');
            btn.textContent = 'Loading...';
            btn.disabled = true;
            try {
                const r = await fetch('/mc/income-ops');
                const json = await r.json();
                if (json.ok) {
                    revData = json;
                    revRender();
                    document.getElementById('rev-updated').textContent = 'Updated: ' + new Date(json.updated).toLocaleTimeString();
                } else {
                    document.getElementById('rev-loading').textContent = 'Error: ' + (json.error || 'Unknown');
                }
            } catch(e) {
                document.getElementById('rev-loading').textContent = 'Failed to fetch: ' + e.message;
            }
            btn.textContent = 'Refresh';
            btn.disabled = false;
        }

        function toggleRevenue() {
            const panel = document.getElementById('revenue-panel');
            const isVisible = panel.style.display !== 'none';
            panel.style.display = isVisible ? 'none' : 'block';
            if (!isVisible) {
                if (!revData) revFetchData();
                else revRender();
                panel.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
        }

        // ── Intel Panel ─────────────────────────────────────────────────────
        const INTEL_STORAGE_KEY = 'dwe_intel_data';
        const INTEL_BRIEF_KEY = 'dwe_intel_brief';

        const INTEL_CATEGORIES = {
            'ai-news': { label: 'AI News', icon: '🤖', color: '#00c8ff' },
            'industry': { label: 'Industry', icon: '📊', color: '#00ff88' },
            'competitor': { label: 'Competitor', icon: '🔍', color: '#ffaa00' },
            'opportunity': { label: 'Opportunity', icon: '💎', color: '#c864ff' }
        };

        const INTEL_IMPORTANCE = {
            'critical': { label: 'CRITICAL', color: '#ff4444', bg: 'rgba(255,68,68,0.15)' },
            'high': { label: 'HIGH', color: '#ffaa00', bg: 'rgba(255,170,0,0.12)' },
            'medium': { label: 'MED', color: '#00c8ff', bg: 'rgba(0,200,255,0.1)' },
            'low': { label: 'LOW', color: 'rgba(255,255,255,0.4)', bg: 'rgba(255,255,255,0.05)' }
        };

        function intelLoad() {
            const raw = localStorage.getItem(INTEL_STORAGE_KEY);
            if (!raw) return [];
            return JSON.parse(raw);
        }

        function intelSave(items) {
            localStorage.setItem(INTEL_STORAGE_KEY, JSON.stringify(items));
        }

        function intelSaveBrief() {
            const text = document.getElementById('intel-brief-text').value;
            const today = new Date().toISOString().slice(0, 10);
            const briefs = JSON.parse(localStorage.getItem(INTEL_BRIEF_KEY) || '{}');
            briefs[today] = text;
            localStorage.setItem(INTEL_BRIEF_KEY, JSON.stringify(briefs));
        }

        function intelLoadBrief() {
            const today = new Date().toISOString().slice(0, 10);
            const briefs = JSON.parse(localStorage.getItem(INTEL_BRIEF_KEY) || '{}');
            document.getElementById('intel-brief-text').value = briefs[today] || '';
            document.getElementById('intel-brief-date').textContent = today;
        }

        function intelAdd() {
            const title = document.getElementById('intel-title').value.trim();
            if (!title) return;
            const item = {
                id: Date.now(),
                title: title,
                source: document.getElementById('intel-source').value.trim(),
                category: document.getElementById('intel-category').value,
                importance: document.getElementById('intel-importance').value,
                notes: document.getElementById('intel-notes').value.trim(),
                url: document.getElementById('intel-url').value.trim(),
                date: new Date().toISOString(),
                read: false
            };
            const items = intelLoad();
            items.unshift(item);
            intelSave(items);
            document.getElementById('intel-title').value = '';
            document.getElementById('intel-source').value = '';
            document.getElementById('intel-notes').value = '';
            document.getElementById('intel-url').value = '';
            document.getElementById('intel-importance').value = 'medium';
            intelRender();
        }

        function intelDelete(id) {
            const items = intelLoad().filter(i => i.id !== id);
            intelSave(items);
            intelRender();
        }

        function intelToggleRead(id) {
            const items = intelLoad();
            const item = items.find(i => i.id === id);
            if (item) item.read = !item.read;
            intelSave(items);
            intelRender();
        }

        function intelRender() {
            const items = intelLoad();
            const catFilter = document.getElementById('intel-filter').value;
            const impFilter = document.getElementById('intel-importance-filter').value;

            // Stats
            const counts = { 'ai-news': 0, 'industry': 0, 'competitor': 0, 'opportunity': 0 };
            items.forEach(i => { if (counts[i.category] !== undefined) counts[i.category]++; });
            document.getElementById('intel-count-ai').textContent = counts['ai-news'];
            document.getElementById('intel-count-industry').textContent = counts['industry'];
            document.getElementById('intel-count-competitor').textContent = counts['competitor'];
            document.getElementById('intel-count-opportunity').textContent = counts['opportunity'];

            // Filter
            let filtered = items;
            if (catFilter !== 'all') filtered = filtered.filter(i => i.category === catFilter);
            if (impFilter !== 'all') filtered = filtered.filter(i => i.importance === impFilter);

            // Sort: importance (critical > high > medium > low), then date desc
            const impOrder = { critical: 0, high: 1, medium: 2, low: 3 };
            filtered.sort((a, b) => {
                const d = (impOrder[a.importance] || 3) - (impOrder[b.importance] || 3);
                if (d !== 0) return d;
                return new Date(b.date) - new Date(a.date);
            });

            // Render feed
            const feed = document.getElementById('intel-feed');
            if (filtered.length === 0) {
                feed.innerHTML = '<div style="text-align:center; padding:3rem; color:rgba(255,255,255,0.3); font-family:Inter,sans-serif;">No intel items yet. Add your first item above.</div>';
                return;
            }

            feed.innerHTML = filtered.map(item => {
                const cat = INTEL_CATEGORIES[item.category] || INTEL_CATEGORIES['ai-news'];
                const imp = INTEL_IMPORTANCE[item.importance] || INTEL_IMPORTANCE['medium'];
                const dateStr = new Date(item.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
                const readOpacity = item.read ? '0.5' : '1';
                const urlLink = item.url ? `<a href="${item.url}" target="_blank" rel="noopener" style="color:${cat.color}; font-size:0.75rem; text-decoration:none; opacity:0.8;">🔗 Source</a>` : '';

                return `<div style="background:rgba(20,20,40,0.6); border:1px solid rgba(255,255,255,0.08); border-left:3px solid ${cat.color}; border-radius:0.75rem; padding:1rem 1.25rem; backdrop-filter:blur(12px); opacity:${readOpacity}; transition:opacity 0.3s;">
                    <div style="display:flex; align-items:flex-start; justify-content:space-between; gap:0.75rem;">
                        <div style="flex:1; min-width:0;">
                            <div style="display:flex; align-items:center; gap:0.5rem; margin-bottom:0.4rem; flex-wrap:wrap;">
                                <span style="font-size:0.85rem;">${cat.icon}</span>
                                <span style="color:${cat.color}; font-size:0.65rem; text-transform:uppercase; letter-spacing:0.05em; font-family:Inter,sans-serif;">${cat.label}</span>
                                <span style="background:${imp.bg}; color:${imp.color}; font-size:0.6rem; font-weight:700; padding:0.15rem 0.5rem; border-radius:0.25rem; font-family:Inter,sans-serif; letter-spacing:0.05em;">${imp.label}</span>
                                <span style="color:rgba(255,255,255,0.3); font-size:0.7rem; font-family:Inter,sans-serif;">${dateStr}</span>
                                ${item.source ? `<span style="color:rgba(255,255,255,0.25); font-size:0.7rem; font-family:Inter,sans-serif;">via ${item.source}</span>` : ''}
                            </div>
                            <div style="color:#fff; font-family:Inter,sans-serif; font-size:0.9rem; font-weight:500; margin-bottom:${item.notes ? '0.4rem' : '0'};">${item.title}</div>
                            ${item.notes ? `<div style="color:rgba(255,255,255,0.5); font-family:Inter,sans-serif; font-size:0.8rem; line-height:1.4;">${item.notes}</div>` : ''}
                            ${urlLink ? `<div style="margin-top:0.4rem;">${urlLink}</div>` : ''}
                        </div>
                        <div style="display:flex; gap:0.3rem; flex-shrink:0;">
                            <button onclick="intelToggleRead(${item.id})" title="${item.read ? 'Mark unread' : 'Mark read'}" style="background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.08); color:rgba(255,255,255,0.5); border-radius:0.4rem; width:28px; height:28px; cursor:pointer; font-size:0.7rem; display:flex; align-items:center; justify-content:center;">${item.read ? '📖' : '✓'}</button>
                            <button onclick="intelDelete(${item.id})" title="Delete" style="background:rgba(255,50,50,0.08); border:1px solid rgba(255,50,50,0.15); color:rgba(255,100,100,0.7); border-radius:0.4rem; width:28px; height:28px; cursor:pointer; font-size:0.7rem; display:flex; align-items:center; justify-content:center;">✕</button>
                        </div>
                    </div>
                </div>`;
            }).join('');

            intelLoadBrief();
        }

        function toggleIntel() {
            const panel = document.getElementById('intel-panel');
            const isVisible = panel.style.display !== 'none';
            panel.style.display = isVisible ? 'none' : 'block';
            if (!isVisible) {
                intelRender();
                intelLoadBrief();
                intelLoadCriticalTickets();
                intelLoadOCUpdate();
                panel.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
        }

        async function intelLoadCriticalTickets() {
            const container = document.getElementById('intel-critical-tickets');
            const list = document.getElementById('intel-critical-list');
            const countBadge = document.getElementById('intel-critical-count');
            try {
                const resp = await fetch('/mc/notion-tasks');
                const data = await resp.json();
                const tasks = data.tasks || [];
                const critical = tasks.filter(t =>
                    t.priority === 'Critical' ||
                    t.status === 'Blocked' ||
                    t.status === 'blocked'
                );
                if (critical.length === 0) {
                    container.style.display = 'none';
                    return;
                }
                countBadge.textContent = critical.length;
                list.innerHTML = critical.map(t => {
                    const isBlocked = t.status === 'Blocked' || t.status === 'blocked';
                    const isCritical = t.priority === 'Critical';
                    const badges = [];
                    if (isCritical) badges.push('<span style="background:rgba(255,60,60,0.2); color:#ff6b6b; font-size:0.65rem; font-weight:700; padding:0.1rem 0.4rem; border-radius:0.25rem;">CRITICAL</span>');
                    if (isBlocked) badges.push('<span style="background:rgba(255,170,0,0.2); color:#ffaa00; font-size:0.65rem; font-weight:700; padding:0.1rem 0.4rem; border-radius:0.25rem;">BLOCKED</span>');
                    const role = t.role || 'Unassigned';
                    return `<div style="background:rgba(20,20,40,0.5); border:1px solid rgba(255,60,60,0.12); border-radius:0.5rem; padding:0.6rem 0.8rem;">
                        <div style="display:flex; align-items:center; gap:0.4rem; flex-wrap:wrap;">
                            ${badges.join(' ')}
                            <span style="color:#fff; font-family:Inter,sans-serif; font-size:0.85rem; font-weight:500;">${t.name || 'Untitled'}</span>
                        </div>
                        <div style="display:flex; gap:0.75rem; margin-top:0.3rem;">
                            <span style="color:rgba(255,255,255,0.4); font-family:Inter,sans-serif; font-size:0.7rem;">${role}</span>
                            <span style="color:rgba(255,255,255,0.3); font-family:Inter,sans-serif; font-size:0.7rem;">${t.status || 'No Status'}</span>
                        </div>
                    </div>`;
                }).join('');
                container.style.display = 'block';
            } catch (e) {
                console.error('Failed to load critical tickets:', e);
                container.style.display = 'none';
            }
        }

        async function intelLoadOCUpdate() {
            const container = document.getElementById('intel-oc-update');
            const body = document.getElementById('intel-oc-update-body');
            try {
                const resp = await fetch('/mc/openclaw-update-check');
                const data = await resp.json();
                if (!data.ok || !data.updateAvailable) {
                    container.style.display = 'none';
                    return;
                }
                let html = `<div style="margin-bottom:0.6rem;">
                    <span style="color:rgba(255,255,255,0.5);">Current:</span> <strong style="color:#fff;">${data.currentVersion}</strong>
                    <span style="color:rgba(255,255,255,0.3); margin:0 0.3rem;">&rarr;</span>
                    <span style="color:rgba(255,255,255,0.5);">Latest:</span> <strong style="color:#ffaa00;">${data.latestVersion}</strong>
                    <span style="color:rgba(255,255,255,0.3); margin-left:0.5rem; font-size:0.75rem;">(${data.channel || 'stable'})</span>
                </div>`;
                if (data.releaseNotes) {
                    html += `<div style="background:rgba(255,170,0,0.06); border:1px solid rgba(255,170,0,0.1); border-radius:0.5rem; padding:0.6rem 0.8rem; margin-bottom:0.6rem;">
                        <div style="color:rgba(255,255,255,0.5); font-size:0.7rem; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:0.3rem;">Release Notes</div>
                        <div style="color:rgba(255,255,255,0.8); font-size:0.85rem; line-height:1.5;">${data.releaseNotes}</div>
                    </div>`;
                }
                if (data.actions && data.actions.length > 0) {
                    html += `<div style="color:rgba(255,255,255,0.5); font-size:0.75rem; margin-top:0.3rem;">Actions: ${data.actions.join(', ')}</div>`;
                }
                if (data.releaseUrl) {
                    html += `<a href="${data.releaseUrl}" target="_blank" rel="noopener" style="color:#ffaa00; font-size:0.8rem; text-decoration:none; opacity:0.8;">View on npm &rarr;</a>`;
                }
                body.innerHTML = html;
                container.style.display = 'block';
            } catch (e) {
                console.error('Failed to load OC update:', e);
                container.style.display = 'none';
            }
        }

        // ═══ NEWSLETTER DIGEST ═══
        let newsData = null;

        function toggleNewsletters() {
            const panel = document.getElementById('newsletters-panel');
            const isVisible = panel.style.display !== 'none';
            panel.style.display = isVisible ? 'none' : 'block';
            if (!isVisible) {
                if (newsData) newsRender();
                panel.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
        }

        // ═══ SKOOL DIGEST ═══
        let skoolData = null;
        const skoolProcessed = new Set();
        let skoolConfigData = { communities: [] };
        let currentSkoolTTSBtn = null;

        function toggleSkool() {
            const panel = document.getElementById('skool-panel');
            const isVisible = panel.style.display !== 'none';
            panel.style.display = isVisible ? 'none' : 'block';
            if (!isVisible) {
                skoolLoadConfig();
                if (skoolData) skoolRender();
                panel.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
        }

        function styleHypeCheck(summary) {
            summary = summary.replace(/HYPE CHECK: 🟢 Solid/g, '<span style="background:rgba(0,255,136,0.12);border:1px solid rgba(0,255,136,0.3);color:#00ff88;padding:0.15rem 0.5rem;border-radius:0.3rem;font-weight:700;font-size:0.75rem;">🟢 SOLID</span>');
            summary = summary.replace(/HYPE CHECK: 🟡 Mixed/g, '<span style="background:rgba(255,170,0,0.12);border:1px solid rgba(255,170,0,0.3);color:#ffaa00;padding:0.15rem 0.5rem;border-radius:0.3rem;font-weight:700;font-size:0.75rem;">🟡 MIXED</span>');
            summary = summary.replace(/HYPE CHECK: 🔴 Hype/g, '<span style="background:rgba(255,60,60,0.12);border:1px solid rgba(255,60,60,0.3);color:#ff6b6b;padding:0.15rem 0.5rem;border-radius:0.3rem;font-weight:700;font-size:0.75rem;">🔴 HYPE</span>');
            summary = summary.replace(/HYPE CHECK:\s*\[?🟢[^\]]*\]?/g, '<span style="background:rgba(0,255,136,0.12);border:1px solid rgba(0,255,136,0.3);color:#00ff88;padding:0.15rem 0.5rem;border-radius:0.3rem;font-weight:700;font-size:0.75rem;">🟢 SOLID</span>');
            summary = summary.replace(/HYPE CHECK:\s*\[?🟡[^\]]*\]?/g, '<span style="background:rgba(255,170,0,0.12);border:1px solid rgba(255,170,0,0.3);color:#ffaa00;padding:0.15rem 0.5rem;border-radius:0.3rem;font-weight:700;font-size:0.75rem;">🟡 MIXED</span>');
            summary = summary.replace(/HYPE CHECK:\s*\[?🔴[^\]]*\]?/g, '<span style="background:rgba(255,60,60,0.12);border:1px solid rgba(255,60,60,0.3);color:#ff6b6b;padding:0.15rem 0.5rem;border-radius:0.3rem;font-weight:700;font-size:0.75rem;">🔴 HYPE</span>');
            return summary;
        }

        async function skoolRunDigest(telegram = false) {
            const btn = document.getElementById(telegram ? 'skool-tg-btn' : 'skool-email-btn');
            const origText = btn.textContent;
            btn.disabled = true;
            btn.textContent = 'Scanning...';
            const status = document.getElementById('skool-status');
            status.style.display = 'block';
            status.textContent = '🎓 Scanning Skool emails + pulling video transcripts... this may take 2-5 minutes';
            status.style.borderColor = 'rgba(139,92,246,0.2)';
            status.style.background = 'rgba(139,92,246,0.08)';
            try {
                const url = telegram ? '/mc/skool-digest?telegram=1' : '/mc/skool-digest';
                const resp = await fetch(url);
                skoolData = await resp.json();
                if (skoolData.error) {
                    status.textContent = '❌ ' + skoolData.error;
                    status.style.borderColor = 'rgba(255,50,50,0.3)';
                    status.style.background = 'rgba(255,50,50,0.08)';
                } else {
                    status.style.display = 'none';
                    skoolRender();
                }
            } catch (e) {
                status.textContent = '❌ Failed: ' + e.message;
                status.style.borderColor = 'rgba(255,50,50,0.3)';
                status.style.background = 'rgba(255,50,50,0.08)';
            }
            btn.disabled = false;
            btn.textContent = origText;
        }

        async function skoolDirectScrape(unreadsOnly = false) {
            const btnId = unreadsOnly ? 'skool-unreads-btn' : 'skool-direct-btn';
            const btn = document.getElementById(btnId);
            const origText = btn.textContent;
            btn.disabled = true;
            btn.textContent = unreadsOnly ? 'Fetching...' : 'Scraping...';
            const status = document.getElementById('skool-status');
            status.style.display = 'block';
            const label = unreadsOnly ? 'unread posts (API)' : 'all posts (API)';
            status.textContent = `🎓 Fetching ${label} + pulling transcripts... this may take 1-5 minutes`;
            status.style.borderColor = 'rgba(139,92,246,0.2)';
            status.style.background = 'rgba(139,92,246,0.08)';
            try {
                let url = '/mc/skool-scrape?method=api';
                if (unreadsOnly) url += '&unreads=1';
                const resp = await fetch(url);
                skoolData = await resp.json();
                if (skoolData.error) {
                    status.textContent = '❌ ' + skoolData.error;
                    if (skoolData.session_ok === false) {
                        status.textContent += ' — Set SKOOL_AUTH_TOKEN in .env or click Re-auth below.';
                    }
                    status.style.borderColor = 'rgba(255,50,50,0.3)';
                    status.style.background = 'rgba(255,50,50,0.08)';
                } else {
                    status.style.display = 'none';
                    skoolRender();
                }
            } catch (e) {
                status.textContent = '❌ Failed: ' + e.message;
                status.style.borderColor = 'rgba(255,50,50,0.3)';
                status.style.background = 'rgba(255,50,50,0.08)';
            }
            btn.disabled = false;
            btn.textContent = origText;
        }

        function skoolRender() {
            if (!skoolData) return;
            const { themes, classrooms, videos, total, theme_count, video_count } = skoolData;

            // Cross-Classroom Intelligence
            const themesEl = document.getElementById('skool-themes');
            if (themes) {
                themesEl.style.display = 'block';
                let html = themes.replace(/🎓 THEME DETECTED: ([^\n]*)/g,
                    '<div style="color:#b480ff;font-weight:700;font-size:0.95rem;margin-top:0.5rem;">🎓 THEME DETECTED: $1</div>');
                html = html.replace(/Classrooms: ([^\n]*)/g,
                    '<div style="color:rgba(255,255,255,0.5);font-size:0.8rem;font-style:italic;">Classrooms: $1</div>');
                html = html.replace(/Signal: ([^\n]*)/g,
                    '<div style="color:rgba(255,255,255,0.8);font-size:0.85rem;margin-bottom:0.4rem;">$1</div>');
                html = html.replace(/📈 LEARNING PULSE:/g,
                    '<div style="color:#00c8ff;font-weight:700;font-size:0.95rem;margin-top:0.75rem;">📈 LEARNING PULSE:</div>');
                document.getElementById('skool-themes-content').innerHTML = html;
            } else { themesEl.style.display = 'none'; }

            // Video Golden Nuggets
            const videosEl = document.getElementById('skool-videos');
            if (videos && videos.length > 0) {
                videosEl.style.display = 'block';
                document.getElementById('skool-video-count').textContent = videos.length;
                const vcontent = document.getElementById('skool-videos-content');
                vcontent.innerHTML = videos.map(v => {
                    let summary = v.summary || '';
                    summary = styleHypeCheck(summary);
                    summary = summary.replace(/GOLDEN NUGGETS:/g, '<span style="color:#ff9500;font-weight:600;">GOLDEN NUGGETS:</span>');
                    summary = summary.replace(/TOOLS\/TECH MENTIONED:/g, '<span style="color:#00c8ff;font-weight:600;">TOOLS/TECH MENTIONED:</span>');
                    summary = summary.replace(/DWE ACTION ITEMS:/g, '<span style="color:#00ff88;font-weight:600;">DWE ACTION ITEMS:</span>');
                    summary = summary.replace(/\n/g, '<br>');
                    summary = summary.replace(/• /g, '&nbsp;&nbsp;• ');
                    const rawText = (v.summary || '').replace(/\n/g, ' ').replace(/"/g, '&quot;');
                    return `<div style="border-left:3px solid rgba(255,150,0,0.3); padding:0.75rem 1rem;">
                        <div style="display:flex;justify-content:space-between;align-items:start;margin-bottom:0.4rem;">
                            <div>
                                <a href="${escH(v.url)}" target="_blank" style="color:#fff;font-weight:600;font-size:0.9rem;text-decoration:none;">🎬 ${escH(v.title)}</a>
                                <div style="color:rgba(255,255,255,0.4);font-size:0.72rem;margin-top:0.15rem;">📍 ${escH(v.classroom)} ${v.has_transcript ? '✅ Transcript' : '⚠️ No transcript'}</div>
                            </div>
                            <div style="display:flex;gap:0.4rem;align-items:center;flex-shrink:0;margin-left:0.5rem;">
                                <button onclick="skoolTTS(this)" data-text="${rawText}" style="background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.12);color:rgba(255,255,255,0.5);border-radius:0.3rem;padding:0.2rem 0.4rem;cursor:pointer;font-size:0.65rem;font-family:Inter,sans-serif;transition:all 0.2s;" title="Listen">🔊</button>
                                <button onclick="skoolAddTask('${escH(v.title).replace(/'/g,"\\'")}','Skool Video',this,'${escH(v.url)}')" style="background:rgba(255,170,0,0.1);border:1px solid rgba(255,170,0,0.2);color:#ffaa00;border-radius:0.3rem;padding:0.2rem 0.4rem;cursor:pointer;font-size:0.65rem;font-family:Inter,sans-serif;transition:all 0.2s;" title="Add to Task">+ Task</button>
                            </div>
                        </div>
                        <div style="color:rgba(255,255,255,0.75);font-size:0.85rem;line-height:1.6;">${summary}</div>
                    </div>`;
                }).join('');
            } else { videosEl.style.display = 'none'; }

            // Classrooms
            const container = document.getElementById('skool-classrooms');
            if (!classrooms || classrooms.length === 0) {
                container.innerHTML = '<div style="text-align:center;color:rgba(255,255,255,0.5);padding:1.5rem;font-size:0.9rem;">✅ No unread Skool content.</div>';
                return;
            }
            container.innerHTML = classrooms.map((cr, cIdx) => {
                const items = cr.emails.map(em => {
                    let summary = em.summary || '';
                    summary = styleHypeCheck(summary);
                    summary = summary.replace(/KEY POINTS:/g, '<span style="color:#b480ff;font-weight:600;">KEY POINTS:</span>');
                    summary = summary.replace(/LINKS:/g, '<span style="color:#00ff88;font-weight:600;">LINKS:</span>');
                    summary = summary.replace(/RELEVANCE:/g, '<span style="color:#ff9500;font-weight:600;">RELEVANCE:</span>');
                    summary = summary.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" style="color:#b480ff;text-decoration:underline;">$1</a>');
                    summary = summary.replace(/\n/g, '<br>');
                    summary = summary.replace(/• /g, '&nbsp;&nbsp;• ');
                    const rawText = (em.summary || '').replace(/\n/g, ' ').replace(/"/g, '&quot;');
                    const ytLinks = (em.youtube_urls || []).map(u =>
                        `<a href="${escH(u)}" target="_blank" style="color:#ff9500;font-size:0.75rem;text-decoration:none;">🎬 Video</a>`
                    ).join(' ');
                    return `<div style="border-left:3px solid rgba(139,92,246,0.3);padding:0.75rem 1rem;margin:0.4rem 0;">
                        <div style="display:flex;justify-content:space-between;align-items:start;margin-bottom:0.4rem;">
                            <div style="color:#fff;font-weight:600;font-size:0.9rem;">📧 ${escH(em.subject)} ${ytLinks}</div>
                            <div style="display:flex;gap:0.4rem;align-items:center;flex-shrink:0;margin-left:0.5rem;">
                                <button onclick="skoolTTS(this)" data-text="${rawText}" style="background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.12);color:rgba(255,255,255,0.5);border-radius:0.3rem;padding:0.2rem 0.4rem;cursor:pointer;font-size:0.65rem;font-family:Inter,sans-serif;transition:all 0.2s;" title="Listen">🔊</button>
                                <button onclick="skoolAddTask('${escH(em.subject).replace(/'/g,"\\'")}','Skool: ${escH(cr.name).replace(/'/g,"\\'")}',this,'${escH(em.postUrl || (em.msg_id ? "https://mail.google.com/mail/u/0/#inbox/" + em.msg_id : ""))}')" style="background:rgba(255,170,0,0.1);border:1px solid rgba(255,170,0,0.2);color:#ffaa00;border-radius:0.3rem;padding:0.2rem 0.4rem;cursor:pointer;font-size:0.65rem;font-family:Inter,sans-serif;transition:all 0.2s;" title="Add to Task">+ Task</button>
                                <span style="color:rgba(255,255,255,0.35);font-size:0.72rem;white-space:nowrap;">${escH(em.date)}</span>
                            </div>
                        </div>
                        <div style="color:rgba(255,255,255,0.75);font-size:0.85rem;line-height:1.6;">${summary}</div>
                    </div>`;
                }).join('');
                const msgIds = cr.emails.map(em => em.msg_id || '').filter(Boolean);
                return `<div id="skool-classroom-${cIdx}" data-msgids="${msgIds.join(',')}" style="background:rgba(20,20,40,0.6);border:1px solid rgba(139,92,246,0.12);border-radius:1rem;padding:1.25rem 1.5rem;transition:all 0.3s;">
                    <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.75rem;">
                        <div onclick="skoolToggleClassroom(${cIdx})" style="width:22px;height:22px;border:2px solid rgba(139,92,246,0.4);border-radius:4px;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:0.7rem;transition:all 0.2s;flex-shrink:0;" id="skool-check-${cIdx}" title="Archive all from this classroom">
                        </div>
                        <span style="font-size:1.1rem;">📚</span>
                        <h3 style="color:#fff;font-family:Inter,sans-serif;font-size:0.95rem;margin:0;">${escH(cr.name)}</h3>
                        <span style="background:rgba(139,92,246,0.15);color:#b480ff;border-radius:1rem;padding:0.15rem 0.6rem;font-size:0.72rem;font-weight:600;">${cr.emails.length} new</span>
                    </div>
                    ${items}
                </div>`;
            }).join('');

            const footer = document.getElementById('skool-footer');
            footer.style.display = 'block';
            let footerText = `📊 ${total} Skool posts from ${classrooms.length} classrooms`;
            if (video_count > 0) footerText += ` | 🎬 ${video_count} video${video_count > 1 ? 's' : ''} processed`;
            if (theme_count > 0) footerText += ` | 🎓 ${theme_count} theme${theme_count > 1 ? 's' : ''} detected`;
            footer.textContent = footerText;
        }

        function skoolToggleClassroom(idx) {
            const card = document.getElementById('skool-classroom-' + idx);
            const check = document.getElementById('skool-check-' + idx);
            if (skoolProcessed.has(idx)) {
                skoolProcessed.delete(idx);
                check.innerHTML = '';
                check.style.background = 'transparent';
                check.style.borderColor = 'rgba(139,92,246,0.4)';
                card.style.opacity = '1';
                card.style.borderColor = 'rgba(139,92,246,0.12)';
            } else {
                skoolProcessed.add(idx);
                check.innerHTML = '✓';
                check.style.background = 'rgba(0,255,136,0.15)';
                check.style.borderColor = 'rgba(0,255,136,0.5)';
                check.style.color = '#00ff88';
                card.style.opacity = '0.5';
                card.style.borderColor = 'rgba(0,255,136,0.15)';
                const msgIds = (card.dataset.msgids || '').split(',').filter(Boolean);
                msgIds.forEach(id => {
                    fetch('/mc/gmail-archive?id=' + encodeURIComponent(id)).catch(() => {});
                });
            }
        }

        function skoolTTS(btn) {
            if (speechSynthesis.speaking) {
                speechSynthesis.cancel();
                if (currentSkoolTTSBtn) currentSkoolTTSBtn.textContent = '🔊';
                if (currentSkoolTTSBtn === btn) { currentSkoolTTSBtn = null; return; }
            }
            const text = btn.dataset.text;
            if (!text) return;
            const utter = new SpeechSynthesisUtterance(text);
            utter.rate = 1.05;
            utter.onend = () => { btn.textContent = '🔊'; currentSkoolTTSBtn = null; };
            btn.textContent = '⏹';
            currentSkoolTTSBtn = btn;
            speechSynthesis.speak(utter);
        }

        function skoolTTSThemes() {
            const btn = document.getElementById('skool-themes-tts-btn');
            if (speechSynthesis.speaking) {
                speechSynthesis.cancel();
                btn.textContent = '🔊 Listen';
                if (currentSkoolTTSBtn === btn) { currentSkoolTTSBtn = null; return; }
            }
            const el = document.getElementById('skool-themes-content');
            if (!el) return;
            const text = el.innerText;
            if (!text) return;
            const utter = new SpeechSynthesisUtterance(text);
            utter.rate = 1.05;
            utter.onend = () => { btn.textContent = '🔊 Listen'; currentSkoolTTSBtn = null; };
            btn.textContent = '⏹ Stop';
            currentSkoolTTSBtn = btn;
            speechSynthesis.speak(utter);
        }

        async function skoolAddTask(subject, source, btn, sourceUrl) {
            btn.disabled = true;
            btn.textContent = '...';
            try {
                const taskName = `Review: ${subject} (${source})`;
                const payload = { name: taskName, priority: 'Medium', role: 'CEO' };
                if (sourceUrl) payload.url = sourceUrl;
                const resp = await fetch('/mc/notion-tasks/create', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                const data = await resp.json();
                btn.textContent = (data.ok || data.id) ? '✅' : '❌';
            } catch (e) {
                btn.textContent = '❌';
            }
        }

        async function skoolLoadConfig() {
            try {
                const resp = await fetch('/mc/skool-config');
                skoolConfigData = await resp.json();
                skoolRenderConfig();
                const authResp = await fetch('/mc/skool-auth');
                const authData = await authResp.json();
                const statusEl = document.getElementById('skool-session-status');
                if (authData.session_ok) {
                    statusEl.textContent = '✅ Logged In';
                    statusEl.style.background = 'rgba(0,255,136,0.12)';
                    statusEl.style.color = '#00ff88';
                } else {
                    statusEl.textContent = '❌ Not Logged In';
                    statusEl.style.background = 'rgba(255,60,60,0.12)';
                    statusEl.style.color = '#ff6b6b';
                }
                const footer = document.getElementById('skool-config-footer');
                if (skoolConfigData.lastRun) {
                    footer.textContent = 'Last scrape: ' + new Date(skoolConfigData.lastRun).toLocaleString();
                } else {
                    footer.textContent = 'No scrapes yet — click Direct Scrape above to start';
                }
            } catch (e) {
                console.error('Skool config load error:', e);
            }
        }

        function skoolRenderConfig() {
            const container = document.getElementById('skool-community-tags');
            const communities = skoolConfigData.communities || [];
            container.innerHTML = communities.map((c, i) => {
                const enabledStyle = c.enabled !== false
                    ? 'background:rgba(139,92,246,0.15);border:1px solid rgba(139,92,246,0.3);color:#b480ff;'
                    : 'background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.12);color:rgba(255,255,255,0.4);';
                return `<span style="${enabledStyle}border-radius:2rem;padding:0.3rem 0.7rem;font-size:0.8rem;display:flex;align-items:center;gap:0.3rem;">
                    📚 ${escH(c.name)}
                    <span onclick="skoolRemoveCommunity(${i})" style="cursor:pointer;color:rgba(255,255,255,0.3);font-size:0.9rem;margin-left:0.2rem;" title="Remove">×</span>
                </span>`;
            }).join('');
        }

        function skoolAddCommunity() {
            const input = document.getElementById('skool-community-input');
            const val = input.value.trim();
            if (!val) return;
            let name = val;
            let url = val;
            const match = val.match(/skool\.com\/([^?#/]+)/);
            if (match) {
                name = match[1].replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
                url = 'https://www.skool.com/' + match[1];
            } else if (!val.includes('skool.com')) {
                url = 'https://www.skool.com/' + val.replace(/\s+/g, '-').toLowerCase();
                name = val;
            }
            skoolConfigData.communities = skoolConfigData.communities || [];
            skoolConfigData.communities.push({ name, url, enabled: true });
            input.value = '';
            skoolRenderConfig();
        }

        function skoolRemoveCommunity(idx) {
            skoolConfigData.communities.splice(idx, 1);
            skoolRenderConfig();
        }

        async function skoolSaveConfig() {
            const btn = document.getElementById('skool-save-btn');
            btn.textContent = 'Saving...';
            btn.disabled = true;
            try {
                const resp = await fetch('/mc/skool-config', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ communities: skoolConfigData.communities })
                });
                const data = await resp.json();
                btn.textContent = data.ok ? '✅ Saved' : '❌ Error';
            } catch (e) {
                btn.textContent = '❌ Failed';
            }
            setTimeout(() => { btn.textContent = 'Save'; btn.disabled = false; }, 2000);
        }

        async function skoolReauth() {
            const btn = document.getElementById('skool-reauth-btn');
            btn.textContent = 'Launching...';
            btn.disabled = true;
            try {
                await fetch('/mc/skool-auth', { method: 'POST' });
                btn.textContent = 'Browser Open';
                setTimeout(async () => {
                    await skoolLoadConfig();
                    btn.textContent = 'Re-auth';
                    btn.disabled = false;
                }, 30000);
            } catch (e) {
                btn.textContent = 'Failed';
                setTimeout(() => { btn.textContent = 'Re-auth'; btn.disabled = false; }, 3000);
            }
        }

        // ── WF2 Reddit Config Panel ─────────────────────────────────────────
        let wf2Subs = [];
        let wf2Kws = [];
        let wf2Loaded = false;

        function toggleWF2Config() {
            const panel = document.getElementById('wf2-config-panel');
            const isVisible = panel.style.display !== 'none';
            panel.style.display = isVisible ? 'none' : 'block';
            if (!isVisible) {
                if (!wf2Loaded) wf2FetchConfig();
                panel.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
        }

        async function wf2FetchConfig() {
            try {
                const resp = await fetch('/mc/wf2-config');
                const data = await resp.json();
                if (data.ok) {
                    wf2Subs = data.subreddits || [];
                    wf2Kws = data.keywords || [];
                    wf2Loaded = true;
                    wf2RenderTags();
                    const footer = document.getElementById('wf2-footer');
                    if (data.last_updated) {
                        const d = new Date(data.last_updated);
                        footer.textContent = 'Last saved: ' + d.toLocaleString() + ' — Changes apply on next WF2 run (every 3h)';
                    }
                } else {
                    wf2ShowStatus('Failed to load config: ' + (data.error || 'unknown'), true);
                }
            } catch(e) {
                wf2ShowStatus('Network error: ' + e.message, true);
            }
        }

        function wf2RenderTags() {
            const subsEl = document.getElementById('wf2-subs-tags');
            const kwsEl = document.getElementById('wf2-kw-tags');
            const countEl = document.getElementById('wf2-kw-count');

            subsEl.innerHTML = wf2Subs.map((s, i) =>
                '<span style="display:inline-flex;align-items:center;gap:0.3rem;background:rgba(0,245,255,0.1);border:1px solid rgba(0,245,255,0.25);color:#00f5ff;border-radius:2rem;padding:0.25rem 0.6rem 0.25rem 0.75rem;font-family:Inter,sans-serif;font-size:0.8rem;">' +
                'r/' + s +
                '<span onclick="wf2RemoveSub(' + i + ')" style="cursor:pointer;opacity:0.6;font-size:0.9rem;line-height:1;" title="Remove">&times;</span>' +
                '</span>'
            ).join('');

            kwsEl.innerHTML = wf2Kws.map((k, i) =>
                '<span style="display:inline-flex;align-items:center;gap:0.3rem;background:rgba(184,41,221,0.1);border:1px solid rgba(184,41,221,0.25);color:#d070ff;border-radius:2rem;padding:0.25rem 0.6rem 0.25rem 0.75rem;font-family:Inter,sans-serif;font-size:0.78rem;">' +
                k +
                '<span onclick="wf2RemoveKw(' + i + ')" style="cursor:pointer;opacity:0.6;font-size:0.9rem;line-height:1;" title="Remove">&times;</span>' +
                '</span>'
            ).join('');

            countEl.textContent = '(' + wf2Kws.length + ')';
        }

        function wf2AddSub() {
            const input = document.getElementById('wf2-sub-input');
            let val = input.value.trim().replace(/^r\//, '').replace(/[^a-zA-Z0-9_]/g, '');
            if (!val) return;
            if (wf2Subs.includes(val)) { wf2ShowStatus('Subreddit already exists', true); return; }
            wf2Subs.push(val);
            input.value = '';
            wf2RenderTags();
        }

        function wf2RemoveSub(idx) {
            wf2Subs.splice(idx, 1);
            wf2RenderTags();
        }

        function wf2AddKw() {
            const input = document.getElementById('wf2-kw-input');
            let val = input.value.trim().toLowerCase();
            if (!val) return;
            if (wf2Kws.includes(val)) { wf2ShowStatus('Keyword already exists', true); return; }
            wf2Kws.push(val);
            input.value = '';
            wf2RenderTags();
        }

        function wf2RemoveKw(idx) {
            wf2Kws.splice(idx, 1);
            wf2RenderTags();
        }

        async function wf2SaveConfig() {
            const btn = document.getElementById('wf2-save-btn');
            const orig = btn.textContent;
            btn.disabled = true;
            btn.textContent = 'Saving...';
            try {
                const resp = await fetch('/mc/wf2-config', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        subreddits: wf2Subs.join(','),
                        keywords: wf2Kws.join(',')
                    })
                });
                const data = await resp.json();
                if (data.ok) {
                    wf2ShowStatus('Saved! ' + wf2Subs.length + ' subreddits, ' + wf2Kws.length + ' keywords. Next run picks up changes automatically.', false);
                    const footer = document.getElementById('wf2-footer');
                    footer.textContent = 'Last saved: ' + new Date(data.updated).toLocaleString() + ' — Changes apply on next WF2 run (every 3h)';
                } else {
                    wf2ShowStatus('Save failed: ' + (data.error || 'unknown'), true);
                }
            } catch(e) {
                wf2ShowStatus('Network error: ' + e.message, true);
            }
            btn.disabled = false;
            btn.textContent = orig;
        }

        function wf2ShowStatus(msg, isError) {
            const el = document.getElementById('wf2-status');
            el.style.display = 'block';
            el.textContent = msg;
            el.style.borderColor = isError ? 'rgba(255,80,80,0.3)' : 'rgba(0,255,136,0.3)';
            el.style.background = isError ? 'rgba(255,80,80,0.08)' : 'rgba(0,255,136,0.08)';
            el.style.color = isError ? '#ff6b6b' : '#00ff88';
            setTimeout(() => { el.style.display = 'none'; }, 5000);
        }

        async function newsRunDigest(telegram = false) {
            const btn = document.getElementById(telegram ? 'news-tg-btn' : 'news-run-btn');
            const origText = btn.textContent;
            btn.disabled = true;
            btn.textContent = 'Scanning...';
            const status = document.getElementById('news-status');
            status.style.display = 'block';
            status.textContent = '📡 Scanning 5 priority senders... this takes 1-2 minutes';
            status.style.borderColor = 'rgba(0,200,255,0.2)';
            status.style.background = 'rgba(0,200,255,0.08)';

            try {
                const url = telegram ? '/mc/newsletters?telegram=1' : '/mc/newsletters';
                const resp = await fetch(url);
                newsData = await resp.json();
                if (newsData.error) {
                    status.textContent = '❌ ' + newsData.error;
                    status.style.borderColor = 'rgba(255,50,50,0.3)';
                    status.style.background = 'rgba(255,50,50,0.08)';
                } else {
                    status.style.display = 'none';
                    newsRender();
                }
            } catch (e) {
                status.textContent = '❌ Failed: ' + e.message;
                status.style.borderColor = 'rgba(255,50,50,0.3)';
                status.style.background = 'rgba(255,50,50,0.08)';
            }
            btn.disabled = false;
            btn.textContent = origText;
        }

        function newsRender() {
            if (!newsData) return;
            const { synergy, senders, total, synergy_count } = newsData;

            // Synergy section
            const synergyEl = document.getElementById('news-synergy');
            if (synergy) {
                synergyEl.style.display = 'block';
                let html = synergy.replace(/🔥 SYNERGY DETECTED: ([^\n]*)/g,
                    '<div style="color:#ff9500; font-weight:700; font-size:0.95rem; margin-top:0.75rem;">🔥 SYNERGY DETECTED: $1</div>');
                html = html.replace(/Sources: ([^\n]*)/g,
                    '<div style="color:rgba(255,255,255,0.5); font-size:0.8rem; font-style:italic;">Sources: $1</div>');
                html = html.replace(/Signal: ([^\n]*)/g,
                    '<div style="color:rgba(255,255,255,0.8); font-size:0.85rem; margin-bottom:0.5rem;">$1</div>');
                html = html.replace(/📈 MARKET PULSE:/g,
                    '<div style="color:#00c8ff; font-weight:700; font-size:0.95rem; margin-top:1rem;">📈 MARKET PULSE:</div>');
                document.getElementById('news-synergy-content').innerHTML = html;
            } else {
                synergyEl.style.display = 'none';
            }

            // Sender cards
            const container = document.getElementById('news-senders');
            if (!senders || senders.length === 0) {
                container.innerHTML = '<div style="text-align:center; color:rgba(255,255,255,0.5); padding:2rem; font-family:Inter,sans-serif;">✅ All caught up — nothing new from any sender.</div>';
                return;
            }

            container.innerHTML = senders.map(sender => {
                const items = sender.newsletters.map(nl => {
                    let summary = nl.summary || '';
                    // Style sections
                    summary = summary.replace(/KEY POINTS:/g, '<span style="color:#00c8ff; font-weight:600;">KEY POINTS:</span>');
                    summary = summary.replace(/LINKS:/g, '<span style="color:#00ff88; font-weight:600;">LINKS:</span>');
                    summary = summary.replace(/SALES OPP:/g, '<span style="color:#ff9500; font-weight:600;">SALES OPP:</span>');
                    // Make markdown links clickable
                    summary = summary.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" style="color:#00c8ff; text-decoration:underline;">$1</a>');
                    summary = summary.replace(/\n/g, '<br>');
                    summary = summary.replace(/• /g, '&nbsp;&nbsp;• ');

                    return `<div style="border-left:3px solid rgba(0,200,255,0.3); padding:0.75rem 1rem; margin:0.5rem 0;">
                        <div style="display:flex; justify-content:space-between; align-items:start; margin-bottom:0.5rem;">
                            <div style="color:#fff; font-weight:600; font-size:0.9rem;">📧 ${escH(nl.subject)}</div>
                            <div style="color:rgba(255,255,255,0.35); font-size:0.7rem; white-space:nowrap; margin-left:0.5rem;">${escH(nl.date)}</div>
                        </div>
                        <div style="color:rgba(255,255,255,0.75); font-size:0.82rem; line-height:1.6;">${summary}</div>
                        <div style="display:flex; gap:0.5rem; margin-top:0.5rem; flex-wrap:wrap;">
                            <button onclick="newsAction('nicole', '${escAttr(nl.subject)}')" style="background:rgba(200,100,255,0.1); border:1px solid rgba(200,100,255,0.25); color:#c864ff; border-radius:0.4rem; padding:0.3rem 0.6rem; cursor:pointer; font-size:0.72rem; font-family:Inter,sans-serif;">
                                👉 Send to Nicole
                            </button>
                            <button onclick="newsAction('task', '${escAttr(nl.subject)}')" style="background:rgba(0,200,255,0.1); border:1px solid rgba(0,200,255,0.25); color:#00c8ff; border-radius:0.4rem; padding:0.3rem 0.6rem; cursor:pointer; font-size:0.72rem; font-family:Inter,sans-serif;">
                                📋 Create Task
                            </button>
                        </div>
                    </div>`;
                }).join('');

                return `<div style="background:rgba(20,20,40,0.6); border:1px solid rgba(255,255,255,0.08); border-radius:1rem; padding:1.25rem; backdrop-filter:blur(12px);">
                    <div style="display:flex; align-items:center; gap:0.5rem; margin-bottom:0.75rem;">
                        <span style="font-size:1.2rem;">${sender.emoji}</span>
                        <h3 style="color:#fff; font-family:Inter,sans-serif; font-size:1rem; margin:0;">${escH(sender.name)}</h3>
                        <span style="background:rgba(0,200,255,0.15); color:#00c8ff; border-radius:1rem; padding:0.15rem 0.6rem; font-size:0.72rem; font-family:Inter,sans-serif; font-weight:600;">${sender.newsletters.length} new</span>
                    </div>
                    ${items}
                </div>`;
            }).join('');

            // Footer
            const footer = document.getElementById('news-footer');
            footer.style.display = 'block';
            let footerText = `📊 ${total} newsletters from ${senders.length} senders`;
            if (synergy_count > 0) footerText += ` | 🔗 ${synergy_count} synergy signal${synergy_count > 1 ? 's' : ''}`;
            footer.textContent = footerText;
        }

        function newsAction(type, subject) {
            const safe = subject.substring(0, 50);
            if (type === 'nicole') {
                alert('Send to Nicole:\\n/nicole review "' + safe + '"\\n\\nCopy this command to Telegram.');
            } else {
                alert('Create Task:\\n/task "Review: ' + safe + '"\\n\\nCopy this command to Telegram.');
            }
        }

        function escH(s) { return s ? String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;') : ''; }
        function escAttr(s) { return s ? String(s).replace(/\\/g,'\\\\').replace(/'/g,"\\'").replace(/"/g,'\\"').substring(0, 60) : ''; }

        function revRender() {
            if (!revData) return;
            const { streams, summary } = revData;

            // Summary cards
            document.getElementById('rev-sum-daily').textContent = revFmt(summary.daily_total);
            document.getElementById('rev-sum-weekly').textContent = revFmt(summary.weekly_total);
            document.getElementById('rev-sum-monthly').textContent = revFmt(summary.monthly_total);
            document.getElementById('rev-sum-yearly').textContent = revFmt(summary.yearly_total);
            document.getElementById('rev-sum-staked').textContent = revFmt(summary.staked_total);

            // Gauge — monthly income vs goal
            const monthlyIncome = revParseDollar(summary.monthly_total);
            const goal = parseInt(localStorage.getItem(REV_GOAL_KEY)) || 10000;
            const pct = goal > 0 ? Math.min(Math.round((monthlyIncome / goal) * 100), 100) : 0;
            const deg = (pct / 100) * 360;
            const color = pct >= 100 ? '#00ff88' : pct >= 50 ? '#00f5ff' : '#b829dd';
            const gaugeEl = document.getElementById('rev-gauge');
            gaugeEl.style.background = `conic-gradient(${color} 0deg, ${color} ${deg}deg, rgba(255,255,255,0.06) ${deg}deg)`;
            document.getElementById('rev-gauge-pct').textContent = pct + '%';
            document.getElementById('rev-gauge-pct').style.color = color;
            document.getElementById('rev-gauge-mrr').textContent = revFmtCurrency(monthlyIncome) + '/mo';
            document.getElementById('rev-goal-display').textContent = revFmtCurrency(goal);

            // Portfolio snapshot
            const projProfit = revParseDollar(summary.projected_profit);
            document.getElementById('rev-proj-profit').textContent = projProfit > 0 ? revFmtCurrency(projProfit) : revFmt(summary.projected_profit);
            const activeStreams = streams.filter(s => s.Status && s.Status.includes('Active')).length;
            document.getElementById('rev-proj-streams').textContent = activeStreams;

            // Avg daily growth
            const growths = streams.map(s => parseFloat(String(s.Daily_Growth || '0').replace('%', ''))).filter(g => g > 0);
            const avgGrowth = growths.length > 0 ? (growths.reduce((a, b) => a + b, 0) / growths.length).toFixed(2) : '0';
            document.getElementById('rev-proj-growth').textContent = avgGrowth + '%';

            // Cash Flow vs Long-Term split
            const cfMonthly = revParseDollar(revData.cashflow_monthly || '$0');
            const ltMonthly = revParseDollar(revData.longterm_monthly || '$0');
            document.getElementById('rev-cashflow-monthly').textContent = revFmtCurrency(cfMonthly);
            document.getElementById('rev-longterm-monthly').textContent = revFmtCurrency(ltMonthly);
            document.getElementById('rev-cashflow-count').textContent = (revData.cashflow_streams || []).length;
            document.getElementById('rev-longterm-count').textContent = (revData.longterm_streams || []).length;

            // Cash Flow progress bar
            const cfPct = goal > 0 ? Math.min(Math.round((cfMonthly / goal) * 100), 100) : 0;
            document.getElementById('rev-cf-progress-bar').style.width = cfPct + '%';
            document.getElementById('rev-cf-progress-label').textContent = revFmtCurrency(cfMonthly) + ' / ' + revFmtCurrency(goal);

            // Bar chart — daily income per stream
            revRenderChart(streams);

            // Streams table
            revRenderStreams(streams);

            // Load GO products for graduation dropdown
            gradFetchProducts();
        }

        function revRenderChart(streams) {
            const chart = document.getElementById('rev-chart');
            const items = streams.filter(s => s.Stream_Name);
            if (items.length === 0) {
                chart.innerHTML = '<div style="display:flex; align-items:center; justify-content:center; width:100%; color:rgba(255,255,255,0.3); font-family:Inter,sans-serif; font-size:0.85rem;">No daily income data</div>';
                return;
            }
            const vals = items.map(s => ({ name: (s.Stream_Name || '').replace(/^(Crypto: |BYTNEX |Bytnex )/i, '').substring(0, 18), value: revParseDollar(s['1_Day']) }));
            const maxVal = Math.max(...vals.map(v => v.value), 1);
            chart.innerHTML = vals.map(v => {
                const heightPct = (v.value / maxVal) * 100;
                const barColor = v.value > 0 ? 'linear-gradient(to top, #00ff88, #00f5ff)' : 'rgba(255,255,255,0.06)';
                return `<div style="flex:1; display:flex; flex-direction:column; align-items:center; gap:0.4rem; min-width:50px;">
                    <span style="color:rgba(255,255,255,0.5); font-size:0.65rem; font-family:Inter,sans-serif;">${v.value > 0 ? revFmtCurrency(v.value) : ''}</span>
                    <div style="width:100%; max-width:60px; height:${Math.max(heightPct, 2)}%; background:${barColor}; border-radius:0.4rem 0.4rem 0 0; min-height:4px; transition:height 0.4s ease;"></div>
                    <span style="color:rgba(255,255,255,0.35); font-size:0.6rem; font-family:Inter,sans-serif; font-weight:500; text-align:center; line-height:1.2; max-width:70px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">${v.name}</span>
                </div>`;
            }).join('');
        }

        function revRenderStreams(streams) {
            const tbody = document.getElementById('rev-streams-tbody');
            const loading = document.getElementById('rev-loading');
            if (streams.length === 0) {
                loading.textContent = 'No active income streams found.';
                loading.style.display = 'block';
                tbody.innerHTML = '';
                return;
            }
            loading.style.display = 'none';

            const tierColors = { 'High': '#00ff88', 'Medium': '#ffaa00', 'New': '#aaa' };

            function esc(s) { const d = document.createElement('div'); d.textContent = s; return d.innerHTML; }

            tbody.innerHTML = streams.map(s => {
                const tierRaw = s['Monitoring_Tier'] || '';
                const tierLabel = tierRaw.replace(/[^\w\s]/g, '').trim();
                const tierColor = tierColors[tierLabel] || '#aaa';
                const isActive = (s.Status || '').includes('Active');
                const statusColor = isActive ? '#00ff88' : '#ff4466';
                const statusBg = isActive ? 'rgba(0,255,136,0.1)' : 'rgba(255,68,102,0.1)';
                return `<tr style="border-bottom:1px solid rgba(255,255,255,0.04);">
                    <td style="padding:0.6rem 0.75rem; color:#fff; font-size:0.8rem; max-width:200px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;" title="${esc(s.Stream_Name || '')}">${esc(s.Stream_Name || '—')}</td>
                    <td style="padding:0.6rem 0.75rem; color:rgba(255,255,255,0.5); font-size:0.8rem; text-align:center;">${esc(s.Source_Platform || '—')}</td>
                    <td style="padding:0.6rem 0.75rem; text-align:center;">
                        <span style="background:${statusBg}; color:${statusColor}; padding:0.15rem 0.55rem; border-radius:1rem; font-size:0.7rem; font-weight:500;">${isActive ? 'Active' : 'Inactive'}</span>
                    </td>
                    <td style="padding:0.6rem 0.75rem; color:#ffaa00; font-size:0.8rem; text-align:right; font-weight:500;">${revFmt(s['Staked_Balance'] || '')}</td>
                    <td style="padding:0.6rem 0.75rem; color:#00ff88; font-size:0.8rem; text-align:right; font-weight:600;">${revFmt(s['1_Day'] || '')}</td>
                    <td style="padding:0.6rem 0.75rem; color:#00f5ff; font-size:0.8rem; text-align:right;">${revFmt(s['30_Days'] || '')}</td>
                    <td style="padding:0.6rem 0.75rem; color:#b829dd; font-size:0.8rem; text-align:right;">${revFmt(s['365_Days'] || '')}</td>
                    <td style="padding:0.6rem 0.75rem; color:#00ff88; font-size:0.8rem; text-align:right; font-weight:600;">${revFmt(s['Projected_Profit'] || '')}</td>
                    <td style="padding:0.6rem 0.75rem; color:rgba(255,255,255,0.6); font-size:0.8rem; text-align:center;">${esc(s['Cumulative_ROI'] || '—')}</td>
                    <td style="padding:0.6rem 0.75rem; text-align:center;">
                        <span style="color:${tierColor}; font-size:0.75rem; font-weight:500;">${tierLabel || '—'}</span>
                    </td>
                    <td style="padding:0.6rem 0.75rem; text-align:center;">
                        ${s.Income_Type === 'Cash Flow'
                            ? '<span style="background:rgba(0,255,136,0.1); color:#00ff88; padding:0.15rem 0.55rem; border-radius:1rem; font-size:0.7rem; font-weight:500;">Cash Flow</span>'
                            : '<span style="background:rgba(0,200,255,0.1); color:#00c8ff; padding:0.15rem 0.55rem; border-radius:1rem; font-size:0.7rem; font-weight:500;">Long-Term</span>'
                        }
                    </td>
                </tr>`;
            }).join('');
        }

        function revEditGoal() {
            const display = document.getElementById('rev-goal-display');
            const input = document.getElementById('rev-goal-input');
            input.value = parseInt(localStorage.getItem(REV_GOAL_KEY)) || 10000;
            display.style.display = 'none';
            input.style.display = 'inline-block';
            input.focus();
            input.select();
        }

        function revSaveGoal() {
            const display = document.getElementById('rev-goal-display');
            const input = document.getElementById('rev-goal-input');
            const val = parseInt(input.value);
            if (!isNaN(val) && val > 0) {
                localStorage.setItem(REV_GOAL_KEY, val);
            }
            display.style.display = 'inline';
            input.style.display = 'none';
            revRender();
        }

        // ── Graduate Product ─────────────────────────────────────────────────
        let gradProducts = [];

        async function gradFetchProducts() {
            try {
                const r = await fetch('/mc/pipeline-products');
                const json = await r.json();
                if (json.ok) {
                    gradProducts = json.products || [];
                    const sel = document.getElementById('grad-product-select');
                    if (gradProducts.length === 0) {
                        sel.innerHTML = '<option value="">No GO products ready to graduate</option>';
                    } else {
                        sel.innerHTML = '<option value="">Select a GO product...</option>' +
                            gradProducts.map((p, i) => `<option value="${i}">${p.Product___Service || p.Product_Service || 'Unknown'} (${p.Source_ID}) — ${p.Price || 'N/A'}</option>`).join('');
                    }
                }
            } catch(e) {
                document.getElementById('grad-product-select').innerHTML = '<option value="">Failed to load products</option>';
            }
        }

        async function gradGraduate() {
            const sel = document.getElementById('grad-product-select');
            const idx = parseInt(sel.value);
            if (isNaN(idx) || !gradProducts[idx]) {
                document.getElementById('grad-status').textContent = 'Please select a product first.';
                document.getElementById('grad-status').style.color = '#ff4466';
                return;
            }
            const p = gradProducts[idx];
            const name = p.Product___Service || p.Product_Service || 'Unknown';
            if (!confirm(`Graduate "${name}" to IncomeOps as Cash Flow?\n\nThis will:\n• Add it to IncomeOps_Monitor\n• Mark it as "Graduated → IncomeOps" in Pipeline`)) return;

            const btn = document.getElementById('grad-btn');
            btn.textContent = 'Graduating...';
            btn.disabled = true;
            try {
                const r = await fetch('/mc/graduate-product', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        source_id: p.Source_ID,
                        product_name: name,
                        price: p.Price || '',
                        row_number: p._row
                    })
                });
                const json = await r.json();
                if (json.ok) {
                    document.getElementById('grad-status').textContent = `✅ ${name} graduated to IncomeOps as Cash Flow!`;
                    document.getElementById('grad-status').style.color = '#00ff88';
                    // Refresh both panels
                    setTimeout(() => { revFetchData(); }, 500);
                } else {
                    document.getElementById('grad-status').textContent = '❌ ' + (json.error || 'Unknown error');
                    document.getElementById('grad-status').style.color = '#ff4466';
                }
            } catch(e) {
                document.getElementById('grad-status').textContent = '❌ Request failed: ' + e.message;
                document.getElementById('grad-status').style.color = '#ff4466';
            }
            btn.textContent = 'Graduate to Cash Flow';
            btn.disabled = false;
        }

        // ── Drive File Browser ───────────────────────────────────────────────
        let driveFilesCache = [];

        async function openDriveInFinder() {
            try { await fetch('/mc/drive-open', { method: 'POST' }); } catch(e) {}
        }

        function toggleDriveBrowser() {
            const browser = document.getElementById('drive-browser');
            const isVisible = browser.style.display !== 'none';
            browser.style.display = isVisible ? 'none' : 'block';
            if (!isVisible && driveFilesCache.length === 0) searchDriveFiles();
        }

        async function searchDriveFiles() {
            const search = document.getElementById('drive-search').value.trim();
            const status = document.getElementById('drive-status');
            const list = document.getElementById('drive-file-list');
            status.textContent = 'Searching...';
            try {
                const url = '/mc/drive-files' + (search ? '?search=' + encodeURIComponent(search) : '');
                const d = await fetch(url).then(r => r.json());
                driveFilesCache = d.files || [];
                status.textContent = driveFilesCache.length + ' document(s) found';
                renderDriveFiles(driveFilesCache);
            } catch(e) {
                status.textContent = 'Error loading files';
                list.innerHTML = '';
            }
        }

        const extIcons = { gsheet:'📊', gdoc:'📝', gslides:'📽️', xlsx:'📊', pdf:'📕', csv:'📋', md:'📄', docx:'📝', txt:'📄' };
        let driveSearchTimer = null;

        function debounceDriveSearch() {
            clearTimeout(driveSearchTimer);
            driveSearchTimer = setTimeout(searchDriveFiles, 300);
        }

        function escHtml(s) {
            return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
        }

        function renderDriveFiles(files) {
            const list = document.getElementById('drive-file-list');
            if (!files.length) { list.innerHTML = '<div style="color:rgba(255,255,255,0.3); font-size:0.7rem; padding:0.5rem;">No files found</div>'; return; }
            list.innerHTML = '';
            files.forEach((f, i) => {
                const icon = extIcons[f.ext] || '📄';
                const date = f.modified ? new Date(f.modified).toLocaleDateString() : '';
                const row = document.createElement('div');
                row.style.cssText = 'display:flex; align-items:center; gap:0.5rem; padding:4px 6px; border-radius:4px; background:rgba(255,255,255,0.02); font-size:0.68rem;';
                row.onmouseover = () => row.style.background = 'rgba(0,245,255,0.06)';
                row.onmouseout = () => row.style.background = 'rgba(255,255,255,0.02)';
                row.innerHTML = '<span>' + icon + '</span>'
                    + '<span style="flex:1; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; color:rgba(255,255,255,0.8);" title="' + escHtml(f.name) + '">' + escHtml(f.name) + '</span>'
                    + '<span style="color:rgba(255,255,255,0.25); font-size:0.6rem; white-space:nowrap;">' + date + '</span>';
                const btn = document.createElement('button');
                btn.textContent = '📋 Copy';
                btn.title = 'Copy to CEO Review';
                btn.style.cssText = 'padding:2px 6px; font-size:0.6rem; background:rgba(16,185,129,0.15); border:1px solid rgba(16,185,129,0.3); border-radius:3px; color:#10b981; cursor:pointer; white-space:nowrap;';
                btn.onclick = () => copyToReview(f.name);
                row.appendChild(btn);
                list.appendChild(row);
            });
        }

        async function copyToReview(filename) {
            const status = document.getElementById('drive-status');
            status.textContent = 'Copying ' + filename + '...';
            try {
                const d = await fetch('/mc/drive-copy', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ file: filename })
                }).then(r => r.json());
                if (d.success) {
                    status.innerHTML = '<span style="color:#10b981;">Copied ' + filename + ' to CEO Review</span>';
                } else {
                    status.innerHTML = '<span style="color:#ef4444;">Error: ' + (d.error || 'Unknown') + '</span>';
                }
            } catch(e) {
                status.innerHTML = '<span style="color:#ef4444;">Copy failed</span>';
            }
            setTimeout(() => { status.textContent = driveFilesCache.length + ' document(s) found'; }, 4000);
        }

        // ── Theme switcher ────────────────────────────────────────────────────
        function setTheme(theme) {
            document.documentElement.setAttribute('data-theme', theme === 'css1' ? '' : theme);
            ['css2','css3','css4','css6'].forEach(t => {
                document.getElementById('theme-' + t).disabled = (theme !== t);
            });
            localStorage.setItem('dwe-theme', theme);
            const dd = document.getElementById('theme-dropdown');
            if (dd) dd.value = theme;
            if (theme === 'css1') startCSS1Bg(); else stopCSS1Bg();
            if (theme === 'css4') startCSS4Bg(); else stopCSS4Bg();
            if (theme === 'css6') startCSS6Bg(); else stopCSS6Bg();
        }
        // Animation frame handles — must be declared before setTheme IIFE runs
        let _css1AnimFrame = null;
        let _css4AnimFrame = null;
        let _css6AnimFrame = null;

        // Restore saved theme on load — always call setTheme so bg starts correctly
        (function() {
            const saved = localStorage.getItem('dwe-theme') || 'css1';
            setTheme(saved);
        })();

        // ── Clock ─────────────────────────────────────────────────────────────
        function updateClock() {
            const now = new Date();
            document.getElementById('date').textContent = now.toLocaleDateString('en-US', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' });
            document.getElementById('clock').textContent = now.toLocaleTimeString('en-US', { hour12: true, hour: 'numeric', minute: '2-digit' });
            const hc = document.getElementById('hud-clock');
            if (hc) hc.textContent = now.toLocaleTimeString('en-US', { hour12: false, hour: '2-digit', minute: '2-digit', second: '2-digit' });
        }
        setInterval(updateClock, 1000);
        updateClock();

        // ── Uptime (server-derived) ────────────────────────────────────────────
        let serverStarted = null;

        // ── Time-ago helper ───────────────────────────────────────────────────
        function timeAgo(dateString) {
            if (!dateString) return '—';
            const diff = Math.floor((Date.now() - new Date(dateString)) / 1000);
            if (diff < 60)  return 'Just now';
            if (diff < 3600) return Math.floor(diff / 60) + ' min ago';
            if (diff < 86400) return Math.floor(diff / 3600) + 'h ago';
            return Math.floor(diff / 86400) + 'd ago';
        }

        // ── Dot helper ────────────────────────────────────────────────────────
        function setDot(id, state) {
            const el = document.getElementById(id);
            if (!el) return;
            el.className = 'pulse-dot' + (state === 'ok' ? '' : state === 'warn' ? ' warning' : state === 'error' ? ' error' : ' offline');
        }

        // ── /mc/status → server uptime + memory ───────────────────────────────
        async function fetchStatus() {
            try {
                const d = await fetch('/mc/status').then(r => r.json());
                serverStarted = Date.now() - d.uptime * 1000;
                document.getElementById('stat-memory').textContent = d.memory + ' MB RAM';
            } catch(e) { console.warn('status fetch failed', e); }
        }

        // ── /dwe/status → Notion progress + metrics (single fetch) ────────────
        async function fetchDWEStats() {
            try {
                const d = await fetch('/dwe/status').then(r => r.json());
                const total = d.maxId || d.total || 0;
                const done  = d.completed || 0;
                const pct   = total > 0 ? Math.round((done / total) * 100) : 0;
                const left  = total - done;

                document.getElementById('prog-total').textContent = total.toLocaleString();
                document.getElementById('prog-done').textContent  = done.toLocaleString();
                document.getElementById('prog-left').textContent  = left.toLocaleString();
                document.getElementById('progress-pct').textContent = pct + '%';
                document.getElementById('stat-inprogress').textContent = (d.inProgress || 0);
                document.getElementById('stat-overdue').textContent = 'Tasks in progress';
                document.getElementById('notion-updated').textContent = 'Updated ' + timeAgo(d.lastUpdated);

                // Progress ring: circumference = 427 (r=68), full = 0 offset, empty = 427
                const offset = 427 - (427 * pct / 100);
                document.getElementById('progress-ring').style.strokeDashoffset = offset;

                // Health dot for Notion
                setDot('dot-notion', total > 0 ? 'ok' : 'warn');
                document.getElementById('health-notion').textContent = total > 0 ? 'Connected' : 'No data';
                document.getElementById('health-notion').className = 'health-status ' + (total > 0 ? 'ok' : 'warning');

                // Pass data to metrics updater (avoids second /dwe/status fetch)
                updateNotionMetrics(d);
            } catch(e) {
                document.getElementById('prog-total').textContent = 'Error';
                setDot('dot-notion', 'error');
            }
        }

        // ── Notion Metrics (uses data from fetchDWEStats, fetches recurring separately) ──
        async function fetchNotionMetrics() {
            // Only fetch recurring tasks — DWE stats are handled by fetchDWEStats above
            try {
                const rc = await fetch('/mc/recurring-tasks').then(r => r.json()).catch(() => ({ daemonActive: false, totalCreated: 0 }));
                // Recurring tasks indicator
                const dot = document.getElementById('recurring-daemon-dot');
                dot.style.background = rc.daemonActive ? '#00ff88' : '#ff4444';
                dot.title = rc.daemonActive ? 'Daemon loaded' : 'Daemon not loaded';
                document.getElementById('recurring-created-count').textContent = rc.totalCreated || 0;
                if (rc.lastRun) {
                    document.getElementById('recurring-last-run').textContent = 'Last: ' + rc.lastRun.split(' ')[0];
                }
                if (rc.taskNames && rc.taskNames.length > 0) {
                    document.getElementById('recurring-task-names').textContent = rc.taskNames.slice(0, 4).join(' · ');
                }
            } catch(e) {
                console.error('Recurring tasks fetch error:', e);
            }
        }

        // Helper: update metrics panel with pre-fetched /dwe/status data
        function updateNotionMetrics(d) {
            try {

                // Key counts
                document.getElementById('nm-inprogress').textContent = d.inProgress || 0;
                document.getElementById('nm-notstarted').textContent = d.notStarted || 0;
                document.getElementById('nm-overdue').textContent = d.overdue || 0;
                document.getElementById('nm-blocked').textContent = d.blocked || 0;

                // Overdue highlight
                const odEl = document.getElementById('nm-overdue');
                if ((d.overdue || 0) > 0) odEl.style.textShadow = '0 0 8px rgba(255,0,170,0.6)';
                else odEl.style.textShadow = 'none';

                // Status distribution bar
                const sc = d.statusCounts || {};
                const total = d.total || 1;
                const statusColors = {
                    'Done': '#00ff88', 'Completed': '#00ff88', 'Complete': '#00ff88', 'Review': '#66ffbb',
                    'In Progress': '#00f5ff', 'In progress': '#00f5ff',
                    'Not started': '#ffa500', 'Not Started': '#ffa500',
                    'Blocked': '#ff4444'
                };
                const defaultColor = '#666';
                let barHtml = '', legendHtml = '';
                const sortedStatuses = Object.entries(sc).sort((a, b) => b[1] - a[1]);
                sortedStatuses.forEach(([name, count]) => {
                    const pct = (count / total * 100).toFixed(1);
                    const color = statusColors[name] || defaultColor;
                    if (parseFloat(pct) > 0.5) {
                        barHtml += '<div style="width:' + pct + '%; background:' + color + '; opacity:0.8;" title="' + name + ': ' + count + '"></div>';
                    }
                    legendHtml += '<span><span style="display:inline-block;width:7px;height:7px;border-radius:2px;background:' + color + ';margin-right:3px;vertical-align:middle;"></span>' + name + ' ' + count + '</span>';
                });
                document.getElementById('nm-status-bar').innerHTML = barHtml;
                document.getElementById('nm-status-legend').innerHTML = legendHtml;

                // Priority breakdown bar
                const pc = d.priorityCounts || {};
                const priorityColors = { 'Critical': '#ff0055', 'High': '#ff6600', 'Medium': '#ffa500', 'Low': '#00ff88', 'None': '#555' };
                let pBarHtml = '', pLegendHtml = '';
                const priorityOrder = ['Critical', 'High', 'Medium', 'Low'];
                priorityOrder.forEach(name => {
                    const count = pc[name] || 0;
                    if (count === 0) return;
                    const pct = (count / total * 100).toFixed(1);
                    const color = priorityColors[name] || defaultColor;
                    pBarHtml += '<div style="width:' + pct + '%; background:' + color + '; opacity:0.8;" title="' + name + ': ' + count + '"></div>';
                    pLegendHtml += '<span><span style="display:inline-block;width:7px;height:7px;border-radius:2px;background:' + color + ';margin-right:3px;vertical-align:middle;"></span>' + name + ' ' + count + '</span>';
                });
                Object.entries(pc).forEach(([name, count]) => {
                    if (priorityOrder.includes(name) || count === 0) return;
                    const pct = (count / total * 100).toFixed(1);
                    pBarHtml += '<div style="width:' + pct + '%; background:#555; opacity:0.8;" title="' + name + ': ' + count + '"></div>';
                    pLegendHtml += '<span><span style="display:inline-block;width:7px;height:7px;border-radius:2px;background:#555;margin-right:3px;vertical-align:middle;"></span>' + name + ' ' + count + '</span>';
                });
                document.getElementById('nm-priority-bar').innerHTML = pBarHtml;
                document.getElementById('nm-priority-legend').innerHTML = pLegendHtml;
            } catch(e) {
                console.error('Notion metrics error:', e);
            }
        }

        // ── /mc/services → external service health ────────────────────────────
        async function fetchServices() {
            try {
                const [d, cr] = await Promise.all([
                    fetch('/mc/services').then(r => r.json()),
                    fetch('/mc/openrouter-credits').then(r => r.json()).catch(() => null)
                ]);
                const list = document.getElementById('services-list');
                list.innerHTML = '';
                d.services.forEach(s => {
                    const ok = s.status === 'online';
                    const dotClass = ok ? '' : ' error';
                    const badgeClass = ok ? 'running' : 'error';

                    // Skip n8n from External Services list — it has its own tile in System Uptime
                    if (s.name.includes('n8n')) {
                        // Still update the System Uptime n8n tile
                        document.getElementById('n8n-status-dot').style.background = ok ? '#00ff88' : '#ff4444';
                        const n8nText = document.getElementById('n8n-status-text');
                        n8nText.textContent = ok ? 'Online' : 'Offline';
                        n8nText.style.color = ok ? '#00ff88' : '#ff4444';
                        setDot('dot-n8n', ok ? 'ok' : 'error');
                        document.getElementById('health-n8n').textContent = ok ? 'Online' : 'Unreachable';
                        document.getElementById('health-n8n').className = 'health-status ' + (ok ? 'ok' : 'error');
                        // Update HUD n8n node
                        const n8nRing = document.getElementById('hud-n8n-ring');
                        const n8nPulse = document.getElementById('hud-n8n-pulse');
                        if (n8nRing) n8nRing.setAttribute('stroke', ok ? 'rgba(255,140,40,0.45)' : 'rgba(255,68,68,0.45)');
                        if (n8nPulse) n8nPulse.setAttribute('fill', ok ? 'rgba(255,140,40,0.8)' : 'rgba(255,68,68,0.8)');
                        return;
                    }

                    // Skip OpenRouter from External Services — now in OpenClaw tile
                    if (s.name === 'OpenRouter') {
                        const orDot = document.getElementById('oc-openrouter-dot');
                        const orCredit = document.getElementById('oc-openrouter-credit');
                        // Update HUD OpenRouter node
                        const orRing = document.getElementById('hud-openrouter-ring');
                        const orPulse = document.getElementById('hud-openrouter-pulse');
                        if (cr && cr.remaining !== undefined && cr.remaining !== null) {
                            const rem = cr.remaining;
                            const creditColor = rem >= 2 ? '#22c55e' : rem >= 0.50 ? '#f59e0b' : '#ef4444';
                            const dotColor = rem >= 2 ? '#00ff88' : rem >= 0.50 ? '#f59e0b' : '#ff4444';
                            orDot.style.background = dotColor;
                            orCredit.textContent = `$${rem.toFixed(2)}`;
                            orCredit.style.color = creditColor;
                            if (orRing) orRing.setAttribute('stroke', ok ? 'rgba(255,200,50,0.4)' : 'rgba(255,68,68,0.4)');
                            if (orPulse) orPulse.setAttribute('fill', ok ? 'rgba(255,200,50,0.8)' : 'rgba(255,68,68,0.8)');
                        } else {
                            orDot.style.background = ok ? '#00ff88' : '#ff4444';
                            orCredit.textContent = ok ? 'Online' : 'Down';
                            orCredit.style.color = ok ? 'rgba(0,255,136,0.6)' : '#ff4444';
                            if (orRing) orRing.setAttribute('stroke', ok ? 'rgba(255,200,50,0.4)' : 'rgba(255,68,68,0.4)');
                            if (orPulse) orPulse.setAttribute('fill', ok ? 'rgba(255,200,50,0.8)' : 'rgba(255,68,68,0.8)');
                        }
                        return;
                    }
                    // Skip OpenClaw Gateway from External Services — now in OpenClaw tile
                    if (s.name === 'OpenClaw Gateway') {
                        const gwDot = document.getElementById('oc-gateway-dot');
                        const gwSt = document.getElementById('oc-gateway-status');
                        gwDot.style.background = ok ? '#00ff88' : '#ff4444';
                        gwSt.textContent = ok ? 'Online' : 'Down';
                        gwSt.style.color = ok ? 'rgba(0,255,136,0.6)' : '#ff4444';
                        return;
                    }

                    // Skip Notion from External Services — has its own tile
                    if (s.name.includes('Notion')) {
                        document.getElementById('notion-status-dot').style.background = ok ? '#00ff88' : '#ff4444';
                        const notionText = document.getElementById('notion-status-text');
                        notionText.textContent = ok ? 'Online' : 'Offline';
                        notionText.style.color = ok ? '#00ff88' : '#ff4444';
                        setDot('dot-notion', ok ? 'ok' : 'error');
                        document.getElementById('health-notion').textContent = ok ? 'Online' : 'Unreachable';
                        document.getElementById('health-notion').className = 'health-status ' + (ok ? 'ok' : 'error');
                        // Update HUD Notion node
                        const notionRing = document.getElementById('hud-notion-ring');
                        const notionPulse = document.getElementById('hud-notion-pulse');
                        if (notionRing) notionRing.setAttribute('stroke', ok ? 'rgba(80,120,255,0.45)' : 'rgba(255,68,68,0.45)');
                        if (notionPulse) notionPulse.setAttribute('fill', ok ? 'rgba(80,120,255,0.8)' : 'rgba(255,68,68,0.8)');
                        return;
                    }
                    // Skip Ollama from External Services — now in Mac mini tile
                    if (s.name.includes('Ollama')) {
                        document.getElementById('mac-ollama-dot').style.background = ok ? '#00ff88' : '#ff4444';
                        const olSt = document.getElementById('mac-ollama-status');
                        olSt.textContent = ok ? 'Running' : 'Down';
                        olSt.style.color = ok ? 'rgba(0,255,136,0.6)' : '#ff4444';
                        return;
                    }
                    // Skip Pinecone from External Services — has its own tile
                    if (s.name.includes('Pinecone')) {
                        document.getElementById('pinecone-status-dot').style.background = ok ? '#00ff88' : '#ff4444';
                        const pcText = document.getElementById('pinecone-status-text');
                        pcText.textContent = ok ? 'Online' : 'Offline';
                        pcText.style.color = ok ? '#00ff88' : '#ff4444';
                        // Update HUD Brain node
                        const brainRing = document.getElementById('hud-brain-ring');
                        const brainPulse = document.getElementById('hud-brain-pulse');
                        if (brainRing) brainRing.setAttribute('stroke', ok ? 'rgba(255,80,200,0.4)' : 'rgba(255,68,68,0.4)');
                        if (brainPulse) brainPulse.setAttribute('fill', ok ? 'rgba(255,80,200,0.8)' : 'rgba(255,68,68,0.8)');
                        return;
                    }

                    list.innerHTML += `<div class="service-item">
                        <span class="pulse-dot${dotClass}"></span>
                        <span class="label">${s.name}</span>
                        <span class="badge ${badgeClass}">${ok ? 'OK' : 'Down'}</span>
                    </div>`;
                });
            } catch(e) {
                document.getElementById('services-list').innerHTML = '<div class="service-item"><span class="pulse-dot error"></span><span>Failed to load</span></div>';
            }
        }

        // ── /mc/launchd → daemon status ───────────────────────────────────────
        async function fetchLaunchd() {
            try {
                const d = await fetch('/mc/launchd').then(r => r.json());
                const list = document.getElementById('launchd-list');
                list.innerHTML = '';

                // Update health dots for core services + tile daemons
                d.services.forEach(s => {
                    if (s.id === 'ai.openclaw.relay-daemon') {
                        const ok = s.status === 'running';
                        setDot('dot-relay', ok ? 'ok' : 'error');
                        document.getElementById('health-relay').textContent = ok ? 'Running' : 'Down';
                        document.getElementById('health-relay').className = 'health-status ' + (ok ? 'ok' : 'error');
                        // Also update OpenClaw tile
                        document.getElementById('oc-relay-dot').style.background = ok ? '#00ff88' : '#ff4444';
                        const rlSt = document.getElementById('oc-relay-status');
                        rlSt.textContent = ok ? 'Running' : 'Down';
                        rlSt.style.color = ok ? 'rgba(0,255,136,0.6)' : '#ff4444';
                        // HUD center relay ring + pulse
                        const relayRing = document.getElementById('hud-relay-ring');
                        const relayPulse = document.getElementById('hud-relay-pulse');
                        if (relayRing) relayRing.setAttribute('stroke', ok ? 'rgba(0,255,136,0.6)' : 'rgba(255,68,68,0.6)');
                        if (relayPulse) relayPulse.setAttribute('fill', ok ? 'rgba(0,255,136,0.5)' : 'rgba(255,68,68,0.5)');
                    }
                    // OpenClaw Gateway daemon → OpenClaw tile
                    if (s.id === 'ai.openclaw.gateway') {
                        const ok = s.status === 'running';
                        document.getElementById('oc-gateway-dot').style.background = ok ? '#00ff88' : '#ff4444';
                        const gwSt = document.getElementById('oc-gateway-status');
                        gwSt.textContent = ok ? 'Running' : 'Down';
                        gwSt.style.color = ok ? 'rgba(0,255,136,0.6)' : '#ff4444';
                    }
                    // ── HUD daemon updates (all groups) ──
                    const hudMap = {
                        'ai.openclaw.gateway':       { dot: 'hud-core-gateway-dot',   st: 'hud-core-gateway-st' },
                        'ai.openclaw.relay-daemon':   { dot: 'hud-core-relay-dot',     st: 'hud-core-relay-st' },
                        'com.missioncontrol.server':  { dot: 'hud-core-mc-dot',        st: 'hud-core-mc-st' },
                        'ai.dwe.anita-email-batch':   { dot: 'hud-email-batch-dot',    st: 'hud-email-batch-st' },
                        'ai.dwe.anita-notion-triage': { dot: 'hud-notion-triage-dot',  st: 'hud-notion-triage-st' },
                        'ai.dwe.morning-digest':      { dot: 'hud-morning-digest-dot', st: 'hud-morning-digest-st' },
                        'ai.dwe.seed-watcher':        { dot: 'hud-seed-watcher-dot',   st: 'hud-seed-watcher-st' },
                        'ai.dwe.notion-sync':         { dot: 'hud-notion-sync-dot',    st: 'hud-notion-sync-st' },
                        'ai.dwe.brain-trainer':       { dot: 'hud-brain-trainer-dot',  st: 'hud-brain-trainer-st' },
                        'ai.dwe.nightly-review':      { dot: 'hud-nightly-review-dot', st: 'hud-nightly-review-st' },
                        'ai.dwe.memory-decay':        { dot: 'hud-memory-decay-dot',   st: 'hud-memory-decay-st' },
                        'ai.dwe.health-monitor':      { dot: 'hud-health-monitor-dot', st: 'hud-health-monitor-st' },
                        'ai.dwe.anomaly-check':       { dot: 'hud-anomaly-check-dot',  st: 'hud-anomaly-check-st' },
                        'ai.dwe.ralphy-monitor':      { dot: 'hud-ralphy-monitor-dot', st: 'hud-ralphy-monitor-st' },
                        'ai.dwe.clawhub-check':       { dot: 'hud-clawhub-check-dot',  st: 'hud-clawhub-check-st' },
                        'ai.dwe.soul-calibration':    { dot: 'hud-soul-calibration-dot',st: 'hud-soul-calibration-st' },
                        'ai.dwe.night-mode-heartbeat':{ dot: 'hud-night-mode-dot',     st: 'hud-night-mode-st' },
                        'ai.dwe.openclaw-backup':     { dot: 'hud-oc-backup-dot',      st: 'hud-oc-backup-st' },
                    };
                    if (hudMap[s.id]) {
                        const h = hudMap[s.id];
                        const ok = s.status === 'running' || (s.scheduled && s.status === 'waiting');
                        const color = ok ? '#00ff88' : '#ff4444';
                        const label = s.status === 'running' ? '▶ RUN' : s.status === 'waiting' ? '⏸ WAIT' : '✕ DOWN';
                        const el = document.getElementById(h.dot);
                        if (el) { el.style.background = color; el.style.boxShadow = `0 0 6px ${color}`; }
                        const stEl = document.getElementById(h.st);
                        if (stEl) { stEl.textContent = label; stEl.style.color = ok ? 'rgba(0,255,136,0.5)' : '#ff4444'; }
                    }
                    // OpenClaw Backup → OpenClaw tile
                    if (s.id === 'ai.dwe.openclaw-backup') {
                        const ok = s.status === 'running' || (s.scheduled && s.status === 'waiting');
                        document.getElementById('oc-backup-dot').style.background = ok ? '#00ff88' : '#ff4444';
                        const bkSt = document.getElementById('oc-backup-status');
                        bkSt.textContent = s.status === 'running' ? 'Running' : s.status === 'waiting' ? 'Scheduled' : 'Down';
                        bkSt.style.color = ok ? 'rgba(0,255,136,0.6)' : '#ff4444';
                    }
                    // ClawHub Check → OpenClaw tile
                    if (s.id === 'ai.dwe.clawhub-check') {
                        const ok = s.status === 'running' || (s.scheduled && s.status === 'waiting');
                        document.getElementById('oc-clawhub-dot').style.background = ok ? '#00ff88' : '#ff4444';
                        const chSt = document.getElementById('oc-clawhub-status');
                        chSt.textContent = s.status === 'running' ? 'Running' : s.status === 'waiting' ? 'Scheduled' : 'Down';
                        chSt.style.color = ok ? 'rgba(0,255,136,0.6)' : '#ff4444';
                    }
                    // Notion Triage daemon → Notion tile
                    if (s.id === 'ai.dwe.anita-notion-triage') {
                        const ok = s.status === 'running' || (s.scheduled && s.status === 'waiting');
                        const color = ok ? '#00ff88' : '#ff4444';
                        document.getElementById('notion-triage-dot').style.background = color;
                        const st = document.getElementById('notion-triage-status');
                        st.textContent = s.status === 'running' ? 'Running' : s.status === 'waiting' ? 'Scheduled' : 'Down';
                        st.style.color = ok ? 'rgba(0,255,136,0.6)' : '#ff4444';
                    }
                    // Notion Sync daemon → Notion tile
                    if (s.id === 'ai.dwe.notion-sync') {
                        const ok = s.status === 'running';
                        const color = ok ? '#00ff88' : '#ff4444';
                        document.getElementById('notion-sync-dot').style.background = color;
                        const st = document.getElementById('notion-sync-status');
                        st.textContent = ok ? 'Running' : 'Down';
                        st.style.color = ok ? 'rgba(0,255,136,0.6)' : '#ff4444';
                    }
                    // Brain/Pinecone daemons → Pinecone tile
                    const pcDaemons = {
                        'ai.dwe.seed-watcher':   { dot: 'pc-seed-watcher-dot',    status: 'pc-seed-watcher-status' },
                        'ai.dwe.brain-trainer':  { dot: 'pc-brain-trainer-dot',    status: 'pc-brain-trainer-status' },
                        'ai.dwe.nightly-review': { dot: 'pc-nightly-review-dot',   status: 'pc-nightly-review-status' },
                        'ai.dwe.memory-decay':   { dot: 'pc-memory-decay-dot',     status: 'pc-memory-decay-status' },
                    };
                    if (pcDaemons[s.id]) {
                        const pd = pcDaemons[s.id];
                        const ok = s.status === 'running' || (s.scheduled && s.status === 'waiting');
                        const color = ok ? '#00ff88' : '#ff4444';
                        document.getElementById(pd.dot).style.background = color;
                        const st = document.getElementById(pd.status);
                        st.textContent = s.status === 'running' ? 'Running' : s.status === 'waiting' ? 'Scheduled' : 'Down';
                        st.style.color = ok ? 'rgba(0,255,136,0.6)' : '#ff4444';
                    }
                });

                // Update agents gateway status
                const gatewayRunning = d.services.some(s => s.id === 'ai.openclaw.gateway' && s.status === 'running');
                document.getElementById('stat-gateway').textContent = gatewayRunning ? 'Gateway online' : 'Gateway offline';

                // ── Ecosystem button color based on worst-case HUD daemon status ──
                const ecoBtn = document.getElementById('ecosystem-btn');
                if (ecoBtn) {
                    const ecoDaemons = new Set(Object.keys(hudMap));
                    let worstLevel = 0; // 0=green, 1=yellow, 2=red
                    d.services.forEach(s => {
                        if (!ecoDaemons.has(s.id)) return;
                        const ok = s.status === 'running' || (s.scheduled && s.status === 'waiting');
                        if (!ok) worstLevel = Math.max(worstLevel, s.status === 'error' ? 2 : 1);
                    });
                    const colors = [
                        { bg: 'rgba(0,255,136,0.15)', border: 'rgba(0,255,136,0.35)', text: '#00ff88', hoverBg: 'rgba(0,255,136,0.28)' },
                        { bg: 'rgba(255,149,0,0.15)', border: 'rgba(255,149,0,0.35)', text: '#ff9500', hoverBg: 'rgba(255,149,0,0.28)' },
                        { bg: 'rgba(255,68,68,0.15)', border: 'rgba(255,68,68,0.35)', text: '#ff4444', hoverBg: 'rgba(255,68,68,0.28)' },
                    ];
                    const c = colors[worstLevel];
                    ecoBtn.style.background = c.bg;
                    ecoBtn.style.borderColor = c.border;
                    ecoBtn.style.color = c.text;
                    ecoBtn.onmouseover = () => ecoBtn.style.background = c.hoverBg;
                    ecoBtn.onmouseout = () => ecoBtn.style.background = c.bg;
                }
            } catch(e) {
                document.getElementById('launchd-list').innerHTML = '<div class="service-item"><span class="pulse-dot error"></span><span>Failed to load</span></div>';
            }
        }

        // ── Revenue & Pipeline tile ──────────────────────────────────────────
        async function fetchRevenuePipeline() {
            let failures = 0;
            // Row 1: Revenue
            try {
                const [incRes, mqtRes] = await Promise.all([
                    fetch('/mc/income-ops').then(r => r.json()).catch(() => null),
                    fetch('/mc/mqt-price').then(r => r.json()).catch(() => null)
                ]);
                if (incRes && incRes.ok) {
                    const s = incRes.summary || {};
                    document.getElementById('rev-total').textContent = s.monthly_total || '$0';
                    document.getElementById('rev-label').textContent = (incRes.streams?.length || 0) + ' streams · monthly';
                    document.getElementById('rev-cashflow').textContent = (incRes.cashflow_monthly || '$0') + '/mo';
                    document.getElementById('rev-longterm').textContent = (incRes.longterm_monthly || '$0') + '/mo';
                    // Row 2: Breakdown
                    document.getElementById('rev-daily').textContent = s.daily_total || '$0';
                    document.getElementById('rev-weekly').textContent = s.weekly_total || '$0';
                    document.getElementById('rev-yearly').textContent = s.yearly_total || '$0';
                    document.getElementById('rev-staked').textContent = s.staked_total || '$0';
                    // Row 2: Streams
                    const streams = incRes.streams || [];
                    document.getElementById('rev-stream-count').textContent = streams.length;
                    const cfCount = (incRes.cashflow_streams || []).length;
                    const ltCount = (incRes.longterm_streams || []).length;
                    document.getElementById('rev-streams-list').innerHTML =
                        `<div style="display:flex;justify-content:space-between;font-size:0.6rem;">
                            <span style="color:rgba(255,255,255,0.4);">Cash Flow</span>
                            <span style="color:rgba(0,255,136,0.6);font-family:monospace;">${cfCount}</span>
                        </div>
                        <div style="display:flex;justify-content:space-between;font-size:0.6rem;">
                            <span style="color:rgba(255,255,255,0.4);">Long-term</span>
                            <span style="color:rgba(0,255,136,0.6);font-family:monospace;">${ltCount}</span>
                        </div>`;
                    // Row 2: Projected Profit
                    const profitEl = document.getElementById('rev-profit');
                    const profit = s.projected_profit || '$0';
                    profitEl.textContent = profit;
                    profitEl.style.color = profit.startsWith('-') ? '#ff4444' : '#00ff88';
                } else { failures++; }
                if (mqtRes && mqtRes.ok) {
                    document.getElementById('rev-mqt').textContent = '$' + Number(mqtRes.price).toFixed(2);
                }
            } catch(e) { failures++;
                document.getElementById('rev-total').textContent = '—';
            }
            // Row 1: Opportunities
            try {
                const d = await fetch('/mc/cso').then(r => r.json());
                document.getElementById('opp-count').textContent = d.count || 0;
                document.getElementById('opp-label').textContent = 'active';
                const list = document.getElementById('opp-list');
                if (d.opportunities && d.opportunities.length > 0) {
                    list.innerHTML = d.opportunities.slice(0, 5).map(o =>
                        `<div style="display:flex;justify-content:space-between;font-size:0.6rem;">
                            <span style="color:rgba(255,255,255,0.45);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:65%;">${o.name}</span>
                            <span style="color:rgba(0,212,255,0.6);font-family:monospace;flex-shrink:0;">${o.status}</span>
                        </div>`
                    ).join('');
                } else {
                    list.innerHTML = '<div style="font-size:0.6rem;color:rgba(255,255,255,0.25);">No active opportunities</div>';
                }
            } catch(e) { failures++;
                document.getElementById('opp-count').textContent = '—';
                document.getElementById('opp-list').innerHTML = '<div style="font-size:0.6rem;color:#ff4444;">Failed to load</div>';
            }
            // Row 1: Funnels
            try {
                const d = await fetch('/mc/prospects/stats?pipeline=dwe-marketing').then(r => r.json());
                if (d.ok) {
                    document.getElementById('funnel-value').textContent = d.pipeline_value || '$0';
                    document.getElementById('funnel-label').textContent = d.total + ' prospects · pipeline value';
                    const stages = d.stages || {};
                    const activeStages = Object.entries(stages).filter(([,v]) => v > 0);
                    const stats = document.getElementById('funnel-stats');
                    if (activeStages.length > 0) {
                        stats.innerHTML = activeStages.map(([name, count]) =>
                            `<div style="display:flex;justify-content:space-between;font-size:0.6rem;">
                                <span style="color:rgba(255,255,255,0.4);">${name}</span>
                                <span style="color:rgba(255,149,0,0.6);font-family:monospace;">${count}</span>
                            </div>`
                        ).join('');
                    } else {
                        stats.innerHTML = '<div style="font-size:0.6rem;color:rgba(255,255,255,0.25);">No prospects yet</div>';
                    }
                } else failures++;
            } catch(e) { failures++;
                document.getElementById('funnel-value').textContent = '—';
                document.getElementById('funnel-stats').innerHTML = '<div style="font-size:0.6rem;color:#ff4444;">Failed to load</div>';
            }
            // Status-color the Revenue button
            const revBtn = document.getElementById('revenue-btn');
            if (revBtn) {
                const level = failures >= 2 ? 2 : failures >= 1 ? 1 : 0;
                const colors = [
                    { bg: 'rgba(0,255,136,0.15)', border: 'rgba(0,255,136,0.35)', text: '#00ff88', hoverBg: 'rgba(0,255,136,0.28)' },
                    { bg: 'rgba(255,149,0,0.15)', border: 'rgba(255,149,0,0.35)', text: '#ff9500', hoverBg: 'rgba(255,149,0,0.28)' },
                    { bg: 'rgba(255,68,68,0.15)', border: 'rgba(255,68,68,0.35)', text: '#ff4444', hoverBg: 'rgba(255,68,68,0.28)' },
                ];
                const c = colors[level];
                revBtn.style.background = c.bg;
                revBtn.style.borderColor = c.border;
                revBtn.style.color = c.text;
                revBtn.onmouseover = () => revBtn.style.background = c.hoverBg;
                revBtn.onmouseout = () => revBtn.style.background = c.bg;
            }
        }

        // ── /mc/crons → cron jobs ─────────────────────────────────────────────
        async function fetchCrons() {
            try {
                const d = await fetch('/mc/crons').then(r => r.json());
                const list = document.getElementById('crons-list');
                list.innerHTML = '';
                if (d.crons.length === 0) {
                    list.innerHTML = '<div class="hud-row"><span class="hud-dot" style="background:#555;"></span><span class="hud-name">No cron jobs</span></div>';
                    return;
                }
                d.crons.forEach(c => {
                    // Constitution Monitor cron → OpenClaw tile
                    if (c.command === 'CONSTITUTION_MONITOR') {
                        document.getElementById('oc-constitution-dot').style.background = '#00ff88';
                        const cSt = document.getElementById('oc-constitution-status');
                        cSt.textContent = c.nextRun || 'Active';
                        cSt.style.color = 'rgba(0,255,136,0.6)';
                    }
                    list.innerHTML += `<div class="hud-row">
                        <span class="hud-dot" style="background:#00d4ff;box-shadow:0 0 4px #00d4ff;"></span>
                        <span class="hud-name">${c.id}</span>
                        <span class="hud-st">${c.nextRun}</span>
                    </div>`;
                });
            } catch(e) {
                document.getElementById('crons-list').innerHTML = '<div class="hud-row"><span class="hud-dot" style="background:#ff4444;box-shadow:0 0 4px #ff4444;"></span><span class="hud-name">Failed to load</span></div>';
            }
        }

        // ── /mc/agents → agent count ──────────────────────────────────────────
        async function fetchAgents() {
            try {
                const d = await fetch('/mc/agents').then(r => r.json());
                document.getElementById('stat-agents').textContent = d.count;
                document.getElementById('stat-gateway').textContent = d.gatewayUp ? 'Gateway online' : 'Gateway offline';
            } catch(e) {}
        }

        // ── /mc/brain → DWE Brain score ───────────────────────────────────────
        async function fetchBrain() {
            try {
                const d = await fetch('/mc/brain').then(r => r.json());

                // Primary metric: explored pages / total (explored = seeded into Pinecone)
                const explored = d.exploredPages || 0;
                // totalNotionPages may be unknown; always ensure denominator >= explored
                const totalKnown = d.totalNotionPages
                    ? Math.max(d.totalNotionPages, explored)
                    : Math.max(1000, Math.ceil(explored / 500) * 500);
                const totalLabel = d.totalNotionPages ? totalKnown : `~${totalKnown}`;
                const exploredPct = totalKnown > 0 ? Math.round((explored / totalKnown) * 100) : 0;
                document.getElementById('stat-brain-score').textContent = exploredPct + '%';
                document.getElementById('brain-bar-fill').style.width = Math.min(exploredPct, 100) + '%';
                document.getElementById('stat-brain-pages').textContent = `${explored} / ${totalLabel} pages`;

                // Detail line
                const runningTag = d.isRunning ? ' · ⚡ Training now' : '';
                const validatedTag = d.pagesValidated > 0 ? ` · ${d.pagesValidated} confirmed` : '';
                const pendingTag = d.pendingValidation > 0 ? ` · ${d.pendingValidation} verifying` : '';
                const sweepTag = `Sweep #${d.sweepNum || 1}`;
                const qaTag = `${d.passed}/${d.total} Q&A`;
                document.getElementById('stat-brain-detail').textContent = `${sweepTag} · ${qaTag}${validatedTag}${pendingTag}${runningTag}`;

                // Pinecone index + queue info
                try {
                    const m = await fetch('/mc/migration').then(r => r.json());
                    document.getElementById('stat-brain-pinecone-vectors').textContent = m.v3Vectors !== null ? m.v3Vectors.toLocaleString() + ' vectors' : '—';
                    const queueEl = document.getElementById('stat-brain-queue');
                    if (m.queueRemaining > 0) {
                        queueEl.textContent = `Seed queue: ${m.queueRemaining} files pending`;
                        queueEl.style.color = '#ffaa00';
                    } else {
                        queueEl.textContent = 'Seed queue: clear';
                        queueEl.style.color = 'rgba(0,255,136,0.5)';
                    }
                } catch(e2) {}

                // Auto-start polling if trainer is running and we're not already polling
                if (d.isRunning && !brainPollTimer) startBrainPolling('🟢 Running');
                // Stop polling if process finished
                if (!d.isRunning && brainPollTimer) {
                    clearInterval(brainPollTimer);
                    brainPollTimer = null;
                    document.getElementById('brain-btn-run').textContent = 'Run Now';
                }
            } catch(e) {}
        }

        // ── Pinecone Migration Status (banner — auto-hides when complete) ───
        async function fetchMigration() {
            try {
                const d = await fetch('/mc/migration').then(r => r.json());
                const tile = document.getElementById('migration-tile');

                if (d.complete) {
                    tile.style.display = 'none';
                    return;
                }

                // Show banner if migration has any progress
                if (d.isRunning || d.reseedProcessed > 0 || (d.queueRemaining && d.queueRemaining > 0)) {
                    tile.style.display = 'flex';
                }

                const pct = d.reseedTotal > 0 ? Math.round((d.reseedProcessed / d.reseedTotal) * 100) : 0;
                document.getElementById('migration-pct').textContent = pct + '%';
                document.getElementById('migration-bar').style.width = Math.min(pct, 100) + '%';

                const queueTag = d.queueRemaining > 0 ? ` · ${d.queueRemaining} in queue` : '';
                document.getElementById('migration-files').textContent = `${d.reseedProcessed} / ${d.reseedTotal} files queued${queueTag}`;
                document.getElementById('migration-vectors').textContent = d.v3Vectors !== null ? `${d.v3Vectors.toLocaleString()} vectors in v3` : '—';

                if (d.isRunning) {
                    document.getElementById('migration-status').textContent = 'RE-SEEDING...';
                    document.getElementById('migration-status').style.color = '#ffaa00';
                } else if (d.queueRemaining > 0) {
                    document.getElementById('migration-status').textContent = `INGESTING (${d.queueRemaining} remaining)`;
                    document.getElementById('migration-status').style.color = '#ffaa00';
                } else {
                    document.getElementById('migration-status').textContent = 'PAUSED';
                    document.getElementById('migration-status').style.color = 'rgba(255,255,255,0.5)';
                }
            } catch(e) {}
        }

        // ── Brain control buttons ──────────────────────────────────────────────
        let brainLogsVisible = false;
        function brainToggleLogs() {
            const panel = document.getElementById('brain-log-panel');
            brainLogsVisible = !brainLogsVisible;
            panel.style.display = brainLogsVisible ? 'block' : 'none';
            document.getElementById('brain-btn-logs').textContent = brainLogsVisible ? 'Hide' : 'Logs';
            if (brainLogsVisible) brainLoadLogs();
        }
        async function brainLoadLogs() {
            try {
                const d = await fetch('/mc/brain').then(r => r.json());
                const panel = document.getElementById('brain-log-panel');
                panel.textContent = (d.lastLines || []).join('\n') || 'No logs yet.';
                panel.scrollTop = panel.scrollHeight;
            } catch(e) {}
        }
        let brainPollTimer = null;
        function startBrainPolling(label) {
            // Poll every 4s for up to 3 minutes, updating tile live
            let ticks = 0;
            const max = 45; // 45 × 4s = 3 min
            if (brainPollTimer) clearInterval(brainPollTimer);
            brainPollTimer = setInterval(async () => {
                await fetchBrain();
                if (brainLogsVisible) brainLoadLogs();
                ticks++;
                const btn = document.getElementById('brain-btn-run');
                const dots = '.'.repeat((ticks % 3) + 1);
                btn.textContent = `${label}${dots}`;
                if (ticks >= max) {
                    clearInterval(brainPollTimer);
                    brainPollTimer = null;
                    btn.textContent = 'Run Now';
                }
            }, 4000);
        }
        async function brainRunNow() {
            const btn = document.getElementById('brain-btn-run');
            btn.textContent = '⏳ Starting';
            try {
                const d = await fetch('/mc/brain-run', { method: 'POST' }).then(r => r.json());
                if (d.ok) {
                    btn.textContent = '🟢 Running.';
                    startBrainPolling('🟢 Running');
                } else {
                    btn.textContent = '❌ Error';
                    setTimeout(() => { btn.textContent = 'Run Now'; }, 3000);
                }
            } catch(e) {
                btn.textContent = '❌ Error';
                setTimeout(() => { btn.textContent = 'Run Now'; }, 3000);
            }
        }
        async function brainRestart() {
            const btn = document.getElementById('brain-btn-restart');
            btn.textContent = '⏳';
            try {
                const d = await fetch('/mc/brain-restart', { method: 'POST' }).then(r => r.json());
                if (d.ok) {
                    btn.textContent = '✅ Rebooted';
                    startBrainPolling('🟢 Running');
                } else {
                    btn.textContent = '❌ Error';
                }
            } catch(e) { btn.textContent = '❌ Error'; }
            setTimeout(() => { btn.textContent = 'Reboot'; }, 4000);
        }

        async function restartGateway() {
            const btn = document.getElementById('gateway-restart-btn');
            btn.textContent = '⏳';
            try {
                const d = await fetch('/mc/gateway-restart', { method: 'POST' }).then(r => r.json());
                if (d.ok) {
                    btn.textContent = '✅ Restarted';
                } else {
                    btn.textContent = '❌ Error';
                }
            } catch(e) {
                btn.textContent = '❌ Error';
            }
            setTimeout(() => { btn.textContent = 'Restart'; }, 4000);
        }

        // ── OpenClaw Version Management ──────────────────────────────────────
        async function fetchOpenclawVersion() {
            try {
                const d = await fetch('/mc/openclaw-version').then(r => r.json());
                if (d.ok) {
                    const badge = document.getElementById('oc-version-badge');
                    badge.textContent = 'v' + d.currentVersion;
                    if (d.updateAvailable) {
                        badge.style.background = 'rgba(255,170,0,0.2)';
                        badge.style.color = '#ffaa00';
                        badge.textContent = 'v' + d.currentVersion + ' → ' + d.latestVersion;
                    } else {
                        badge.style.background = 'rgba(0,255,136,0.1)';
                        badge.style.color = 'rgba(0,255,136,0.6)';
                    }
                }
            } catch(e) { /* silent */ }
        }

        function showUpdateBanner(data) {
            const banner = document.getElementById('oc-update-banner');
            document.getElementById('oc-banner-current').textContent = data.currentVersion;
            document.getElementById('oc-banner-target').textContent = data.latestVersion;
            if (data.releaseNotes) {
                document.getElementById('oc-banner-notes').textContent = '— ' + data.releaseNotes;
            }
            if (data.dweImpact) {
                document.getElementById('oc-banner-impact').textContent = 'DWE Impact: ' + data.dweImpact;
            }
            if (data.releaseUrl) {
                document.getElementById('oc-banner-link').href = data.releaseUrl;
            }
            banner.style.display = 'flex';
        }

        function dismissUpdateBanner() {
            document.getElementById('oc-update-banner').style.display = 'none';
        }

        async function checkOpenclawUpdate() {
            const btn = document.getElementById('oc-update-check-btn');
            btn.textContent = '⏳';
            try {
                const d = await fetch('/mc/openclaw-update-check', { method: 'POST' }).then(r => r.json());
                if (d.ok) {
                    const badge = document.getElementById('oc-version-badge');
                    badge.textContent = 'v' + d.currentVersion;
                    if (d.updateAvailable) {
                        badge.style.background = 'rgba(255,170,0,0.2)';
                        badge.style.color = '#ffaa00';
                        badge.textContent = 'v' + d.currentVersion + ' → ' + d.latestVersion;
                        btn.textContent = '🆕 Update!';
                        showUpdateBanner(d);
                    } else {
                        badge.style.background = 'rgba(0,255,136,0.1)';
                        badge.style.color = 'rgba(0,255,136,0.6)';
                        btn.textContent = '✅ Latest';
                    }
                } else {
                    btn.textContent = '❌ Error';
                }
            } catch(e) {
                btn.textContent = '❌ Error';
            }
            setTimeout(() => { btn.textContent = 'Check Updates'; }, 5000);
        }

        // ── Open System Settings ─────────────────────────────────────────
        function openSystemSettings() {
            fetch('/mc/open-settings', { method: 'POST' });
        }

        // ── Open Terminal ─────────────────────────────────────────────────
        function openTerminal() {
            fetch('/mc/open-terminal', { method: 'POST' });
        }

        // ── n8n Workflow Summary (compact — detail page at /n8n-workflows) ──
        async function fetchN8nWorkflows() {
            try {
                const d = await fetch('/mc/n8n-workflows').then(r => r.json());
                const s = d.summary || {};
                const chips = document.getElementById('n8n-wf-chips');
                if (chips) {
                    chips.innerHTML = `
                        <span class="n8n-chip total">${s.total || 0} total</span>
                        <span class="n8n-chip active">${s.active || 0} active</span>
                        <span class="n8n-chip inactive">${s.inactive || 0} inactive</span>
                    `;
                }
                // Render Strategic Pipeline workflow tiles
                const spGroup = (d.groups || []).find(g => g.id === 'strategic');
                const spGrid = document.getElementById('sp-grid');
                const spCount = document.getElementById('sp-count');
                if (spGroup && spGrid) {
                    const active = spGroup.workflows.filter(w => w.active).length;
                    if (spCount) spCount.textContent = active + '/' + spGroup.workflows.length + ' active';
                    const COLS = 5;
                    const cols = Array.from({length: COLS}, () => []);
                    spGroup.workflows.forEach((wf, i) => cols[i % COLS].push(wf));
                    spGrid.innerHTML = cols.map(col => {
                        const tiles = col.map(wf => {
                            let name = wf.name.replace(/^DWE\s*[-–—]\s*Strategic Pipeline\s*\|\s*/i, '');
                            name = name.replace(/^DWE\s*\|\s*/i, '').replace(/^PROD\s*\|\s*/i, '');
                            const wfNum = name.match(/^WF(\d+)/)?.[0] || '';
                            const shortName = name.replace(/^WF\d+\s*[-–—]\s*/, '');
                            const dotCls = wf.active ? 'on' : 'off';
                            const tileCls = wf.active ? ' active' : '';
                            const trig = wf.triggerType || 'manual';
                            return `<div class="sp-tile${tileCls}" title="${wf.name}">
                                <div class="sp-tile-header">
                                    <span class="sp-dot ${dotCls}"></span>
                                    <span class="sp-name">${shortName}</span>
                                </div>
                                <div class="sp-meta">
                                    <span class="sp-badge ${trig}">${trig}</span>
                                    <span class="sp-status${wf.active?'':' off'}">${wf.active?'Active':'Inactive'}</span>
                                    ${wfNum ? `<span style="margin-left:auto;font-size:0.5rem;color:rgba(255,255,255,0.2);font-family:monospace;">${wfNum}</span>` : ''}
                                </div>
                            </div>`;
                        }).join('');
                        return `<div class="sp-col">${tiles}</div>`;
                    }).join('');
                }
            } catch(e) { /* silent */ }
        }

        // ── Content Intelligence ────────────────────────────────────────
        async function fetchContentIntel() {
            try {
                const d = await fetch('/mc/content-intel').then(r => r.json());
                // Status dot
                const dot = document.getElementById('ci-status-dot');
                const badge = document.getElementById('ci-badge');
                if (d.lastScan) {
                    const ago = Date.now() - new Date(d.lastScan).getTime();
                    const isRecent = ago < 4 * 60 * 60 * 1000;
                    if (dot) { dot.style.background = isRecent ? '#00ff88' : 'rgba(255,200,60,0.5)'; dot.style.boxShadow = isRecent ? '0 0 6px rgba(0,255,136,0.4)' : 'none'; dot.title = isRecent ? 'Active' : 'Stale (>4h)'; }
                }
                // Badge
                const totalNuggets = (d.recentNuggets || []).length;
                if (badge) badge.textContent = totalNuggets > 0 ? totalNuggets + ' nuggets' : 'No data';

                // Weekly stats
                const ws = d.weeklyStats || {};
                const wn = document.getElementById('ci-week-nuggets');
                const wv = document.getElementById('ci-week-videos');
                const wa = document.getElementById('ci-week-avg');
                if (wn) wn.textContent = ws.nuggets || 0;
                if (wv) wv.textContent = ws.videos || 0;
                if (wa) wa.textContent = ws.avgScore || '—';

                // Render top 5 recent nuggets
                const container = document.getElementById('ci-nuggets');
                if (!container) return;
                const nuggets = (d.recentNuggets || []).slice(0, 5);
                if (nuggets.length === 0) {
                    container.innerHTML = '<div class="ci-empty">No nuggets yet — pipeline will populate once YouTube channels are monitored</div>';
                    return;
                }
                container.innerHTML = nuggets.map(n => {
                    const verdict = n.verdict || '';
                    const verdictCls = verdict === 'WATCH' ? 'watch' : verdict === 'SKIM' ? 'skim' : 'skip';
                    const verdictIcon = verdict === 'WATCH' ? '&#127919;' : verdict === 'SKIM' ? '&#128064;' : '&#9197;&#65039;';
                    const topHighlight = (n.key_highlights && n.key_highlights[0]) ? n.key_highlights[0].highlight : ((n.nuggets && n.nuggets[0]) ? n.nuggets[0].insight : (n.summary || 'No details'));
                    const dweApp = (n.key_highlights && n.key_highlights[0]) ? n.key_highlights[0].dwe_application : '';
                    const timeAgo = timeAgoStr(n.timestamp);
                    return `<div class="ci-nugget">
                        <div style="display:flex;flex-direction:column;align-items:center;gap:0.15rem;flex-shrink:0;">
                            <span class="ci-verdict ${verdictCls}">${verdictIcon} ${verdict}</span>
                            <span class="ci-score ${n.score >= 8 ? 'high' : 'med'}">${n.score}/10</span>
                        </div>
                        <div class="ci-nugget-body">
                            <div style="font-size:0.7rem;font-weight:600;color:rgba(255,255,255,0.85);margin-bottom:0.15rem;">${escapeHtml(n.title || '')}</div>
                            <div class="ci-nugget-text">${escapeHtml(topHighlight)}</div>
                            ${dweApp ? '<div style="font-size:0.58rem;color:rgba(255,200,60,0.7);margin-top:0.15rem;">&#8594; ' + escapeHtml(dweApp) + '</div>' : ''}
                            <div class="ci-nugget-meta">
                                <span>${escapeHtml(n.channel || '')}</span>
                                <span>${timeAgo}</span>
                            </div>
                        </div>
                    </div>`;
                }).join('');

                // Last scan time
                const scanEl = document.getElementById('ci-scan-time');
                if (scanEl && d.lastScan) scanEl.textContent = 'Last scan: ' + timeAgoStr(d.lastScan);
            } catch(e) { /* silent */ }
        }
        function timeAgoStr(ts) {
            if (!ts) return '';
            const ms = Date.now() - new Date(ts).getTime();
            if (ms < 60000) return 'just now';
            if (ms < 3600000) return Math.floor(ms / 60000) + 'm ago';
            if (ms < 86400000) return Math.floor(ms / 3600000) + 'h ago';
            return Math.floor(ms / 86400000) + 'd ago';
        }
        function escapeHtml(s) { return (s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

        async function brainQuery() {
            const input  = document.getElementById('brain-query-input');
            const btn    = document.getElementById('brain-query-btn');
            const answer = document.getElementById('brain-query-answer');
            const q = input.value.trim();
            if (!q) return;
            btn.textContent = '⏳ Thinking...';
            btn.disabled = true;
            answer.innerHTML = '<span style="color:rgba(0,245,255,0.5); font-style:italic;">Querying the Brain...</span>';
            try {
                const d = await fetch('/mc/brain-query', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ question: q })
                }).then(r => r.json());
                const text = d.answer || d.error || 'No response.';
                answer.textContent = text;
            } catch(e) {
                answer.textContent = '⚠️ Could not reach the Brain.';
            }
            btn.textContent = 'Ask the Brain ↵';
            btn.disabled = false;
        }

        // ── /mc/backup ─────────────────────────────────────────────────────────
        // ── /mc/internet → ping-based connectivity ────────────────────────────
        async function fetchInternet() {
            try {
                const d = await fetch('/mc/internet').then(r => r.json());
                const dotState = d.status === 'ok' ? 'ok' : d.status === 'warn' ? 'warn' : 'error';
                const textClass = d.status === 'ok' ? 'ok' : d.status === 'warn' ? 'warning' : 'error';
                setDot('dot-gateway', dotState);
                const el = document.getElementById('health-gateway');
                el.textContent = d.status === 'ok' ? `Online · ${d.label}` : d.status === 'warn' ? `Degraded · ${d.label}` : `Offline · ${d.label}`;
                el.className = 'health-status ' + textClass;
                // Color the IP/GW lines based on connectivity
                const ipColor = d.status === 'ok' ? '#00ff88' : d.status === 'warn' ? '#f59e0b' : '#ff4444';
                const ipLine = document.getElementById('sh-ip-line');
                const gwLine = document.getElementById('sh-gw-line');
                if (ipLine) ipLine.style.color = ipColor;
                if (gwLine) gwLine.style.color = ipColor;
            } catch(e) {
                setDot('dot-gateway', 'error');
                document.getElementById('health-gateway').textContent = 'Error';
                const ipLine = document.getElementById('sh-ip-line');
                const gwLine = document.getElementById('sh-gw-line');
                if (ipLine) ipLine.style.color = '#ff4444';
                if (gwLine) gwLine.style.color = '#ff4444';
            }
        }

        function healthTier(hoursAgo) {
            // green < 24h, yellow 24-48h, red > 48h
            if (hoursAgo < 24) return { cls: 'ok', dot: 'ok' };
            if (hoursAgo < 48) return { cls: 'warning', dot: 'warn' };
            return { cls: 'error', dot: 'error' };
        }

        async function updateBackupTime() {
            try {
                const d = await fetch('/mc/backup').then(r => r.json());
                const el = document.getElementById('backupTime');
                if (d.lastBackup && new Date(d.lastBackup).getFullYear() > 2000) {
                    const dt = new Date(d.lastBackup);
                    const ago = timeAgo(d.lastBackup);
                    const hoursAgo = (Date.now() - dt) / 3600000;
                    const tier = healthTier(hoursAgo);
                    el.innerHTML = ago;
                    el.className = 'health-status ' + tier.cls;
                    setDot('dot-backup', tier.dot);
                } else {
                    el.textContent = 'Never';
                    el.className = 'health-status error';
                    setDot('dot-backup', 'error');
                }
            } catch(e) {}
        }

        async function updateOCBackupTime() {
            try {
                const d = await fetch('/mc/openclaw-backup').then(r => r.json());
                const el = document.getElementById('ocBackupTime');
                if (d.lastBackup && new Date(d.lastBackup).getFullYear() > 2000) {
                    const dt = new Date(d.lastBackup);
                    const ago = timeAgo(d.lastBackup);
                    const hoursAgo = (Date.now() - dt) / 3600000;
                    const tier = healthTier(hoursAgo);
                    el.innerHTML = ago;
                    el.className = 'health-status ' + tier.cls;
                    setDot('dot-oc-backup', tier.dot);
                } else {
                    el.textContent = 'Never';
                    el.className = 'health-status error';
                    setDot('dot-oc-backup', 'error');
                }
            } catch(e) {}
        }

        function runGitBackup() {
            const btn = document.getElementById('gitBackupBtn');
            btn.textContent = '⏳ Backing up...';
            fetch('/mc/backup', { method: 'POST' })
                .then(r => r.json())
                .then(data => {
                    btn.textContent = data.success ? '✅ Done!' : '❌ Failed';
                    if (data.success) updateBackupTime();
                    setTimeout(() => { btn.textContent = '💾 Git Backup'; }, 3000);
                })
                .catch(() => {
                    btn.textContent = '❌ Error';
                    setTimeout(() => { btn.textContent = '💾 Git Backup'; }, 3000);
                });
        }

        function runOCBackup() {
            const btn = document.getElementById('ocBackupBtn');
            btn.textContent = '⏳ Backing up...';
            fetch('/mc/openclaw-backup', { method: 'POST' })
                .then(r => r.json())
                .then(data => {
                    btn.textContent = data.success ? '✅ Done!' : '❌ Failed';
                    if (data.success) updateOCBackupTime();
                    setTimeout(() => { btn.textContent = '📦 OC Backup'; }, 3000);
                })
                .catch(() => {
                    btn.textContent = '❌ Error';
                    setTimeout(() => { btn.textContent = '📦 OC Backup'; }, 3000);
                });
        }

        // ── /mc/system → Mac mini health ──────────────────────────────────────
        let _macBootTime = null;
        let _gatewayStartTime = null;

        function formatUptime(sinceISO) {
            if (!sinceISO) return '—';
            const secs = Math.floor((Date.now() - new Date(sinceISO)) / 1000);
            const d = Math.floor(secs / 86400);
            const h = Math.floor((secs % 86400) / 3600);
            const m = Math.floor((secs % 3600) / 60);
            const s = secs % 60;
            if (d > 0) return `${d}d ${h}h ${m}m`;
            if (h > 0) return `${h}h ${m}m ${s}s`;
            return `${m}m ${s}s`;
        }

        function formatDateTime(iso) {
            if (!iso) return '—';
            const dt = new Date(iso);
            return dt.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) +
                   ' ' + dt.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit', second: '2-digit' });
        }

        // Tick the counters every second without a server call
        setInterval(() => {
            if (_macBootTime)       document.getElementById('mac-uptime-counter').textContent     = formatUptime(_macBootTime);
            if (_gatewayStartTime)  document.getElementById('gateway-uptime-counter').textContent = formatUptime(_gatewayStartTime);
        }, 1000);

        async function fetchSystem() {
            try {
                const d = await fetch('/mc/system').then(r => r.json());
                // Chip info
                document.getElementById('mac-chip').textContent =
                    `${d.chip} · ${d.cores} cores`;
                // CPU
                const cpuPct = d.cpu.percent;
                document.getElementById('mac-cpu-pct').textContent = cpuPct + '%';
                document.getElementById('mac-cpu-bar').style.width = cpuPct + '%';
                document.getElementById('mac-cpu-bar').style.background =
                    cpuPct > 80 ? '#ff4444' : cpuPct > 60 ? '#ff9500' : '#00bfff';
                // RAM
                const ramPct = d.memory.percent;
                document.getElementById('mac-ram-pct').textContent =
                    `${d.memory.usedGB.toFixed(1)} / ${d.memory.totalGB.toFixed(0)} GB (${ramPct}%)`;
                document.getElementById('mac-ram-bar').style.width = ramPct + '%';
                document.getElementById('mac-ram-bar').style.background =
                    ramPct > 85 ? '#ff4444' : ramPct > 70 ? '#ff9500' : '#00ff88';
                // Disk
                const diskPct = d.disk.percent;
                document.getElementById('mac-disk-pct').textContent =
                    `${d.disk.usedGB} / ${d.disk.totalGB} GB (${diskPct}%)`;
                document.getElementById('mac-disk-bar').style.width = diskPct + '%';
                document.getElementById('mac-disk-bar').style.background =
                    diskPct > 85 ? '#ff4444' : diskPct > 70 ? '#ff9500' : '#ff9500';
                // Uptime counters
                _macBootTime = d.bootTime || null;
                _gatewayStartTime = d.gatewayStartTime || null;
                document.getElementById('mac-boot-time').textContent =
                    formatDateTime(_macBootTime);
                document.getElementById('gateway-start-time').textContent =
                    formatDateTime(_gatewayStartTime);
                // System Health: IP on main line, GW underneath (color set by fetchInternet)
                const ipLine = document.getElementById('sh-ip-line');
                const gwLine = document.getElementById('sh-gw-line');
                ipLine.textContent = d.localIP || 'No IP';
                gwLine.textContent = d.defaultGateway || 'No GW';
            } catch(e) {}
        }

        // ── /mc/heartbeat → agent schedule status ─────────────────────────────
        async function fetchHeartbeats() {
            try {
                const d = await fetch('/mc/heartbeat').then(r => r.json());
                const list = document.getElementById('heartbeat-list');
                list.innerHTML = '';
                d.agents.forEach(a => {
                    const dotClass = a.status === 'ok' ? '' : a.status === 'stale' ? ' error' : ' offline';
                    const sinceText = a.minutesSince !== null
                        ? (a.minutesSince < 60 ? `${a.minutesSince}m ago` : `${Math.floor(a.minutesSince/60)}h ago`)
                        : 'Never';
                    list.innerHTML += `<div class="service-item" style="flex-direction:column;align-items:flex-start;gap:2px;padding:0.5rem 0.75rem;">
                        <div style="display:flex;align-items:center;gap:0.4rem;width:100%;">
                            <span class="pulse-dot${dotClass}"></span>
                            <span class="label" style="font-weight:600;">${a.name}</span>
                        </div>
                        <div style="font-size:0.65rem;color:rgba(255,255,255,0.45);padding-left:1.1rem;">
                            Last: ${a.lastRunDisplay} (${sinceText}) &nbsp;|&nbsp; Next: ${a.nextRunDisplay}
                        </div>
                    </div>`;
                });
            } catch(e) {
                document.getElementById('heartbeat-list').innerHTML = '<div class="service-item"><span class="pulse-dot error"></span><span>Failed to load</span></div>';
            }
        }

        // ── Team Overview — combined tasks + heartbeat + session per agent ────
        async function fetchTeamOverview() {
            try {
                const [tasksData, hbData, sessionData, launchdData, sidneyDevices, delegationData] = await Promise.all([
                    fetch('/mc/agent-tasks').then(r => r.json()).catch(() => ({ agents: [] })),
                    fetch('/mc/heartbeat').then(r => r.json()).catch(() => ({ agents: [] })),
                    fetch('/mc/acp').then(r => r.json()).catch(() => ({ agents: [], userPresence: null })),
                    fetch('/mc/launchd').then(r => r.json()).catch(() => ({ services: [] })),
                    fetch('/mc/sidney-devices').then(r => r.json()).catch(() => ({ iphone: null, watch: null })),
                    fetch('/mc/delegation-stats').then(r => r.json()).catch(() => ({ total: 0, bySource: {}, byTarget: {} })),
                ]);
                const daemonById = {};
                for (const s of (launchdData.services || [])) daemonById[s.id] = s;

                const tasksByRole = {};
                for (const a of (tasksData.agents || [])) tasksByRole[a.id] = a;
                const hbById = {};
                for (const a of (hbData.agents || [])) hbById[a.id] = a;
                const sessionById = {};
                for (const a of (sessionData.agents || [])) sessionById[a.agentId] = a;
                const userPresence = sessionData.userPresence || null;

                const AGENTS = [
                    { id: 'ceo',   label: 'Sidney',         title: 'CEO',         icon: '👑', taskId: 'ceo',   hbId: null,    sessId: null,            isHuman: true,  daemons: [] },
                    { id: 'cto',   label: 'Steve',          title: 'CTO',         icon: '⚙️', taskId: 'cto',   hbId: 'cto',   sessId: 'cto',           isHuman: false, daemons: [
                        { id: 'ai.dwe.agent-heartbeat-cto', short: 'Heartbeat' },
                        { id: 'ai.dwe.cto-task-followup',   short: 'Follow-Up' },
                    ]},
                    { id: 'anita', label: 'Anita',          title: 'COO',         icon: '📋', taskId: 'anita', hbId: 'anita', sessId: 'anita',         isHuman: false, daemons: [
                        { id: 'ai.dwe.agent-heartbeat-anita',              short: 'Heartbeat' },
                        { id: 'ai.dwe.agent-heartbeat-anita-email-digest', short: 'Email Digest' },
                        { id: 'ai.dwe.agent-heartbeat-anita-finance',      short: 'Finance' },
                        { id: 'ai.dwe.anita-notion-triage',                short: 'Triage' },
                        { id: 'ai.dwe.morning-digest',                     short: 'Morning' },
                        { id: 'ai.dwe.anita-email-batch',                  short: 'Email Batch' },
                    ]},
                    { id: 'nicole',label: 'Nicole',         title: 'CSO',         icon: '📈', taskId: 'nicole',hbId: 'nicole',sessId: 'nicole',        isHuman: false, daemons: [
                        { id: 'ai.dwe.agent-heartbeat-nicole',        short: 'Heartbeat' },
                        { id: 'ai.dwe.nicole-task-followup',           short: 'Follow-Up' },
                        { id: 'ai.dwe.agent-heartbeat-nicole-weekly',  short: 'Weekly' },
                    ]},
                    { id: 'ce',    label: 'Chief Engineer', title: 'Engineering', icon: '🔧', taskId: 'ce',    hbId: 'ce',    sessId: 'chief-engineer', isHuman: false, daemons: [
                        { id: 'ai.dwe.agent-heartbeat-ce', short: 'Heartbeat' },
                        { id: 'ai.dwe.ce-task-followup',   short: 'Follow-Up' },
                    ]},
                    { id: 'cfo',   label: 'Fran',           title: 'CFO',         icon: '💰', taskId: 'cfo',   hbId: 'cfo',   sessId: 'cfo',           isHuman: false, daemons: [
                        { id: 'ai.dwe.agent-heartbeat-cfo', short: 'Heartbeat' },
                        { id: 'ai.dwe.cfo-task-followup',   short: 'Follow-Up' },
                    ]},
                ];

                // Priority config — always show all 4 levels
                const PRIO_ACTIVE = {
                    'Critical': { bg:'rgba(239,68,68,0.18)',   border:'rgba(239,68,68,0.35)',   text:'#f87171' },
                    'High':     { bg:'rgba(249,115,22,0.15)',  border:'rgba(249,115,22,0.3)',   text:'#fb923c' },
                    'Medium':   { bg:'rgba(59,130,246,0.12)',  border:'rgba(59,130,246,0.28)',  text:'#60a5fa' },
                    'Low':      { bg:'rgba(34,197,94,0.10)',   border:'rgba(34,197,94,0.22)',   text:'#4ade80' },
                };
                const PRIO_GHOST = { bg:'transparent', border:'rgba(255,255,255,0.07)', text:'rgba(255,255,255,0.2)' };
                const PRIO_4 = ['Critical', 'High', 'Medium', 'Low'];

                const miniAge = (min) => min == null ? '—'
                    : min < 60 ? `${min}m` : min < 1440 ? `${Math.round(min/60)}h` : `${Math.round(min/1440)}d`;
                const miniNext = (iso) => {
                    if (!iso) return '—';
                    const diff = Math.round((new Date(iso) - Date.now()) / 60000);
                    return diff < 0 ? 'now' : diff < 60 ? `${diff}m` : diff < 1440 ? `${Math.round(diff/60)}h` : `${Math.round(diff/1440)}d`;
                };

                const grid = document.getElementById('team-overview-grid');
                grid.innerHTML = AGENTS.map(agent => {
                    const t  = agent.taskId ? tasksByRole[agent.taskId] : null;
                    const hb = agent.hbId   ? hbById[agent.hbId]       : null;
                    const s  = agent.sessId ? sessionById[agent.sessId] : null;

                    // ── Heartbeat in header (right-justified) ──────────
                    let hbHeaderHtml = '';
                    if (hb) {
                        const hbDot = hb.status === 'ok' ? '#22c55e' : '#f59e0b';
                        hbHeaderHtml = `<div style="text-align:right;flex-shrink:0;line-height:1.3;">
                            <div style="font-size:0.6rem;color:rgba(255,255,255,0.55);">
                                <span style="color:${hbDot};">●</span> ${miniAge(hb.minutesSince)} ago
                            </div>
                            <div style="font-size:0.55rem;color:rgba(255,255,255,0.28);">→ ${miniNext(hb.nextRun)}</div>
                        </div>`;
                    }

                    // ── Session status (between header and tasks) ───────
                    let sessStatusHtml = '';
                    if (agent.isHuman && userPresence) {
                        // Sidney: use Mac idle time as presence signal
                        const idleMin = userPresence.idleMin || 0;
                        const presStatus = userPresence.status;
                        const dot = presStatus === 'active' ? '#22c55e' : presStatus === 'idle' ? '#f59e0b' : '#6b7280';
                        const label = presStatus === 'active'
                            ? `active · ${idleMin < 1 ? 'just now' : idleMin + 'm idle'}`
                            : presStatus === 'idle' ? `idle · ${idleMin}m`
                            : `away · ${Math.round(idleMin/60)}h`;
                        sessStatusHtml = `
                            <div style="display:flex;align-items:center;gap:5px;margin-bottom:7px;padding:3px 6px;background:rgba(255,215,0,0.06);border:1px solid rgba(255,215,0,0.12);border-radius:5px;">
                                <div style="width:7px;height:7px;border-radius:50%;background:${dot};box-shadow:0 0 5px ${dot};flex-shrink:0;"></div>
                                <span style="font-size:0.62rem;color:rgba(255,255,255,0.65);">${label}</span>
                            </div>`;
                    } else if (s) {
                        const dot   = s.status === 'online' ? '#22c55e' : s.status === 'idle' ? '#f59e0b' : '#6b7280';
                        const ctxPct = s.contextPct || 0;
                        const ctxC  = ctxPct > 80 ? '#ef4444' : ctxPct > 50 ? '#f59e0b' : '#22c55e';
                        sessStatusHtml = `
                            <div style="display:flex;align-items:center;gap:5px;margin-bottom:7px;padding:3px 6px;background:rgba(255,255,255,0.04);border-radius:5px;">
                                <div style="width:6px;height:6px;border-radius:50%;background:${dot};flex-shrink:0;"></div>
                                <span style="font-size:0.62rem;color:rgba(255,255,255,0.6);flex:1;">${s.status} · ${miniAge(s.minutesSince)} ago</span>
                                <div style="width:28px;height:2px;background:rgba(255,255,255,0.1);border-radius:2px;">
                                    <div style="height:2px;width:${Math.min(ctxPct,100)}%;background:${ctxC};border-radius:2px;"></div>
                                </div>
                                <span style="font-size:0.55rem;color:rgba(255,255,255,0.3);">${ctxPct}%</span>
                            </div>`;
                    } else if (!agent.isHuman) {
                        sessStatusHtml = `<div style="display:flex;align-items:center;gap:5px;margin-bottom:7px;padding:3px 6px;background:rgba(255,255,255,0.02);border-radius:5px;">
                            <div style="width:6px;height:6px;border-radius:50%;background:#374151;flex-shrink:0;"></div>
                            <span style="font-size:0.62rem;color:rgba(255,255,255,0.2);">no session</span>
                        </div>`;
                    }

                    // ── Tasks — actionable only (Not Started/In Progress, due ≤ today or no due) ─────────
                    let tasksHtml = '';
                    if (t) {
                        const taskLabel = agent.id === 'main' ? 'Needs Assignment' : 'Actionable';
                        const actionCount = t.actionable || 0;
                        const actionOverdue = t.actionableOverdue || 0;
                        const actionNoDue = t.actionableNoDue || 0;
                        const actionByPrio = t.actionableByPriority || {};
                        const actionList = t.actionableList || [];

                        // Priority badges for actionable tasks only
                        const prioBadges = PRIO_4.map(p => {
                            const count = actionByPrio[p] || 0;
                            const c = count > 0 ? PRIO_ACTIVE[p] : PRIO_GHOST;
                            return `<div style="display:flex;justify-content:space-between;align-items:center;padding:2px 5px;background:${c.bg};border:1px solid ${c.border};border-radius:4px;margin-top:2px;">
                                <span style="font-size:0.58rem;color:${c.text};">${p}</span>
                                <span style="font-size:0.7rem;font-weight:${count>0?'700':'400'};color:${c.text};">${count > 0 ? count : '—'}</span>
                            </div>`;
                        }).join('');

                        const overdueHtml = actionOverdue > 0
                            ? `<div style="font-size:0.58rem;color:#f87171;margin-top:3px;">⚠ ${actionOverdue} overdue</div>`
                            : `<div style="font-size:0.58rem;color:rgba(255,255,255,0.18);margin-top:3px;">✓ no overdue</div>`;

                        // Task list (show up to 5 tasks)
                        const listHtml = actionList.length > 0
                            ? `<div style="margin-top:5px;padding-top:4px;border-top:1px solid rgba(255,255,255,0.06);">` +
                              actionList.slice(0, 5).map(tk => {
                                  const prioC = PRIO_ACTIVE[tk.priority] || { text: 'rgba(255,255,255,0.4)' };
                                  const statusDot = tk.status.includes('Progress') ? '#f59e0b' : '#60a5fa';
                                  const dueTag = tk.isOverdue
                                      ? `<span style="font-size:0.48rem;color:#f87171;margin-left:auto;flex-shrink:0;">⚠ ${tk.dueDate}</span>`
                                      : tk.dueDate
                                          ? `<span style="font-size:0.48rem;color:rgba(255,255,255,0.25);margin-left:auto;flex-shrink:0;">${tk.dueDate}</span>`
                                          : `<span style="font-size:0.48rem;color:rgba(255,255,255,0.15);margin-left:auto;flex-shrink:0;">no due</span>`;
                                  return `<div style="display:flex;align-items:center;gap:4px;padding:2px 0;border-bottom:1px solid rgba(255,255,255,0.03);">
                                      <span style="width:5px;height:5px;border-radius:50%;background:${statusDot};flex-shrink:0;"></span>
                                      <span style="font-size:0.52rem;color:${prioC.text};flex-shrink:0;">TAS-${tk.id}</span>
                                      <span style="font-size:0.52rem;color:rgba(255,255,255,0.55);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="${tk.name}">${tk.name.length > 28 ? tk.name.slice(0, 26) + '…' : tk.name}</span>
                                      ${dueTag}
                                  </div>`;
                              }).join('') +
                              (actionList.length > 5 ? `<div style="font-size:0.5rem;color:rgba(255,255,255,0.2);padding-top:2px;">+${actionList.length - 5} more</div>` : '') +
                              `</div>`
                            : '';

                        tasksHtml = `
                            <div style="display:flex;align-items:baseline;gap:4px;margin-bottom:3px;">
                                <span style="font-size:0.55rem;text-transform:uppercase;letter-spacing:0.06em;color:rgba(255,255,255,0.28);">${taskLabel}</span>
                                <span style="font-size:0.9rem;font-weight:700;color:#ff69b4;margin-left:auto;">${actionCount}</span>
                            </div>
                            <div style="display:flex;gap:6px;font-size:0.52rem;color:rgba(255,255,255,0.3);margin-bottom:4px;">
                                <span>Total: ${t.total}</span>
                                <span>Done: ${t.done}</span>
                            </div>
                            ${prioBadges}${overdueHtml}${listHtml}`;
                    } else {
                        tasksHtml = `<div style="font-size:0.55rem;text-transform:uppercase;letter-spacing:0.06em;color:rgba(255,255,255,0.28);margin-bottom:3px;">Tasks</div>
                            <div style="font-size:0.62rem;color:rgba(255,255,255,0.2);">None in Notion</div>`;
                    }

                    // ── Model row ──────────────────────────────────────
                    let modelHtml = '';
                    function modelColorFor(m) {
                        if (!m) return '#22c55e';
                        if (m.startsWith('anthropic/') || m.startsWith('openclaw/') || m.toLowerCase().includes('sonic')) return '#ef4444';
                        if (m.includes('auto')) return '#22c55e';
                        if (m.startsWith('openrouter/') || m.startsWith('openai/')) return '#f59e0b';
                        return '#f59e0b';
                    }
                    function modelDisplayFor(m) {
                        if (!m) return 'or/auto';
                        return m.replace('openrouter/', 'or/').replace('anthropic/', 'claude/').replace('openai/', 'oai/').replace('openclaw/', 'claw/');
                    }
                    if (!agent.isHuman) {
                        const modelFull = s?.model || 'openrouter/auto';
                        modelHtml = `<div style="margin-top:5px;padding-top:5px;border-top:1px solid rgba(255,255,255,0.06);display:flex;align-items:center;gap:4px;">
                            <span style="font-size:0.52rem;color:rgba(255,255,255,0.28);text-transform:uppercase;letter-spacing:0.05em;">Model</span>
                            <span style="font-size:0.58rem;color:${modelColorFor(modelFull)};font-family:monospace;margin-left:auto;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:130px;" title="${modelFull}">${modelDisplayFor(modelFull)}</span>
                        </div>`;
                    } else {
                        // Sidney: show main agent's model with same color logic
                        const mainSess = sessionById['main'];
                        const mainFull = mainSess?.model || 'openrouter/auto';
                        modelHtml = `<div style="margin-top:5px;padding-top:5px;border-top:1px solid rgba(255,215,0,0.1);display:flex;align-items:center;gap:4px;">
                            <span style="font-size:0.52rem;color:rgba(255,215,0,0.35);text-transform:uppercase;letter-spacing:0.05em;">Main</span>
                            <span style="font-size:0.58rem;color:${modelColorFor(mainFull)};font-family:monospace;margin-left:auto;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:130px;" title="${mainFull}">${modelDisplayFor(mainFull)}</span>
                        </div>`;
                    }

                    // ── Daemon / device status rows ────────────────────────
                    let daemonHtml = '';
                    if (agent.isHuman && agent.id === 'ceo') {
                        // Sidney: show iPhone + Apple Watch presence
                        const devices = [
                            { key: 'iphone', icon: '📱', label: 'iPhone' },
                            { key: 'watch',  icon: '⌚', label: 'Apple Watch' },
                        ];
                        const rows = devices.map(dv => {
                            const d = sidneyDevices?.[dv.key];
                            const online = d?.online === true;
                            const dot = online ? '#00ff88' : '#ff4444';
                            const st = online ? 'On Network' : 'Offline';
                            const stColor = online ? 'rgba(0,255,136,0.5)' : 'rgba(255,68,68,0.5)';
                            return `<div style="display:flex;align-items:center;gap:4px;">
                                <span style="width:5px;height:5px;border-radius:50%;background:${dot};flex-shrink:0;"></span>
                                <span style="font-size:0.55rem;color:rgba(255,255,255,0.45);">${dv.icon} ${dv.label}</span>
                                <span style="margin-left:auto;font-size:0.5rem;color:${stColor};font-family:monospace;">${st}</span>
                            </div>`;
                        }).join('');
                        daemonHtml = `<div style="margin-top:6px;padding-top:6px;border-top:1px solid rgba(255,215,0,0.1);display:flex;flex-direction:column;gap:2px;">
                            ${rows}
                        </div>`;
                    } else if (agent.daemons.length > 0) {
                        const rows = agent.daemons.map(dm => {
                            const d = daemonById[dm.id];
                            const ok = d && (d.status === 'running' || (d.scheduled && d.status === 'waiting'));
                            const dot = ok ? '#00ff88' : d ? '#ff4444' : '#555';
                            const st = d ? (d.status === 'running' ? '▶' : d.status === 'waiting' ? '⏸' : '✕') : '?';
                            return `<div style="display:flex;align-items:center;gap:4px;">
                                <span style="width:5px;height:5px;border-radius:50%;background:${dot};flex-shrink:0;"></span>
                                <span style="font-size:0.55rem;color:rgba(255,255,255,0.45);">${dm.short}</span>
                                <span style="margin-left:auto;font-size:0.5rem;color:${ok ? 'rgba(0,255,136,0.5)' : 'rgba(255,68,68,0.6)'};font-family:monospace;">${st}</span>
                            </div>`;
                        }).join('');
                        daemonHtml = `<div style="margin-top:6px;padding-top:6px;border-top:1px solid rgba(255,255,255,0.06);display:flex;flex-direction:column;gap:2px;">
                            ${rows}
                        </div>`;
                    }

                    // ── Delegation stats row (always at bottom, colored) ──
                    let delegHtml = '';
                    if (!agent.isHuman && delegationData) {
                        const delegNameMap = { 'cto': 'Steve', 'anita': 'Anita', 'nicole': 'Nicole', 'cfo': 'Fran', 'ce': 'CE', 'jarvis': 'Jarvis' };
                        const delegName = delegNameMap[agent.id] || agent.id;
                        const sentCount = delegationData.bySource?.[delegName] || 0;
                        const recvCount = delegationData.byTarget?.[agent.id] || 0;
                        delegHtml = `<div style="margin-top:auto;padding-top:6px;border-top:1px solid rgba(255,255,255,0.06);display:flex;align-items:center;gap:6px;">
                            <span style="font-size:0.52rem;color:rgba(255,255,255,0.28);text-transform:uppercase;letter-spacing:0.05em;">Delegations</span>
                            <div style="margin-left:auto;display:flex;gap:6px;align-items:center;">
                                <span style="font-size:0.58rem;color:#00f5ff;" title="Sent to other agents">↑${sentCount}</span>
                                <span style="font-size:0.58rem;color:#b829dd;" title="Received from other agents">↓${recvCount}</span>
                            </div>
                        </div>`;
                    }

                    const bg     = agent.isHuman ? 'linear-gradient(135deg,rgba(255,215,0,0.1),rgba(255,165,0,0.05))' : 'rgba(255,255,255,0.025)';
                    const border = agent.isHuman ? 'rgba(255,215,0,0.22)' : 'rgba(255,255,255,0.07)';

                    return `<div style="background:${bg};border:1px solid ${border};border-radius:10px;padding:0.6rem 0.65rem;min-width:0;display:flex;flex-direction:column;">
                        <div style="display:flex;align-items:center;gap:5px;margin-bottom:6px;">
                            <span style="font-size:1rem;">${agent.icon}</span>
                            <div style="min-width:0;flex:1;">
                                <div style="font-weight:700;font-size:0.76rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${agent.label}</div>
                                <div style="font-size:0.58rem;color:rgba(255,255,255,0.32);">${agent.title}</div>
                            </div>
                            ${hbHeaderHtml}
                        </div>
                        ${sessStatusHtml}
                        ${tasksHtml}
                        ${daemonHtml}
                        ${modelHtml}
                        ${delegHtml}
                    </div>`;
                }).join('');

                // ── Update AI Team button color based on worst-case status ──
                const aitBtn = document.getElementById('ai-team-btn');
                if (aitBtn) {
                    let worstLevel = 0; // 0=green, 1=yellow, 2=red
                    for (const agent of AGENTS) {
                        if (agent.isHuman) continue;
                        // Check daemons — only flag if found in launchd with error status
                        for (const dm of agent.daemons) {
                            const d = daemonById[dm.id];
                            if (!d) continue; // not registered in launchd, skip
                            const ok = d.status === 'running' || (d.scheduled && d.status === 'waiting');
                            if (!ok) worstLevel = Math.max(worstLevel, d.status === 'error' ? 2 : 1);
                        }
                        // Check heartbeat
                        const hb = agent.hbId ? hbById[agent.hbId] : null;
                        if (hb && hb.status !== 'ok') worstLevel = Math.max(worstLevel, 1);
                    }
                    const colors = [
                        { bg: 'rgba(0,255,136,0.15)', border: 'rgba(0,255,136,0.35)', text: '#00ff88', hoverBg: 'rgba(0,255,136,0.28)' },
                        { bg: 'rgba(255,149,0,0.15)', border: 'rgba(255,149,0,0.35)', text: '#ff9500', hoverBg: 'rgba(255,149,0,0.28)' },
                        { bg: 'rgba(255,68,68,0.15)', border: 'rgba(255,68,68,0.35)', text: '#ff4444', hoverBg: 'rgba(255,68,68,0.28)' },
                    ];
                    const c = colors[worstLevel];
                    aitBtn.style.background = c.bg;
                    aitBtn.style.borderColor = c.border;
                    aitBtn.style.color = c.text;
                    aitBtn.onmouseover = () => aitBtn.style.background = c.hoverBg;
                    aitBtn.onmouseout = () => aitBtn.style.background = c.bg;
                }

                // ── Populate unassigned tasks in Notion Task Management tile ──
                const unassigned = tasksByRole['main'];
                const uPanel = document.getElementById('unassigned-tasks-content');
                if (unassigned && uPanel) {
                    const donePct = unassigned.total > 0 ? Math.round((unassigned.done / unassigned.total) * 100) : 0;
                    const barColor = donePct >= 75 ? '#22c55e' : donePct >= 40 ? '#f59e0b' : '#60a5fa';
                    const prioBadges = PRIO_4.map(p => {
                        const count = unassigned.byPriority[p] || 0;
                        const c = count > 0 ? PRIO_ACTIVE[p] : PRIO_GHOST;
                        return `<div style="text-align:center;padding:3px 9px;background:${c.bg};backdrop-filter:blur(4px);border:1px solid ${c.border};border-radius:6px;">
                            <div style="font-size:0.65rem;color:${c.text};opacity:0.8;">${p}</div>
                            <div style="font-size:0.9rem;font-weight:${count>0?'700':'400'};color:${c.text};">${count > 0 ? count : '—'}</div>
                        </div>`;
                    }).join('');
                    const overdueHtml = unassigned.overdue > 0
                        ? `<div style="text-align:center;padding:3px 9px;background:rgba(248,113,113,0.08);backdrop-filter:blur(4px);border:1px solid rgba(248,113,113,0.2);border-radius:6px;">
                            <div style="font-size:0.65rem;color:#f87171;opacity:0.8;">Overdue</div>
                            <div style="font-size:0.9rem;font-weight:700;color:#f87171;">⚠ ${unassigned.overdue}</div>
                          </div>`
                        : '';
                    document.getElementById('unassigned-total-num').textContent = unassigned.total;
                    uPanel.innerHTML = `
                        <div style="text-align:center;padding:2px 10px;background:rgba(255,255,255,0.03);border-radius:6px;">
                            <div style="font-size:0.65rem;color:rgba(255,255,255,0.3);text-transform:uppercase;letter-spacing:0.04em;">Open</div>
                            <div style="font-size:1.1rem;font-weight:700;color:#ff69b4;">${unassigned.open}</div>
                        </div>
                        ${prioBadges}
                        <div style="text-align:center;padding:2px 10px;background:rgba(255,255,255,0.03);border-radius:6px;">
                            <div style="font-size:0.65rem;color:rgba(255,255,255,0.3);text-transform:uppercase;letter-spacing:0.04em;">Done</div>
                            <div style="font-size:1.1rem;font-weight:700;color:#00ff88;">${unassigned.done}</div>
                        </div>
                        ${overdueHtml}`;
                } else if (uPanel) {
                    uPanel.innerHTML = `<span style="font-size:0.62rem;color:rgba(255,255,255,0.2);">None in Notion</span>`;
                }

            } catch(e) {
                document.getElementById('team-overview-grid').innerHTML =
                    `<div style="grid-column:1/-1;color:#f87171;font-size:0.72rem;padding:0.5rem;">Failed: ${e.message}</div>`;
            }
        }

        // ── /mc/agent-tasks → per-agent Notion task breakdown ─────────────────
        async function fetchAgentTasks() {
            try {
                const d = await fetch('/mc/agent-tasks').then(r => r.json());
                const grid = document.getElementById('agent-tasks-grid');
                if (!d.agents || !d.agents.length || d.error) {
                    grid.innerHTML = `<div class="service-item"><span class="pulse-dot error"></span><span>${d.error || 'No data'}</span></div>`;
                    return;
                }
                const PRIO_COLORS = {
                    'Critical':    { bg: 'rgba(239,68,68,0.15)',  border: 'rgba(239,68,68,0.4)',  text: '#f87171', label: 'Critical' },
                    'High':        { bg: 'rgba(249,115,22,0.12)', border: 'rgba(249,115,22,0.35)', text: '#fb923c', label: 'High'     },
                    'Medium':      { bg: 'rgba(59,130,246,0.10)', border: 'rgba(59,130,246,0.3)',  text: '#60a5fa', label: 'Medium'   },
                    'Low':         { bg: 'rgba(34,197,94,0.08)',  border: 'rgba(34,197,94,0.25)',  text: '#4ade80', label: 'Low'      },
                    'No Priority': { bg: 'rgba(255,255,255,0.04)',border: 'rgba(255,255,255,0.1)', text: 'rgba(255,255,255,0.35)', label: 'None' },
                };
                const PRIO_ORDER = ['Critical', 'High', 'Medium', 'Low', 'No Priority'];

                grid.innerHTML = d.agents.map(a => {
                    const prioBadges = PRIO_ORDER
                        .filter(p => (a.byPriority[p] || 0) > 0)
                        .map(p => {
                            const c = PRIO_COLORS[p];
                            return `<div style="display:flex;align-items:center;justify-content:space-between;padding:0.3rem 0.5rem;background:${c.bg};border:1px solid ${c.border};border-radius:5px;margin-top:4px;">
                                <span style="font-size:0.68rem;color:${c.text};font-weight:500;">${c.label}</span>
                                <span style="font-size:0.8rem;font-weight:700;color:${c.text};">${a.byPriority[p]}</span>
                            </div>`;
                        }).join('');

                    const overdueHtml = a.overdue > 0
                        ? `<div style="font-size:0.65rem;color:#f87171;margin-top:6px;">⚠ ${a.overdue} overdue</div>`
                        : '';

                    const donePct = a.total > 0 ? Math.round((a.done / a.total) * 100) : 0;
                    const barColor = donePct >= 75 ? '#22c55e' : donePct >= 40 ? '#f59e0b' : '#60a5fa';

                    return `<div style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:10px;padding:0.75rem 0.85rem;">
                        <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.5rem;">
                            <span style="font-size:1rem;">${a.icon}</span>
                            <span style="font-weight:600;font-size:0.82rem;">${a.name}</span>
                            <span style="margin-left:auto;font-size:0.7rem;color:rgba(255,255,255,0.35);">${a.role}</span>
                        </div>
                        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:0.3rem;text-align:center;margin-bottom:0.5rem;">
                            <div style="background:rgba(0,245,255,0.08);border-radius:5px;padding:0.25rem 0;">
                                <div style="font-size:1rem;font-weight:700;color:#00f5ff;">${a.total}</div>
                                <div style="font-size:0.58rem;color:rgba(255,255,255,0.4);">Total</div>
                            </div>
                            <div style="background:rgba(255,0,170,0.08);border-radius:5px;padding:0.25rem 0;">
                                <div style="font-size:1rem;font-weight:700;color:#ff69b4;">${a.open}</div>
                                <div style="font-size:0.58rem;color:rgba(255,255,255,0.4);">Open</div>
                            </div>
                            <div style="background:rgba(0,255,136,0.08);border-radius:5px;padding:0.25rem 0;">
                                <div style="font-size:1rem;font-weight:700;color:#00ff88;">${a.done}</div>
                                <div style="font-size:0.58rem;color:rgba(255,255,255,0.4);">Done</div>
                            </div>
                        </div>
                        <div style="height:3px;background:rgba(255,255,255,0.07);border-radius:2px;margin-bottom:0.5rem;">
                            <div style="height:3px;width:${donePct}%;background:${barColor};border-radius:2px;transition:width 0.6s;"></div>
                        </div>
                        ${prioBadges}
                        ${overdueHtml}
                    </div>`;
                }).join('');
            } catch(e) {
                document.getElementById('agent-tasks-grid').innerHTML = '<div class="service-item"><span class="pulse-dot error"></span><span>Failed to load</span></div>';
            }
        }

        // ── /mc/acp → AI Team Protocol (live agent sessions) ──────────────────
        async function fetchAgentSessions() {
            try {
                const d = await fetch('/mc/acp').then(r => r.json());
                const list = document.getElementById('acp-agent-list');
                if (!d.agents || !d.agents.length) {
                    list.innerHTML = '<div class="service-item"><span class="pulse-dot offline"></span><span>No session data</span></div>';
                    return;
                }
                list.innerHTML = d.agents.map(a => {
                    const dotClass = a.status === 'online' ? 'active' : a.status === 'idle' ? 'offline' : 'error';
                    const lastSeen = a.minutesSince === null ? 'never'
                                   : a.minutesSince < 60 ? `${a.minutesSince}m ago`
                                   : a.minutesSince < 1440 ? `${Math.round(a.minutesSince/60)}h ago`
                                   : `${Math.round(a.minutesSince/1440)}d ago`;
                    const ctxBar = a.contextPct > 0
                        ? `<div style="height:3px;background:rgba(255,255,255,0.08);border-radius:2px;margin-top:4px;"><div style="height:3px;width:${Math.min(a.contextPct,100)}%;background:${a.contextPct>80?'#ef4444':a.contextPct>50?'#f59e0b':'#22c55e'};border-radius:2px;"></div></div>`
                        : '';
                    const tokStr = a.totalTokens > 0 ? ` · ${(a.totalTokens/1000).toFixed(0)}k tok${a.contextPct>0?' ('+a.contextPct+'%)':''}` : '';
                    return `<div class="service-item" style="flex-direction:column;align-items:flex-start;gap:2px;padding:0.55rem 0.75rem;">
                        <div style="display:flex;align-items:center;gap:0.5rem;width:100%;">
                            <span class="pulse-dot ${dotClass}"></span>
                            <span style="font-weight:500;font-size:0.78rem;">${a.name}</span>
                        </div>
                        <div style="font-size:0.65rem;color:rgba(255,255,255,0.4);padding-left:1.1rem;">${a.status} · ${lastSeen}${tokStr}</div>
                        ${ctxBar}
                    </div>`;
                }).join('');
            } catch (e) {
                document.getElementById('acp-agent-list').innerHTML = '<div class="service-item"><span class="pulse-dot error"></span><span>Failed to load</span></div>';
            }
        }

        // ── /mc/cso → Nicole CSO opportunity pipeline ─────────────────────────
        async function fetchCSoPipeline() {
            try {
                const d = await fetch('/mc/cso').then(r => r.json());
                const list = document.getElementById('cso-pipeline-list');
                list.innerHTML = '';
                if (!d.opportunities || d.opportunities.length === 0) {
                    list.innerHTML = `<div class="service-item" style="font-size:0.72rem;color:rgba(255,255,255,0.4);padding:0.75rem;">${d.note || 'No opportunities in pipeline yet.'}</div>`;
                } else {
                    d.opportunities.slice(0,5).forEach(o => {
                        const scoreColor = o.score >= 7 ? '#22c55e' : o.score >= 4 ? '#f59e0b' : '#ef4444';
                        list.innerHTML += `<div class="service-item">
                            <span class="label">${o.name}</span>
                            <span style="font-size:0.7rem;color:${scoreColor};font-weight:700;">${o.score}/10</span>
                            <span style="font-size:0.65rem;color:rgba(255,255,255,0.4);">${o.status || ''}</span>
                        </div>`;
                    });
                }
                document.getElementById('cso-last-report').textContent = d.lastReport
                    ? `Last report: ${new Date(d.lastReport).toLocaleString()}`
                    : 'No report yet';
            } catch(e) {
                document.getElementById('cso-pipeline-list').innerHTML = '<div class="service-item"><span class="pulse-dot error"></span><span>Failed to load</span></div>';
            }
        }

        // ── /mc/financial → Anita financial pulse ─────────────────────────────
        async function fetchFinancialPulse() {
            try {
                const d = await fetch('/mc/financial').then(r => r.json());
                const list = document.getElementById('financial-pulse-list');
                list.innerHTML = '';
                if (!d.incomeStreams || d.incomeStreams.length === 0) {
                    list.innerHTML = `<div class="service-item" style="font-size:0.72rem;color:rgba(255,255,255,0.4);padding:0.75rem;">${d.note || 'No financial data yet.'}</div>`;
                } else {
                    d.incomeStreams.slice(0,5).forEach(s => {
                        const statusColor = s.status === 'active' ? '#22c55e' : '#f59e0b';
                        list.innerHTML += `<div class="service-item">
                            <span class="label">${s.name}</span>
                            <span style="font-size:0.7rem;color:${statusColor};">${s.status || ''}</span>
                            ${s.risk ? `<span style="font-size:0.65rem;color:#ef4444;">⚠ ${s.risk}</span>` : ''}
                        </div>`;
                    });
                }
                document.getElementById('financial-last-pulse').textContent = d.lastPulse
                    ? `Last pulse: ${new Date(d.lastPulse).toLocaleString()}`
                    : 'No pulse yet — runs Monday 7:30am';
            } catch(e) {
                document.getElementById('financial-pulse-list').innerHTML = '<div class="service-item"><span class="pulse-dot error"></span><span>Failed to load</span></div>';
            }
        }

        // ── Master refresh ────────────────────────────────────────────────────
        // ── Document Pipeline — File Manager ──────────────────────────────────
        const PIPELINE_ORDER = ['1_New','2_CEO_review','3_Approved','4_Ready_to_Seed','5_Failed_Seed'];
        const PIPELINE_META = {
            '1_New':           { color:'rgba(255,255,255,0.55)', accent:'rgba(255,255,255,0.06)' },
            '2_CEO_review':    { color:'#f59e0b',               accent:'rgba(245,158,11,0.08)'  },
            '3_Approved':      { color:'#22c55e',               accent:'rgba(34,197,94,0.08)'   },
            '4_Ready_to_Seed': { color:'#a78bfa',               accent:'rgba(167,139,250,0.08)' },
            '5_Failed_Seed':   { color:'#ef4444',               accent:'rgba(239,68,68,0.08)'   }
        };
        const PIPELINE_NEXT = { '1_New':'2_CEO_review', '2_CEO_review':'3_Approved', '3_Approved':'4_Ready_to_Seed', '5_Failed_Seed':'4_Ready_to_Seed' };

        async function movePipelineFile(file, from, to) {
            try {
                const r = await fetch('/mc/pipeline/move', {
                    method:'POST', headers:{'Content-Type':'application/json'},
                    body: JSON.stringify({ file, from, to })
                }).then(r => r.json());
                if (r.ok) fetchPipeline();
                else alert('Move failed: ' + (r.error || 'unknown'));
            } catch(e) { alert('Move failed: ' + e.message); }
        }

        // Store current modal context so buttons can reference it without inline quoting issues
        let _modalFile = '';
        let _modalStage = '';

        async function openPipelineFile(file, stage) {
            _modalFile = file;
            _modalStage = stage;
            const modal = document.getElementById('pipeline-modal');
            document.getElementById('modal-filename').textContent = file;
            document.getElementById('modal-stage-badge').textContent = stage;
            document.getElementById('modal-content').textContent = 'Loading…';
            document.getElementById('modal-footer').innerHTML = '';
            modal.style.display = 'flex';
            try {
                const r = await fetch(`/mc/pipeline/read?stage=${encodeURIComponent(stage)}&file=${encodeURIComponent(file)}`).then(r => r.json());
                document.getElementById('modal-content').textContent = r.content || '(empty)';
                const next = PIPELINE_NEXT[stage];
                let btns = '';
                // Next-stage button (green)
                if (next) {
                    btns += `<button onclick="modalMoveToStage('${next}')" style="background:rgba(0,200,120,0.15);border:1px solid rgba(0,200,120,0.35);color:#00c878;font-size:0.68rem;font-weight:600;padding:4px 14px;border-radius:5px;cursor:pointer;">→ Move to ${next}</button>`;
                }
                // Fast-track to 4_Ready_to_Seed (purple)
                if (!['4_Ready_to_Seed','5_Failed_Seed'].includes(stage) && next !== '4_Ready_to_Seed') {
                    btns += `<button onclick="modalMoveToStage('4_Ready_to_Seed')" style="background:rgba(160,80,255,0.15);border:1px solid rgba(160,80,255,0.35);color:#a050ff;font-size:0.68rem;font-weight:600;padding:4px 14px;border-radius:5px;cursor:pointer;">⚡ Move to 4_Ready_to_Seed</button>`;
                }
                btns += `<button onclick="fetch('/mc/pipeline/open-finder?stage=${encodeURIComponent(stage)}')" style="background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);color:rgba(255,255,255,0.55);font-size:0.65rem;padding:4px 12px;border-radius:5px;cursor:pointer;">🔍 Open in Finder</button>`;
                btns += `<button onclick="closePipelineModal()" style="margin-left:auto;background:transparent;border:1px solid rgba(255,255,255,0.1);color:rgba(255,255,255,0.4);font-size:0.65rem;padding:4px 12px;border-radius:5px;cursor:pointer;">Close</button>`;
                document.getElementById('modal-footer').innerHTML = btns;
            } catch(e) {
                document.getElementById('modal-content').textContent = 'Error: ' + e.message;
            }
        }

        async function modalMoveToStage(toStage) {
            await movePipelineFile(_modalFile, _modalStage, toStage);
            closePipelineModal();
        }

        function closePipelineModal() {
            ttsStop();
            document.getElementById('pipeline-modal').style.display = 'none';
        }
        document.addEventListener('keydown', e => { if (e.key === 'Escape') closePipelineModal(); });

        // ── Text-to-Speech for Document Pipeline ──────────────────────
        let ttsUtterance = null;
        let ttsIsPlaying = false;

        function ttsToggle() {
            if (ttsIsPlaying && speechSynthesis.speaking) {
                if (speechSynthesis.paused) {
                    speechSynthesis.resume();
                    document.getElementById('tts-play-btn').innerHTML = '⏸ Pause';
                } else {
                    speechSynthesis.pause();
                    document.getElementById('tts-play-btn').innerHTML = '▶ Resume';
                }
                return;
            }
            // Start fresh
            ttsStop();
            const text = document.getElementById('modal-content').textContent;
            if (!text || text === 'Loading…' || text === '(empty)') return;

            // Strip markdown formatting for cleaner reading
            const cleaned = text
                .replace(/^#{1,6}\s+/gm, '')      // headings
                .replace(/\*\*([^*]+)\*\*/g, '$1') // bold
                .replace(/\*([^*]+)\*/g, '$1')     // italic
                .replace(/`([^`]+)`/g, '$1')       // inline code
                .replace(/```[\s\S]*?```/g, '')    // code blocks
                .replace(/^[-*]\s+/gm, '')         // list bullets
                .replace(/^\d+\.\s+/gm, '')        // numbered lists
                .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1') // links
                .replace(/^[|].*$/gm, '')          // table rows
                .replace(/^[-:]+$/gm, '')          // table separators
                .replace(/\n{3,}/g, '\n\n');       // excessive newlines

            ttsUtterance = new SpeechSynthesisUtterance(cleaned);
            ttsUtterance.rate = parseFloat(document.getElementById('tts-speed').value);
            ttsUtterance.pitch = 1;

            // Try to pick a good voice
            const voices = speechSynthesis.getVoices();
            const preferred = voices.find(v => v.name.includes('Samantha')) ||
                              voices.find(v => v.name.includes('Daniel')) ||
                              voices.find(v => v.lang.startsWith('en') && v.localService) ||
                              voices.find(v => v.lang.startsWith('en'));
            if (preferred) ttsUtterance.voice = preferred;

            ttsUtterance.onend = () => {
                ttsIsPlaying = false;
                document.getElementById('tts-play-btn').innerHTML = '▶ Read';
                document.getElementById('tts-play-btn').style.color = '#00c878';
                document.getElementById('tts-play-btn').style.borderColor = 'rgba(0,200,120,0.25)';
                document.getElementById('tts-play-btn').style.background = 'rgba(0,200,120,0.12)';
                document.getElementById('tts-stop-btn').style.display = 'none';
            };

            ttsUtterance.onerror = (e) => {
                if (e.error !== 'canceled') console.warn('TTS error:', e.error);
                ttsIsPlaying = false;
                document.getElementById('tts-play-btn').innerHTML = '▶ Read';
                document.getElementById('tts-stop-btn').style.display = 'none';
            };

            speechSynthesis.speak(ttsUtterance);
            ttsIsPlaying = true;
            document.getElementById('tts-play-btn').innerHTML = '⏸ Pause';
            document.getElementById('tts-play-btn').style.color = '#ffaa00';
            document.getElementById('tts-play-btn').style.borderColor = 'rgba(255,170,0,0.25)';
            document.getElementById('tts-play-btn').style.background = 'rgba(255,170,0,0.12)';
            document.getElementById('tts-stop-btn').style.display = 'inline-block';
        }

        function ttsStop() {
            speechSynthesis.cancel();
            ttsIsPlaying = false;
            ttsUtterance = null;
            const btn = document.getElementById('tts-play-btn');
            if (btn) {
                btn.innerHTML = '▶ Read';
                btn.style.color = '#00c878';
                btn.style.borderColor = 'rgba(0,200,120,0.25)';
                btn.style.background = 'rgba(0,200,120,0.12)';
            }
            const stopBtn = document.getElementById('tts-stop-btn');
            if (stopBtn) stopBtn.style.display = 'none';
        }

        function ttsUpdateSpeed() {
            if (ttsIsPlaying && ttsUtterance) {
                // Restart with new speed (SpeechSynthesis doesn't support live rate change)
                const text = ttsUtterance.text;
                ttsStop();
                ttsUtterance = new SpeechSynthesisUtterance(text);
                ttsUtterance.rate = parseFloat(document.getElementById('tts-speed').value);
                const voices = speechSynthesis.getVoices();
                const preferred = voices.find(v => v.name.includes('Samantha')) ||
                                  voices.find(v => v.name.includes('Daniel')) ||
                                  voices.find(v => v.lang.startsWith('en') && v.localService) ||
                                  voices.find(v => v.lang.startsWith('en'));
                if (preferred) ttsUtterance.voice = preferred;
                ttsUtterance.onend = () => {
                    ttsIsPlaying = false;
                    document.getElementById('tts-play-btn').innerHTML = '▶ Read';
                    document.getElementById('tts-play-btn').style.color = '#00c878';
                    document.getElementById('tts-play-btn').style.borderColor = 'rgba(0,200,120,0.25)';
                    document.getElementById('tts-play-btn').style.background = 'rgba(0,200,120,0.12)';
                    document.getElementById('tts-stop-btn').style.display = 'none';
                };
                speechSynthesis.speak(ttsUtterance);
                ttsIsPlaying = true;
                document.getElementById('tts-play-btn').innerHTML = '⏸ Pause';
                document.getElementById('tts-play-btn').style.color = '#ffaa00';
                document.getElementById('tts-play-btn').style.borderColor = 'rgba(255,170,0,0.25)';
                document.getElementById('tts-play-btn').style.background = 'rgba(255,170,0,0.12)';
                document.getElementById('tts-stop-btn').style.display = 'inline-block';
            }
        }

        // Pre-load voices (some browsers need this)
        if (typeof speechSynthesis !== 'undefined') {
            speechSynthesis.getVoices();
            speechSynthesis.onvoiceschanged = () => speechSynthesis.getVoices();
        }

        async function fetchPipeline() {
            try {
                const d = await fetch('/mc/pipeline').then(r => r.json());
                const board = document.getElementById('pipeline-board');
                if (!board) return;
                const ext2icon = e => e==='md'?'📝':e==='json'?'{}':e==='txt'?'📄':'📎';

                board.innerHTML = PIPELINE_ORDER.map(stage => {
                    const files = d.stages[stage] || [];
                    const meta = PIPELINE_META[stage];
                    const next = PIPELINE_NEXT[stage];
                    const isReady = stage === '4_Ready_to_Seed';

                    let col = `<div data-stage="${stage}" style="border-right:1px solid rgba(255,255,255,0.05);display:flex;flex-direction:column;overflow:hidden;transition:background 0.12s;">`;

                    // Title bar
                    col += `<div style="padding:5px 7px;background:${meta.accent};border-bottom:1px solid rgba(255,255,255,0.06);display:flex;align-items:center;gap:4px;flex-shrink:0;">
                        <span style="font-size:0.62rem;font-weight:700;color:${meta.color};font-family:monospace;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="${stage}">${stage}</span>
                        <button onclick="fetch('/mc/pipeline/open-finder?stage=${encodeURIComponent(stage)}')" title="Open in Finder" style="background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.09);color:rgba(255,255,255,0.45);font-size:0.55rem;padding:1px 5px;border-radius:3px;cursor:pointer;flex-shrink:0;">🔍</button>
                        ${next && files.length > 0 ? `<button onclick="(async()=>{for(const f of ${JSON.stringify(files)})await movePipelineFile(f,${JSON.stringify(stage)},${JSON.stringify(next)});fetchPipeline();})()" title="Move all to next" style="background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.09);color:rgba(255,255,255,0.45);font-size:0.55rem;padding:1px 5px;border-radius:3px;cursor:pointer;flex-shrink:0;">→ all</button>` : ''}
                    </div>`;

                    // Count subheader
                    col += `<div style="padding:2px 7px;background:rgba(255,255,255,0.02);border-bottom:1px solid rgba(255,255,255,0.04);font-size:0.52rem;color:rgba(255,255,255,0.28);">${files.length} item${files.length!==1?'s':''}${isReady?' · ⚡ seeding':''}</div>`;

                    // File rows
                    col += `<div style="flex:1;overflow-y:auto;">`;
                    if (files.length === 0) {
                        col += `<div style="padding:12px 8px;font-size:0.58rem;color:rgba(255,255,255,0.15);text-align:center;">(empty — drop files here)</div>`;
                    } else {
                        files.forEach((f, i) => {
                            const ext = (f.split('.').pop() || '').toLowerCase();
                            const icon = ext2icon(ext);
                            const rowBg = i % 2 === 0 ? 'transparent' : 'rgba(255,255,255,0.015)';
                            col += `<div
                                draggable="true"
                                data-file="${f.replace(/"/g,'&quot;')}"
                                data-stage="${stage}"
                                style="display:flex;align-items:center;gap:4px;padding:3px 5px 3px 6px;background:${rowBg};border-bottom:1px solid rgba(255,255,255,0.025);cursor:pointer;"
                                ondblclick="openPipelineFile(${JSON.stringify(f).replace(/"/g,'&quot;')},${JSON.stringify(stage).replace(/"/g,'&quot;')})"
                                onmouseenter="this.style.background='rgba(255,255,255,0.08)'"
                                onmouseleave="this.style.background='${rowBg}'">
                                <span style="font-size:0.62rem;flex-shrink:0;pointer-events:none;">${icon}</span>
                                <span title="${f}" style="font-size:0.6rem;color:rgba(255,255,255,0.72);flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;pointer-events:none;">${f}</span>
                                ${next && !isReady ? `<button onclick="movePipelineFile(${JSON.stringify(f)},${JSON.stringify(stage)},${JSON.stringify(next)})" title="Move to ${next}" style="background:transparent;border:none;color:rgba(255,255,255,0.3);font-size:0.75rem;padding:0 3px;cursor:pointer;flex-shrink:0;" onmouseenter="this.style.color='${meta.color}'" onmouseleave="this.style.color='rgba(255,255,255,0.3)'">›</button>` : ''}
                            </div>`;
                        });
                    }
                    col += `</div></div>`;
                    return col;
                }).join('');

                // Wire up drag-and-drop via JS event listeners (not inline handlers)
                // This avoids the render-time interpolation bug
                board.querySelectorAll('[data-file]').forEach(row => {
                    row.addEventListener('dragstart', e => {
                        e.dataTransfer.effectAllowed = 'move';
                        e.dataTransfer.setData('text/plain', JSON.stringify({
                            file: row.dataset.file,
                            from: row.dataset.stage
                        }));
                        row.style.opacity = '0.4';
                    });
                    row.addEventListener('dragend', e => { row.style.opacity = '1'; });
                });

                board.querySelectorAll('[data-stage]').forEach(col => {
                    const toStage = col.dataset.stage;
                    col.addEventListener('dragover', e => {
                        e.preventDefault();
                        e.dataTransfer.dropEffect = 'move';
                        col.style.background = 'rgba(255,255,255,0.06)';
                    });
                    col.addEventListener('dragleave', e => {
                        if (!col.contains(e.relatedTarget)) col.style.background = '';
                    });
                    col.addEventListener('drop', e => {
                        e.preventDefault();
                        col.style.background = '';
                        try {
                            const { file, from } = JSON.parse(e.dataTransfer.getData('text/plain'));
                            if (file && from && from !== toStage) {
                                movePipelineFile(file, from, toStage);
                            }
                        } catch(err) {}
                    });
                });

            } catch(e) {
                const b = document.getElementById('pipeline-board');
                if (b) b.innerHTML = `<div style="padding:1rem;color:#ef4444;font-size:0.7rem;">Failed to load pipeline</div>`;
            }
        }

        // Auto-refresh pipeline every 30s
        setInterval(fetchPipeline, 30000);

        // ── /mc/digitalocean-status → droplet health metrics ──────────────
        async function fetchDOMetrics(forceRefresh) {
            const panel = document.getElementById('do-metrics-content');
            if (!panel) return;
            try {
                const qs = forceRefresh ? '?refresh=1' : '';
                if (forceRefresh) panel.innerHTML = '<span style="color:rgba(255,255,255,0.4);font-size:0.55rem;">Refreshing...</span>';
                const d = await fetch('/mc/digitalocean-status' + qs).then(r => r.json());
                if (d.configured === false) {
                    panel.innerHTML = '<span style="color:rgba(255,255,255,0.3);font-size:0.55rem;">Add DO token for metrics</span>';
                    return;
                }
                if (d.loading) {
                    panel.innerHTML = '<span style="color:rgba(255,255,255,0.3);font-size:0.55rem;">Loading metrics...</span>';
                    return;
                }
                if (d.error && !d.cpu && d.cpu !== 0) {
                    panel.innerHTML = `<span style="color:#ff6b6b;font-size:0.55rem;">${d.error}</span>`;
                    return;
                }
                if (!d.agentInstalled && d.cpu === null) {
                    panel.innerHTML = '<span style="color:rgba(255,200,50,0.6);font-size:0.55rem;">Install do-agent on droplet for metrics</span>';
                    return;
                }

                function barColor(pct) {
                    if (pct >= 80) return '#ff4444';
                    if (pct >= 60) return '#f5a623';
                    return '#00ff88';
                }
                function bar(label, pct, detail) {
                    if (pct === null || pct === undefined) return '';
                    const color = barColor(pct);
                    const width = Math.min(100, Math.max(0, pct));
                    return `<div style="display:flex;align-items:center;gap:0.4rem;margin-bottom:0.25rem;">
                        <span style="width:2.2rem;font-size:0.55rem;color:rgba(255,255,255,0.45);text-transform:uppercase;letter-spacing:0.03em;">${label}</span>
                        <div style="flex:1;height:6px;background:rgba(255,255,255,0.08);border-radius:3px;overflow:hidden;">
                            <div style="width:${width}%;height:100%;background:${color};border-radius:3px;transition:width 0.5s;"></div>
                        </div>
                        <span style="width:2rem;text-align:right;font-size:0.55rem;font-family:monospace;color:${color};font-weight:600;">${Math.round(pct)}%</span>
                        <span style="width:2.5rem;text-align:right;font-size:0.5rem;color:rgba(255,255,255,0.3);font-family:monospace;">${detail}</span>
                    </div>`;
                }

                const memUsed = d.memTotalMB && d.memFreeMB ? d.memTotalMB - d.memFreeMB : null;
                const memDetail = memUsed !== null ? (memUsed >= 1024 ? (memUsed/1024).toFixed(1)+'G' : memUsed+'M') : '';
                const diskUsed = d.diskTotalMB && d.diskFreeMB ? d.diskTotalMB - d.diskFreeMB : null;
                const diskDetail = diskUsed !== null ? (diskUsed >= 1024 ? (diskUsed/1024).toFixed(0)+'G' : diskUsed+'M') : '';

                let html = '';
                html += bar('CPU', d.cpu, '');
                html += bar('MEM', d.memUsedPct, memDetail);
                html += bar('DISK', d.diskUsedPct, diskDetail);
                if (d.load1 !== null) {
                    const loadColor = d.load1 >= 2 ? '#ff4444' : d.load1 >= 1 ? '#f5a623' : '#00ff88';
                    html += `<div style="display:flex;align-items:center;gap:0.4rem;">
                        <span style="width:2.2rem;font-size:0.55rem;color:rgba(255,255,255,0.45);text-transform:uppercase;letter-spacing:0.03em;">LOAD</span>
                        <span style="font-size:0.6rem;font-family:monospace;color:${loadColor};font-weight:600;">${d.load1}</span>
                        ${d.dropletName ? `<span style="margin-left:auto;font-size:0.48rem;color:rgba(255,255,255,0.2);">${d.dropletName} · ${d.region}</span>` : ''}
                    </div>`;
                }
                panel.innerHTML = html;
            } catch(e) {
                panel.innerHTML = '<span style="color:rgba(255,255,255,0.3);font-size:0.55rem;">Metrics unavailable</span>';
            }
        }

        // ── Sprint Mode ──────────────────────────────────────────────────
        async function fetchSprintStatus() {
            try {
                const d = await fetch('/mc/sprint').then(r => r.json());
                const banner = document.getElementById('sprint-banner');
                if (d.active) {
                    banner.style.display = 'flex';
                    document.getElementById('sprint-status-label').textContent = 'ACTIVE';
                    document.getElementById('sprint-icon').textContent = '🏃';
                    banner.style.borderColor = 'rgba(0,245,255,0.3)';
                    const triggerMap = { geofence_leave: '📍 Left Home', sleep_mode: '😴 Sleep', manual: '🖐️ Manual', watch_absent: '⌚ Watch Away' };
                    document.getElementById('sprint-trigger').textContent = triggerMap[d.trigger] || d.trigger || '—';
                    document.getElementById('sprint-cycles').textContent = d.cycleCount || 0;
                    document.getElementById('sprint-since').textContent = d.started ? new Date(d.started).toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' }) : '—';
                    document.getElementById('sprint-toggle-btn').textContent = 'Deactivate';
                    document.getElementById('sprint-toggle-btn').style.color = '#ff6b6b';
                    document.getElementById('sprint-toggle-btn').style.borderColor = 'rgba(255,107,107,0.4)';
                    // Show assignments
                    if (d.assignments && Object.keys(d.assignments).length > 0) {
                        const assignHtml = Object.entries(d.assignments).map(([role, a]) =>
                            `${role}: TAS-${a.taskNumber}`
                        ).join(' | ');
                        document.getElementById('sprint-assignments').textContent = assignHtml;
                    } else {
                        document.getElementById('sprint-assignments').textContent = 'Waiting for first cycle...';
                    }
                } else {
                    // Show a subtle inactive indicator
                    banner.style.display = 'flex';
                    document.getElementById('sprint-status-label').textContent = 'INACTIVE';
                    document.getElementById('sprint-icon').textContent = '⏸️';
                    banner.style.borderColor = 'rgba(255,255,255,0.1)';
                    banner.style.background = 'rgba(255,255,255,0.03)';
                    document.getElementById('sprint-trigger').textContent = '—';
                    document.getElementById('sprint-cycles').textContent = d.cycleCount || 0;
                    document.getElementById('sprint-since').textContent = d.stopped ? 'Stopped ' + new Date(d.stopped).toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' }) : '—';
                    document.getElementById('sprint-toggle-btn').textContent = 'Activate';
                    document.getElementById('sprint-toggle-btn').style.color = '#00f5ff';
                    document.getElementById('sprint-toggle-btn').style.borderColor = 'rgba(0,245,255,0.4)';
                    document.getElementById('sprint-assignments').textContent = '';
                }
                // Watch presence indicator
                if (d.presence) {
                    const dot = document.getElementById('sprint-watch-dot');
                    const label = document.getElementById('sprint-watch-label');
                    if (d.presence.watchDetected) {
                        dot.style.background = '#00ff88';
                        dot.style.boxShadow = '0 0 4px #00ff88';
                        label.textContent = '⌚ Watch nearby';
                        label.style.color = 'rgba(0,255,136,0.6)';
                    } else if (d.presence.watchDetected === false) {
                        dot.style.background = '#ff6b6b';
                        dot.style.boxShadow = '0 0 4px #ff6b6b';
                        label.textContent = '⌚ Watch away';
                        label.style.color = 'rgba(255,107,107,0.6)';
                    } else {
                        dot.style.background = '#666';
                        dot.style.boxShadow = 'none';
                        label.textContent = '⌚ Checking...';
                        label.style.color = 'rgba(255,255,255,0.3)';
                    }
                }
            } catch(e) {}
        }

        async function toggleSprint() {
            const d = await fetch('/mc/sprint').then(r => r.json());
            const action = d.active ? 'deactivate' : 'activate';
            await fetch('/mc/sprint', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ action, trigger: 'manual' })
            });
            fetchSprintStatus();
        }

        async function manualSprintCycle() {
            await fetch('/mc/sprint', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ action: 'cycle' })
            });
            fetchSprintStatus();
        }

        async function refreshAll() {
            await Promise.all([
                fetchStatus(),
                fetchDWEStats(),
                fetchNotionMetrics(),
                fetchSprintStatus(),
                fetchServices(),
                fetchLaunchd(),
                fetchCrons(),
                fetchAgents(),
                fetchBrain(),
                fetchMigration(),
                fetchSystem(),
                fetchTeamOverview(),
                fetchHeartbeats(),
                fetchAgentTasks(),
                fetchAgentSessions(),
                fetchCSoPipeline(),
                fetchFinancialPulse(),
                fetchPipeline(),
                updateBackupTime(),
                updateOCBackupTime(),
                fetchInternet(),
                fetchOpenclawVersion(),
                fetchDOMetrics(),
                fetchRevenuePipeline(),
                fetchN8nWorkflows(),
                fetchContentIntel()
            ]);
            // refresh complete
        }

        // ── CSS1 Sea Life Background ──────────────────────────────────────────
        function startCSS1Bg() {
            const canvas = document.getElementById('css1-bg');
            if (!canvas) return;
            canvas.style.display = 'block';
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
            const ctx = canvas.getContext('2d');

            // Realistic reef fish species palettes
            // [backTop, backMid, belly, finColor, stripeColor, stripeCount, tailColor]
            const SPECIES = [
                { bT:'#e85d04', bM:'#f48c06', bV:'#ffd166', fin:'#b84000', sc:'#ffffff', sn:2, tc:'#c1440e' }, // clownfish
                { bT:'#0077b6', bM:'#00b4d8', bV:'#caf0f8', fin:'#023e8a', sc:null,      sn:0, tc:'#ffd166' }, // blue tang
                { bT:'#2d6a4f', bM:'#52b788', bV:'#b7e4c7', fin:'#1b4332', sc:null,      sn:0, tc:'#40916c' }, // parrotfish
                { bT:'#f9c74f', bM:'#f8961e', bV:'#fffcf0', fin:'#1d3557', sc:'#1d3557', sn:3, tc:'#f9c74f' }, // angelfish
                { bT:'#3a0ca3', bM:'#4361ee', bV:'#a8baff', fin:'#240046', sc:null,      sn:0, tc:'#7209b7' }, // surgeonfish
                { bT:'#d62828', bM:'#f77f00', bV:'#ffd166', fin:'#9d0208', sc:null,      sn:0, tc:'#d62828' }, // wrasse
                { bT:'#023e8a', bM:'#0096c7', bV:'#ade8f4', fin:'#03045e', sc:'#ffd166', sn:1, tc:'#0096c7' }, // damsel
                { bT:'#ffe566', bM:'#fff740', bV:'#fffde7', fin:'#ff9500', sc:'#111111', sn:2, tc:'#ff9500' }, // butterflyfish
                { bT:'#6a0572', bM:'#b5179e', bV:'#ff84c4', fin:'#480060', sc:null,      sn:0, tc:'#b5179e' }, // dottyback
                { bT:'#006400', bM:'#2dc653', bV:'#a8f5b8', fin:'#004b23', sc:'#ffffff', sn:1, tc:'#2dc653' }, // lionfish-green
            ];

            // Fish
            const fish = Array.from({ length: 18 }, (_, i) => {
                const sp = SPECIES[i % SPECIES.length];
                const size = 18 + Math.random() * 28;
                const dir = Math.random() > 0.5 ? 1 : -1;
                return {
                    x: Math.random() * canvas.width,
                    y: 70 + Math.random() * (canvas.height * 0.62),
                    vx: (0.28 + Math.random() * 0.5) * dir,
                    vy: (Math.random() - 0.5) * 0.1,
                    size, sp,
                    phase: Math.random() * Math.PI * 2,
                    ws: 0.032 + Math.random() * 0.022
                };
            });

            // Squids (cuttlefish style)
            const squids = Array.from({ length: 4 }, () => {
                const size = 20 + Math.random() * 24;
                const hue = [280, 310, 200, 260][Math.floor(Math.random() * 4)];
                // Pre-generate chromatophore spot positions
                const spots = Array.from({ length: 10 }, () => ({
                    ox: (Math.random() - 0.5) * size * 0.55,
                    oy: -size * 0.5 + Math.random() * size * 0.9,
                    r: size * 0.03 + Math.random() * size * 0.025,
                    ph: Math.random() * Math.PI * 2
                }));
                return {
                    x: Math.random() * canvas.width,
                    y: 100 + Math.random() * (canvas.height * 0.5),
                    vx: (Math.random() - 0.5) * 0.32,
                    vy: (Math.random() - 0.5) * 0.18,
                    size, hue, spots,
                    tPhase: Math.random() * Math.PI * 2,
                    pPhase: Math.random() * Math.PI * 2
                };
            });

            // Bubbles
            const bubbles = Array.from({ length: 28 }, () => ({
                x: Math.random() * canvas.width,
                y: canvas.height + Math.random() * canvas.height,
                r: 1 + Math.random() * 4,
                speed: 0.2 + Math.random() * 0.38,
                drift: (Math.random() - 0.5) * 0.12,
                wobble: Math.random() * Math.PI * 2
            }));

            // Coral reef formations
            const corals = [];
            const W = canvas.width, H = canvas.height;
            // Brain corals
            for (let i = 0; i < 4; i++)
                corals.push({ type:'brain', x: W*(0.06+i*0.24+Math.random()*0.06), y: H-18-Math.random()*22, r: 22+Math.random()*32, c1:'#d4622a', c2:'#a03a18' });
            // Branching coral
            for (let i = 0; i < 5; i++)
                corals.push({ type:'branch', x: W*(0.04+i*0.19+Math.random()*0.09), y: H-8, h: 55+Math.random()*75, col:'#ff6b6b', ph: Math.random()*Math.PI*2 });
            // Sea anemones
            for (let i = 0; i < 7; i++) {
                const hues = [0,25,300,270,190,50,330];
                corals.push({ type:'anem', x: W*(0.03+i*0.14+Math.random()*0.07), y: H-4, tn: 8+Math.floor(Math.random()*6), r: 14+Math.random()*18, col:`hsl(${hues[i]},80%,62%)`, ph: Math.random()*Math.PI*2 });
            }
            // Fan coral
            for (let i = 0; i < 3; i++)
                corals.push({ type:'fan', x: W*(0.08+i*0.38+Math.random()*0.08), y: H-12, h: 55+Math.random()*60, col:'#9b2226', ph: Math.random()*Math.PI*2 });

            // Light rays
            const rays = Array.from({ length: 7 }, (_, i) => ({
                x: W * (0.08 + i * 0.13 + Math.random() * 0.05),
                spread: 55 + Math.random() * 75,
                ph: Math.random() * Math.PI * 2,
                spd: 0.0025 + Math.random() * 0.003
            }));

            // ── Helper: draw a body bezier path (reused for fill + clip)
            function fishBodyPath(size) {
                ctx.beginPath();
                ctx.moveTo( size*0.88,  0);
                ctx.bezierCurveTo( size*0.88, -size*0.4,  size*0.15, -size*0.46, -size*0.62, -size*0.2);
                ctx.bezierCurveTo(-size*0.88, -size*0.08, -size*0.88,  size*0.08, -size*0.62,  size*0.2);
                ctx.bezierCurveTo( size*0.15,  size*0.46,  size*0.88,  size*0.4,   size*0.88,  0);
                ctx.closePath();
            }

            function drawFish(f, t) {
                const { x, y, size, sp, phase, ws } = f;
                const wag = Math.sin(t * ws + phase) * 0.32;
                ctx.save();
                ctx.translate(x, y);
                if (f.vx < 0) ctx.scale(-1, 1);

                // Forked tail with wag
                ctx.save();
                ctx.translate(-size*0.65, 0);
                ctx.rotate(wag * 0.7);
                ctx.beginPath();
                ctx.moveTo(0, 0);
                ctx.bezierCurveTo(-size*0.28, -size*0.52, -size*0.62, -size*0.48, -size*0.68, -size*0.08);
                ctx.bezierCurveTo(-size*0.62,  size*0.48, -size*0.28,  size*0.52, 0, 0);
                const tg = ctx.createLinearGradient(0,0,-size*0.68,0);
                tg.addColorStop(0, sp.bM); tg.addColorStop(1, sp.tc);
                ctx.fillStyle = tg; ctx.fill();
                ctx.restore();

                // Body fill with dorsal-to-belly gradient
                const bg = ctx.createLinearGradient(0, -size*0.46, 0, size*0.46);
                bg.addColorStop(0,   sp.bT);
                bg.addColorStop(0.45, sp.bM);
                bg.addColorStop(1,   sp.bV);
                fishBodyPath(size);
                ctx.fillStyle = bg; ctx.fill();

                // Stripes clipped to body
                if (sp.sn > 0 && sp.sc) {
                    ctx.save();
                    fishBodyPath(size); ctx.clip();
                    const isWhite = sp.sc === '#ffffff';
                    for (let i = 0; i < sp.sn; i++) {
                        const sx = size*0.55 - i*(size*0.52/sp.sn);
                        const sw = size * 0.1;
                        ctx.fillStyle = isWhite ? 'rgba(255,255,255,0.82)' : 'rgba(0,0,0,0.32)';
                        ctx.fillRect(sx - sw/2, -size*0.5, sw, size);
                    }
                    ctx.restore();
                }

                // Subtle belly sheen
                const sg = ctx.createLinearGradient(0, size*0.05, 0, size*0.4);
                sg.addColorStop(0, 'rgba(255,255,255,0.18)');
                sg.addColorStop(1, 'rgba(255,255,255,0)');
                ctx.beginPath();
                ctx.ellipse(0, size*0.22, size*0.48, size*0.2, 0, 0, Math.PI*2);
                ctx.fillStyle = sg; ctx.fill();

                // Dorsal fin (semi-transparent)
                ctx.beginPath();
                ctx.moveTo(-size*0.1, -size*0.43);
                ctx.bezierCurveTo(size*0.05, -size*0.82, size*0.32, -size*0.78, size*0.48, -size*0.43);
                ctx.closePath();
                ctx.fillStyle = sp.fin; ctx.globalAlpha = 0.72; ctx.fill(); ctx.globalAlpha = 1;

                // Pectoral fin
                ctx.beginPath();
                ctx.moveTo(size*0.18, size*0.12);
                ctx.bezierCurveTo(size*0.42, size*0.58, size*0.02, size*0.65, -size*0.12, size*0.38);
                ctx.closePath();
                ctx.fillStyle = sp.fin; ctx.globalAlpha = 0.58; ctx.fill(); ctx.globalAlpha = 1;

                // Lateral line
                ctx.beginPath();
                ctx.moveTo( size*0.75, -size*0.07);
                ctx.bezierCurveTo(size*0.2, -size*0.13, -size*0.18, -size*0.08, -size*0.6, size*0.0);
                ctx.strokeStyle = 'rgba(0,0,0,0.15)'; ctx.lineWidth = 0.8; ctx.stroke();

                // Eye — iris
                const ex = size*0.62, ey = -size*0.1;
                ctx.beginPath(); ctx.arc(ex, ey, size*0.13, 0, Math.PI*2);
                ctx.fillStyle = '#c8a84b'; ctx.fill();
                // Pupil
                ctx.beginPath(); ctx.arc(ex+size*0.02, ey, size*0.075, 0, Math.PI*2);
                ctx.fillStyle = '#0a0a0a'; ctx.fill();
                // Eye ring
                ctx.beginPath(); ctx.arc(ex, ey, size*0.13, 0, Math.PI*2);
                ctx.strokeStyle = 'rgba(0,0,0,0.35)'; ctx.lineWidth = 0.7; ctx.stroke();
                // Catchlight
                ctx.beginPath(); ctx.arc(ex-size*0.04, ey-size*0.04, size*0.032, 0, Math.PI*2);
                ctx.fillStyle = 'rgba(255,255,255,0.92)'; ctx.fill();

                // Mouth
                ctx.beginPath();
                ctx.arc(size*0.85, size*0.05, size*0.065, 0.35, Math.PI*0.8);
                ctx.strokeStyle = sp.fin; ctx.lineWidth = 1.4; ctx.stroke();

                ctx.restore();
            }

            function drawBranch(x, y, angle, len, depth, col, t, ph) {
                if (depth <= 0 || len < 4) return;
                const sway = Math.sin(t*0.018 + ph + depth*0.4) * 0.04;
                const ex = x + len * Math.cos(angle + sway);
                const ey = y + len * Math.sin(angle + sway);
                ctx.beginPath(); ctx.moveTo(x, y); ctx.lineTo(ex, ey);
                ctx.strokeStyle = col; ctx.lineWidth = depth * 0.9; ctx.lineCap = 'round'; ctx.stroke();
                drawBranch(ex, ey, angle-0.48, len*0.67, depth-1, col, t, ph+0.3);
                drawBranch(ex, ey, angle+0.42, len*0.67, depth-1, col, t, ph-0.3);
            }

            function drawCoral(c, t) {
                if (c.type === 'brain') {
                    ctx.beginPath(); ctx.arc(c.x, c.y, c.r, Math.PI, 0);
                    ctx.fillStyle = c.c1; ctx.fill();
                    ctx.strokeStyle = c.c2; ctx.lineWidth = 1.4;
                    for (let a = Math.PI+0.2; a <= 2*Math.PI-0.2; a += 0.28) {
                        ctx.beginPath();
                        ctx.arc(c.x + c.r*0.82*Math.cos(a), c.y + c.r*0.75*Math.sin(a), c.r*0.14, 0, Math.PI*2);
                        ctx.stroke();
                    }
                } else if (c.type === 'branch') {
                    drawBranch(c.x, c.y, -Math.PI/2, c.h*0.52, 5, c.col, t, c.ph);
                } else if (c.type === 'anem') {
                    for (let i = 0; i < c.tn; i++) {
                        const a = (i/c.tn)*Math.PI*2;
                        const w = Math.sin(t*0.028 + c.ph + i*0.85) * 0.28;
                        const tx = c.x + c.r*Math.sin(a+w);
                        const ty = c.y - c.r*0.65*Math.cos(a);
                        ctx.beginPath();
                        ctx.moveTo(c.x, c.y);
                        ctx.quadraticCurveTo(c.x*0.3+tx*0.7, c.y*0.4+ty*0.6, tx, ty);
                        ctx.strokeStyle = c.col; ctx.lineWidth = 2.8; ctx.lineCap = 'round'; ctx.stroke();
                        ctx.beginPath(); ctx.arc(tx, ty, 2.8, 0, Math.PI*2);
                        ctx.fillStyle = c.col; ctx.fill();
                    }
                    ctx.beginPath(); ctx.ellipse(c.x, c.y, c.r*0.35, 7, 0, 0, Math.PI*2);
                    ctx.fillStyle = 'rgba(255,255,255,0.15)'; ctx.fill();
                } else if (c.type === 'fan') {
                    const sw = Math.sin(t*0.018 + c.ph) * 0.07;
                    ctx.save(); ctx.translate(c.x, c.y); ctx.rotate(sw);
                    ctx.beginPath(); ctx.moveTo(0,0); ctx.lineTo(0,-c.h*0.28);
                    ctx.strokeStyle = c.col; ctx.lineWidth = 4; ctx.stroke();
                    for (let i = -6; i <= 6; i++) {
                        ctx.beginPath(); ctx.moveTo(0,-c.h*0.28); ctx.lineTo(i*c.h*0.095, -c.h);
                        ctx.strokeStyle = `rgba(155,34,38,0.65)`; ctx.lineWidth = 1.4; ctx.stroke();
                    }
                    for (let j = 0; j < 5; j++) {
                        const ly = -c.h*(0.35+j*0.14);
                        const sp2 = Math.abs(ly+c.h*0.28)*0.5;
                        ctx.beginPath(); ctx.moveTo(-sp2,ly); ctx.lineTo(sp2,ly);
                        ctx.strokeStyle = `rgba(155,34,38,0.4)`; ctx.lineWidth = 1; ctx.stroke();
                    }
                    ctx.restore();
                }
            }

            function drawSquid(s, t) {
                const { x, y, size, hue, tPhase, pPhase, spots } = s;
                const pulse = 0.86 + 0.14*Math.sin(t*0.055+pPhase);
                ctx.save(); ctx.translate(x, y);
                if (s.vx < 0) ctx.scale(-1, 1);

                // Tentacles (10: 2 long feeding, 8 shorter)
                for (let i = 0; i < 10; i++) {
                    const tp = (i-4.5)*size*0.14;
                    const wg = Math.sin(t*0.038+tPhase+i*0.62)*size*0.36;
                    const ln = (i===4||i===5) ? 1.95 : 1.42;
                    const lw = (i===4||i===5) ? size*0.085 : size*0.052;
                    ctx.beginPath();
                    ctx.moveTo(tp, size*0.58);
                    ctx.quadraticCurveTo(tp+wg*0.45, size*1.05, tp+wg, size*ln);
                    ctx.strokeStyle = `hsla(${hue},68%,58%,0.88)`;
                    ctx.lineWidth = Math.max(1, lw); ctx.lineCap = 'round'; ctx.stroke();
                }

                // Mantle with pulse
                ctx.save(); ctx.scale(pulse, 1/pulse*0.96+0.04);
                const mg = ctx.createRadialGradient(-size*0.1,-size*0.2,0, 0,0,size*0.62);
                mg.addColorStop(0, `hsla(${hue},55%,82%,0.92)`);
                mg.addColorStop(0.55, `hsla(${hue},68%,55%,0.86)`);
                mg.addColorStop(1, `hsla(${hue},78%,32%,0.72)`);
                ctx.beginPath(); ctx.ellipse(0,0,size*0.34,size*0.58,0,0,Math.PI*2);
                ctx.fillStyle = mg; ctx.fill();
                // Chromatophores (pre-generated stable positions)
                for (const sp2 of spots) {
                    const a = 0.35 + 0.35*Math.sin(t*0.07+sp2.ph);
                    ctx.beginPath(); ctx.arc(sp2.ox, sp2.oy, sp2.r, 0, Math.PI*2);
                    ctx.fillStyle = `hsla(${hue+45},88%,38%,${a})`; ctx.fill();
                }
                ctx.restore();

                // Side fins
                for (const sd of [-1,1]) {
                    ctx.beginPath();
                    ctx.moveTo(sd*size*0.3,-size*0.28);
                    ctx.bezierCurveTo(sd*size*0.62,-size*0.08,sd*size*0.58,size*0.18,sd*size*0.3,size*0.22);
                    ctx.fillStyle = `hsla(${hue},62%,62%,0.52)`; ctx.fill();
                }
                // Pointed apex
                ctx.beginPath();
                ctx.moveTo(-size*0.17,-size*0.56); ctx.lineTo(0,-size*0.96); ctx.lineTo(size*0.17,-size*0.56);
                ctx.fillStyle = `hsla(${hue},70%,48%,0.92)`; ctx.fill();

                // Eyes with slit pupil
                for (const sd of [-1,1]) {
                    ctx.beginPath(); ctx.arc(sd*size*0.17,size*0.06,size*0.12,0,Math.PI*2);
                    ctx.fillStyle = 'rgba(8,8,8,0.88)'; ctx.fill();
                    ctx.beginPath(); ctx.arc(sd*size*0.17,size*0.06,size*0.062,0,Math.PI*2);
                    ctx.fillStyle = `hsla(${hue+55},75%,68%,0.9)`; ctx.fill();
                    ctx.beginPath(); ctx.ellipse(sd*size*0.17,size*0.06,size*0.068,size*0.022,0,0,Math.PI*2);
                    ctx.fillStyle = 'rgba(0,0,0,0.95)'; ctx.fill();
                    ctx.beginPath(); ctx.arc(sd*size*0.14,size*0.03,size*0.02,0,Math.PI*2);
                    ctx.fillStyle = 'rgba(255,255,255,0.85)'; ctx.fill();
                }
                ctx.restore();
            }

            let t = 0;
            function css1Frame() {
                ctx.clearRect(0, 0, canvas.width, canvas.height);
                t++;

                // Underwater depth overlay
                const depthG = ctx.createLinearGradient(0, 0, 0, canvas.height);
                depthG.addColorStop(0,    'rgba(0,18,55,0.55)');
                depthG.addColorStop(0.55, 'rgba(0,38,85,0.28)');
                depthG.addColorStop(0.88, 'rgba(8,55,72,0.18)');
                depthG.addColorStop(1,    'rgba(25,72,50,0.38)');
                ctx.fillStyle = depthG;
                ctx.fillRect(0, 0, canvas.width, canvas.height);

                // Light rays from surface
                ctx.save();
                for (const r of rays) {
                    const alpha = 0.018 + 0.012*Math.sin(t*r.spd+r.ph);
                    const sp2 = r.spread*(0.78+0.28*Math.sin(t*r.spd*0.72+r.ph));
                    const rg = ctx.createLinearGradient(r.x,0,r.x,canvas.height);
                    rg.addColorStop(0, `rgba(120,195,255,${alpha})`);
                    rg.addColorStop(0.7, `rgba(80,160,220,${alpha*0.4})`);
                    rg.addColorStop(1, 'rgba(80,160,220,0)');
                    ctx.beginPath();
                    ctx.moveTo(r.x, 0);
                    ctx.lineTo(r.x-sp2, canvas.height);
                    ctx.lineTo(r.x+sp2, canvas.height);
                    ctx.closePath();
                    ctx.fillStyle = rg; ctx.fill();
                }
                ctx.restore();

                // Sandy seafloor
                const sfG = ctx.createLinearGradient(0, canvas.height-45, 0, canvas.height);
                sfG.addColorStop(0, 'rgba(175,138,75,0.28)');
                sfG.addColorStop(1, 'rgba(155,118,55,0.48)');
                ctx.fillStyle = sfG;
                ctx.fillRect(0, canvas.height-45, canvas.width, 45);

                // Coral reef
                for (const c of corals) drawCoral(c, t);

                // Bubbles
                for (const b of bubbles) {
                    b.y -= b.speed;
                    b.x += b.drift + Math.sin(t*0.025+b.wobble)*0.1;
                    if (b.y < -20) { b.y = canvas.height+20; b.x = Math.random()*canvas.width; }
                    ctx.beginPath(); ctx.arc(b.x, b.y, b.r, 0, Math.PI*2);
                    ctx.strokeStyle = 'rgba(140,200,255,0.42)'; ctx.lineWidth = 0.8; ctx.stroke();
                    ctx.beginPath(); ctx.arc(b.x-b.r*0.32, b.y-b.r*0.32, b.r*0.26, 0, Math.PI*2);
                    ctx.fillStyle = 'rgba(255,255,255,0.48)'; ctx.fill();
                }

                // Squids
                for (const s of squids) {
                    s.x += s.vx; s.y += s.vy; s.tPhase += 0.032; s.pPhase += 0.04;
                    if (s.x < -80) s.x = canvas.width+80;
                    if (s.x > canvas.width+80) s.x = -80;
                    if (s.y < 60) s.vy = Math.abs(s.vy);
                    if (s.y > canvas.height-85) s.vy = -Math.abs(s.vy);
                    drawSquid(s, t);
                }

                // Fish
                for (const f of fish) {
                    f.x += f.vx; f.y += f.vy;
                    f.vy += (Math.random()-0.5)*0.014;
                    f.vy = Math.max(-0.24, Math.min(0.24, f.vy));
                    if (f.vx > 0 && f.x > canvas.width+f.size*2) f.x = -f.size*2;
                    if (f.vx < 0 && f.x < -f.size*2) f.x = canvas.width+f.size*2;
                    if (f.y < 45) f.vy = Math.abs(f.vy);
                    if (f.y > canvas.height-75) f.vy = -Math.abs(f.vy);
                    drawFish(f, t);
                }

                _css1AnimFrame = requestAnimationFrame(css1Frame);
            }
            css1Frame();

            window._css1Resize = () => { canvas.width = window.innerWidth; canvas.height = window.innerHeight; };
            window.addEventListener('resize', window._css1Resize);
        }

        function stopCSS1Bg() {
            if (_css1AnimFrame) { cancelAnimationFrame(_css1AnimFrame); _css1AnimFrame = null; }
            const canvas = document.getElementById('css1-bg');
            if (canvas) canvas.style.display = 'none';
            if (window._css1Resize) { window.removeEventListener('resize', window._css1Resize); window._css1Resize = null; }
        }

        // ── CSS4 Neural Network Background ────────────────────────────────────
        function startCSS4Bg() {
            const canvas = document.getElementById('css4-bg');
            if (!canvas) return;
            canvas.style.display = 'block';
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
            const ctx = canvas.getContext('2d');

            const WHITE     = [255, 255, 255];
            const ICE       = [200, 240, 255];
            const LTEAL     = [120, 230, 225];
            const LVIOLET   = [200, 190, 255];
            const COLORS = [WHITE, WHITE, ICE, ICE, LTEAL, LVIOLET];
            const N = 75;

            const pts = Array.from({ length: N }, () => ({
                x: Math.random() * canvas.width,
                y: Math.random() * canvas.height,
                vx: (Math.random() - 0.5) * 0.35,
                vy: (Math.random() - 0.5) * 0.35,
                r: Math.random() * 1.8 + 0.8,
                phase: Math.random() * Math.PI * 2,
                speed: 0.015 + Math.random() * 0.02,
                color: COLORS[Math.floor(Math.random() * COLORS.length)],
                depth: 0.4 + Math.random() * 0.6   // simulated Z depth
            }));

            // A few larger "hub" nodes
            for (let i = 0; i < 6; i++) {
                pts[i].r = 3 + Math.random() * 2;
                pts[i].speed = 0.008;
                pts[i].depth = 0.9;
            }

            // Slowly rotating hexagonal grid overlay
            let gridAngle = 0;

            function drawHexGrid(ctx, w, h, angle) {
                ctx.save();
                ctx.translate(w / 2, h / 2);
                ctx.rotate(angle);
                ctx.strokeStyle = 'rgba(32,178,170,0.03)';
                ctx.lineWidth = 0.5;
                const size = 60;
                const cols = Math.ceil(w / size / 0.866) + 4;
                const rows = Math.ceil(h / size / 1.5) + 4;
                for (let row = -rows; row < rows; row++) {
                    for (let col = -cols; col < cols; col++) {
                        const cx = col * size * 1.732 + (row % 2) * size * 0.866;
                        const cy = row * size * 1.5;
                        ctx.beginPath();
                        for (let i = 0; i < 6; i++) {
                            const a = (Math.PI / 3) * i;
                            const px = cx + size * Math.cos(a);
                            const py = cy + size * Math.sin(a);
                            i === 0 ? ctx.moveTo(px, py) : ctx.lineTo(px, py);
                        }
                        ctx.closePath();
                        ctx.stroke();
                    }
                }
                ctx.restore();
            }

            function frame() {
                ctx.clearRect(0, 0, canvas.width, canvas.height);
                gridAngle += 0.00015;
                drawHexGrid(ctx, canvas.width, canvas.height, gridAngle);

                // Update positions
                for (const p of pts) {
                    p.x += p.vx * p.depth;
                    p.y += p.vy * p.depth;
                    p.phase += p.speed;
                    if (p.x < -20) p.x = canvas.width + 20;
                    if (p.x > canvas.width + 20) p.x = -20;
                    if (p.y < -20) p.y = canvas.height + 20;
                    if (p.y > canvas.height + 20) p.y = -20;
                }

                // Connection lines
                for (let i = 0; i < pts.length; i++) {
                    for (let j = i + 1; j < pts.length; j++) {
                        const dx = pts[i].x - pts[j].x;
                        const dy = pts[i].y - pts[j].y;
                        const dist = Math.sqrt(dx * dx + dy * dy);
                        const maxDist = 140;
                        if (dist < maxDist) {
                            const alpha = (1 - dist / maxDist) * 0.35 * Math.min(pts[i].depth, pts[j].depth);
                            const [r, g, b] = pts[i].color;
                            ctx.beginPath();
                            ctx.moveTo(pts[i].x, pts[i].y);
                            ctx.lineTo(pts[j].x, pts[j].y);
                            ctx.strokeStyle = `rgba(${r},${g},${b},${alpha})`;
                            ctx.lineWidth = 0.6 * pts[i].depth;
                            ctx.stroke();
                        }
                    }
                }

                // Nodes
                for (const p of pts) {
                    const pulse = 0.5 + 0.5 * Math.sin(p.phase);
                    const alpha = (0.55 + 0.4 * pulse) * p.depth;
                    const radius = p.r * (1 + 0.3 * pulse) * p.depth;
                    const [r, g, b] = p.color;

                    // Outer glow
                    const grd = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, radius * 6);
                    grd.addColorStop(0, `rgba(${r},${g},${b},${alpha * 0.5})`);
                    grd.addColorStop(1, `rgba(${r},${g},${b},0)`);
                    ctx.beginPath();
                    ctx.arc(p.x, p.y, radius * 6, 0, Math.PI * 2);
                    ctx.fillStyle = grd;
                    ctx.fill();

                    // Core dot — bright white center
                    ctx.beginPath();
                    ctx.arc(p.x, p.y, radius, 0, Math.PI * 2);
                    ctx.fillStyle = `rgba(${r},${g},${b},${Math.min(alpha + 0.45, 1)})`;
                    ctx.fill();
                }

                _css4AnimFrame = requestAnimationFrame(frame);
            }

            frame();

            window._css4Resize = () => {
                canvas.width = window.innerWidth;
                canvas.height = window.innerHeight;
            };
            window.addEventListener('resize', window._css4Resize);
        }

        function stopCSS4Bg() {
            if (_css4AnimFrame) { cancelAnimationFrame(_css4AnimFrame); _css4AnimFrame = null; }
            const canvas = document.getElementById('css4-bg');
            if (canvas) canvas.style.display = 'none';
            if (window._css4Resize) { window.removeEventListener('resize', window._css4Resize); window._css4Resize = null; }
        }

        // ── CSS6 Plasma Shader Background (WebGL) ───────────────────────────
        function startCSS6Bg() {
            const canvas = document.getElementById('css6-bg');
            if (!canvas) return;
            canvas.style.display = 'block';
            const gl = canvas.getContext('webgl');
            if (!gl) return;

            const vsSource = 'attribute vec4 aVertexPosition; void main() { gl_Position = aVertexPosition; }';
            const fsSource = [
                'precision highp float;',
                'uniform vec2 iResolution;',
                'uniform float iTime;',
                'const float overallSpeed = 0.2;',
                'const float gridSmoothWidth = 0.015;',
                'const float axisWidth = 0.05;',
                'const float majorLineWidth = 0.025;',
                'const float minorLineWidth = 0.0125;',
                'const float majorLineFrequency = 5.0;',
                'const float minorLineFrequency = 1.0;',
                'const vec4 gridColor = vec4(0.5);',
                'const float scale = 5.0;',
                'const vec4 lineColor = vec4(0.4, 0.2, 0.8, 1.0);',
                'const float minLineWidth = 0.01;',
                'const float maxLineWidth = 0.2;',
                'const float lineSpeed = 1.0 * overallSpeed;',
                'const float lineAmplitude = 1.0;',
                'const float lineFrequency = 0.2;',
                'const float warpSpeed = 0.2 * overallSpeed;',
                'const float warpFrequency = 0.5;',
                'const float warpAmplitude = 1.0;',
                'const float offsetFrequency = 0.5;',
                'const float offsetSpeed = 1.33 * overallSpeed;',
                'const float minOffsetSpread = 0.6;',
                'const float maxOffsetSpread = 2.0;',
                'const int linesPerGroup = 16;',
                '#define drawCircle(pos, radius, coord) smoothstep(radius + gridSmoothWidth, radius, length(coord - (pos)))',
                '#define drawSmoothLine(pos, halfWidth, t) smoothstep(halfWidth, 0.0, abs(pos - (t)))',
                '#define drawCrispLine(pos, halfWidth, t) smoothstep(halfWidth + gridSmoothWidth, halfWidth, abs(pos - (t)))',
                '#define drawPeriodicLine(freq, width, t) drawCrispLine(freq / 2.0, width, abs(mod(t, freq) - (freq) / 2.0))',
                'float drawGridLines(float axis) {',
                '  return drawCrispLine(0.0, axisWidth, axis)',
                '        + drawPeriodicLine(majorLineFrequency, majorLineWidth, axis)',
                '        + drawPeriodicLine(minorLineFrequency, minorLineWidth, axis);',
                '}',
                'float drawGrid(vec2 space) {',
                '  return min(1.0, drawGridLines(space.x) + drawGridLines(space.y));',
                '}',
                'float random(float t) {',
                '  return (cos(t) + cos(t * 1.3 + 1.3) + cos(t * 1.4 + 1.4)) / 3.0;',
                '}',
                'float getPlasmaY(float x, float horizontalFade, float offset) {',
                '  return random(x * lineFrequency + iTime * lineSpeed) * horizontalFade * lineAmplitude + offset;',
                '}',
                'void main() {',
                '  vec2 fragCoord = gl_FragCoord.xy;',
                '  vec4 fragColor;',
                '  vec2 uv = fragCoord.xy / iResolution.xy;',
                '  vec2 space = (fragCoord - iResolution.xy / 2.0) / iResolution.x * 2.0 * scale;',
                '  float horizontalFade = 1.0 - (cos(uv.x * 6.28) * 0.5 + 0.5);',
                '  float verticalFade = 1.0 - (cos(uv.y * 6.28) * 0.5 + 0.5);',
                '  space.y += random(space.x * warpFrequency + iTime * warpSpeed) * warpAmplitude * (0.5 + horizontalFade);',
                '  space.x += random(space.y * warpFrequency + iTime * warpSpeed + 2.0) * warpAmplitude * horizontalFade;',
                '  vec4 lines = vec4(0.0);',
                '  vec4 bgColor1 = vec4(0.02, 0.02, 0.08, 1.0);',
                '  vec4 bgColor2 = vec4(0.08, 0.02, 0.12, 1.0);',
                '  for(int l = 0; l < linesPerGroup; l++) {',
                '    float normalizedLineIndex = float(l) / float(linesPerGroup);',
                '    float offsetTime = iTime * offsetSpeed;',
                '    float offsetPosition = float(l) + space.x * offsetFrequency;',
                '    float rand = random(offsetPosition + offsetTime) * 0.5 + 0.5;',
                '    float halfWidth = mix(minLineWidth, maxLineWidth, rand * horizontalFade) / 2.0;',
                '    float offset = random(offsetPosition + offsetTime * (1.0 + normalizedLineIndex)) * mix(minOffsetSpread, maxOffsetSpread, horizontalFade);',
                '    float linePosition = getPlasmaY(space.x, horizontalFade, offset);',
                '    float line = drawSmoothLine(linePosition, halfWidth, space.y) / 2.0 + drawCrispLine(linePosition, halfWidth * 0.15, space.y);',
                '    float circleX = mod(float(l) + iTime * lineSpeed, 25.0) - 12.0;',
                '    vec2 circlePosition = vec2(circleX, getPlasmaY(circleX, horizontalFade, offset));',
                '    float circle = drawCircle(circlePosition, 0.01, space) * 4.0;',
                '    line = line + circle;',
                '    lines += line * lineColor * rand;',
                '  }',
                '  fragColor = mix(bgColor1, bgColor2, uv.x);',
                '  fragColor *= verticalFade;',
                '  fragColor.a = 1.0;',
                '  fragColor += lines;',
                '  gl_FragColor = fragColor;',
                '}'
            ].join('\n');

            function loadShader(gl, type, source) {
                var shader = gl.createShader(type);
                gl.shaderSource(shader, source);
                gl.compileShader(shader);
                if (!gl.getShaderParameter(shader, gl.COMPILE_STATUS)) {
                    console.error('CSS6 shader error:', gl.getShaderInfoLog(shader));
                    gl.deleteShader(shader);
                    return null;
                }
                return shader;
            }

            var vertexShader = loadShader(gl, gl.VERTEX_SHADER, vsSource);
            var fragmentShader = loadShader(gl, gl.FRAGMENT_SHADER, fsSource);
            var program = gl.createProgram();
            gl.attachShader(program, vertexShader);
            gl.attachShader(program, fragmentShader);
            gl.linkProgram(program);
            if (!gl.getProgramParameter(program, gl.LINK_STATUS)) {
                console.error('CSS6 program link error:', gl.getProgramInfoLog(program));
                return;
            }

            var positionBuffer = gl.createBuffer();
            gl.bindBuffer(gl.ARRAY_BUFFER, positionBuffer);
            gl.bufferData(gl.ARRAY_BUFFER, new Float32Array([-1,-1, 1,-1, -1,1, 1,1]), gl.STATIC_DRAW);

            var vertexPos = gl.getAttribLocation(program, 'aVertexPosition');
            var resLoc = gl.getUniformLocation(program, 'iResolution');
            var timeLoc = gl.getUniformLocation(program, 'iTime');

            function resize() {
                canvas.width = window.innerWidth;
                canvas.height = window.innerHeight;
                gl.viewport(0, 0, canvas.width, canvas.height);
            }
            window._css6Resize = resize;
            window.addEventListener('resize', resize);
            resize();

            var startTime = Date.now();
            function frame() {
                var t = (Date.now() - startTime) / 1000;
                gl.clearColor(0, 0, 0, 1);
                gl.clear(gl.COLOR_BUFFER_BIT);
                gl.useProgram(program);
                gl.uniform2f(resLoc, canvas.width, canvas.height);
                gl.uniform1f(timeLoc, t);
                gl.bindBuffer(gl.ARRAY_BUFFER, positionBuffer);
                gl.vertexAttribPointer(vertexPos, 2, gl.FLOAT, false, 0, 0);
                gl.enableVertexAttribArray(vertexPos);
                gl.drawArrays(gl.TRIANGLE_STRIP, 0, 4);
                _css6AnimFrame = requestAnimationFrame(frame);
            }
            requestAnimationFrame(frame);
        }

        function stopCSS6Bg() {
            if (_css6AnimFrame) { cancelAnimationFrame(_css6AnimFrame); _css6AnimFrame = null; }
            var canvas = document.getElementById('css6-bg');
            if (canvas) canvas.style.display = 'none';
            if (window._css6Resize) { window.removeEventListener('resize', window._css6Resize); window._css6Resize = null; }
        }

        // ── Real-time per-service network traffic visualization ────────────
        const SVG_NS = 'http://www.w3.org/2000/svg';

        // ── HUD layer toggle state ─────────────────────────────────────────
        const hudToggles = {
            telegram: true, notion: true, openrouter: true, n8n: true, brain: true, github: true,
            ollama: true, mcp: true, openclaw: true,
            'ring-cpu': true, 'ring-mem': true, 'ring-net': true, 'ring-router': true
        };
        function hudToggle(key) {
            hudToggles[key] = !hudToggles[key];
            const btn = document.getElementById('tog-' + key);
            if (btn) btn.classList.toggle('tog-off', !hudToggles[key]);
            if (key === 'ring-cpu') {
                ['hud-scan-arc','hud-inner-spin'].forEach(id => {
                    const el = document.getElementById(id);
                    if (el) el.style.visibility = hudToggles[key] ? '' : 'hidden';
                });
            }
            if (key === 'ring-net') {
                const el = document.getElementById('hud-net-ring');
                if (el) el.style.visibility = hudToggles[key] ? '' : 'hidden';
            }
            if (key === 'ring-router') {
                ['hud-relay-ring', 'hud-outer-ring', 'hud-ring1'].forEach(id => {
                    const el = document.getElementById(id);
                    if (el) el.style.visibility = hudToggles[key] ? '' : 'hidden';
                });
            }
            if (key === 'ring-mem') {
                const el = document.getElementById('hud-mem-ring');
                if (el) el.style.visibility = hudToggles[key] ? '' : 'hidden';
            }
            // Clear dots for service that just turned off
            if (!hudToggles[key]) {
                const svc = (typeof TRAFFIC_SERVICES !== 'undefined' && TRAFFIC_SERVICES[key]);
                if (svc) { const c = document.getElementById(svc.container); if (c) while (c.firstChild) c.removeChild(c.firstChild); }
                const lsvc = (typeof LOCAL_SERVICES !== 'undefined' && LOCAL_SERVICES[key]);
                if (lsvc) { const c = document.getElementById(lsvc.container); if (c) while (c.firstChild) c.removeChild(c.firstChild); }
            }
        }

        // Service config: color, path ID, container ID
        const TRAFFIC_SERVICES = {
            notion:     { color: 'rgba(0,255,136,',     path: '#pulse-mm-notion',      container: 'rt-traffic-notion' },
            n8n:        { color: 'rgba(255,140,40,',     path: '#pulse-n8n-mm',          container: 'rt-traffic-n8n' },
            openrouter: { color: 'rgba(255,255,255,',    path: '#pulse-mm-openrouter',   container: 'rt-traffic-openrouter' },
            github:     { color: 'rgba(0,140,255,',      path: '#pulse-mm-github',       container: 'rt-traffic-github' },
            brain:      { color: 'rgba(255,100,200,',    path: '#pulse-mm-brain',        container: 'rt-traffic-brain' },
            'brain-relay': { color: 'rgba(255,100,200,', path: '#pulse-brain-relay',     container: 'rt-traffic-brain-relay' },
            telegram:   { color: 'rgba(0,200,255,',       path: '#pulse-mm-telegram',     container: 'rt-traffic-telegram' },
        };

        async function fetchTraffic() {
            try {
                const d = await fetch('/mc/traffic').then(r => r.json());
                updateTrafficViz(d);
            } catch(e) {}
        }

        const LOCAL_SERVICES = {
            ollama:   { color: 'rgba(255,220,50,',  path: '#laser-ollama',   container: 'rt-local-ollama' },
            mcp:      { color: 'rgba(255,180,50,',  path: '#laser-mcporter', container: 'rt-local-mcp' },
            openclaw: { color: 'rgba(255,200,80,',  path: '#laser-openclaw', container: 'rt-local-openclaw' },
            mem:      { color: 'rgba(255,220,50,',  path: '#laser-mem',      container: 'rt-local-mem' },
        };

        async function fetchLocalTraffic() {
            try {
                const d = await fetch('/mc/local-traffic').then(r => r.json());
                updateLocalTrafficViz(d);
            } catch(e) {}
        }

        function createTrafficDot(fill, pathRef, dur, begin, reverse) {
            const dot = document.createElementNS(SVG_NS, 'circle');
            dot.setAttribute('r', '2.2');
            dot.setAttribute('fill', fill);
            const motion = document.createElementNS(SVG_NS, 'animateMotion');
            motion.setAttribute('dur', dur + 's');
            motion.setAttribute('repeatCount', 'indefinite');
            motion.setAttribute('begin', begin + 's');
            if (reverse) {
                motion.setAttribute('keyPoints', '1;0');
                motion.setAttribute('keyTimes', '0;1');
                motion.setAttribute('calcMode', 'linear');
            }
            const mpath = document.createElementNS(SVG_NS, 'mpath');
            mpath.setAttribute('href', pathRef);
            motion.appendChild(mpath);
            dot.appendChild(motion);
            return dot;
        }

        function updateLocalTrafficViz(data) {
            // Only show dots when there are real local connections — 0 = nothing animates
            const memPct = data.memPct || 0;
            const counts = {
                ollama:   Math.min(6, data.ollama),
                mcp:      Math.min(6, data.mcp),
                openclaw: Math.min(6, data.gateway),
                mem:      Math.max(1, memPct > 80 ? 3 : memPct > 60 ? 2 : 1), // always 1 heartbeat
            };

            // Update MEM node color + text
            const memRing = document.getElementById('hud-mem-ring');
            const memPctEl = document.getElementById('hud-mem-pct');
            if (memRing && memPct > 0) {
                const ringColor = memPct > 80 ? 'rgba(255,80,80,0.6)' : memPct > 60 ? 'rgba(255,220,50,0.6)' : 'rgba(0,255,136,0.5)';
                const textColor = memPct > 80 ? 'rgba(255,80,80,0.9)' : memPct > 60 ? 'rgba(255,220,50,0.9)' : 'rgba(0,255,136,0.9)';
                memRing.setAttribute('stroke', ringColor);
                if (memPctEl) { memPctEl.textContent = Math.round(memPct) + '%'; memPctEl.setAttribute('fill', textColor); }
                const ramBadge = document.getElementById('hud-ram-badge');
                if (ramBadge) { ramBadge.textContent = 'RAM ' + Math.round(memPct) + '%'; ramBadge.setAttribute('fill', textColor.replace('0.9', '0.55')); }
            }
            // Blue scanning arc = Mac Mini CPU throughput
            const cpuPct = data.cpuPct || 0;
            const cpuDur = cpuPct > 85 ? 1 : cpuPct > 70 ? 3 : cpuPct > 50 ? 6 : cpuPct > 30 ? 12 : cpuPct > 10 ? 20 : 35;
            if (hudToggles['ring-cpu']) {
                const scanArc = document.getElementById('hud-scan-arc');
                const innerSpin = document.getElementById('hud-inner-spin');
                if (scanArc) scanArc.style.animation = `hud-spin ${cpuDur}s linear infinite`;
                if (innerSpin) innerSpin.style.animation = `hud-spin ${(cpuDur * 0.6).toFixed(1)}s linear infinite`;
            }
            // Orange arc ring = Mac Mini network throughput (local interface bandwidth)
            const macMbps = (data.macMbpsIn || 0) + (data.macMbpsOut || 0);
            const netDur = macMbps > 50 ? 1 : macMbps > 15 ? 3 : macMbps > 5 ? 6 : macMbps > 1 ? 12 : macMbps > 0.1 ? 20 : 35;
            if (hudToggles['ring-net']) {
                const netRing = document.getElementById('hud-net-ring');
                if (netRing) netRing.style.animation = `hud-spin-rev ${netDur}s linear infinite`;
            }

            // Update router external IP display
            if (data.routerExtIp) {
                const extIpEl = document.getElementById('hud-router-extip');
                if (extIpEl) extIpEl.textContent = data.routerExtIp;
            }

            // Green relay ring = Router WAN throughput (BGW320 counters)
            const rMbps = data.routerMbps || 0;
            const rDur = rMbps > 200 ? 0.8 : rMbps > 100 ? 1.5 : rMbps > 50 ? 2.5 : rMbps > 15 ? 4 : rMbps > 5 ? 8 : rMbps > 1 ? 14 : rMbps > 0.1 ? 22 : 35;
            const relayRing = document.getElementById('hud-relay-ring');
            if (hudToggles['ring-router'] && !data.routerAlert && relayRing) {
                relayRing.style.animation = `hud-spin-rev ${rDur}s linear infinite`;
                if (rMbps >= 900) {
                    // 900+ Mbps: bright red with pulse
                    relayRing.setAttribute('stroke', 'rgba(255,50,50,1)');
                    relayRing.setAttribute('stroke-width', '5');
                    relayRing.style.filter = 'drop-shadow(0 0 8px rgba(255,50,50,0.8))';
                    relayRing.style.animation = `hud-spin-rev ${rDur}s linear infinite, hud-relay-pulse 0.6s ease-in-out infinite`;
                } else {
                    // Normal: dim → bold green
                    const gAlpha = Math.min(1, 0.25 + (rMbps / 9) * 0.75);
                    const gWidth = rMbps >= 9 ? 4.5 : rMbps >= 3 ? 3.5 : 2.5;
                    relayRing.setAttribute('stroke', `rgba(0,255,136,${gAlpha.toFixed(2)})`);
                    relayRing.setAttribute('stroke-width', gWidth);
                    relayRing.style.filter = '';
                }
            }

            // Outer ring (Ring 3) + Ring 1 — speed + color driven by router throughput
            const outerRing = document.getElementById('hud-outer-ring');
            const ring1 = document.getElementById('hud-ring1');
            if (!data.routerAlert) {
                const oDur = rMbps > 400 ? 2 : rMbps > 200 ? 4 : rMbps > 100 ? 8 : rMbps > 50 ? 15 : rMbps > 15 ? 25 : rMbps > 5 ? 40 : rMbps > 1 ? 55 : 80;
                const r1Dur = rMbps > 400 ? 3 : rMbps > 200 ? 6 : rMbps > 100 ? 10 : rMbps > 50 ? 18 : rMbps > 15 ? 28 : rMbps > 5 ? 38 : rMbps > 1 ? 45 : 50;
                if (outerRing) {
                    outerRing.style.animation = `hud-spin ${oDur}s linear infinite`;
                    if (rMbps >= 400) {
                        outerRing.setAttribute('stroke', 'rgba(0,255,136,0.9)');
                        outerRing.setAttribute('stroke-width', '3');
                    } else if (rMbps >= 100) {
                        outerRing.setAttribute('stroke', `rgba(0,255,136,${(0.3 + (rMbps / 400) * 0.6).toFixed(2)})`);
                        outerRing.setAttribute('stroke-width', '2');
                    } else if (rMbps >= 10) {
                        outerRing.setAttribute('stroke', `rgba(0,255,136,${(0.1 + (rMbps / 100) * 0.2).toFixed(2)})`);
                        outerRing.setAttribute('stroke-width', '1.5');
                    } else {
                        outerRing.setAttribute('stroke', 'rgba(0,180,255,0.07)');
                        outerRing.setAttribute('stroke-width', '1');
                    }
                }
                if (ring1) {
                    ring1.style.animation = `hud-spin ${r1Dur}s linear infinite`;
                    // Ring 1 notch lines: gray at idle → green at speed
                    const r1Lines = ring1.querySelectorAll('line, circle');
                    const r1Color = rMbps >= 400 ? 'rgba(0,255,136,0.7)' : rMbps >= 100 ? 'rgba(0,255,136,0.45)' : rMbps >= 10 ? 'rgba(0,255,136,0.25)' : 'rgba(0,180,255,0.3)';
                    const r1CircleColor = rMbps >= 400 ? 'rgba(0,255,136,0.6)' : rMbps >= 100 ? 'rgba(0,255,136,0.35)' : rMbps >= 10 ? 'rgba(0,255,136,0.2)' : 'rgba(0,180,255,0.25)';
                    r1Lines.forEach(el => el.setAttribute('stroke', el.tagName === 'circle' ? r1CircleColor : r1Color));
                }
            }

            // Router health alert — flash relay ring red if BGW320 drops/errors incremented
            if (data.routerAlert) {
                if (relayRing) {
                    relayRing.style.stroke = 'rgba(255,80,80,0.9)';
                    setTimeout(() => { relayRing.style.stroke = ''; }, 3000);
                }
                if (outerRing) {
                    outerRing.setAttribute('stroke', 'rgba(255,80,80,0.5)');
                    setTimeout(() => { outerRing.setAttribute('stroke', ''); }, 3000);
                }
                if (ring1) {
                    ring1.querySelectorAll('line, circle').forEach(el => el.setAttribute('stroke', 'rgba(255,80,80,0.4)'));
                    setTimeout(() => { ring1.querySelectorAll('line, circle').forEach(el => el.setAttribute('stroke', '')); }, 3000);
                }
            }
            for (const [svc, cfg] of Object.entries(LOCAL_SERVICES)) {
                const container = document.getElementById(cfg.container);
                if (!container) continue;
                while (container.firstChild) container.removeChild(container.firstChild);
                if (!hudToggles[svc]) continue;
                const dotCount = counts[svc] || 0;
                if (dotCount === 0) continue;  // no connections = no animation
                // Speed scales with activity: more dots = faster (1.2s min, 3s idle)
                const dur = Math.max(1.2, 3.5 - dotCount * 0.5);
                for (let i = 0; i < dotCount; i++) {
                    const begin = (i * dur / dotCount).toFixed(1);
                    // outbound dot (bright)
                    container.appendChild(createTrafficDot(cfg.color + '0.95)', cfg.path, dur, begin, false));
                    // return dot (dimmer)
                    container.appendChild(createTrafficDot(cfg.color + '0.5)', cfg.path, dur + 0.4, begin, true));
                }
            }

            // n8n ↔ Ollama direct traffic — bright yellow
            const n8nOllamaContainer = document.getElementById('rt-traffic-n8n-ollama');
            if (n8nOllamaContainer) {
                while (n8nOllamaContainer.firstChild) n8nOllamaContainer.removeChild(n8nOllamaContainer.firstChild);
                const n8nOllamaActivity = data.n8nOllama || 0;
                if (n8nOllamaActivity > 0 && hudToggles['n8n'] && hudToggles['ollama']) {
                    const dotCount = Math.min(6, n8nOllamaActivity);
                    const dur = Math.max(2.0, 5.0 - dotCount * 0.6);
                    for (let i = 0; i < dotCount; i++) {
                        const begin = (i * dur / dotCount).toFixed(1);
                        // Bright yellow dots flowing n8n → Router → Mac Mini → Ollama
                        n8nOllamaContainer.appendChild(createTrafficDot('rgba(255,255,0,0.95)', '#pulse-n8n-ollama', dur, begin, false));
                        // Return dots Ollama → Mac Mini → Router → n8n
                        n8nOllamaContainer.appendChild(createTrafficDot('rgba(255,255,0,0.6)', '#pulse-n8n-ollama', dur + 0.4, begin, true));
                    }
                }
            }
        }

        function updateTrafficViz(data) {
            const readout = document.getElementById('traffic-readout');

            // Update total Mbps readout
            if (readout && data.total) {
                readout.textContent = '\u25BC' + data.total.mbpsIn.toFixed(1) + ' \u25B2' + data.total.mbpsOut.toFixed(1) + ' Mbps';
            }

            // Orange/green ring speeds now driven by CPU% and router Mbps in updateLocalTrafficViz

            // Update each service's traffic lines
            const services = data.services || {};
            for (const [svc, cfg] of Object.entries(TRAFFIC_SERVICES)) {
                if (!hudToggles[svc]) continue;
                const container = document.getElementById(cfg.container);
                if (!container) continue;

                // Clear previous
                while (container.firstChild) container.removeChild(container.firstChild);

                const svcData = services[svc];
                if (!svcData) continue;

                const totalBytes = (svcData.bytesIn || 0) + (svcData.bytesOut || 0);
                // Cumulative bytes: 1 pair per 10KB, min 0 (no traffic = no lines), max 6
                let pairCount = Math.min(6, Math.max(0, Math.round(totalBytes / 10000)));

                // For server-side services (brain, openrouter), use activity blip if no local traffic
                if (pairCount === 0 && data.activity) {
                    const lastBlip = data.activity[svc] || 0;
                    const ageSec = (Date.now() - lastBlip) / 1000;
                    if (ageSec < 25) {
                        // Fresh blip — show 2 pairs fading as age increases (25s window)
                        pairCount = Math.max(1, Math.round(2 * (1 - ageSec / 25)));
                    }
                }

                if (pairCount === 0) continue;

                const dur = Math.max(3, 10 - pairCount * 0.8);
                for (let i = 0; i < pairCount; i++) {
                    const beginOffset = (i * dur / pairCount).toFixed(1);
                    // Outbound line (main color, full opacity)
                    container.appendChild(createTrafficRect(cfg.color + '0.9)', cfg.path, dur, beginOffset, false));
                    // Return line (same color, dimmer)
                    container.appendChild(createTrafficRect(cfg.color + '0.6)', cfg.path, dur, beginOffset, true));
                }
            }

            // Also show total traffic on the Router↔Mac Mini link
            const totalContainer = document.getElementById('rt-traffic-total');
            if (totalContainer) {
                while (totalContainer.firstChild) totalContainer.removeChild(totalContainer.firstChild);
                if (data.total) {
                    const totalBytes = (data.total.bytesIn || 0) + (data.total.bytesOut || 0);
                    const pairCount = Math.min(6, Math.max(0, Math.round(totalBytes / 10000)));
                    if (pairCount > 0) {
                        const dur = Math.max(2, 6 - pairCount * 0.5);
                        for (let i = 0; i < pairCount; i++) {
                            const beginOffset = (i * dur / pairCount).toFixed(1);
                            totalContainer.appendChild(createTrafficRect('rgba(255,240,50,0.8)', '#relay-macmini-line', dur, beginOffset, false));
                            totalContainer.appendChild(createTrafficRect('rgba(255,240,50,0.5)', '#relay-macmini-line', dur, beginOffset, true));
                        }
                    }
                }
            }
        }

        function createTrafficRect(fill, pathRef, dur, begin, reverse) {
            const rect = document.createElementNS(SVG_NS, 'rect');
            rect.setAttribute('x', '-3');
            rect.setAttribute('y', '-0.5');
            rect.setAttribute('width', '6');
            rect.setAttribute('height', '1');
            rect.setAttribute('rx', '0.5');
            rect.setAttribute('fill', fill);

            const motion = document.createElementNS(SVG_NS, 'animateMotion');
            motion.setAttribute('rotate', 'auto');
            motion.setAttribute('dur', dur + 's');
            motion.setAttribute('repeatCount', 'indefinite');
            motion.setAttribute('begin', begin + 's');
            if (reverse) {
                motion.setAttribute('keyPoints', '1;0');
                motion.setAttribute('keyTimes', '0;1');
                motion.setAttribute('calcMode', 'linear');
            }

            const mpath = document.createElementNS(SVG_NS, 'mpath');
            mpath.setAttribute('href', pathRef);
            motion.appendChild(mpath);
            rect.appendChild(motion);
            return rect;
        }

        // ── CEO Productivity status on pill ──
        function updateCeoCornerStatus() {
            const pill = document.getElementById('ceo-corner-pill');
            if (!pill) return;
            const today = new Date().toISOString().slice(0, 10);
            let state;
            try { state = JSON.parse(localStorage.getItem('dwe_ceo_pipeline')); } catch(e) { state = null; }

            const items = [
                { id: 'daily-praxus' },
                { id: 'process-newsletter' },
                { id: 'check-email' }
            ];
            const total = items.length;
            let doneCount = 0;
            if (state && state.date === today) {
                doneCount = items.filter(i => state.done && state.done[i.id]).length;
            }

            const now = new Date();
            const day = now.getDay();
            const hour = now.getHours();
            const isWorkday = day >= 1 && day <= 5 && hour >= 7;

            if (doneCount === total) {
                pill.style.background = 'rgba(0,255,136,0.15)';
                pill.style.borderColor = 'rgba(0,255,136,0.35)';
                pill.style.color = '#00ff88';
            } else if (doneCount > 0 || !isWorkday) {
                pill.style.background = 'rgba(255,170,0,0.15)';
                pill.style.borderColor = 'rgba(255,170,0,0.35)';
                pill.style.color = '#ffaa00';
            } else {
                pill.style.background = 'rgba(255,60,60,0.15)';
                pill.style.borderColor = 'rgba(255,60,60,0.35)';
                pill.style.color = '#ff6b6b';
            }
        }

        // Initial load + 60s auto-refresh
        refreshAll();
        updateCeoCornerStatus();
        setInterval(refreshAll, 60000);
        setInterval(updateCeoCornerStatus, 60000);
        // Dedicated 60s refresh for Brain Knowledge + Mac mini Health
        setInterval(fetchBrain, 60000);
        setInterval(fetchSystem, 60000);
        setInterval(fetchInternet, 60000);
        // 5s traffic monitor
        fetchTraffic();
        setInterval(fetchTraffic, 5000);
        // 5s local process traffic (Mac Mini satellites)
        fetchLocalTraffic();
        setInterval(fetchLocalTraffic, 5000);

        // ── 5-minute idle → full page reload ─────────────────────────────────
        const IDLE_RELOAD_MS = 5 * 60 * 1000;
        let idleTimer = null;
        function resetIdleTimer() {
            clearTimeout(idleTimer);
            idleTimer = setTimeout(() => location.reload(), IDLE_RELOAD_MS);
        }
        ['mousemove','mousedown','keydown','scroll','touchstart','click'].forEach(evt =>
            document.addEventListener(evt, resetIdleTimer, { passive: true })
        );
        // Also reload when tab becomes visible again after being hidden for >5 min
        let hiddenAt = null;
        document.addEventListener('visibilitychange', () => {
            if (document.hidden) {
                hiddenAt = Date.now();
            } else if (hiddenAt && (Date.now() - hiddenAt) >= IDLE_RELOAD_MS) {
                location.reload();
            } else {
                hiddenAt = null;
            }
        });
        resetIdleTimer();

    </script>
</body>
</html>
